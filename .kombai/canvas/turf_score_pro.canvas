      "html": "\n<div class=\"min-h-screen bg-[#F8F8FF] font-sans selection:bg-[#FF4F00] selection:text-white\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito+Sans:wght@400;600;700;800&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            --ghost-white: #F8F8FF;\n            --flame-orange: #FF4F00;\n            --jungle-green: #00A550;\n        }\n\n        .font-heading { font-family: 'Fredoka', sans-serif; }\n        .font-body { font-family: 'Nunito Sans', sans-serif; }\n\n        .clay-surface {\n            box-shadow: \n                15px 15px 35px rgba(0,0,0,0.05),\n                -10px -10px 30px rgba(255,255,255,1),\n                inset 6px 6px 12px rgba(255,255,255,0.9),\n                inset -6px -6px 15px rgba(0,0,0,0.03);\n            border: 4px solid white;\n        }\n\n        .clay-island {\n            box-shadow: \n                0 40px 80px -15px rgba(0,0,0,0.1),\n                inset 10px 10px 20px rgba(255,255,255,0.4),\n                inset -10px -10px 20px rgba(0,0,0,0.05);\n        }\n\n        .blob-shape {\n            border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;\n        }\n\n        .glossy-overlay {\n            background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0) 50%);\n            pointer-events: none;\n        }\n\n        .gummy-pill {\n            background: var(--ghost-white);\n            border-radius: 999px;\n            box-shadow: \n                0 20px 40px rgba(255, 79, 0, 0.2),\n                inset 0 -10px 0 rgba(0,0,0,0.1),\n                inset 0 10px 15px rgba(255,255,255,1);\n            border: 5px solid white;\n        }\n\n        .player-card-3d {\n            perspective: 1000px;\n            transform-style: preserve-3d;\n        }\n\n        .island-grass {\n            background-image: url('https://images.unsplash.com/photo-1748360544385-ca703f8bed0c?auto=format&w=800&q=80&fit=crop');\n            background-size: cover;\n            background-position: center;\n        }\n\n        /* Prevent scrollbars while horizontal animations happen */\n        body { overflow-x: clip; }\n    </style>\n\n    \n    <nav class=\"fixed top-0 left-0 w-full z-50 p-8 flex justify-between items-center pointer-events-none\" data-kid=\"2\">\n        <div class=\"pointer-events-auto\" data-kid=\"3\">\n            <div class=\"flex items-center gap-3\" data-kid=\"4\">\n                <div class=\"w-12 h-12 bg-[#FF4F00] rounded-2xl flex items-center justify-center shadow-lg transform -rotate-6\" data-kid=\"5\">\n                    <i class=\"ti ti-trophy text-white text-2xl\" data-kid=\"6\"></i>\n                </div>\n                <span class=\"font-heading text-2xl font-bold text-gray-800 tracking-tight\" data-kid=\"7\">TurfScore<span class=\"text-[#FF4F00]\" data-kid=\"8\">Pro</span></span>\n            </div>\n        </div>\n        <div class=\"pointer-events-auto flex gap-4\" data-kid=\"9\">\n            <button class=\"font-heading px-6 py-2 text-gray-600 font-medium hover:text-[#FF4F00] transition-colors\" data-kid=\"10\">How it works</button>\n            <button class=\"font-heading bg-white px-8 py-3 rounded-full shadow-sm border border-gray-100 font-semibold text-gray-800 hover:shadow-md transition-all\" data-kid=\"11\">Log In</button>\n        </div>\n    </nav>\n\n    \n    <section class=\"relative min-h-screen flex items-center px-20 pt-20 overflow-visible\" data-kid=\"12\">\n        <div class=\"grid grid-cols-2 gap-20 items-center w-full max-w-7xl mx-auto\" data-kid=\"13\">\n            \n            <div class=\"z-10\" data-kid=\"14\">\n                <h1 class=\"font-heading text-9xl font-bold leading-[1.05] text-gray-900 mb-8\" id=\"hero-headline\" data-kid=\"15\">\n                    <span class=\"inline-block hero-word\" data-kid=\"16\">Score</span><br data-kid=\"17\">\n                    <span class=\"inline-block hero-word\" data-kid=\"18\">Like</span><br data-kid=\"19\">\n                    <span class=\"inline-block hero-word text-[#FF4F00]\" data-kid=\"20\">a Pro.</span>\n                </h1>\n                <p class=\"font-body text-xl text-gray-500 mb-12 max-w-md leading-relaxed font-medium\" data-kid=\"21\">\n                    Step onto the digital pitch with real-time tracking, 3D player cards, and community leagues.\n                </p>\n                <div class=\"flex items-center gap-4\" data-kid=\"22\">\n                    <button class=\"font-heading bg-[#FF4F00] text-white px-10 py-5 rounded-3xl text-2xl font-bold shadow-2xl active:scale-95\" id=\"hero-cta\" data-kid=\"23\">\n                        Join the League\n                    </button>\n                    <div class=\"w-px h-12 bg-gray-200 mx-2\" data-kid=\"24\"></div>\n                    <button class=\"font-heading text-gray-400 hover:text-[#FF4F00] text-xl font-bold transition-colors\" data-kid=\"25\">\n                        Explore Teams\n                    </button>\n                </div>\n            </div>\n\n            \n            <div class=\"relative h-[700px] w-full\" id=\"island-container\" data-kid=\"26\">\n                \n                <div class=\"absolute top-10 right-10 w-[450px] h-[300px] clay-island island-grass blob-shape transform rotate-3 float-item bg-white\" data-speed=\"0.8\" data-kid=\"27\">\n                    <div class=\"absolute inset-0 glossy-overlay blob-shape\" data-kid=\"28\"></div>\n                    <div class=\"absolute -top-10 -right-5 w-32 h-32 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center border-4 border-white/30 shadow-2xl\" data-kid=\"29\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/soccer-ball.svg\" class=\"w-20 h-20\" data-kid=\"30\">\n                    </div>\n                </div>\n\n                \n                <div class=\"absolute top-[45%] left-[-5%] w-[340px] clay-surface bg-white p-8 rounded-[40px] transform -rotate-2 float-item\" data-speed=\"1.2\" data-kid=\"31\">\n                    <div class=\"absolute inset-0 glossy-overlay rounded-[40px]\" data-kid=\"32\"></div>\n                    <div class=\"flex justify-between items-center mb-6\" data-kid=\"33\">\n                        <span class=\"font-heading text-gray-400 font-bold tracking-wider text-[10px]\" data-kid=\"34\">MATCHDAY 12 • LIVE</span>\n                        <div class=\"w-2.5 h-2.5 bg-red-500 rounded-full animate-pulse shadow-[0_0_10px_rgba(239,68,68,0.5)]\" data-kid=\"35\"></div>\n                    </div>\n                    <div class=\"flex items-center justify-between gap-4\" data-kid=\"36\">\n                        <div class=\"flex flex-col items-center gap-2\" data-kid=\"37\">\n                            <div class=\"w-16 h-16 bg-blue-50 rounded-3xl flex items-center justify-center text-3xl shadow-inner\" data-kid=\"38\">🦁</div>\n                            <span class=\"font-heading text-lg font-bold\" data-kid=\"39\">LNS</span>\n                        </div>\n                        <div class=\"flex flex-col items-center\" data-kid=\"40\">\n                            <span class=\"font-heading text-5xl font-black text-[#FF4F00]\" data-kid=\"41\">3 - 2</span>\n                            <span class=\"font-body text-[10px] text-gray-400 mt-2 uppercase font-black tracking-[0.2em]\" data-kid=\"42\">78' MIN</span>\n                        </div>\n                        <div class=\"flex flex-col items-center gap-2\" data-kid=\"43\">\n                            <div class=\"w-16 h-16 bg-red-50 rounded-3xl flex items-center justify-center text-3xl shadow-inner\" data-kid=\"44\">🦅</div>\n                            <span class=\"font-heading text-lg font-bold\" data-kid=\"45\">EGL</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"absolute bottom-10 right-10 w-[220px] h-[220px] bg-[#00A550] clay-island rounded-full flex items-center justify-center float-item\" data-speed=\"0.6\" data-kid=\"46\">\n                    <div class=\"absolute inset-0 glossy-overlay rounded-full\" data-kid=\"47\"></div>\n                    <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/foot.svg\" class=\"w-32 h-32\" data-kid=\"48\">\n                    <div class=\"absolute -bottom-4 -left-4 bg-white px-4 py-2 rounded-2xl shadow-lg border-2 border-green-50\" data-kid=\"49\">\n                        <span class=\"font-heading text-[#00A550] font-bold text-sm\" data-kid=\"50\">SPEED +15</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-20 bg-white/50 backdrop-blur-3xl\" data-kid=\"51\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"52\">\n            <div class=\"text-center mb-24\" data-kid=\"53\">\n                <h2 class=\"font-heading text-6xl font-bold text-gray-900 mb-6\" data-kid=\"54\">Unfair Advantage</h2>\n                <p class=\"font-body text-xl text-gray-500 max-w-2xl mx-auto\" data-kid=\"55\">We've built the ultimate toolkit for amateur pros who take their turf time seriously.</p>\n            </div>\n\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-start\" data-kid=\"56\">\n                \n                <div class=\"clay-surface bg-white blob-shape p-10 flex flex-col items-center text-center group h-[400px] justify-center\" data-kid=\"57\">\n                    <div class=\"w-24 h-24 mb-10 transform\" id=\"ref-flag-container\" data-kid=\"58\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/triangular-flag.svg\" class=\"w-full h-full\" data-kid=\"59\">\n                    </div>\n                    <h3 class=\"font-heading text-3xl font-bold mb-4 text-[#00A550]\" data-kid=\"60\">Live Ticker</h3>\n                    <p class=\"font-body text-base text-gray-500 font-medium\" data-kid=\"61\">Every goal, card, and foul recorded instantly. Zero latency, pure adrenaline.</p>\n                </div>\n\n                \n                <div class=\"clay-surface rounded-[50px] p-10 flex flex-col h-[700px] overflow-hidden group row-span-2 relative\" style=\"background-color: #FF4F00; color: white;\" data-kid=\"62\">\n                    <div class=\"absolute top-0 right-0 w-40 h-40 bg-white/10 rounded-full -mr-20 -mt-20 blur-3xl\" data-kid=\"63\"></div>\n                    <h3 class=\"font-heading text-4xl font-bold mb-2\" data-kid=\"64\">Player Cards</h3>\n                    <p class=\"font-body opacity-80 mb-12 text-lg font-medium\" data-kid=\"65\">Level up your profile and trade stats with friends.</p>\n                    \n                    <div class=\"flex-1 flex flex-col gap-4 items-center justify-center relative scale-90\" data-kid=\"66\">\n                        \n                        <div class=\"player-card-3d w-full max-w-[280px] h-[360px] cursor-pointer tilt-target -rotate-3\" data-kid=\"67\">\n                            <div class=\"w-full h-full bg-white rounded-[32px] p-6 shadow-2xl flex flex-col text-gray-900 border-8 border-white/20 relative\" data-kid=\"68\">\n                                <div class=\"absolute inset-0 glossy-overlay rounded-[32px] opacity-50\" data-kid=\"69\"></div>\n                                <div class=\"flex justify-between items-start mb-4\" data-kid=\"70\">\n                                    <div class=\"w-12 h-12 bg-[#FF4F00]/10 rounded-xl flex items-center justify-center font-heading font-bold text-[#FF4F00] text-xl\" data-kid=\"71\">99</div>\n                                    <i class=\"ti ti-medal text-3xl text-yellow-500\" data-kid=\"72\"></i>\n                                </div>\n                                <div class=\"flex-1 flex items-center justify-center mb-4\" data-kid=\"73\">\n                                    <div class=\"w-28 h-28 rounded-full overflow-hidden border-4 border-[#FF4F00]/10 shadow-inner\" data-kid=\"74\">\n                                        <img src=\"https://i.pravatar.cc/200?u=ace\" class=\"w-full h-full object-cover\" data-kid=\"75\">\n                                    </div>\n                                </div>\n                                <div class=\"text-center\" data-kid=\"76\">\n                                    <h4 class=\"font-heading text-2xl font-bold\" data-kid=\"77\">Ace Striker</h4>\n                                    <p class=\"font-body text-gray-400 font-black text-[9px] tracking-[0.2em] uppercase\" data-kid=\"78\">WORLD CLASS</p>\n                                </div>\n                            </div>\n                        </div>\n                        \n                        <div class=\"player-card-3d w-full max-w-[280px] h-[360px] cursor-pointer tilt-target rotate-3 -mt-20\" data-kid=\"79\">\n                            <div class=\"w-full h-full bg-[#00A550] rounded-[32px] p-6 shadow-2xl flex flex-col text-white border-8 border-white/20 relative\" data-kid=\"80\">\n                                <div class=\"absolute inset-0 glossy-overlay rounded-[32px] opacity-30\" data-kid=\"81\"></div>\n                                <div class=\"flex justify-between items-start mb-4\" data-kid=\"82\">\n                                    <div class=\"w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center font-heading font-bold text-white text-xl\" data-kid=\"83\">84</div>\n                                    <i class=\"ti ti-shield-check text-3xl text-white/50\" data-kid=\"84\"></i>\n                                </div>\n                                <div class=\"flex-1 flex items-center justify-center mb-4\" data-kid=\"85\">\n                                    <div class=\"w-28 h-28 rounded-full overflow-hidden border-4 border-white/20 shadow-inner\" data-kid=\"86\">\n                                        <img src=\"https://i.pravatar.cc/200?u=wall\" class=\"w-full h-full object-cover\" data-kid=\"87\">\n                                    </div>\n                                </div>\n                                <div class=\"text-center\" data-kid=\"88\">\n                                    <h4 class=\"font-heading text-2xl font-bold\" data-kid=\"89\">The Wall</h4>\n                                    <p class=\"font-body opacity-60 font-black text-[9px] tracking-[0.2em] uppercase\" data-kid=\"90\">PRO LEAGUE</p>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"clay-surface bg-[#F8F8FF] blob-shape p-10 overflow-hidden h-[500px]\" data-kid=\"91\">\n                    <div class=\"flex items-center justify-between mb-8\" data-kid=\"92\">\n                        <div data-kid=\"93\">\n                            <h3 class=\"font-heading text-3xl font-bold\" data-kid=\"94\">League Tables</h3>\n                            <p class=\"font-body text-gray-500 font-bold text-xs uppercase tracking-widest\" data-kid=\"95\">Weekly Ladder</p>\n                        </div>\n                        <div class=\"w-12 h-12 bg-[#FF4F00]/10 rounded-full flex items-center justify-center\" data-kid=\"96\">\n                            <i class=\"ti ti-chart-bar text-2xl text-[#FF4F00]\" data-kid=\"97\"></i>\n                        </div>\n                    </div>\n                    <div class=\"space-y-3\" data-kid=\"98\">\n                        <div class=\"flex items-center gap-4 bg-white p-4 rounded-3xl shadow-sm border border-gray-50 group transition-all cursor-pointer\" data-kid=\"99\">\n                            <span class=\"