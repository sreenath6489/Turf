      "html": "\n<div class=\"relative min-h-screen bg-[#010B13] overflow-x-clip font-['Fira_Sans'] text-white\" data-kid=\"0\">\n    \n    <div class=\"absolute inset-0 z-0 pointer-events-none\" data-kid=\"1\">\n        <img src=\"https://images.unsplash.com/photo-1642436273796-28447b6d3f93?auto=format&w=1440&q=80&fit=crop\" class=\"w-full h-full object-cover opacity-40 mix-blend-screen grayscale\" alt=\"turf-background\" decoding=\"async\" loading=\"lazy\" data-kid=\"2\">\n        <div class=\"absolute inset-0 bg-gradient-to-r from-[#010B13] via-[#010B13]/80 to-transparent\" data-kid=\"3\"></div>\n        <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#010B13_100%)] opacity-60\" data-kid=\"4\"></div>\n        \n        \n        <div class=\"absolute inset-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_4px,3px_100%] pointer-events-none opacity-20\" data-kid=\"5\"></div>\n    </div>\n\n    \n    <div id=\"particle-canvas\" class=\"absolute inset-0 z-1 pointer-events-none overflow-hidden\" data-kid=\"6\"></div>\n\n    \n    <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"7\">\n\n    \n    <nav class=\"absolute top-0 left-0 w-full p-8 z-50 flex justify-between items-center px-12 lg:px-20\" data-kid=\"8\">\n        <div class=\"flex items-center gap-3\" data-kid=\"9\">\n            <div class=\"w-10 h-10 bg-[#66FF00] rounded-xs flex items-center justify-center shadow-[0_0_15px_#66FF00]\" data-kid=\"10\">\n                <i class=\"ti ti-trophy text-black text-xl\" data-kid=\"11\"></i>\n            </div>\n            <span class=\"font-['Space_Grotesk'] font-bold text-xl tracking-tight uppercase\" data-kid=\"12\">Turf Pro</span>\n        </div>\n        <div class=\"hidden md:flex gap-10 text-sm font-medium tracking-widest uppercase text-white/50\" data-kid=\"13\">\n            <a href=\"#\" class=\"hover:text-[#66FF00] transition-colors\" data-kid=\"14\">Season 24</a>\n            <a href=\"#\" class=\"hover:text-[#66FF00] transition-colors\" data-kid=\"15\">Tournaments</a>\n            <a href=\"#\" class=\"hover:text-[#66FF00] transition-colors\" data-kid=\"16\">Rankings</a>\n        </div>\n    </nav>\n\n    \n    <main class=\"relative z-10 grid grid-cols-1 lg:grid-cols-12 min-h-screen items-center px-12 lg:px-20 pt-20 pb-40 lg:pb-0\" data-kid=\"17\">\n        \n        \n        <div class=\"lg:col-span-7 flex flex-col items-start gap-10\" data-kid=\"18\">\n            <div class=\"space-y-6\" data-kid=\"19\">\n                <h1 id=\"hero-headline\" class=\"font-['Space_Grotesk'] text-[min(12vw,140px)] leading-[0.8] font-black tracking-tighter uppercase text-transparent select-none animate-flicker\" style=\"-webkit-text-stroke: 2px #66FF00; paint-order: stroke fill; filter: drop-shadow(0 0 30px rgba(102, 255, 0, 0.4));\" data-kid=\"20\">\n                    TURF<br data-kid=\"21\">\n                    <span id=\"headline-glow\" class=\"text-white\" style=\"-webkit-text-stroke: 0;\" data-kid=\"22\">CRASHERS</span>\n                </h1>\n                <p class=\"max-w-xl text-lg md:text-xl text-white/70 leading-relaxed font-light font-['Fira_Sans']\" data-kid=\"23\">\n                    The playground evolved. <span class=\"text-[#66FF00]\" data-kid=\"24\">Cyber-integrated scoring</span> for teams that leave it all on the synthetic grass.\n                </p>\n            </div>\n\n            <div class=\"flex flex-wrap gap-8 mt-2\" data-kid=\"25\">\n                <button id=\"btn-start\" class=\"group relative px-12 py-6 bg-[#66FF00] text-black font-black text-xl uppercase tracking-widest overflow-hidden\" data-kid=\"26\">\n                    <span class=\"relative z-10 flex items-center gap-3\" data-kid=\"27\">\n                        <i class=\"ti ti-swords text-2xl\" data-kid=\"28\"></i>\n                        Start Match\n                    </span>\n                    <div class=\"absolute inset-0 bg-white/30 -translate-x-full group-hover:translate-x-0 transition-transform duration-500 skew-x-12\" data-kid=\"29\"></div>\n                </button>\n\n                <button id=\"btn-manage\" class=\"group relative px-12 py-6 border border-[#FF00CC]/50 bg-[#FF00CC]/5 backdrop-blur-xl text-white font-black text-xl uppercase tracking-widest overflow-hidden\" data-kid=\"30\">\n                    <span class=\"relative z-10 flex items-center gap-3\" data-kid=\"31\">\n                        <i class=\"ti ti-settings text-2xl group-hover:rotate-90 transition-transform duration-500\" data-kid=\"32\"></i>\n                        Dashboard\n                    </span>\n                    <div class=\"absolute bottom-0 left-0 w-full h-[2px] bg-[#FF00CC] shadow-[0_0_15px_#FF00CC]\" data-kid=\"33\"></div>\n                    <div class=\"absolute inset-0 bg-[#FF00CC]/10 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"34\"></div>\n                </button>\n            </div>\n\n            \n            <div id=\"live-feed\" class=\"w-full max-w-lg mt-12 bg-black/40 border border-white/5 p-6 backdrop-blur-md font-mono text-[11px] space-y-2 opacity-80\" data-kid=\"35\">\n                <div class=\"flex justify-between items-center text-[#66FF00]/50 border-b border-white/5 pb-2 mb-4\" data-kid=\"36\">\n                    <span data-kid=\"37\">LIVE_TRAFFIC_FEED</span>\n                    <span class=\"animate-pulse\" data-kid=\"38\">● REC</span>\n                </div>\n                <div class=\"flex gap-4\" data-kid=\"39\">\n                    <span class=\"text-[#FF00CC]\" data-kid=\"40\">[08:24:12]</span>\n                    <span class=\"text-white/60\" data-kid=\"41\">New League Created: <span class=\"text-white\" data-kid=\"42\">Neon Knights</span></span>\n                </div>\n                <div class=\"flex gap-4\" data-kid=\"43\">\n                    <span class=\"text-[#FF00CC]\" data-kid=\"44\">[08:23:45]</span>\n                    <span class=\"text-white/60\" data-kid=\"45\">Match Finalized: <span class=\"text-[#66FF00]\" data-kid=\"46\">Turf Warriors vs. Blitz </span> (+24 R)</span>\n                </div>\n                <div class=\"flex gap-4\" data-kid=\"47\">\n                    <span class=\"text-[#FF00CC]\" data-kid=\"48\">[08:22:10]</span>\n                    <span class=\"text-white/60\" data-kid=\"49\">Player Registered: <span class=\"text-white\" data-kid=\"50\">A. Cyberman</span> (Lvl 12)</span>\n                </div>\n                <div class=\"flex gap-4 opacity-40\" data-kid=\"51\">\n                    <span class=\"text-[#FF00CC]\" data-kid=\"52\">[08:21:05]</span>\n                    <span data-kid=\"53\">System Sync Complete. Ready for match protocol...</span>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"lg:col-span-5 relative h-[500px] lg:h-full flex items-center justify-center\" data-kid=\"54\">\n            <div id=\"three-container\" class=\"w-full h-full cursor-grab active:cursor-grabbing\" data-kid=\"55\"></div>\n            \n            \n            <div class=\"absolute inset-0 pointer-events-none flex items-center justify-center\" data-kid=\"56\">\n                <div class=\"w-[80%] aspect-square max-w-[450px] border border-white/5 rounded-full animate-spin-slow\" data-kid=\"57\"></div>\n                <div class=\"w-[90%] aspect-square max-w-[500px] border border-[#66FF00]/10 rounded-full animate-reverse-spin-slow\" data-kid=\"58\"></div>\n                <div class=\"w-[60%] aspect-square max-w-[350px] border-2 border-dashed border-[#FF00CC]/10 rounded-full\" data-kid=\"59\"></div>\n                \n                \n                <div class=\"absolute top-[15%] right-[5%] p-4 bg-black/60 backdrop-blur-xl border border-white/10 rounded-xs\" data-kid=\"60\">\n                    <div class=\"text-[9px] text-white/40 uppercase tracking-widest\" data-kid=\"61\">Core Status</div>\n                    <div class=\"text-[#66FF00] font-bold text-xs\" data-kid=\"62\">OPERATIONAL.SYS</div>\n                </div>\n                <div class=\"absolute bottom-[15%] left-[5%] p-4 bg-black/60 backdrop-blur-xl border border-white/10 rounded-xs\" data-kid=\"63\">\n                    <div class=\"text-[9px] text-white/40 uppercase tracking-widest\" data-kid=\"64\">Active Latency</div>\n                    <div class=\"text-[#FF00CC] font-bold text-xs\" data-kid=\"65\">0.02 MS</div>\n                </div>\n            </div>\n        </div>\n    </main>\n\n    \n    <div class=\"absolute bottom-0 left-0 w-full p-8 flex justify-between items-end z-20 px-12 lg:px-20\" data-kid=\"66\">\n        <div class=\"text-white/20 text-[10px] uppercase tracking-[0.5em] [writing-mode:vertical-lr] rotate-180\" data-kid=\"67\">\n            EST. 2024 / PROTOCOL ALPHA\n        </div>\n        <div class=\"flex flex-col items-end gap-2\" data-kid=\"68\">\n            <div class=\"flex gap-4\" data-kid=\"69\">\n                <a href=\"#\" class=\"w-10 h-10 border border-white/10 flex items-center justify-center hover:bg-[#66FF00] hover:text-black transition-all rounded-xs\" data-kid=\"70\">\n                    <i class=\"ti ti-brand-discord\" data-kid=\"71\"></i>\n                </a>\n                <a href=\"#\" class=\"w-10 h-10 border border-white/10 flex items-center justify-center hover:bg-[#FF00CC] hover:text-black transition-all rounded-xs\" data-kid=\"72\">\n                    <i class=\"ti ti-brand-twitter\" data-kid=\"73\"></i>\n                </a>\n            </div>\n            <div class=\"text-white/30 text-[10px] uppercase tracking-widest\" data-kid=\"74\">\n                Scroll to explore arena\n            </div>\n        </div>\n    </div>\n</div>\n\n<style data-kid=\"75\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700;900&family=Fira+Sans:wght@300;400;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    body {\n        margin: 0;\n        background: #010B13;\n        overflow-x: clip;\n    }\n\n    .animate-spin-slow {\n        animation: spin 30s linear infinite;\n    }\n\n    .animate-reverse-spin-slow {\n        animation: reverse-spin 25s linear infinite;\n    }\n\n    @keyframes flicker {\n        0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% { opacity: 1; transform: skewX(0deg); }\n        20%, 24%, 55% { opacity: 0.8; transform: skewX(2deg); }\n    }\n\n    .animate-flicker {\n        animation: flicker 4s infinite;\n    }\n\n    @keyframes spin {\n        from { transform: rotate(0deg); }\n        to { transform: rotate(360deg); }\n    }\n\n    @keyframes reverse-spin {\n        from { transform: rotate(360deg); }\n        to { transform: rotate(0deg); }\n    }\n\n    .particle {\n        position: absolute;\n        width: 3px;\n        height: 3px;\n        background: #66FF00;\n        border-radius: 50%;\n        filter: blur(1px);\n        pointer-events: none;\n    }\n\n    /* Custom scrollbar for webkit */\n    ::-webkit-scrollbar {\n        width: 6px;\n    }\n    ::-webkit-scrollbar-track {\n        background: #010B13;\n    }\n    ::-webkit-scrollbar-thumb {\n        background: #1A1A1A;\n        border-radius: 10px;\n    }\n    ::-webkit-scrollbar-thumb:hover {\n        background: #66FF00;\n    }\n</style>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"76\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"77\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/TextPlugin.min.js\" data-kid=\"78\"></script>\n<script data-kid=\"79\">\n    gsap.registerPlugin(ScrollTrigger);\n    gsap.registerPlugin(TextPlugin);\n</script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js\" data-kid=\"80\"></script>\n<script type=\"module\" data-kid=\"81\">\n    import { animate, hover } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n    import Lenis from \"https://esm.sh/lenis@1\";\n\n    // 1. Lenis Smooth Scroll\n    const lenis = new Lenis({ autoRaf: true });\n\n    // 2. Ambient Particles with GSAP\n    const particleContainer = document.getElementById('particle-canvas');\n    const particleCount = 60;\n    \n    for (let i = 0; i < particleCount; i++) {\n        const p = document.createElement('div');\n        p.className = 'particle';\n        particleContainer.appendChild(p);\n        \n        const initialX = Math.random() * window.innerWidth;\n        const initialY = Math.random() * window.innerHeight;\n        \n        gsap.set(p, {\n            x: initialX,\n            y: initialY,\n            opacity: Math.random() * 0.4 + 0.1,\n            scale: Math.random() * 0.5 + 0.5,\n            backgroundColor: Math.random() > 0.5 ? '#66FF00' : '#FF00CC'\n        });\n\n        // Drift animation\n        gsap.to(p, {\n            x: `+=${Math.random() * 400 - 200}`,\n            y: `+=${Math.random() * 400 - 200}`,\n            duration: 15 + Math.random() * 15,\n            repeat: -1,\n            yoyo: true,\n            ease: \"sine.inOut\"\n        });\n\n        // Pulse opacity\n        gsap.to(p, {\n            opacity: 0.1,\n            duration: 2 + Math.random() * 3,\n            repeat: -1,\n            yoyo: true,\n            ease: \"power1.inOut\"\n        });\n    }\n\n    // 3. Three.js Neon Ball\n    const initThree = () => {\n        const container = document.getElementById('three-container');\n        const scene = new THREE.Scene();\n        const camera = new THREE.PerspectiveCamera(40, container.clientWidth / container.clientHeight, 0.1, 1000);\n        const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });\n        \n        renderer.setSize(container.clientWidth, container.clientHeight);\n        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n        container.appendChild(renderer.domElement);\n\n        // Improved Lighting\n        const pointLight1 = new THREE.PointLight(0x66FF00, 5, 100);\n        pointLight1.position.set(10, 10, 10);\n        scene.add(pointLight1);\n\n        const pointLight2 = new THREE.PointLight(0xFF00CC, 5, 100);\n        pointLight2.position.set(-10, -10, 10);\n        scene.add(pointLight2);\n\n        // Inner core glow light\n        const coreLight = new THREE.PointLight(0x66FF00, 10, 15);\n        scene.add(coreLight);\n\n        const ballGroup = new THREE.Group();\n        scene.add(ballGroup);\n\n        // Core Sphere - More visible emissive\n        const sphereGeo = new THREE.SphereGeometry(2.2, 64, 64);\n        const sphereMat = new THREE.MeshStandardMaterial({\n            color: 0x010B13,\n            roughness: 0,\n            metalness: 1,\n            emissive: 0x66FF00,\n            emissiveIntensity: 2\n        });\n        const sphere = new THREE.Mesh(sphereGeo, sphereMat);\n        ballGroup.add(sphere);\n\n        // Neon Lattice\n        const wireGeo = new THREE.SphereGeometry(2.25, 32, 32);\n        const wireMat = new THREE.MeshBasicMaterial({\n            color: 0xFF00CC,\n            wireframe: true,\n            transparent: true,\n            opacity: 0.4\n        });\n        const wireSphere = new THREE.Mesh(wireGeo, wireMat);\n        ballGroup.add(wireSphere);\n\n        // Abstract Neon Trails\n        const ringConfigs = [\n            { radius: 3.2, color: 0x66FF00, rx: Math.PI / 4, ry: 0, thick: 0.06 },\n            { radius: 3.8, color: 0xFF00CC, rx: -Math.PI / 3, ry: Math.PI / 6, thick: 0.06 },\n            { radius: 4.4, color: 0x66FF00, rx: Math.PI / 2, ry: -Math.PI / 4, thick: 0.06 }\n        ];\n\n        const rings = ringConfigs.map(config => {\n            const torusGeo = new THREE.TorusGeometry(config.radius, config.thick, 24, 100);\n            const torusMat = new THREE.MeshBasicMaterial({ color: config.color });\n            const ring = new THREE.Mesh(torusGeo, torusMat);\n            ring.rotation.x = config.rx;\n            ring.rotation.y = config.ry;\n            ballGroup.add(ring);\n            return ring;\n        });\n\n        camera.position.z = 12;\n\n        const animateScene = () => {\n            requestAnimationFrame(animateScene);\n            ballGroup.rotation.y += 0.008;\n            ballGroup.rotation.x += 0.003;\n            rings.forEach((ring, idx) => ring.rotation.z += 0.012 * (idx + 1));\n            renderer.render(scene, camera);\n        };\n\n        animateScene();\n\n        // Responsive resize\n        window.addEventListener('resize', () => {\n            camera.aspect = container.clientWidth / container.clientHeight;\n            camera.updateProjectionMatrix();\n            renderer.setSize(container.clientWidth, container.clientHeight);\n        });\n    };\n\n    initThree();\n\n    // 4. Headline Glitch & Animations\n    gsap.from(\"#hero-headline\", {\n        duration: 1.5,\n        y: 100,\n        opacity: 0,\n        ease: \"power4.out\",\n        delay: 0.5\n    });\n\n    const glowInterval = setInterval(() => {\n        gsap.to(\"#headline-glow\", {\n            duration: 0.1,\n            opacity: Math.random() > 0.9 ? 0.3 : 1,\n            repeat: 1,\n            yoyo: true\n        });\n    }, 2000);\n\n    // 5. Live Feed Animation (Replacement for slop stats)\n    const feedLines = document.querySelectorAll('#live-feed .flex');\n    feedLines.forEach((line, i) => {\n        gsap.from(line, {\n            opacity: 0,\n            x: -20,\n            duration: 0.8,\n            delay: 1.2 + (i * 0.2),\n            ease: \"power2.out\"\n        });\n        \n        // Simulating typewriter for the text content\n        const textSpan = line.querySelector('span:last-child');\n        const originalText = textSpan.innerText;\n        textSpan.innerText = \"\";\n        \n        gsap.to(textSpan, {\n            text: originalText,\n            duration: 1,\n            delay: 1.4 + (i * 0.2),\n            ease: \"none\"\n        });\n    });\n\n    // 6. Button Hover Glow with motionjs\n    hover(\"#btn-start\", (el) => {\n        animate(el, { \n            boxShadow: \"0 0 30px rgba(102, 255, 0, 0.8)\",\n            scale: 1.05\n        }, { duration: 0.3 });\n        return () => animate(el, { \n            boxShadow: \"0 0 0px rgba(102, 255, 0, 0)\",\n            scale: 1\n        }, { duration: 0.3 });\n    });\n\n    hover(\"#btn-manage\", (el) => {\n        animate(el, { \n            boxShadow: \"0 0 30px rgba(255, 0, 204, 0.6)\",\n            scale: 1.05\n        }, { duration: 0.3 });\n        return () => animate(el, { \n            boxShadow: \"0 0 0px rgba(255, 0, 204, 0)\",\n            scale: 1\n        }, { duration: 0.3 });\n    });\n\n</script>\n",
