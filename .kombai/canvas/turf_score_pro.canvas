                <div class=\"team-card min-w-[420px] snap-center\" data-color=\"#66FF00\" data-kid=\"56\">\n                    <div class=\"relative bg-white/5 border border-white/10 backdrop-blur-xl p-10 rounded-xs h-full flex flex-col overflow-hidden group\" data-kid=\"57\">\n                        \n                        <div class=\"absolute -bottom-10 -right-10 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"58\">\n                            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/nested-hexagons.svg\" class=\"w-64 h-64 invert\" style=\"color: #66FF00;\" data-kid=\"59\">\n                        </div>\n\n                        <div class=\"flex justify-between items-start mb-12\" data-kid=\"60\">\n                            <div class=\"w-20 h-20 bg-black/60 border border-[#66FF00]/30 flex items-center justify-center rounded-xs relative\" data-kid=\"61\">\n                                <i class=\"ti ti-shield-check text-[#66FF00] text-4xl\" data-kid=\"62\"></i>\n                                <div class=\"absolute -top-1 -left-1 w-3 h-3 border-t-2 border-l-2 border-[#66FF00]\" data-kid=\"63\"></div>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"64\">\n                                <span class=\"block font-mono text-[10px] text-[#66FF00]/60 uppercase tracking-widest mb-1\" data-kid=\"65\">Status: Active</span>\n                                <span class=\"text-2xl font-bold font-mono\" data-kid=\"66\">#01</span>\n                            </div>\n                        </div>\n\n                        <div class=\"mb-10\" data-kid=\"67\">\n                            <h4 class=\"text-4xl font-black tracking-tight mb-2\" data-kid=\"68\">NEON VIPERS</h4>\n                            <p class=\"text-[#66FF00] text-xs font-mono uppercase tracking-[0.2em]\" data-kid=\"69\">Cpt. @CyberStrike_99</p>\n                        </div>\n\n                        <div class=\"mt-auto space-y-6\" data-kid=\"70\">\n                            <div class=\"flex justify-between items-end\" data-kid=\"71\">\n                                <div class=\"space-y-1\" data-kid=\"72\">\n                                    <span class=\"text-[10px] text-white/40 uppercase font-mono\" data-kid=\"73\">Squad Strength</span>\n                                    <div class=\"text-xl font-bold\" data-kid=\"74\">94.2 <span class=\"text-xs text-white/40 font-normal\" data-kid=\"75\">PWR</span></div>\n                                </div>\n                                <div class=\"flex -space-x-3\" data-kid=\"76\">\n                                    <img src=\"https://i.pravatar.cc/100?u=a1\" class=\"w-10 h-10 rounded-full border-2 border-black/80 ring-1 ring-white/10\" decoding=\"async\" loading=\"lazy\" data-kid=\"77\">\n                                    <img src=\"https://i.pravatar.cc/100?u=a2\" class=\"w-10 h-10 rounded-full border-2 border-black/80 ring-1 ring-white/10\" decoding=\"async\" loading=\"lazy\" data-kid=\"78\">\n                                    <img src=\"https://i.pravatar.cc/100?u=a3\" class=\"w-10 h-10 rounded-full border-2 border-black/80 ring-1 ring-white/10\" decoding=\"async\" loading=\"lazy\" data-kid=\"79\">\n                                    <div class=\"w-10 h-10 rounded-full bg-black border-2 border-white/10 flex items-center justify-center text-[10px] font-mono text-white/60\" data-kid=\"80\">+12</div>\n                                </div>\n                            </div>\n                            <div class=\"h-[2px] bg-white/10 relative overflow-hidden\" data-kid=\"81\">\n                                <div class=\"absolute inset-y-0 left-0 bg-[#66FF00] w-[94%] shadow-[0_0_10px_#66FF00]\" data-kid=\"82\"></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"team-card min-w-[420px] snap-center\" data-color=\"#FF00CC\" data-kid=\"83\">\n                    <div class=\"relative bg-white/5 border border-white/10 backdrop-blur-xl p-10 rounded-xs h-full flex flex-col overflow-hidden group\" data-kid=\"84\">\n                        <div class=\"absolute -bottom-10 -right-10 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"85\">\n                            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/swords-emblem.svg\" class=\"w-64 h-64 invert\" style=\"color: #FF00CC;\" data-kid=\"86\">\n                        </div>\n\n                        <div class=\"flex justify-between items-start mb-12\" data-kid=\"87\">\n                            <div class=\"w-20 h-20 bg-black/60 border border-[#FF00CC]/30 flex items-center justify-center rounded-xs relative\" data-kid=\"88\">\n                                <i class=\"ti ti-swords text-[#FF00CC] text-4xl\" data-kid=\"89\"></i>\n                                <div class=\"absolute -top-1 -left-1 w-3 h-3 border-t-2 border-l-2 border-[#FF00CC]\" data-kid=\"90\"></div>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"91\">\n                                <span class=\"block font-mono text-[10px] text-[#FF00CC]/60 uppercase tracking-widest mb-1\" data-kid=\"92\">Status: Stable</span>\n                                <span class=\"text-2xl font-bold font-mono\" data-kid=\"93\">#02</span>\n                            </div>\n                        </div>\n\n                        <div class=\"mb-10\" data-kid=\"94\">\n                            <h4 class=\"text-4xl font-black tracking-tight mb-2\" data-kid=\"95\">PULSE RAIDERS</h4>\n                            <p class=\"text-[#FF00CC] text-xs font-mono uppercase tracking-[0.2em]\" data-kid=\"96\">Cpt. @Echo_Phantom</p>\n                        </div>\n\n                        <div class=\"mt-auto space-y-6\" data-kid=\"97\">\n                            <div class=\"flex justify-between items-end\" data-kid=\"98\">\n                                <div class=\"space-y-1\" data-kid=\"99\">\n                                    <span class=\"text-[10px] text-white/40 uppercase font-mono\" data-kid=\"100\">Squad Strength</span>\n                                    <div class=\"text-xl font-bold\" data-kid=\"101\">81.5 <span class=\"text-xs text-white/40 font-normal\" data-kid=\"102\">PWR</span></div>\n                                </div>\n                                <div class=\"flex -space-x-3\" data-kid=\"103\">\n                                    <img src=\"https://i.pravatar.cc/100?u=b1\" class=\"w-10 h-10 rounded-full border-2 border-black/80 ring-1 ring-white/10\" decoding=\"async\" loading=\"lazy\" data-kid=\"104\">\n                                    <img src=\"https://i.pravatar.cc/100?u=b2\" class=\"w-10 h-10 rounded-full border-2 border-black/80 ring-1 ring-white/10\" decoding=\"async\" loading=\"lazy\" data-kid=\"105\">\n                                    <div class=\"w-10 h-10 rounded-full bg-black border-2 border-white/10 flex items-center justify-center text-[10px] font-mono text-white/60\" data-kid=\"106\">+15</div>\n                                </div>\n                            </div>\n                            <div class=\"h-[2px] bg-white/10 relative overflow-hidden\" data-kid=\"107\">\n                                <div class=\"absolute inset-y-0 left-0 bg-[#FF00CC] w-[81%] shadow-[0_0_10px_#FF00CC]\" data-kid=\"108\"></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"team-card min-w-[420px] snap-center opacity-50\" data-color=\"#00F0FF\" data-kid=\"109\">\n                    <div class=\"relative bg-black/40 border border-white/5 backdrop-blur-xl p-10 rounded-xs h-full flex flex-col overflow-hidden group border-dashed\" data-kid=\"110\">\n                        <div class=\"absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10\" data-kid=\"111\"></div>\n                        \n                        <div class=\"flex justify-between items-start mb-12 relative z-10\" data-kid=\"112\">\n                            <div class=\"w-20 h-20 bg-white/5 border border-white/10 flex items-center justify-center rounded-xs opacity-40\" data-kid=\"113\">\n                                <i class=\"ti ti-power text-white text-4xl\" data-kid=\"114\"></i>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"115\">\n                                <span class=\"block font-mono text-[9px] text-white/40 uppercase tracking-widest mb-1\" data-kid=\"116\">Status: Disconnected</span>\n                                <span class=\"text-2xl font-bold font-mono text-white/20\" data-kid=\"117\">#03</span>\n                            </div>\n                        </div>\n\n                        <div class=\"mb-10 relative z-10\" data-kid=\"118\">\n                            <h4 class=\"text-4xl font-black tracking-tight mb-2 text-white/30\" data-kid=\"119\">VOID PHANTOMS</h4>\n                            <p class=\"text-white/20 text-xs font-mono uppercase tracking-[0.2em]\" data-kid=\"120\">Cpt. Unknown_Entity</p>\n                        </div>\n\n                        <div class=\"mt-auto relative z-10\" data-kid=\"121\">\n                            <div class=\"p-4 border border-dashed border-white/20 bg-white/5 text-center relative overflow-hidden group-hover:bg-[#00F0FF]/5 transition-colors\" data-kid=\"122\">\n                                <div class=\"absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent -translate-x-full animate-[shimmer_2s_infinite]\" data-kid=\"123\"></div>\n                                <p class=\"text-[10px] font-mono text-white/40 uppercase animate-pulse\" data-kid=\"124\">Waiting for network link...</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n            </div>\n        </section>\n    </main>\n\n    \n    <div class=\"fixed bottom-0 right-0 p-8 z-50 pointer-events-none\" data-kid=\"125\">\n        <div class=\"flex gap-12 items-center bg-black/60 backdrop-blur-md px-10 py-5 border-l border-t border-white/10\" data-kid=\"126\">\n            <div class=\"text-center\" data-kid=\"127\">\n                <span class=\"block text-[8px] font-mono text-white/30 uppercase tracking-[0.2em]\" data-kid=\"128\">Live Nodes</span>\n                <span class=\"text-lg font-bold text-[#66FF00]\" data-kid=\"129\">1,204</span>\n            </div>\n            <div class=\"w-px h-8 bg-white/10\" data-kid=\"130\"></div>\n            <div class=\"text-center\" data-kid=\"131\">\n                <span class=\"block text-[8px] font-mono text-white/30 uppercase tracking-[0.2em]\" data-kid=\"132\">Sync Latency</span>\n                <span class=\"text-lg font-bold text-[#FF00CC]\" data-kid=\"133\">14ms</span>\n            </div>\n        </div>\n    </div>\n</div>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"134\">\n<style data-kid=\"135\">\n@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Code:wght@300;400;500&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n.no-scrollbar::-webkit-scrollbar { display: none; }\n.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n@keyframes shimmer {\n    100% { transform: translateX(100%); }\n}\n</style>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"136\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"137\"></script>\n<script type=\"module\" data-kid=\"138\">\n    import { animate, scroll, hover, inView } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n    import Lenis from \"https://esm.sh/lenis@1\"\n    import Snap from \"https://esm.sh/lenis@1/snap\"\n\n    // Initialize Lenis for smooth scrolling\n    const lenis = new Lenis({ autoRaf: true });\n\n    // GSAP Entrance Animations\n    gsap.from(\"#team-form-panel\", {\n        xPercent: -100,\n        duration: 1.2,\n        ease: \"power4.out\"\n    });\n\n    gsap.from(\"#section-title\", {\n        y: 50,\n        opacity: 0,\n        duration: 1,\n        delay: 0.4,\n        ease: \"power3.out\"\n    });\n\n    gsap.from(\".team-card\", {\n        x: 100,\n        opacity: 0,\n        duration: 0.8,\n        stagger: 0.15,\n        delay: 0.6,\n        ease: \"power2.out\"\n    });\n\n    // Motion.dev Hover Effects (Glow Halo)\n    document.querySelectorAll('.team-card').forEach(card => {\n        const color = card.getAttribute('data-color') || '#66FF00';\n        const inner = card.querySelector('.relative');\n        \n        hover(card, () => {\n            animate(inner, { \n                boxShadow: `0 20px 60px ${color}22`,\n                borderColor: `${color}66`,\n                backgroundColor: 'rgba(255, 255, 255, 0.08)'\n            }, { \n                duration: 0.4, \n                ease: 'easeOut' \n            });\n            return () => animate(inner, { \n                boxShadow: '0 0px 0px rgba(0,0,0,0)',\n                borderColor: 'rgba(255, 255, 255, 0.1)',\n                backgroundColor: 'rgba(255, 255, 255, 0.05)'\n            }, { \n                duration: 0.3 \n            });\n        });\n    });\n\n    // Carousel Navigation\n    const carousel = document.getElementById('team-carousel');\n    document.querySelectorAll('.carousel-nav-btn').forEach(btn => {\n        btn.addEventListener('click', () => {\n            const direction = btn.getAttribute('data-dir');\n            const scrollAmount = 452; // Card width (420) + gap (32)\n            carousel.scrollBy({\n                left: direction === 'next' ? scrollAmount : -scrollAmount,\n                behavior: 'smooth'\n            });\n        });\n    });\n\n    // Particle Effect Logic (Ambient Particles)\n    const createParticle = () => {\n        const p = document.createElement('div');\n        p.className = 'fixed w-1 h-1 bg-white/20 rounded-full z-0 pointer-events-none';\n        p.style.left = Math.random() * 100 + 'vw';\n        p.style.top = Math.random() * 100 + 'vh';\n        document.body.appendChild(p);\n        \n        animate(p, {\n            y: [0, -100],\n            opacity: [0, 1, 0],\n            scale: [1, 2]\n        }, {\n            duration: 10 + Math.random() * 20,\n            repeat: Infinity,\n            ease: 'linear'\n        });\n    };\n\n    for(let i=0; i<30; i++) createParticle();\n\n</script>\n",
