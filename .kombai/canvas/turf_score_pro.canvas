      "html": "\n<div class=\"min-h-screen bg-[#010B13] text-white font-['Space_Grotesk'] selection:bg-[#66FF00] selection:text-black overflow-x-clip relative\" data-kid=\"0\">\n    \n    <div class=\"fixed inset-0 z-0 pointer-events-none opacity-10\" data-kid=\"1\">\n        <img src=\"https://images.unsplash.com/photo-1642436273796-28447b6d3f93?auto=format&w=1920&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale brightness-50 contrast-125\" decoding=\"async\" loading=\"lazy\" data-kid=\"2\">\n    </div>\n    \n    \n    <div class=\"fixed inset-0 z-0 pointer-events-none overflow-hidden\" data-kid=\"3\">\n        <div class=\"absolute top-1/4 -left-20 w-[150%] h-px bg-[#66FF00]/10 rotate-12\" data-kid=\"4\"></div>\n        <div class=\"absolute bottom-1/3 -right-20 w-[150%] h-px bg-[#FF00CC]/10 -rotate-6\" data-kid=\"5\"></div>\n    </div>\n\n    \n    <main class=\"relative z-10 flex min-h-screen\" data-kid=\"6\">\n        \n        \n        <aside id=\"team-form-panel\" class=\"w-[420px] border-r border-white/5 bg-black/80 backdrop-blur-3xl p-10 flex flex-col justify-between shrink-0 relative overflow-hidden\" data-kid=\"7\">\n            \n            <div class=\"absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-[#66FF00]/20 pointer-events-none\" data-kid=\"8\"></div>\n            <div class=\"absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-[#66FF00]/20 pointer-events-none\" data-kid=\"9\"></div>\n            \n            <div class=\"relative z-10\" data-kid=\"10\">\n                <div class=\"mb-12\" data-kid=\"11\">\n                    <div class=\"flex items-center gap-3 mb-4\" data-kid=\"12\">\n                        <div class=\"w-8 h-[2px] bg-[#66FF00]\" data-kid=\"13\"></div>\n                        <span class=\"text-[10px] font-mono tracking-widest text-[#66FF00] uppercase\" data-kid=\"14\">Squad Onboarding</span>\n                    </div>\n                    <h1 class=\"text-4xl font-black tracking-tighter leading-none mb-4\" data-kid=\"15\">\n                        REGISTER<br data-kid=\"16\">\n                        <span class=\"text-white/10\" style=\"-webkit-text-stroke: 1.5px #66FF00;\" data-kid=\"17\">FRANCHISE</span>\n                    </h1>\n                    <p class=\"text-white/60 text-sm max-w-[280px] font-light leading-relaxed\" data-kid=\"18\">Initialize a new professional collective into the global competitive network.</p>\n                </div>\n\n                <form class=\"space-y-8\" data-kid=\"19\">\n                    \n                    <div class=\"space-y-3\" data-kid=\"20\">\n                        <label class=\"block text-[10px] font-mono uppercase tracking-widest text-white/50\" data-kid=\"21\">Team Designation</label>\n                        <div class=\"relative group\" data-kid=\"22\">\n                            <input type=\"text\" placeholder=\"e.g. TITAN STRIKERS\" class=\"w-full bg-white/5 border border-white/10 py-4 px-6 rounded-xs focus:outline-none focus:border-[#66FF00]/60 focus:bg-white/10 transition-all text-base placeholder:text-white/20\" data-kid=\"23\">\n                            <div class=\"absolute top-0 left-0 w-1 h-1 bg-[#66FF00] opacity-0 group-focus-within:opacity-100\" data-kid=\"24\"></div>\n                            <div class=\"absolute bottom-0 right-0 w-1 h-1 bg-[#66FF00] opacity-0 group-focus-within:opacity-100\" data-kid=\"25\"></div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"space-y-3\" data-kid=\"26\">\n                        <label class=\"block text-[10px] font-mono uppercase tracking-widest text-white/50\" data-kid=\"27\">Field Commander</label>\n                        <div class=\"relative group\" data-kid=\"28\">\n                            <input type=\"text\" placeholder=\"Assigned Alias...\" class=\"w-full bg-white/5 border border-white/10 py-4 px-6 rounded-xs focus:outline-none focus:border-[#FF00CC]/60 focus:bg-white/10 transition-all text-base placeholder:text-white/20\" data-kid=\"29\">\n                            <div class=\"absolute top-0 left-0 w-1 h-1 bg-[#FF00CC] opacity-0 group-focus-within:opacity-100\" data-kid=\"30\"></div>\n                            <div class=\"absolute bottom-0 right-0 w-1 h-1 bg-[#FF00CC] opacity-0 group-focus-within:opacity-100\" data-kid=\"31\"></div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"space-y-4\" data-kid=\"32\">\n                        <label class=\"block text-[10px] font-mono uppercase tracking-widest text-white/70\" data-kid=\"33\">Team Spectrum</label>\n                        <div class=\"flex gap-4\" data-kid=\"34\">\n                            <button type=\"button\" class=\"w-10 h-10 rounded-xs bg-[#66FF00] shadow-[0_0_15px_rgba(102,255,0,0.4)] border-2 border-white/20\" data-kid=\"35\"></button>\n                            <button type=\"button\" class=\"w-10 h-10 rounded-xs bg-[#FF00CC] hover:scale-110 transition-transform\" data-kid=\"36\"></button>\n                            <button type=\"button\" class=\"w-10 h-10 rounded-xs bg-[#00F0FF] hover:scale-110 transition-transform\" data-kid=\"37\"></button>\n                            <button type=\"button\" class=\"w-10 h-10 rounded-xs bg-[#FFB800] hover:scale-110 transition-transform\" data-kid=\"38\"></button>\n                        </div>\n                    </div>\n\n                    \n                    <button type=\"submit\" class=\"w-full relative py-6 mt-6 bg-transparent group overflow-hidden border border-[#66FF00]/50\" data-kid=\"39\">\n                        <div class=\"absolute inset-0 bg-[#66FF00] translate-y-full group-hover:translate-y-0 transition-transform duration-300\" data-kid=\"40\"></div>\n                        <span class=\"relative z-10 font-bold uppercase tracking-[0.2em] text-[#66FF00] group-hover:text-black transition-colors\" data-kid