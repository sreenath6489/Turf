xt-center relative z-10\" data-kid=\"72\">\n                        <span class=\"text-[#66FF00] text-sm uppercase tracking-[1em] opacity-80 mb-6 block\" data-kid=\"73\">Current Score</span>\n                        <div class=\"flex items-center justify-center gap-6\" data-kid=\"74\">\n                            <div id=\"score-runs-wrap\" class=\"text-[180px] lg:text-[220px] font-black leading-none tracking-tighter tabular-nums text-white drop-shadow-[0_0_40px_rgba(102,255,0,0.2)]\" data-kid=\"75\">\n                                <span id=\"runs-counter\" class=\"stat\" data-target=\"184\" data-kid=\"76\">184</span>\n                            </div>\n                            <div class=\"h-32 w-px bg-white/10 mx-4 self-center\" data-kid=\"77\"></div>\n                            <div id=\"score-wickets-wrap\" class=\"text-[120px] lg:text-[140px] font-bold leading-none text-[#FF00CC] drop-shadow-[0_0_30px_rgba(255,0,204,0.3)]\" data-kid=\"78\">\n                                <span id=\"wickets-counter\" data-kid=\"79\">3</span>\n                            </div>\n                        </div>\n                        \n                        <div class=\"mt-12 flex items-center justify-center gap-12\" data-kid=\"80\">\n                            <div class=\"text-center\" data-kid=\"81\">\n                                <p class=\"text-white/30 text-[10px] uppercase tracking-[0.3em] mb-1\" data-kid=\"82\">Overs</p>\n                                <p class=\"text-4xl font-mono text-white tracking-widest\" data-kid=\"83\">18.4</p>\n                            </div>\n                            <div class=\"text-center\" data-kid=\"84\">\n                                <p class=\"text-white/30 text-[10px] uppercase tracking-[0.3em] mb-1\" data-kid=\"85\">Target</p>\n                                <p class=\"text-4xl font-mono text-[#66FF00] tracking-widest\" data-kid=\"86\">214</p>\n                            </div>\n                            <div class=\"text-center\" data-kid=\"87\">\n                                <p class=\"text-white/30 text-[10px] uppercase tracking-[0.3em] mb-1\" data-kid=\"88\">Need</p>\n                                <p class=\"text-4xl font-mono text-[#FF00CC] tracking-widest animate-pulse\" data-kid=\"89\">30</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"grid grid-cols-4 lg:grid-cols-6 gap-4 bg-[#1A1A1A]/40 p-6 rounded-2xl border border-white/10 shadow-2xl relative overflow-hidden group\" data-kid=\"90\">\n                    \n                    <div id=\"sparks-canvas\" class=\"absolute inset-0 pointer-events-none z-20\" data-kid=\"91\"></div>\n\n                    <button class=\"score-btn col-span-1 bg-[#252525] border-b-6 border-[#66FF00] p-6 rounded-xl flex flex-col items-center justify-center hover:brightness-110 active:border-b-0 active:translate-y-1 group relative outline-hidden\" onclick=\"triggerEffect(this, 6)\" data-kid=\"92\">\n                        <span class=\"text-4xl lg:text-5xl font-black group-hover:drop-shadow-[0_0_10px_#66FF00]\" data-kid=\"93\">6</span>\n                        <span class=\"text-[10px] text-white/40 font-bold tracking-tighter\" data-kid=\"94\">SIXER</span>\n                    </button>\n                    \n                    <button class=\"score-btn col-span-1 bg-[#252525] border-b-6 border-[#66FF00] p-6 rounded-xl flex flex-col items-center justify-center hover:brightness-110 active:border-b-0 active:translate-y-1 group relative outline-hidden\" onclick=\"triggerEffect(this, 4)\" data-kid=\"95\">\n                        <span class=\"text-4xl lg:text-5xl font-black group-hover:drop-shadow-[0_0_10px_#66FF00]\" data-kid=\"96\">4</span>\n                        <span class=\"text-[10px] text-white/40 font-bold tracking-tighter\" data-kid=\"97\">FOUR</span>\n                    </button>\n\n                    <button class=\"score-btn col-span-1 bg-[#1a1a1a] border-b-6 border-white/20 p-6 rounded-xl flex flex-col items-center justify-center hover:brightness-110 active:border-b-0 active:translate-y-1 group outline-hidden\" data-kid=\"98\">\n                        <span class=\"text-3xl lg:text-4xl font-black text-white/80 group-hover:text-white\" data-kid=\"99\">1</span>\n                        <span class=\"text-[10px] text-white/40 font-bold tracking-tighter\" data-kid=\"100\">SINGLE</span>\n                    </button>\n\n                    <button class=\"score-btn col-span-1 bg-[#1a1a1a] border-b-6 border-white/20 p-6 rounded-xl flex flex-col items-center justify-center hover:brightness-110 active:border-b-0 active:translate-y-1 group outline-hidden\" data-kid=\"101\">\n                        <span class=\"text-3xl lg:text-4xl font-black text-white/80 group-hover:text-white\" data-kid=\"102\">2</span>\n                        <span class=\"text-[10px] text-white/40 font-bold tracking-tighter\" data-kid=\"103\">DOUBLE</span>\n                    </button>\n\n                    <button class=\"score-btn col-span-2 bg-[#1a1a1a] border-b-6 border-[#FF00CC]/50 p-6 rounded-xl flex flex-col items-center justify-center hover:brightness-110 active:border-b-0 active:translate-y-1 group outline-hidden\" data-kid=\"104\">\n                        <span class=\"text-2xl font-black text-[#FF00CC] group-hover:drop-shadow-[0_0_8px_#FF00CC]\" data-kid=\"105\">WIDE</span>\n                    </button>\n\n                    <button class=\"score-btn col-span-2 bg-[#1a1a1a] border-b-6 border-white/20 p-6 rounded-xl flex flex-col items-center justify-center hover:brightness-110 active:border-b-0 active:translate-y-1 group outline-hidden\" data-kid=\"106\">\n                        <span class=\"text-2xl font-black text-white/80 group-hover:text-white\" data-kid=\"107\">NB</span>\n                    </button>\n\n                    <button class=\"score-btn col-span-2 bg-[#FF00CC]/10 border-2 border-[#FF00CC] border-b-6 p-6 rounded-xl flex flex-col items-center justify-center hover:bg-[#FF00CC]/20 active:border-b-0 active:translate-y-1 group outline-hidden shadow-[0_0_15px_rgba(255,0,204,0.1)]\" data-kid=\"108\">\n                        <span class=\"text-2xl lg:text-3xl font-black text-[#FF00CC] group-hover:text-white drop-shadow-[0_0_8px_#FF00CC]\" data-kid=\"109\">WICKET</span>\n                    </button>\n\n                    <button class=\"score-btn col-span-2 bg-white/5 border-b-6 border-white/10 p-6 rounded-xl flex flex-col items-center justify-center hover:bg-white/10 active:border-b-0 active:translate-y-1 group outline-hidden\" data-kid=\"110\">\n                        <span class=\"text-2xl font-black text-white/40 group-hover:text-white\" data-kid=\"111\">0</span>\n                        <span class=\"text-[10px] text-white/40 font-bold tracking-tighter\" data-kid=\"112\">DOT</span>\n                    </button>\n                </div>\n            </section>\n\n            \n            <aside class=\"col-span-3 space-y-6 hidden lg:flex flex-col\" data-kid=\"113\">\n                <div class=\"flex-grow hud-card border border-white/5 bg-[#1A1A1A]/40 backdrop-blur-sm rounded-2xl flex flex-col overflow-hidden\" data-kid=\"114\">\n                    <div class=\"p-6 border-b border-white/5 flex justify-between items-center bg-white/2\" data-kid=\"115\">\n                        <h3 class=\"text-xs font-bold uppercase tracking-widest flex items-center gap-2\" data-kid=\"116\">\n                            <span class=\"w-1.5 h-1.5 bg-[#FF00CC] rounded-full\" data-kid=\"117\"></span> Live Commentary\n                        </h3>\n                        <span class=\"text-[10px] text-white/40 font-mono\" data-kid=\"118\">18.4 OVERS</span>\n                    </div>\n                    \n                    <div id=\"commentary-ticker\" class=\"flex-grow overflow-y-auto p-4 space-y-4 custom-scrollbar\" data-kid=\"119\">\n                        \n                        <div class=\"commentary-item p-4 bg-white/2 border-l-2 border-[#66FF00] rounded-r-lg\" data-kid=\"120\">\n                            <div class=\"flex items-center gap-3 mb-1\" data-kid=\"121\">\n                                <span class=\"text-[10px] font-mono text-[#66FF00] bg-[#66FF00]/10 px-1 rounded\" data-kid=\"122\">18.4</span>\n                                <span class=\"text-[10px] text-white/60 font-mono\" data-kid=\"123\">12:44:02</span>\n                            </div>\n                            <p class=\"text-sm font-medium leading-relaxed\" data-kid=\"124\">Phantom-X to Raven, <span class=\"text-[#66FF00] font-bold\" data-kid=\"125\">SIX RUNS!</span> Smashed over deep mid-wicket. Pure power!</p>\n                        </div>\n                        \n                        \n                        <div class=\"commentary-item p-4 bg-white/2 border-l-2 border-white/10 rounded-r-lg opacity-80\" data-kid=\"126\">\n                            <div class=\"flex items-center gap-3 mb-1\" data-kid=\"127\">\n                                <span class=\"text-[10px] font-mono text-white/40 bg-white/5 px-1 rounded\" data-kid=\"128\">18.3</span>\n                                <span class=\"text-[10px] text-white/40 font-mono\" data-kid=\"129\">12:43:40</span>\n                            </div>\n                            <p class=\"text-sm\" data-kid=\"130\">Phantom-X to Raven, no run. Yorker length outside off.</p>\n                        </div>\n\n                        \n                        <div class=\"commentary-item p-4 bg-white/2 border-l-2 border-[#66FF00] rounded-r-lg opacity-60\" data-kid=\"131\">\n                            <div class=\"flex justify-between mb-1\" data-kid=\"132\">\n                                <span class=\"text-[10px] font-mono text-[#66FF00]\" data-kid=\"133\">18.2</span>\n                                <span class=\"text-[10px] text-white/40\" data-kid=\"134\">12:43:12</span>\n                            </div>\n                            <p class=\"text-sm font-medium\" data-kid=\"135\"><span class=\"text-[#66FF00] font-bold\" data-kid=\"136\">FOUR RUNS!</span> Cut away past backward point. Exquisite timing.</p>\n                        </div>\n\n                        \n                        <div class=\"commentary-item p-4 bg-white/2 border-l-2 border-white/10 rounded-r-lg opacity-40\" data-kid=\"137\">\n                            <div class=\"flex justify-between mb-1\" data-kid=\"138\">\n                                <span class=\"text-[10px] font-mono text-white/40\" data-kid=\"139\">18.1</span>\n                                <span class=\"text-[10px] text-white/40\" data-kid=\"140\">12:42:50</span>\n                            </div>\n                            <p class=\"text-sm\" data-kid=\"141\">Phantom-X to Neon, 1 run. Pushed to long-on for a single.</p>\n                        </div>\n\n                        \n                        <div class=\"text-center py-2\" data-kid=\"142\">\n                            <span class=\"text-[10px] text-white/20 uppercase tracking-[0.5em]\" data-kid=\"143\">End of Over 18</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"p-6 border border-white/5 bg-[#1A1A1A]/80 backdrop-blur-md rounded-2xl relative\" data-kid=\"144\">\n                    <div class=\"flex justify-between items-center\" data-kid=\"145\">\n                        <div data-kid=\"146\">\n                            <p class=\"text-[10px] text-white/40 uppercase tracking-widest\" data-kid=\"147\">Win Prob</p>\n                            <p class=\"text-2xl font-black text-[#66FF00]\" data-kid=\"148\">68%</p>\n                        </div>\n                        <div class=\"w-24 h-2 bg-white/5 rounded-full overflow-hidden\" data-kid=\"149\">\n                            <div class=\"h-full bg-gradient-to-r from-[#FF00CC] to-[#66FF00]\" style=\"width: 68%;\" data-kid=\"150\"></div>\n                        </div>\n                    </div>\n                </div>\n            </aside>\n        </div>\n    </main>\n\n    \n    <footer class=\"fixed bottom-0 left-0 w-full p-4 flex justify-between items-center text-[10px] text-white/20 uppercase tracking-[0.2em] pointer-events-none z-50\" data-kid=\"151\">\n        <div class=\"flex gap-4\" data-kid=\"152\">\n            <span data-kid=\"153\">System: Optimal</span>\n            <span data-kid=\"154\">Latency: 14ms</span>\n        </div>\n        <div class=\"flex gap-4\" data-kid=\"155\">\n            <span data-kid=\"156\">S7-TURF-OS v4.0.2</span>\n            <span data-kid=\"157\">&copy; Cyber Turf 2024</span>\n        </div>\n    </footer>\n</div>\n\n<style data-kid=\"158\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;900&family=Fira+Sans:wght@300;400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n    @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n    body {\n        background-color: #010B13;\n        margin: 0;\n        cursor: crosshair;\n    }\n\n    .scanline {\n        background: linear-gradient(to bottom, transparent 50%, rgba(0, 0, 0, .2) 51%);\n        background-size: 100% 4px;\n        z-index: 100;\n        pointer-events: none;\n    }\n\n    .custom-scrollbar::-webkit-scrollbar {\n        width: 4px;\n    }\n    .custom-scrollbar::-webkit-scrollbar-track {\n        background: transparent;\n    }\n    .custom-scrollbar::-webkit-scrollbar-thumb {\n        background: rgba(255, 255, 255, 0.1);\n        border-radius: 10px;\n    }\n\n    .hud-card {\n        box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.02);\n    }\n\n    .border-b-6 {\n        border-bottom-width: 6px;\n    }\n\n    .score-btn {\n        user-select: none;\n    }\n\n    .score-btn:active {\n        transform: translateY(2px);\n    }\n\n    .marquee-track {\n        display: flex;\n        width: fit-content;\n    }\n\n    .particle {\n        position: absolute;\n        width: 3px;\n        height: 3px;\n        background: #66FF00;\n        border-radius: 50%;\n        pointer-events: none;\n    }\n\n    .spark {\n        position: absolute;\n        width: 4px;\n        height: 4px;\n        background: #66FF00;\n        pointer-events: none;\n        z-index: 50;\n    }\n\n    /* Prevent overflow issues with position sticky if added later */\n    .overflow-x-clip {\n        overflow-x: clip;\n    }\n</style>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"159\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"160\"></script>\n<script data-kid=\"161\">gsap.registerPlugin(ScrollTrigger);</script>\n<script type=\"module\" data-kid=\"162\">\n    import { animate, scroll, inView, hover } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n    import Lenis from \"https://esm.sh/lenis@1\"\n\n    // 1. Lenis Smooth Scroll\n    const lenis = new Lenis({ autoRaf: true });\n\n    // 2. Marquee Animation\n    gsap.to(\".marquee-track\", {\n        xPercent: -50,\n        repeat: -1,\n        duration: 20,\n        ease: \"none\"\n    });\n\n    // 3. Score Count Up Animation\n    const scoreElement = document.getElementById('runs-counter');\n    const targetScore = parseInt(scoreElement.dataset.target);\n    \n    gsap.from(scoreElement, {\n        textContent: 0,\n        duration: 2,\n        ease: \"power2.out\",\n        snap: { textContent: 1 },\n        stagger: { each: 0.1 }\n    });\n\n    // 4. Ambient Particles\n    const particleContainer = document.getElementById('particle-container');\n    const colors = ['#66FF00', '#FF00CC', '#FFFFFF'];\n    \n    for (let i = 0; i < 40; i++) {\n        const p = document.createElement('div');\n        p.className = 'particle';\n        p.style.left = `${Math.random() * 100}%`;\n        p.style.top = `${Math.random() * 100}%`;\n        p.style.opacity = Math.random() * 0.5;\n        p.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];\n        particleContainer.appendChild(p);\n\n        gsap.to(p, {\n            x: \"random(-100, 100)\",\n            y: \"random(-100, 100)\",\n            duration: \"random(10, 20)\",\n            repeat: -1,\n            yoyo: true,\n            ease: \"sine.inOut\"\n        });\n    }\n\n    // 5. Boundary Sparks Effect\n    window.triggerEffect = function(btn, type) {\n        const rect = btn.getBoundingClientRect();\n        const centerX = rect.left + rect.width / 2;\n        const centerY = rect.top + rect.height / 2;\n        \n        // Count update animation\n        const scoreDisplay = document.getElementById('runs-counter');\n        const currentScore = parseInt(scoreDisplay.innerText);\n        gsap.to(scoreDisplay, {\n            textContent: currentScore + type,\n            duration: 0.5,\n            snap: { textContent: 1 },\n            ease: \"back.out\"\n        });\n\n        // Sparks\n        for (let i = 0; i < 30; i++) {\n            const spark = document.createElement('div');\n            spark.className = 'spark';\n            spark.style.backgroundColor = type === 6 ? '#66FF00' : '#FF00CC';\n            spark.style.left = `${centerX}px`;\n            spark.style.top = `${centerY}px`;\n            spark.style.boxShadow = `0 0 10px ${spark.style.backgroundColor}`;\n            document.body.appendChild(spark);\n\n            const angle = Math.random() * Math.PI * 2;\n            const velocity = 5 + Math.random() * 15;\n            const tx = Math.cos(angle) * velocity * 20;\n            const ty = Math.sin(angle) * velocity * 20;\n\n            gsap.to(spark, {\n                x: tx,\n                y: ty,\n                opacity: 0,\n                scale: 0,\n                rotation: Math.random() * 720,\n                duration: 0.8 + Math.random() * 0.4,\n                ease: \"power4.out\",\n                onComplete: () => spark.remove()\n            });\n        }\n\n        // Screen shake for sixer\n        if (type === 6) {\n            gsap.to(\"main\", {\n                x: \"random(-10, 10)\",\n                y: \"random(-10, 10)\",\n                duration: 0.05,\n                repeat: 5,\n                yoyo: true,\n                onComplete: () => gsap.set(\"main\", { x: 0, y: 0 })\n            });\n        }\n    };\n\n    // 6. Hover Effects\n    hover(\".score-btn\", (el) => {\n        gsap.to(el, { scale: 1.05, duration: 0.2 });\n        return () => gsap.to(el, { scale: 1, duration: 0.2 });\n    });\n\n    // 7. Entrance Animations\n    gsap.from(\".hud-card\", {\n        autoAlpha: 0,\n        y: 30,\n        duration: 0.8,\n        stagger: 0.1,\n        ease: \"power3.out\"\n    });\n\n    gsap.from(\".score-btn\", {\n        scale: 0,\n        autoAlpha: 0,\n        duration: 0.5,\n        stagger: {\n            each: 0.05,\n            from: \"center\"\n        },\n        ease: \"back.out(1.7)\"\n    });\n\n    // 8. Ambient Loops\n    gsap.to(\"#score-runs-wrap\", {\n        scale: 1.05,\n        duration: 2,\n        yoyo: true,\n        repeat: -1,\n        ease: \"power1.inOut\"\n    });\n\n</script>\n",
