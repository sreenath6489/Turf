      "html": "\n<div id=\"app-root\" class=\"min-h-screen font-['Fredoka'] overflow-x-clip select-none\" style=\"background-color: #FDF5E6; color: #333;\" data-kid=\"0\">\n    \n    <div class=\"fixed inset-0 pointer-events-none z-0 overflow-hidden\" data-kid=\"1\">\n        <div class=\"absolute -top-20 -left-20 w-96 h-96 bg-[#4CBB17]/5 rounded-full blur-3xl\" data-kid=\"2\"></div>\n        <div class=\"absolute top-1/2 -right-20 w-80 h-80 bg-[#00BFFF]/5 rounded-full blur-3xl\" data-kid=\"3\"></div>\n        <div class=\"absolute -bottom-20 left-1/3 w-64 h-64 bg-[#FFC40C]/5 rounded-full blur-3xl\" data-kid=\"4\"></div>\n    </div>\n\n    \n    <nav class=\"relative z-10 px-8 py-6 flex justify-between items-center max-w-7xl mx-auto\" data-kid=\"5\">\n        <div class=\"flex items-center gap-3\" data-kid=\"6\">\n            <div class=\"w-12 h-12 bg-[#4CBB17] rounded-2xl flex items-center justify-center shadow-[0_6px_0_#2E720D] transform -rotate-6\" data-kid=\"7\">\n                <i class=\"ti ti-ball-cricket text-white text-2xl\" data-kid=\"8\"></i>\n            </div>\n            <span class=\"text-3xl font-bold tracking-tight text-slate-800\" data-kid=\"9\">Turf<span class=\"text-[#4CBB17]\" data-kid=\"10\">Score</span>Pro</span>\n        </div>\n        <div class=\"flex items-center gap-6\" data-kid=\"11\">\n            <button class=\"nav-item text-lg font-bold text-slate-500 hover:text-[#4CBB17] transition-colors\" data-kid=\"12\">Leagues</button>\n            <button class=\"nav-item text-lg font-bold text-slate-500 hover:text-[#4CBB17] transition-colors\" data-kid=\"13\">History</button>\n            <div class=\"w-12 h-12 rounded-full border-4 border-white shadow-lg overflow-hidden cursor-pointer active:scale-95 transition-transform\" data-kid=\"14\">\n                <img src=\"https://i.pravatar.cc/100?u=manager\" alt=\"Admin\" decoding=\"async\" loading=\"lazy\" data-kid=\"15\">\n            </div>\n        </div>\n    </nav>\n\n    \n    <main class=\"relative z-10 max-w-7xl mx-auto px-8 pb-20\" data-kid=\"16\">\n        \n        <section class=\"mt-12 mb-16 flex flex-col md:flex-row justify-between items-center gap-12\" data-kid=\"17\">\n            <div class=\"max-w-2xl order-2 md:order-1\" data-kid=\"18\">\n                <div class=\"inline-flex items-center gap-2 bg-[#4CBB17]/10 text-[#4CBB17] px-4 py-2 rounded-full font-bold mb-6\" data-kid=\"19\">\n                    <i class=\"ti ti-sparkles\" data-kid=\"20\"></i>\n                    <span data-kid=\"21\">Manage your dream squad</span>\n                </div>\n                <h1 class=\"text-6xl md:text-7xl font-bold leading-tight text-slate-900 mb-6\" data-kid=\"22\">\n                    Team <span class=\"relative inline-block\" data-kid=\"23\">\n                        Manager\n                        <svg class=\"absolute -bottom-2 left-0 w-full\" viewBox=\"0 0 200 20\" fill=\"none\" data-kid=\"24\">\n                            <path d=\"M5 15C50 5 150 5 195 15\" stroke=\"#FFC40C\" stroke-width=\"8\" stroke-linecap=\"round\" data-kid=\"25\"></path>\n                        </svg>\n                    </span>\n                </h1>\n                <p class=\"text-2xl text-slate-500 max-w-lg mb-8\" data-kid=\"26\">Create, squish, and organize your players into winning machines. It's time to play!</p>\n                <div class=\"flex flex-col gap-4 w-full md:w-auto\" data-kid=\"27\">\n                    <button id=\"add-team-btn\" class=\"clay-button bg-[#FFC40C] hover:bg-[#FFD700] text-white px-10 py-5 rounded-[2.5rem] text-2xl font-bold shadow-[0_12px_0_#B8860B,0_20px_40px_rgba(255,196,12,0.3)] active:shadow-none active:translate-y-2 transition-all flex items-center justify-center gap-3 w-fit\" data-kid=\"28\">\n                        <i class=\"ti ti-plus-circle text-3xl\" data-kid=\"29\"></i>\n                        <span data-kid=\"30\">Create New Team</span>\n                    </button>\n                </div>\n            </div>\n            <div class=\"w-full md:w-1/3 order-1 md:order-2 flex justify-center\" data-kid=\"31\">\n                <div class=\"relative w-64 h-64 md:w-80 md:h-80 flex items-center justify-center\" data-kid=\"32\">\n                    <div class=\"absolute inset-0 bg-[#4CBB17]/20 rounded-[60%_40%_30%_70%/60%_30%_70%_40%] animate-pulse blur-xl\" data-kid=\"33\"></div>\n                    <img src=\"https://images.unsplash.com/photo-1689481172416-dae28c4a08b4?auto=format&w=800&q=80&fit=crop\" alt=\"3D Cricket Art\" class=\"relative z-10 w-full h-full object-contain drop-shadow-2xl floating-clay mix-blend-darken\" decoding=\"async\" loading=\"lazy\" data-kid=\"34\">\n                </div>\n            </div>\n        </section>\n\n        \n        <div id=\"team-grid\" class=\"columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8\" data-kid=\"35\">\n            \n            <div class=\"team-card break-inside-avoid bg-white rounded-[60%_40%_70%_30%/30%_50%_40%_60%] p-10 shadow-[inset_-10px_-10px_15px_rgba(0,0,0,0.02),inset_10px_10px_15px_rgba(255,255,255,0.9),15px_25px_50px_rgba(0,0,0,0.08)] relative group\" data-kid=\"36\">\n                \n                <div class=\"absolute -top-6 -right-2 opacity-10 pointer-events-none\" data-kid=\"37\">\n                    <span class=\"text-9xl font-bold\" data-kid=\"38\">G</span>\n                </div>\n                \n                <div class=\"flex justify-between items-start mb-8\" data-kid=\"39\">\n                    <div class=\"w-20 h-20 bg-[#00BFFF] rounded-[2rem] flex items-center justify-center shadow-[0_8px_0_#009ACD] transform -rotate-3 group-hover:rotate-3 transition-transform\" data-kid=\"40\">\n                        <i class=\"ti ti-trophy text-white text-4xl\" data-kid=\"41\"></i>\n                    </div>\n                    <div class=\"flex items-center gap-2\" data-kid=\"42\">\n                        <button class=\"w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-300 hover:text-red-500 hover:bg-red-50 transition-all\" data-kid=\"43\">\n                            <i class=\"ti ti-trash text-xl\" data-kid=\"44\"></i>\n                        </button>\n                    </div>\n                </div>\n\n                <h3 class=\"text-3xl font-bold text-slate-800 mb-2\" data-kid=\"45\">The Grass Hoppers</h3>\n                <div class=\"flex flex-wrap gap-2 mb-8\" data-kid=\"46\">\n                    <span class=\"bg-[#4CBB17]/10 text-[#4CBB17] px-4 py-1.5 rounded-full text-sm font-bold border border-[#4CBB17]/20\" data-kid=\"47\">Pro League</span>\n                    <span class=\"bg-blue-50 text-blue-600 px-4 py-1.5 rounded-full text-sm font-bold border border-blue-100\" data-kid=\"48\">11/15 Players</span>\n                </div>\n\n                \n                <div class=\"mb-10\" data-kid=\"49\">\n                    <h4 class=\"text-sm font-bold text-slate-400 uppercase tracking-widest mb-4\" data-kid=\"50\">Starting Lineup</h4>\n                    <div class=\"flex -space-x-4\" data-kid=\"51\">\n                        <div class=\"w-14 h-14 rounded-[60%_40%_30%_70%/60%_30%_70%_40%] bg-rose-400 border-4 border-white shadow-xl overflow-hidden relative\" data-kid=\"52\">\n                            <img src=\"https://i.pravatar.cc/150?u=1\" class=\"w-full h-full object-cover\" alt=\"p1\" decoding=\"async\" loading=\"lazy\" data-kid=\"53\">\n                        </div>\n                        <div class=\"w-14 h-14 rounded-[40%_60%_70%_30%/30%_70%_40%_60%] bg-indigo-400 border-4 border-white shadow-xl overflow-hidden relative\" data-kid=\"54\">\n                            <img src=\"https://i.pravatar.cc/150?u=2\" class=\"w-full h-full object-cover\" alt=\"p2\" decoding=\"async\" loading=\"lazy\" data-kid=\"55\">\n                        </div>\n                        <div class=\"w-14 h-14 rounded-[50%_50%_40%_60%/40%_60%_50%_50%] bg-amber-400 border-4 border-white shadow-xl overflow-hidden relative\" data-kid=\"56\">\n                            <img src=\"https://i.pravatar.cc/150?u=3\" class=\"w-full h-full object-cover\" alt=\"p3\" decoding=\"async\" loading=\"lazy\" data-kid=\"57\">\n                        </div>\n                        <div class=\"w-14 h-14 rounded-[70%_30%_50%_50%/50%_50%_30%_70%] bg-emerald-400 border-4 border-white shadow-xl overflow-hidden relative\" data-kid=\"58\">\n                            <img src=\"https://i.pravatar.cc/150?u=4\" class=\"w-full h-full object-cover\" alt=\"p4\" decoding=\"async\" loading=\"lazy\" data-kid=\"59\">\n                        </div>\n                        <button class=\"add-player-btn-inline w-14 h-14 rounded-full bg-slate-100 border-4 border-white shadow-lg flex items-center justify-center text-slate-400 hover:bg-[#4CBB17] hover:text-white transition-all\" data-kid=\"60\">\n                            <i class=\"ti ti-plus font-bold\" data-kid=\"61\"></i>\n                        </button>\n                    </div>\n                </div>\n\n                <button class=\"manage-btn w-full bg-[#00BFFF] hover:bg-[#009ACD] text-white py-5 rounded-[2rem] text-xl font-bold shadow-[0_10px_0_#007EA7] active:shadow-none active:translate-y-2\" data-kid=\"62\">\n                    Manage Squad\n                </button>\n            </div>\n\n            \n            <div class=\"team-card break-inside-avoid bg-white rounded-[40%_60%_30%_70%/60%_30%_70%_40%] p-10 shadow-[inset_-10px_-10px_15px_rgba(0,0,0,0.02),inset_10px_10px_15px_rgba(255,255,255,0.9),15px_25px_50px_rgba(0,0,0,0.08)] relative group\" data-kid=\"63\">\n                <div class=\"absolute -top-6 -right-2 opacity-10 pointer-events-none\" data-kid=\"64\">\n                    <span class=\"text-9xl font-bold\" data-kid=\"65\">T</span>\n                </div>\n                \n                <div class=\"flex justify-between items-start mb-8\" data-kid=\"66\">\n                    <div class=\"w-20 h-20 bg-[#FFC40C] rounded-[2rem] flex items-center justify-center shadow-[0_8px_0_#B8860B] transform rotate-6 group-hover:-rotate-6 transition-transform\" data-kid=\"67\">\n                        <i class=\"ti ti-bolt text-white text-4xl\" data-kid=\"68\"></i>\n                    </div>\n                </div>\n\n                <h3 class=\"text-3xl font-bold text-slate-800 mb-2\" data-kid=\"69\">Thunder Strikers</h3>\n                <div class=\"flex flex-wrap gap-2 mb-8\" data-kid=\"70\">\n                    <span class=\"bg-yellow-50 text-yellow-600 px-4 py-1.5 rounded-full text-sm font-bold border border-yellow-100\" data-kid=\"71\">Regional Cup</span>\n                    <span class=\"bg-green-50 text-green-600 px-4 py-1.5 rounded-full text-sm font-bold border border-green-100\" data-kid=\"72\">8 Players</span>\n                </div>\n\n                <div class=\"bg-slate-50 rounded-3xl p-6 mb-8 border border-slate-100 italic text-slate-500\" data-kid=\"73\">\n                    \"When the storm hits the pitch, we strike twice as hard!\"\n                </div>\n\n                <div class=\"grid grid-cols-4 gap-4 mb-10\" data-kid=\"74\">\n                    <div class=\"aspect-square rounded-[60%_40%_30%_70%/60%_30%_70%_40%] bg-sky-100 border-4 border-white shadow-lg transform rotate-6 overflow-hidden\" data-kid=\"75\">\n                        <img src=\"https://i.pravatar.cc/100?u=5\" alt=\"p5\" class=\"w-full h-full object-cover\" data-kid=\"76\">\n                    </div>\n                    <div class=\"aspect-square rounded-[40%_60%_70%_30%/30%_70%_40%_60%] bg-violet-100 border-4 border-white shadow-lg transform -rotate-12 overflow-hidden\" data-kid=\"77\">\n                        <img src=\"https://i.pravatar.cc/100?u=6\" alt=\"p6\" class=\"w-full h-full object-cover\" data-kid=\"78\">\n                    </div>\n                    <div class=\"aspect-square rounded-[50%_50%_40%_60%/40%_60%_50%_50%] bg-orange-100 border-4 border-white shadow-lg transform rotate-12 overflow-hidden\" data-kid=\"79\">\n                        <img src=\"https://i.pravatar.cc/100?u=7\" alt=\"p7\" class=\"w-full h-full object-cover\" data-kid=\"80\">\n                    </div>\n                    <div class=\"aspect-square rounded-[70%_30%_50%_50%/50%_50%_30%_70%] bg-teal-100 border-4 border-white shadow-lg flex items-center justify-center text-teal-400\" data-kid=\"81\">\n                        <i class=\"ti ti-plus text-2xl\" data-kid=\"82\"></i>\n                    </div>\n                </div>\n\n                <button class=\"manage-btn w-full bg-[#4CBB17] hover:bg-[#3E9A12] text-white py-5 rounded-[2rem] text-xl font-bold shadow-[0_10px_0_#2E720D] active:shadow-none active:translate-y-2\" data-kid=\"83\">\n                    Open Team Hub\n                </button>\n            </div>\n\n            \n            <div class=\"team-card break-inside-avoid bg-white rounded-[70%_30%_50%_50%/50%_60%_40%_50%] p-10 shadow-[inset_-10px_-10px_15px_rgba(0,0,0,0.02),inset_10px_10px_15px_rgba(255,255,255,0.9),15px_25px_50px_rgba(0,0,0,0.08)] relative group\" data-kid=\"84\">\n                <div class=\"absolute -top-6 -right-2 opacity-10 pointer-events-none\" data-kid=\"85\">\n                    <span class=\"text-9xl font-bold\" data-kid=\"86\">B</span>\n                </div>\n                \n                <div class=\"flex justify-between items-start mb-8\" data-kid=\"87\">\n                    <div class=\"w-20 h-20 bg-slate-900 rounded-[2rem] flex items-center justify-center shadow-[0_8px_0_#000] transform -rotate-12 group-hover:rotate-0 transition-transform\" data-kid=\"88\">\n                        <i class=\"ti ti-ghost text-white text-4xl\" data-kid=\"89\"></i>\n                    </div>\n                </div>\n\n                <h3 class=\"text-3xl font-bold text-slate-800 mb-2\" data-kid=\"90\">Black Phantoms</h3>\n                <div class=\"flex flex-wrap gap-2 mb-8\" data-kid=\"91\">\n                    <span class=\"bg-slate-50 text-slate-600 px-4 py-1.5 rounded-full text-sm font-bold border border-slate-100\" data-kid=\"92\">Draft Status</span>\n                </div>\n\n                <div class=\"flex flex-col gap-4 mb-10\" data-kid=\"93\">\n                    <div class=\"flex items-center gap-4 bg-slate-50 p-4 rounded-2xl\" data-kid=\"94\">\n                        <div class=\"w-12 h-12 bg-[#00BFFF] rounded-xl flex items-center justify-center text-white\" data-kid=\"95\">\n                            <i class=\"ti ti-chart-bar\" data-kid=\"96\"></i>\n                        </div>\n                        <div data-kid=\"97\">\n                            <p class=\"text-xs font-bold text-slate-400 uppercase\" data-kid=\"98\">Current Elo</p>\n                            <p class=\"text-lg font-bold text-slate-800\" data-kid=\"99\">1,240 XP</p>\n                        </div>\n                    </div>\n                </div>\n\n                <button class=\"manage-btn w-full bg-slate-900 hover:bg-black text-white py-5 rounded-[2rem] text-xl font-bold shadow-[0_10px_0_#000] active:shadow-none active:translate-y-2\" data-kid=\"100\">\n                    Enter Ghost Mode\n                </button>\n            </div>\n\n            \n            <div class=\"team-card break-inside-avoid bg-white rounded-[50%_50%_60%_40%/40%_40%_60%_60%] p-8 shadow-[inset_-10px_-10px_15px_rgba(0,0,0,0.02),inset_10px_10px_15px_rgba(255,255,255,0.9),15px_25px_50px_rgba(0,0,0,0.08)] relative group\" data-kid=\"101\">\n                <div class=\"flex items-center gap-4 mb-6\" data-kid=\"102\">\n                    <div class=\"w-14 h-14 bg-rose-400 rounded-2xl flex items-center justify-center text-white shadow-[0_6px_0_#B91C1C] transform -rotate-6 group-hover:rotate-0 transition-transform\" data-kid=\"103\">\n                        <i class=\"ti ti-star-filled text-2xl\" data-kid=\"104\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-slate-800\" data-kid=\"105\">Rising Suns</h3>\n                </div>\n                <div class=\"flex gap-2 mb-6\" data-kid=\"106\">\n                    <div class=\"w-10 h-10 rounded-full bg-slate-100 border-2 border-white shadow-sm overflow-hidden\" data-kid=\"107\">\n                        <img src=\"https://i.pravatar.cc/100?u=10\" alt=\"p10\" data-kid=\"108\">\n                    </div>\n                    <div class=\"w-10 h-10 rounded-full bg-slate-100 border-2 border-white shadow-sm flex items-center justify-center text-slate-300\" data-kid=\"109\">\n                        <i class=\"ti ti-user-plus text-xs\" data-kid=\"110\"></i>\n                    </div>\n                </div>\n                <button class=\"manage-btn w-full bg-rose-500 hover:bg-rose-600 text-white py-4 rounded-2xl font-bold shadow-[0_8px_0_#9F1239] active:shadow-none active:translate-y-2\" data-kid=\"111\">\n                    Quick Start\n                </button>\n            </div>\n\n            \n            <div class=\"team-card break-inside-avoid bg-white rounded-[40%_40%_40%_40%/40%_40%_40%_40%] p-10 shadow-[inset_-10px_-10px_15px_rgba(0,0,0,0.02),inset_10px_10px_15px_rgba(255,255,255,0.9),15px_25px_50px_rgba(0,0,0,0.08)] relative group\" data-kid=\"112\">\n                <div class=\"w-full aspect-video bg-indigo-50 rounded-[2rem] mb-8 flex items-center justify-center relative overflow-hidden\" data-kid=\"113\">\n                    <div class=\"absolute inset-0 bg-linear-to-br from-indigo-100 to-blue-50 opacity-50\" data-kid=\"114\"></div>\n                    <div class=\"absolute w-32 h-32 bg-indigo-400/20 rounded-full blur-2xl animate-pulse\" data-kid=\"115\"></div>\n                    <i class=\"ti ti-stadium text-indigo-400 text-7xl relative z-10 drop-shadow-sm\" data-kid=\"116\"></i>\n                </div>\n                <h3 class=\"text-3xl font-bold text-slate-800 mb-2\" data-kid=\"117\">Ocean Giants</h3>\n                <p class=\"text-slate-500 mb-8 leading-relaxed\" data-kid=\"118\">Deep water dwellers from the southern coast. Current rank: #4.</p>\n                <div class=\"flex justify-between items-center bg-indigo-50 p-6 rounded-3xl mb-8\" data-kid=\"119\">\n                    <div class=\"text-center\" data-kid=\"120\">\n                        <p class=\"text-xs font-bold text-indigo-400 uppercase\" data-kid=\"121\">Wins</p>\n                        <p class=\"text-2xl font-bold text-indigo-900\" data-kid=\"122\">24</p>\n                    </div>\n                    <div class=\"h-8 w-[2px] bg-indigo-100\" data-kid=\"123\"></div>\n                    <div class=\"text-center\" data-kid=\"124\">\n                        <p class=\"text-xs font-bold text-indigo-400 uppercase\" data-kid=\"125\">XP</p>\n                        <p class=\"text-2xl font-bold text-indigo-900\" data-kid=\"126\">4.8k</p>\n                    </div>\n                </div>\n                <button class=\"manage-btn w-full bg-indigo-600 hover:bg-indigo-700 text-white py-5 rounded-[2rem] font-bold shadow-[0_10px_0_#3730A3] active:shadow-none active:translate-y-2\" data-kid=\"127\">\n                    Enter Stadium\n                </button>\n            </div>\n        </div>\n    </main>\n\n    \n    <div id=\"modal-overlay\" class=\"fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex items-end justify-center hidden opacity-0\" data-kid=\"128\">\n        <div id=\"bottom-sheet\" class=\"w-full max-w-2xl bg-white rounded-t-[4rem] p-10 shadow-[0_-20px_50px_rgba(0,0,0,0.1)] translate-y-full flex flex-col max-h-[90vh]\" data-kid=\"129\">\n            \n            <div class=\"w-20 h-2 bg-slate-100 rounded-full mx-auto mb-10 cursor-pointer\" data-kid=\"130\"></div>\n            \n            <div class=\"flex justify-between items-center mb-10\" data-kid=\"131\">\n                <div data-kid=\"132\">\n                    <h2 class=\"text-4xl font-bold text-slate-800\" data-kid=\"133\">New Player</h2>\n                    <p class=\"text-slate-400 font-medium\" data-kid=\"134\">Add a squishy teammate!</p>\n                </div>\n                <button id=\"close-modal\" class=\"w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-400 hover:bg-slate-100 transition-colors\" data-kid=\"135\">\n                    <i class=\"ti ti-x text-2xl\" data-kid=\"136\"></i>\n                </button>\n            </div>\n\n            <div class=\"overflow-y-auto pr-2 custom-scrollbar\" data-kid=\"137\">\n                <form id=\"add-player-form\" class=\"space-y-8 pb-10\" data-kid=\"138\">\n                    \n                    <div class=\"flex flex-col items-center gap-4\" data-kid=\"139\">\n                        <div class=\"relative group\" data-kid=\"140\">\n                            <div id=\"avatar-preview\" class=\"w-40 h-40 rounded-[60%_40%_30%_70%/60%_30%_70%_40%] bg-[#FFC40C]/10 border-4 border-dashed border-[#FFC40C] flex items-center justify-center shadow-inner group-hover:bg-[#FFC40C]/20 transition-all cursor-pointer overflow-hidden\" data-kid=\"141\">\n                                <i class=\"ti ti-camera-plus text-[#FFC40C] text-5xl\" data-kid=\"142\"></i>\n                            </div>\n                            <div class=\"absolute -bottom-2 -right-2 w-12 h-12 bg-[#4CBB17] rounded-full border-4 border-white shadow-lg flex items-center justify-center text-white cursor-pointer hover:scale-110 transition-transform\" data-kid=\"143\">\n                                <i class=\"ti ti-palette\" data-kid=\"144\"></i>\n                            </div>\n                        </div>\n                        <p class=\"text-sm font-bold text-[#FFC40C] uppercase tracking-widest\" data-kid=\"145\">Select Mojo Avatar</p>\n                    </div>\n\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\" data-kid=\"146\">\n                        <div class=\"space-y-3\" data-kid=\"147\">\n                            <label class=\"block text-xl font-bold text-slate-700 ml-2\" data-kid=\"148\">Player Nickname</label>\n                            <input type=\"text\" placeholder=\"e.g. Slider Sam\" class=\"w-full bg-slate-50 border-4 border-transparent focus:border-[#4CBB17]/20 focus:bg-white rounded-[2rem] px-8 py-5 outline-hidden transition-all text-xl font-medium shadow-inner\" data-kid=\"149\">\n                        </div>\n                        <div class=\"space-y-3\" data-kid=\"150\">\n                            <label class=\"block text-xl font-bold text-slate-700 ml-2\" data-kid=\"151\">Primary Role</label>\n                            <div class=\"relative\" data-kid=\"152\">\n                                <select class=\"w-full appearance-none bg-slate-50 border-4 border-transparent focus:border-[#4CBB17]/20 focus:bg-white rounded-[2rem] px-8 py-5 outline-hidden transition-all text-xl font-medium shadow-inner cursor-pointer\" data-kid=\"153\">\n                                    <option data-kid=\"154\">Opening Batsman</option>\n                                    <option data-kid=\"155\">Fast Bowler</option>\n                                    <option data-kid=\"156\">Spin Wizard</option>\n                                    <option data-kid=\"157\">Flying Keeper</option>\n                                    <option data-kid=\"158\">All-Rounder</option>\n                                </select>\n                                <i class=\"ti ti-chevron-down absolute right-8 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none\" data-kid=\"159\"></i>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"space-y-4\" data-kid=\"160\">\n                        <label class=\"block text-xl font-bold text-slate-700 ml-2\" data-kid=\"161\">Skill Level</label>\n                        <div class=\"flex gap-4 p-2 bg-slate-50 rounded-[2.5rem]\" data-kid=\"162\">\n                            <button type=\"button\" class=\"skill-tab flex-1 py-4 rounded-3xl font-bold transition-all text-slate-400\" data-kid=\"163\">Rookie</button>\n                            <button type=\"button\" class=\"skill-tab flex-1 py-4 rounded-3xl font-bold transition-all bg-white text-[#FFC40C] shadow-sm\" data-kid=\"164\">Semi-Pro</button>\n                            <button type=\"button\" class=\"skill-tab flex-1 py-4 rounded-3xl font-bold transition-all text-slate-400\" data-kid=\"165\">G.O.A.T</button>\n                        </div>\n                    </div>\n\n                    <div class=\"pt-4\" data-kid=\"166\">\n                        <button type=\"submit\" id=\"submit-player\" class=\"w-full bg-[#4CBB17] hover:bg-[#3E9A12] text-white py-6 rounded-[2.5rem] text-2xl font-bold shadow-[0_12px_0_#2E720D,0_20px_40px_rgba(76,187,23,0.3)] active:shadow-none active:translate-y-2\" data-kid=\"167\">\n                            Blast Off! Add Player 🚀\n                        </button>\n                    </div>\n                </form>\n            </div>\n        </div>\n    </div>\n\n    \n    <div id=\"celebration-layer\" class=\"fixed inset-0 pointer-events-none z-[60]\" data-kid=\"168\"></div>\n\n</div>\n\n<style data-kid=\"169\">\n    @import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .custom-scrollbar::-webkit-scrollbar {\n        width: 8px;\n    }\n    .custom-scrollbar::-webkit-scrollbar-track {\n        background: #f1f1f1;\n        border-radius: 10px;\n    }\n    .custom-scrollbar::-webkit-scrollbar-thumb {\n        background: #ccc;\n        border-radius: 10px;\n    }\n    .custom-scrollbar::-webkit-scrollbar-thumb:hover {\n        background: #999;\n    }\n\n    .clay-button {\n    }\n\n    .floating-clay {\n        animation: float 6s ease-in-out infinite;\n    }\n\n    @keyframes float {\n        0%, 100% { transform: translateY(0) rotate(0); }\n        50% { transform: translateY(-20px) rotate(5deg); }\n    }\n\n    .skill-tab.active {\n        background: white;\n        color: #FFC40C;\n        box-shadow: 0 4px 15px rgba(0,0,0,0.05);\n    }\n</style>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"170\"></script>\n<script type=\"module\" data-kid=\"171\">\n    import { animate, spring } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n\n    const modalOverlay = document.getElementById('modal-overlay');\n    const bottomSheet = document.getElementById('bottom-sheet');\n    const addTeamBtn = document.getElementById('add-team-btn');\n    const addPlayerBtns = document.querySelectorAll('.add-player-btn-inline');\n    const closeModalBtn = document.getElementById('close-modal');\n    const playerForm = document.getElementById('add-player-form');\n    const celebrationLayer = document.getElementById('celebration-layer');\n\n    function openModal() {\n        modalOverlay.classList.remove('hidden');\n        gsap.to(modalOverlay, { opacity: 1, duration: 0.3 });\n        animate(bottomSheet, { y: [\"100%\", 0] }, { type: 'spring', stiffness: 400, damping: 35 });\n    }\n\n    function closeModal() {\n        gsap.to(modalOverlay, { opacity: 0, duration: 0.3, onComplete: () => modalOverlay.classList.add('hidden') });\n        animate(bottomSheet, { y: \"100%\" }, { type: 'spring', stiffness: 400, damping: 45 });\n    }\n\n    addTeamBtn.addEventListener('click', openModal);\n    addPlayerBtns.forEach(btn => btn.addEventListener('click', openModal));\n    closeModalBtn.addEventListener('click', closeModal);\n    modalOverlay.addEventListener('click', (e) => {\n        if(e.target === modalOverlay) closeModal();\n    });\n\n    // Skill Tabs\n    const skillTabs = document.querySelectorAll('.skill-tab');\n    skillTabs.forEach(tab => {\n        tab.addEventListener('click', () => {\n            skillTabs.forEach(t => {\n                t.classList.remove('bg-white', 'text-[#FFC40C]', 'shadow-sm');\n                t.classList.add('text-slate-400');\n            });\n            tab.classList.remove('text-slate-400');\n            tab.classList.add('bg-white', 'text-[#FFC40C]', 'shadow-sm');\n        });\n    });\n\n    // Confetti Effect\n    function createConfetti(x, y) {\n        const colors = ['#4CBB17', '#FFC40C', '#00BFFF', '#FF4D4D', '#FFD700'];\n        for (let i = 0; i < 30; i++) {\n            const particle = document.createElement('div');\n            particle.className = 'absolute w-3 h-3 rounded-full';\n            particle.style.left = x + 'px';\n            particle.style.top = y + 'px';\n            particle.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];\n            celebrationLayer.appendChild(particle);\n\n            const destX = (Math.random() - 0.5) * 400;\n            const destY = (Math.random() - 0.5) * 400 - 100;\n\n            gsap.to(particle, {\n                x: destX,\n                y: destY,\n                rotation: Math.random() * 360,\n                scale: 0,\n                opacity: 0,\n                duration: 1 + Math.random(),\n                ease: \"power2.out\",\n                onComplete: () => particle.remove()\n            });\n        }\n    }\n\n    playerForm.addEventListener('submit', (e) => {\n        e.preventDefault();\n        const rect = document.getElementById('submit-player').getBoundingClientRect();\n        createConfetti(rect.left + rect.width / 2, rect.top + rect.height / 2);\n        \n        // Success animation\n        animate(\"#submit-player\", { scale: [1, 1.05, 1] }, { duration: 0.3 });\n        \n        setTimeout(() => {\n            closeModal();\n            // Optional: reset form\n            playerForm.reset();\n        }, 800);\n    });\n\n    // Squishy button interactions using GSAP for precise control or Motion\n    const buttons = document.querySelectorAll('.manage-btn, .clay-button');\n    buttons.forEach(btn => {\n        btn.addEventListener('mouseenter', () => {\n            gsap.to(btn, { scale: 1.05, duration: 0.3, ease: \"back.out(2)\" });\n        });\n        btn.addEventListener('mouseleave', () => {\n            gsap.to(btn, { scale: 1, duration: 0.3, ease: \"back.out(2)\" });\n        });\n    });\n\n    const cards = document.querySelectorAll('.team-card');\n    cards.forEach(card => {\n        card.addEventListener('mouseenter', () => {\n            gsap.to(card, { y: -10, scale: 1.02, duration: 0.4, ease: \"power2.out\" });\n        });\n        card.addEventListener('mouseleave', () => {\n            gsap.to(card, { y: 0, scale: 1, duration: 0.4, ease: \"power2.out\" });\n        });\n    });\n\n    // Avatar interaction\n    const avatars = document.querySelectorAll('.team-card img, .team-card .aspect-square');\n    avatars.forEach(avatar => {\n        avatar.addEventListener('mouseenter', () => {\n            gsap.to(avatar, { scale: 1.15, rotation: (Math.random() - 0.5) * 10, duration: 0.3, ease: \"back.out(3)\" });\n        });\n        avatar.addEventListener('mouseleave', () => {\n            gsap.to(avatar, { scale: 1, rotation: 0, duration: 0.3, ease: \"back.out(3)\" });\n        });\n    });\n\n    // Animate team cards on entry\n    gsap.from(\".team-card\", {\n        y: 100,\n        opacity: 0,\n        stagger: 0.15,\n        duration: 1,\n        ease: \"back.out(1.5)\",\n        delay: 0.5\n    });\n\n</script>\n",
