    "var_06800c8a28e4": {
      "type": "variant",
      "label": "Scoreboard - Claymorphism",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 16300,
        "y": 0,
        "w": 1440,
        "h": 800
