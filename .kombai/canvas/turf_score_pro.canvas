      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --chartreuse: #E3FF00;\n    --onyx: #111111;\n    --magenta: #FF00FF;\n  }\n\n  body {\n    background-color: var(--chartreuse);\n    color: var(--onyx);\n    font-family: 'Space Grotesk', sans-serif;\n    overflow-x: clip;\n  }\n\n  .font-anton { font-family: 'Anton', sans-serif; }\n  \n  .brutalist-border {\n    border: 4px solid var(--onyx);\n    box-shadow: 12px 12px 0px 0px var(--onyx);\n  }\n\n  .brutalist-border-sm {\n    border: 3px solid var(--onyx);\n    box-shadow: 6px 6px 0px 0px var(--onyx);\n  }\n\n  .magenta-shadow {\n    box-shadow: 12px 12px 0px 0px var(--magenta);\n  }\n\n  /* Hide scrollbar but keep functionality */\n  .no-scrollbar::-webkit-scrollbar { display: none; }\n  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n  /* Anime mask reveal classes */\n  .line-mask-wrap {\n    overflow: hidden;\n    display: block;\n    padding-bottom: 0.1em;\n    margin-bottom: -0.1em;\n  }\n  .line-mask-inner {\n    display: block;\n  }\n\n  /* Lenis Velocity Distort */\n  .velocity-distort {\n    transform: skewY(var(--velocity-skew, 0deg));\n  }\n  .clip-jersey {\n    clip-path: polygon(25% 0%, 75% 0%, 100% 20%, 100% 40%, 85% 40%, 85% 100%, 15% 100%, 15% 40%, 0% 40%, 0% 20%);\n  }\n</style>\n\n<div id=\"smooth-wrapper\" data-kid=\"1\">\n  <div id=\"smooth-content\" data-kid=\"2\">\n    \n    \n    <section id=\"hero\" class=\"min-h-screen flex flex-col md:flex-row items-center justify-between px-6 md:px-20 py-20 relative overflow-hidden\" data-kid=\"3\">\n      \n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"absolute top-20 left-10 w-24 h-24 opacity-10 pointer-events-none velocity-distort\" style=\"filter: brightness(0);\" data-kid=\"4\">\n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/split-cross.svg\" class=\"absolute bottom-20 right-10 w-32 h-32 opacity-10 pointer-events-none velocity-distort\" style=\"filter: brightness(0);\" data-kid=\"5\">\n\n      <div class=\"w-full md:w-1/2 z-10\" data-kid=\"6\">\n        <h1 class=\"font-anton text-[clamp(4rem,10vw,9.5rem)] leading-[1.05] uppercase mb-12\" id=\"hero-headline\" data-kid=\"7\">\n          <span class=\"line-mask-wrap\" data-kid=\"8\"><span class=\"line-mask-inner\" data-kid=\"9\">OWN THE</span></span>\n          <span class=\"line-mask-wrap text-[var(--magenta)]\" data-kid=\"10\"><span class=\"line-mask-inner\" data-kid=\"11\">TURF.</span></span>\n          <span class=\"line-mask-wrap\" data-kid=\"12\"><span class=\"line-mask-inner\" data-kid=\"13\">OWN THE</span></span>\n          <span class=\"line-mask-wrap text-[var(--magenta)]\" data-kid=\"14\"><span class=\"line-mask-inner\" data-kid=\"15\">SCORE.</span></span>\n        </h1>\n        <p class=\"text-xl md:text-2xl max-w-lg mb-12 font-medium leading-relaxed\" id=\"hero-subtext\" data-kid=\"16\">\n          Precision scoring. Elite team management. Spatial stats. The definitive tool for high-energy turf warriors.\n        </p>\n        <div class=\"flex flex-wrap gap-6\" id=\"hero-ctas\" data-kid=\"17\">\n          <button class=\"bg-[var(--magenta)] text-white px-12 py-6 text-2xl font-black border-4 border-[var(--onyx)] shadow-[8px_8px_0px_0px_var(--onyx)] active:shadow-none active:translate-x-1 active:translate-y-1 uppercase cursor-pointer\" data-kid=\"18\">\n            Start Scoring\n          </button>\n          <button class=\"bg-white text-[var(--onyx)] px-12 py-6 text-2xl font-black border-4 border-[var(--onyx)] shadow-[8px_8px_0px_0px_var(--onyx)] active:shadow-none active:translate-x-1 active:translate-y-1 uppercase cursor-pointer\" data-kid=\"19\">\n            Watch Demo\n          </button>\n        </div>\n      </div>\n\n      <div class=\"w-full md:w-1/2 h-[600px] relative mt-20 md:mt-0 flex items-center justify-center\" id=\"hero-visual\" data-kid=\"20\">\n        \n        <div class=\"relative w-72 h-[550px] bg-[var(--onyx)] rounded-[3.5rem] p-3 shadow-2xl z-20 overflow-hidden border-4 border-[#333]\" data-kid=\"21\">\n          <div class=\"absolute inset-0 bg-gradient-to-tr from-[#222] to-[#444] opacity-50 pointer-events-none\" data-kid=\"22\"></div>\n          <div class=\"w-full h-full bg-[var(--chartreuse)] rounded-[3rem] p-6 flex flex-col relative overflow-hidden\" data-kid=\"23\">\n            \n            <div class=\"flex justify-between items-center mb-10\" data-kid=\"24\">\n              <span class=\"text-xs font-bold px-2 py-1 border-2 border-[var(--onyx)] rounded-md\" data-kid=\"25\">TURF SCORE PRO</span>\n              <i class=\"ti ti-activity text-2xl\" data-kid=\"26\"></i>\n            </div>\n            <div class=\"text-center\" data-kid=\"27\">\n              <span class=\"font-anton text-2xl\" data-kid=\"28\">QUARTER 3</span>\n              <div class=\"text-7xl font-anton mt-2\" data-kid=\"29\">14 - 12</div>\n              <div class=\"mt-4 text-sm font-bold opacity-70\" data-kid=\"30\">POSSESSION: 56%</div>\n            </div>\n            <div class=\"mt-auto space-y-4\" data-kid=\"31\">\n              <div class=\"h-20 bg-[var(--onyx)] rounded-2xl flex items-center px-4 gap-4 border-2 border-white/10\" data-kid=\"32\">\n                <div class=\"w-12 h-12 bg-[var(--magenta)] rounded-lg flex items-center justify-center font-anton text-white text-xl border-2 border-white/20\" data-kid=\"33\">7</div>\n                <div class=\"flex-1\" data-kid=\"34\">\n                  <div class=\"text-[10px] font-bold text-white/40 uppercase tracking-widest\" data-kid=\"35\">Top Scorer</div>\n                  <div class=\"text-xs font-bold text-white\" data-kid=\"36\">MARCO ROSSI</div>\n                  <div class=\"w-full bg-white/10 h-1.5 rounded-full mt-1 overflow-hidden\" data-kid=\"37\">\n                    <div class=\"bg-[var(--magenta)] w-4/5 h-full\" data-kid=\"38\"></div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"h-12 bg-[var(--magenta)] rounded-xl border-2 border-[var(--onyx)] shadow-[4px_4px_0px_0px_var(--onyx)] flex items-center justify-center font-bold text-white cursor-pointer active:shadow-none active:translate-y-1 transition-all\" data-kid=\"39\">\n                VIEW LIVE STATS\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"absolute inset-0 pointer-events-none\" id=\"orbit-container\" data-kid=\"40\">\n          <video src=\"https://videos.pexels.com/video-files/19825062/19825062-sd_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/19825062/2020-background-4k-4k-background-4k-footage-19825062.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"absolute top-1/4 -right-10 w-44 h-44 rounded-full border-4 border-[var(--onyx)] shadow-xl z-30 bg-white\" id=\"ball-1\" data-kid=\"41\"></video>\n          <video src=\"https://videos.pexels.com/video-files/34839075/14768140_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/34839075/pexels-photo-34839075.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"absolute bottom-1/4 -left-10 w-36 h-36 rounded-full border-4 border-[var(--onyx)] shadow-xl z-10 bg-white\" id=\"ball-2\" data-kid=\"42\"></video>\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"absolute top-10 left-20 w-12 h-12\" style=\"filter: brightness(0);\" data-kid=\"43\">\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/star-medal.svg\" class=\"absolute bottom-10 right-20 w-16 h-16\" style=\"filter: brightness(0);\" data-kid=\"44\">\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"features\" class=\"py-32 px-6 md:px-20\" data-kid=\"45\">\n      <div class=\"grid grid-cols-1 md:grid-cols-12 gap-8 auto-rows-min\" data-kid=\"46\">\n        \n        \n        <div class=\"md:col-span-8 md:row-span-2 relative brutalist-border overflow-hidden bg-[var(--onyx)] group feature-card\" data-kid=\"47\">\n          <img src=\"https://images.unsplash.com/photo-1544914379-806667cd9489?auto=format&w=1600&q=80&fit=crop\" alt=\"Turf\" class=\"absolute inset-0 w-full h-full object-cover opacity-60 transition-transform duration-700 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"48\">\n          <div class=\"absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent\" data-kid=\"49\"></div>\n          <div class=\"absolute top-8 left-8 bg-[var(--magenta)] text-white px-6 py-3 font-bold border-2 border-white shadow-[4px_4px_0px_0px_white]\" data-kid=\"50\">\n            LIVE NOW\n          </div>\n          <div class=\"absolute bottom-8 left-8 right-8 text-white z-10\" data-kid=\"51\">\n            <h3 class=\"font-anton text-6xl uppercase mb-4 leading-none\" data-kid=\"52\">Real-Time Scoring</h3>\n            <p class=\"text-xl max-w-md font-medium opacity-80\" data-kid=\"53\">Sync every touch point with millisecond accuracy across all spectator devices.</p>\n            <div class=\"mt-8 flex gap-4\" data-kid=\"54\">\n              <div class=\"p-4 bg-white/10 backdrop-blur-md border border-white/20 rounded-xl flex items-center gap-4\" data-kid=\"55\">\n                <i class=\"ti ti-activity-heartbeat text-3xl text-[var(--chartreuse)]\" data-kid=\"56\"></i>\n                <div data-kid=\"57\">\n                  <div class=\"text-xs uppercase opacity-60\" data-kid=\"58\">Avg. Latency</div>\n                  <div class=\"font-bold\" data-kid=\"59\">12ms</div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"md:col-span-4 md:row-span-2 bg-white brutalist-border p-8 flex flex-col feature-card\" data-kid=\"60\">\n          <div class=\"mb-8\" data-kid=\"61\">\n            <h3 class=\"font-anton text-4xl uppercase leading-none mb-2\" data-kid=\"62\">Spatial Stats</h3>\n            <p class=\"text-sm font-bold text-gray-500 uppercase tracking-widest\" data-kid=\"63\">Performance Radar</p>\n          </div>\n          \n          <div class=\"flex-grow flex items-center justify-center relative my-8\" data-kid=\"64\">\n            <svg viewBox=\"0 0 100 100\" class=\"w-full max-w-[280px]\" data-kid=\"65\">\n              \n              <polygon points=\"50,10 88.3,37.5 73.8,82.5 26.2,82.5 11.7,37.5\" fill=\"none\" stroke=\"#ccc\" stroke-width=\"1\" data-kid=\"66\"></polygon>\n              <polygon points=\"50,30 73.5,47.5 64.5,72.5 35.5,72.5 26.5,47.5\" fill=\"none\" stroke=\"#ccc\" stroke-width=\"1\" data-kid=\"67\"></polygon>\n              <polygon points=\"50,50 50,10 50,50 88.3,37.5 50,50 73.8,82.5 50,50 26.2,82.5 50,50 11.7,37.5\" fill=\"none\" stroke=\"#ccc\" stroke-width=\"1\" data-kid=\"68\"></polygon>\n              \n              \n              <polygon points=\"50,15 80,40 70,75 35,80 20,45\" fill=\"rgba(255,0,255,0.2)\" stroke=\"var(--magenta)\" stroke-width=\"3\" data-kid=\"69\"></polygon>\n              \n              \n              <text x=\"50\" y=\"5\" text-anchor=\"middle\" font-weight=\"900\" font-size=\"6\" class=\"fill-[var(--onyx)]\" data-kid=\"70\">SPD</text>\n              <text x=\"94\" y=\"38\" text-anchor=\"start\" font-weight=\"900\" font-size=\"6\" class=\"fill-[var(--onyx)]\" data-kid=\"71\">PWR</text>\n              <text x=\"80\" y=\"90\" text-anchor=\"middle\" font-weight=\"900\" font-size=\"6\" class=\"fill-[var(--onyx)]\" data-kid=\"72\">STA</text>\n              <text x=\"20\" y=\"90\" text-anchor=\"middle\" font-weight=\"900\" font-size=\"6\" class=\"fill-[var(--onyx)]\" data-kid=\"73\">DEF</text>\n              <text x=\"6\" y=\"38\" text-anchor=\"end\" font-weight=\"900\" font-size=\"6\" class=\"fill-[var(--onyx)]\" data-kid=\"74\">ACC</text>\n            </svg>\n          </div>\n\n          <button class=\"w-full py-5 border-4 border-[var(--onyx)] font-black uppercase text-lg shadow-[6px_6px_0px_0px_var(--onyx)] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all bg-[var(--chartreuse)]\" data-kid=\"75\">\n            Analyze Roster\n          </button>\n        </div>\n\n        \n        <div class=\"md:col-span-12 bg-[var(--magenta)] brutalist-border p-10 flex flex-col md:flex-row items-center gap-12 overflow-hidden feature-card\" data-kid=\"76\">\n          <div class=\"md:w-1/3\" data-kid=\"77\">\n            <h3 class=\"font-anton text-5xl uppercase leading-tight text-white mb-4\" data-kid=\"78\">Team<br data-kid=\"79\">Architect</h3>\n            <p class=\"text-white font-medium opacity-90 text-lg\" data-kid=\"80\">Manage kit assignments and spatial positioning in a 3D environment.</p>\n          </div>\n          \n          <div class=\"flex-grow flex gap-6 overflow-x-auto no-scrollbar py-6 px-4 pr-12\" data-kid=\"81\">\n            \n            <div class=\"shrink-0 w-44 h-64 bg-white brutalist-border-sm relative flex flex-col items-center justify-center group cursor-pointer transition-transform jersey-card\" data-kid=\"82\">\n              <div class=\"relative w-28 h-32 mb-4\" data-kid=\"83\">\n                 <div class=\"absolute inset-0 bg-[var(--onyx)] clip-jersey\" data-kid=\"84\"></div>\n                 <div class=\"absolute inset-x-4 top-0 h-full bg-[var(--magenta)] flex items-center justify-center font-anton text-5xl text-white\" data-kid=\"85\">07</div>\n              </div>\n              <span class=\"font-anton text-2xl uppercase\" data-kid=\"86\">STRIKER</span>\n              <div class=\"absolute -top-3 -right-3 w-10 h-10 bg-[var(--chartreuse)] border-2 border-[var(--onyx)] flex items-center justify-center shadow-[3px_3px_0px_0px_var(--onyx)]\" data-kid=\"87\"><i class=\"ti ti-plus font-bold\" data-kid=\"88\"></i></div>\n            </div>\n            <div class=\"shrink-0 w-44 h-64 bg-white brutalist-border-sm relative flex flex-col items-center justify-center group cursor-pointer transition-transform\" data-kid=\"89\">\n              <div class=\"relative w-28 h-32 mb-4\" data-kid=\"90\">\n                 <div class=\"absolute inset-0 bg-[var(--onyx)] clip-jersey\" data-kid=\"91\"></div>\n                 <div class=\"absolute inset-x-4 top-0 h-full bg-white flex items-center justify-center font-anton text-5xl text-[var(--onyx)]\" data-kid=\"92\">10</div>\n              </div>\n              <span class=\"font-anton text-2xl uppercase\" data-kid=\"93\">CAPTAIN</span>\n            </div>\n            <div class=\"shrink-0 w-44 h-64 bg-white brutalist-border-sm relative flex flex-col items-center justify-center group cursor-pointer transition-transform\" data-kid=\"94\">\n              <div class=\"relative w-28 h-32 mb-4\" data-kid=\"95\">\n                 <div class=\"absolute inset-0 bg-[var(--onyx)] clip-jersey\" data-kid=\"96\"></div>\n                 <div class=\"absolute inset-x-4 top-0 h-full bg-[var(--chartreuse)] flex items-center justify-center font-anton text-5xl text-[var(--onyx)]\" data-kid=\"97\">11</div>\n              </div>\n              <span class=\"font-anton text-2xl uppercase\" data-kid=\"98\">WINGER</span>\n            </div>\n            <div class=\"shrink-0 w-44 h-64 bg-white brutalist-border-sm relative flex flex-col items-center justify-center group cursor-pointer transition-transform\" data-kid=\"99\">\n              <div class=\"relative w-28 h-32 mb-4\" data-kid=\"100\">\n                 <div class=\"absolute inset-0 bg-[var(--onyx)] clip-jersey\" data-kid=\"101\"></div>\n                 <div class=\"absolute inset-x-4 top-0 h-full bg-[#333] flex items-center justify-center font-anton text-5xl text-white\" data-kid=\"102\">01</div>\n              </div>\n              <span class=\"font-anton text-2xl uppercase\" data-kid=\"103\">KEEPER</span>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </section>\n\n    \n    <section id=\"cta\" class=\"py-40 relative overflow-hidden flex flex-col items-center justify-center bg-[var(--chartreuse)]\" data-kid=\"104\">\n      \n      \n      <div class=\"absolute inset-0 flex items-center pointer-events-none rotate-2 scale-110 z-0\" id=\"marquee-parent\" data-kid=\"105\">\n        <div class=\"bg-[var(--magenta)] py-12 flex items-center border-y-8 border-[var(--onyx)] w-full\" data-kid=\"106\">\n           <div class=\"flex whitespace-nowrap font-anton text-[15vw] leading-none uppercase marquee-content text-[var(--onyx)]\" data-kid=\"107\">\n            PLAY HARD. SCORE EASY. <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/star-medal.svg\" class=\"w-[8vw] h-[8vw] mx-[4vw] inline-block self-center\" style=\"filter: brightness(0);\" data-kid=\"108\">\n            PLAY HARD. SCORE EASY. <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/star-medal.svg\" class=\"w-[8vw] h-[8vw] mx-[4vw] inline-block self-center\" style=\"filter: brightness(0);\" data-kid=\"109\">\n          </div>\n        </div>\n      </div>\n\n      <div class=\"container mx-auto px-6 relative z-10 flex flex-col items-center\" data-kid=\"110\">\n        <div class=\"bg-[var(--onyx)] p-12 md:p-24 border-8 border-white shadow-[24px_24px_0px_0px_var(--magenta)] relative max-w-5xl w-full text-center\" id=\"cta-box\" data-kid=\"111\">\n          \n          \n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/crossed-axes.svg\" class=\"absolute -top-16 -left-16 w-40 h-40 rotate-12 drop-shadow-2xl z-20\" style=\"filter: invert(1) sepia(1) saturate(10000%) hue-rotate(290deg);\" data-kid=\"112\">\n          <video src=\"https://videos.pexels.com/video-files/19825062/19825062-sd_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/19825062/2020-background-4k-4k-background-4k-footage-19825062.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"absolute -bottom-20 -right-20 w-56 h-56 rounded-full border-8 border-white object-cover shadow-2xl z-20\" data-kid=\"113\"></video>\n\n          <h2 class=\"font-anton text-6xl md:text-9xl text-white mb-10 leading-[0.9] uppercase\" data-kid=\"114\">Dominance is<br data-kid=\"115\"><span class=\"text-[var(--magenta)]\" data-kid=\"116\">a choice.</span></h2>\n          <p class=\"text-white/70 text-2xl mb-16 max-w-2xl mx-auto font-medium leading-relaxed\" data-kid=\"117\">Stop tracking stats on paper. Join the high-voltage ecosystem built for the next generation of turf athletes.</p>\n          \n          <button id=\"cta-button\" class=\"bg-[var(--magenta)] text-white px-16 py-8 text-3xl font-black border-4 border-white shadow-[10px_10px_0px_0px_white] active:shadow-none active:translate-x-1 active:translate-y-1 uppercase cursor-pointer group\" data-kid=\"118\">\n            Download Turf Score Pro\n          </button>\n        </div>\n      </div>\n    </section>\n\n    \n    <footer class=\"bg-[var(--onyx)] text-white py-20 px-6 md:px-20 border-t-8 border-[var(--magenta)]\" data-kid=\"119\">\n      <div class=\"grid grid-cols-1 md:grid-cols-4 gap-16\" data-kid=\"120\">\n        <div class=\"md:col-span-2\" data-kid=\"121\">\n          <div class=\"font-anton text-5xl mb-8 flex items-center gap-4\" data-kid=\"122\">\n            TURF SCORE PRO <i class=\"ti ti-activity text-[var(--chartreuse)]\" data-kid=\"123\"></i>\n          </div>\n          <p class=\"text-xl text-white/50 max-w-md leading-relaxed\" data-kid=\"124\">Revolutionizing local sports management through high-performance spatial data and 3D visualization. Own the field.</p>\n        </div>\n        <div data-kid=\"125\">\n          <h4 class=\"font-anton text-2xl mb-8 uppercase text-[var(--chartreuse)]\" data-kid=\"126\">Platform</h4>\n          <ul class=\"space-y-4 font-bold\" data-kid=\"127\">\n            <li data-kid=\"128\"><a href=\"#\" class=\"hover:text-[var(--magenta)] transition-colors\" data-kid=\"129\">Features</a></li>\n            <li data-kid=\"130\"><a href=\"#\" class=\"hover:text-[var(--magenta)] transition-colors\" data-kid=\"131\">Scoring Engine</a></li>\n            <li data-kid=\"132\"><a href=\"#\" class=\"hover:text-[var(--magenta)] transition-colors\" data-kid=\"133\">Team Cloud</a></li>\n            <li data-kid=\"134\"><a href=\"#\" class=\"hover:text-[var(--magenta)] transition-colors\" data-kid=\"135\">Integrations</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"136\">\n          <h4 class=\"font-anton text-2xl mb-8 uppercase text-[var(--chartreuse)]\" data-kid=\"137\">Connect</h4>\n          <ul class=\"space-y-4 font-bold\" data-kid=\"138\">\n            <li data-kid=\"139\"><a href=\"#\" class=\"hover:text-[var(--magenta)] transition-colors\" data-kid=\"140\">Discord</a></li>\n            <li data-kid=\"141\"><a href=\"#\" class=\"hover:text-[var(--magenta)] transition-colors\" data-kid=\"142\">Twitter / X</a></li>\n            <li data-kid=\"143\"><a href=\"#\" class=\"hover:text-[var(--magenta)] transition-colors\" data-kid=\"144\">Instagram</a></li>\n            <li data-kid=\"145\"><a href=\"#\" class=\"hover:text-[var(--magenta)] transition-colors\" data-kid=\"146\">Support</a></li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"mt-20 pt-10 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"147\">\n        <div class=\"text-white/30 text-sm font-bold\" data-kid=\"148\">&copy; 2024 TURF SCORE PRO. ALL RIGHTS RESERVED.</div>\n        <div class=\"flex gap-8\" data-kid=\"149\">\n          <a href=\"#\" class=\"text-white/30 text-sm font-bold hover:text-white\" data-kid=\"150\">PRIVACY</a>\n          <a href=\"#\" class=\"text-white/30 text-sm font-bold hover:text-white\" data-kid=\"151\">TERMS</a>\n        </div>\n      </div>\n    </footer>\n\n  </div>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"152\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"153\"></script>\n<script type=\"module\" data-kid=\"154\">\n  import { animate, scroll, stagger, hover, spring } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import Lenis from \"https://esm.sh/lenis@1\"\n  import { animate as animeAnimate, splitText } from 'https://esm.sh/animejs@4';\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // --- LENIS SMOOTH SCROLL & GSAP SYNC ---\n  const lenis = new Lenis({\n    duration: 1.2,\n    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n    smoothWheel: true,\n  });\n\n  // Sync ScrollTrigger with Lenis\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n\n  // Velocity Distortion Effect\n  lenis.on('scroll', (e) => {\n    const velocity = Math.min(Math.abs(lenis.velocity), 40);\n    const skew = (lenis.velocity * 0.05);\n    document.documentElement.style.setProperty('--velocity-skew', `${skew}deg`);\n  });\n\n  // --- ANIME.JS: TEXT LINE MASK REVEAL ---\n  const headlineSplit = splitText(\"#hero-headline\", { lines: { wrap: \"clip\" } });\n  \n  headlineSplit.addEffect(({ lines }) => {\n    animeAnimate(lines, {\n      y: [\"100%\", \"0%\"],\n      delay: (el, i) => i * 150,\n      duration: 1000,\n      easing: 'easeOutExpo'\n    });\n  });\n\n  // Infinite Marquee\n  animeAnimate(\".marquee-content\", {\n    translateX: [\"0%\", \"-50%\"],\n    duration: 15000,\n    loop: true,\n    easing: 'linear'\n  });\n\n  // --- GSAP: ENTRANCE REVEALS ---\n  gsap.from(\"#hero-subtext\", {\n    autoAlpha: 0,\n    y: 40,\n    duration: 1,\n    delay: 0.8,\n    ease: \"power4.out\"\n  });\n\n  gsap.from(\"#hero-ctas\", {\n    autoAlpha: 0,\n    y: 40,\n    duration: 1,\n    delay: 1,\n    ease: \"power4.out\"\n  });\n\n  gsap.from(\"#hero-visual\", {\n    autoAlpha: 0,\n    scale: 0.8,\n    duration: 1.5,\n    delay: 0.5,\n    ease: \"elastic.out(1, 0.75)\"\n  });\n\n  // Feature Batch Reveal\n  ScrollTrigger.batch(\".feature-card\", {\n    start: \"top 85%\",\n    onEnter: (elements) => {\n      gsap.from(elements, {\n        autoAlpha: 0,\n        y: 60,\n        stagger: 0.15,\n        duration: 1,\n        ease: \"power3.out\"\n      });\n    }\n  });\n\n  // CTA Section reveal\n  gsap.from(\"#cta-box\", {\n    scrollTrigger: {\n      trigger: \"#cta\",\n      start: \"top 70%\",\n    },\n    autoAlpha: 0,\n    scale: 0.9,\n    y: 50,\n    duration: 1,\n    ease: \"back.out(1.7)\"\n  });\n\n  // --- MOTION.DEV: INTERACTIVITY ---\n  \n  // Orbiting animation for hero balls\n  animate(\"#ball-1\", { \n    y: [-20, 20], \n    x: [-10, 10], \n    rotate: [0, 5, -5, 0] \n  }, { \n    duration: 4, \n    repeat: Infinity, \n    direction: \"alternate\", \n    easing: \"ease-in-out\" \n  });\n\n  animate(\"#ball-2\", { \n    y: [20, -20], \n    x: [10, -10], \n    rotate: [0, -5, 5, 0] \n  }, { \n    duration: 5, \n    repeat: Infinity, \n    direction: \"alternate\", \n    easing: \"ease-in-out\" \n  });\n\n  // Hover Spring Button\n  const ctaBtn = document.querySelector(\"#cta-button\");\n  hover(ctaBtn, (el) => {\n    animate(ctaBtn, { scale: 1.05, y: -4 }, { type: spring, stiffness: 400, damping: 10 });\n    return () => animate(ctaBtn, { scale: 1, y: 0 }, { type: spring, stiffness: 400, damping: 10 });\n  });\n\n  const heroCta1 = document.querySelector(\"#hero-ctas button:first-child\");\n  hover(heroCta1, () => {\n    animate(heroCta1, { scale: 1.05, y: -4 }, { type: spring, stiffness: 400, damping: 10 });\n    return () => animate(heroCta1, { scale: 1, y: 0 }, { type: spring, stiffness: 400, damping: 10 });\n  });\n\n  // Jersey Card Hovers\n  document.querySelectorAll(\".jersey-card\").forEach(card => {\n    hover(card, () => {\n      animate(card, { y: -10, rotate: -2 }, { type: spring, stiffness: 300, damping: 15 });\n      return () => animate(card, { y: 0, rotate: 0 }, { type: spring, stiffness: 300, damping: 15 });\n    });\n  });\n\n</script>\n",
