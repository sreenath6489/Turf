      "html": "\n<div class=\"min-h-screen bg-[#000830] text-white font-['Plus_Jakarta_Sans',sans-serif] relative overflow-hidden flex flex-col\" data-kid=\"0\">\n    \n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            --royal-blue: #0014A8;\n            --gold: #D4AF37;\n            --scarlet: #E60026;\n            --dark-bg: #00041a;\n            --panel-bg: rgba(0, 8, 48, 0.85);\n            --border-white: rgba(255, 255, 255, 0.1);\n        }\n\n        .broadcast-panel {\n            background: var(--panel-bg);\n            border: 1px solid var(--border-white);\n            position: relative;\n        }\n\n        .accent-bar-gold {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 4px;\n            height: 100%;\n            background: var(--gold);\n        }\n\n        .accent-bar-scarlet {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 4px;\n            height: 100%;\n            background: var(--scarlet);\n        }\n\n        .panel-header {\n            background: rgba(255, 255, 255, 0.05);\n            border-bottom: 1px solid var(--border-white);\n            padding: 0.75rem 1.5rem;\n        }\n\n        .scanlines {\n            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.2) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));\n            background-size: 100% 4px, 3px 100%;\n            pointer-events: none;\n        }\n\n        .gold-underline {\n            border-bottom: 3px solid var(--gold);\n        }\n\n        .vertical-text {\n            writing-mode: vertical-rl;\n            text-orientation: mixed;\n        }\n\n        /* Custom Scrollbar */\n        ::-webkit-scrollbar {\n            width: 4px;\n        }\n        ::-webkit-scrollbar-track {\n            background: transparent;\n        }\n        ::-webkit-scrollbar-thumb {\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 10px;\n        }\n\n        .mesh-gradient {\n            background: \n                radial-gradient(at 0% 0%, rgba(0, 20, 168, 0.3) 0px, transparent 50%),\n                radial-gradient(at 100% 0%, rgba(212, 175, 55, 0.1) 0px, transparent 50%),\n                radial-gradient(at 100% 100%, rgba(230, 0, 38, 0.1) 0px, transparent 50%),\n                radial-gradient(at 0% 100%, rgba(0, 20, 168, 0.2) 0px, transparent 50%);\n        }\n\n        .pulse-live {\n            animation: pulse-red 2s infinite;\n        }\n\n        @keyframes pulse-red {\n            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(230, 0, 38, 0.7); }\n            70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(230, 0, 38, 0); }\n            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(230, 0, 38, 0); }\n        }\n\n        .text-plugin-target {\n            display: inline-block;\n        }\n    </style>\n\n    \n    <div class=\"absolute inset-0 z-0\" data-kid=\"2\">\n        <img src=\"https://images.unsplash.com/photo-1774600551775-747997267949?auto=format&w=1920&q=80&fit=crop\" alt=\"Stadium\" class=\"w-full h-full object-cover opacity-30 mix-blend-luminosity scale-105\" loading=\"lazy\" decoding=\"async\" data-kid=\"3\">\n        <div class=\"absolute inset-0 mesh-gradient opacity-60\" data-kid=\"4\"></div>\n        <div class=\"absolute inset-0 bg-gradient-to-t from-[#000830] via-transparent to-[#000830]/80\" data-kid=\"5\"></div>\n    </div>\n\n    \n    <header class=\"relative z-30 bg-[#0014A8] border-b border-white/20 h-20 px-8 flex items-center justify-between shadow-xl\" data-kid=\"6\">\n        <div class=\"flex items-center gap-6\" data-kid=\"7\">\n            <div class=\"flex items-center gap-3\" data-kid=\"8\">\n                <div class=\"w-3 h-3 rounded-full bg-[#E60026] pulse-live shadow-[0_0_10px_#E60026]\" data-kid=\"9\"></div>\n                <span class=\"text-xs font-extrabold tracking-[0.1em] uppercase\" data-kid=\"10\">Feed: CAM-04 LIVE</span>\n            </div>\n            <div class=\"h-8 w-[1px] bg-white/20\" data-kid=\"11\"></div>\n            <div class=\"flex items-center gap-8\" data-kid=\"12\">\n                <div class=\"flex flex-col\" data-kid=\"13\">\n                    <span class=\"text-[10px] font-bold text-white/60 uppercase\" data-kid=\"14\">Titans</span>\n                    <div class=\"flex items-baseline gap-2\" data-kid=\"15\">\n                        <span id=\"score-main\" class=\"text-3xl font-black text-[#D4AF37]\" data-kid=\"16\">184</span>\n                        <span class=\"text-xl font-bold text-white/30\" data-kid=\"17\">/</span>\n                        <span id=\"wickets-main\" class=\"text-2xl font-bold\" data-kid=\"18\">4</span>\n                    </div>\n                </div>\n                <div class=\"flex flex-col items-center justify-center bg-black/30 px-4 py-1 rounded-lg border border-white/10\" data-kid=\"19\">\n                    <span id=\"overs-main\" class=\"text-lg font-black text-[#D4AF37]\" data-kid=\"20\">18.4 <span class=\"text-xs font-medium text-white/50\" data-kid=\"21\">OVERS</span></span>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"flex items-center gap-10\" data-kid=\"22\">\n            <div class=\"text-center\" data-kid=\"23\">\n                <span class=\"text-[10px] font-bold text-white/40 uppercase block mb-1\" data-kid=\"24\">Current RR</span>\n                <span id=\"crr-display\" class=\"text-xl font-black\" data-kid=\"25\">9.86</span>\n            </div>\n            <div class=\"text-center\" data-kid=\"26\">\n                <span class=\"text-[10px] font-bold te