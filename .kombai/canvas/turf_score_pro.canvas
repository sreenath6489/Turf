      "html": "\n<div class=\"bg-[#010B13] text-white font-['Inter'] selection:bg-[#FFD700] selection:text-[#010B13] overflow-x-clip\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap');\n\n        body {\n            margin: 0;\n            background-color: #010B13;\n        }\n\n        .font-serif { font-family: 'Playfair Display', serif; }\n        .font-sans { font-family: 'Inter', sans-serif; }\n\n        /* Custom Scrollbar */\n        ::-webkit-scrollbar { width: 6px; }\n        ::-webkit-scrollbar-track { background: #010B13; }\n        ::-webkit-scrollbar-thumb { background: #1B1B1B; border-radius: 10px; }\n        ::-webkit-scrollbar-thumb:hover { background: #FFD700; }\n\n        .glass-panel {\n            background: rgba(255, 255, 255, 0.03);\n            backdrop-filter: blur(12px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            position: relative;\n        }\n\n        .glass-highlight::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 1px;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);\n        }\n\n        .gold-border {\n            border: 1px solid #FFD700;\n        }\n\n        .gold-glow {\n            box-shadow: 0 0 30px rgba(255, 215, 0, 0.1);\n        }\n\n        .ball-shadow {\n            box-shadow: \n                inset -20px -20px 60px rgba(0,0,0,0.8),\n                20px 20px 60px rgba(0,0,0,0.5),\n                0 0 100px rgba(220,38,38,0.1);\n        }\n\n        .text-outline {\n            -webkit-text-stroke: 1px rgba(255, 255, 255, 0.1);\n            color: transparent;\n        }\n\n        .perspective-3000 { perspective: 3000px; }\n        .transform-style-3d { transform-style: preserve-3d; }\n    </style>\n\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"2\">\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"3\">\n\n    \n    <nav class=\"fixed top-0 left-0 w-full z-[100] px-10 py-8 flex justify-between items-center mix-blend-difference\" data-kid=\"4\">\n        <div class=\"flex items-center gap-3\" data-kid=\"5\">\n            <div class=\"w-8 h-8 bg-[#FFD700] rounded-sm flex items-center justify-center text-[#010B13] font-bold\" data-kid=\"6\">T</div>\n            <span class=\"font-serif italic font-bold text-xl tracking-tight text-white\" data-kid=\"7\">Turf Score Pro</span>\n        </div>\n        <div class=\"hidden md:flex gap-12 text-[10px] uppercase tracking-[0.3em] font-bold text-white/60\" data-kid=\"8\">\n            <a href=\"#\" class=\"hover:text-[#FFD700] transition-colors\" data-kid=\"9\">The Pitch</a>\n            <a href=\"#\" class=\"hover:text-[#FFD700] transition-colors\" data-kid=\"10\">Live Dashboard</a>\n            <a href=\"#\" class=\"hover:text-[#FFD700] transition-colors\" data-kid=\"11\">Player Stats</a>\n            <a href=\"#\" class=\"hover:text-[#FFD700] transition-colors\" data-kid=\"12\">Squad Creator</a>\n        </div>\n        <button class=\"px-6 py-2 border border-white/20 rounded-full text-[10px] uppercase tracking-widest hover:bg-white hover:text-[#010B13] transition-all duration-500\" data-kid=\"13\">\n            Launch Engine\n        </button>\n    </nav>\n\n    \n    <section id=\"hero\" class=\"relative min-h-screen flex items-center justify-center lg:justify-start overflow-hidden px-10 md:px-24 lg:px-32\" data-kid=\"14\">\n        \n        <div class=\"absolute inset-0 z-0\" data-kid=\"15\">\n            <img src=\"https://images.unsplash.com/photo-1619170622820-cb6528f6a985?auto=format&w=1920&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale brightness-[0.15]\" alt=\"Macro Grass\" decoding=\"async\" loading=\"lazy\" data-kid=\"16\">\n            <div class=\"absolute inset-0 bg-gradient-to-r from-[#010B13] via-transparent to-transparent\" data-kid=\"17\"></div>\n        </div>\n\n        \n        <div class=\"absolute inset-0 flex items-center justify-center z-1 overflow-hidden pointer-events-none\" data-kid=\"18\">\n            <h1 class=\"hero-bg-text text-[45vw] font-serif font-bold text-white/[0.08] uppercase leading-none tracking-tighter select-none mix-blend-overlay\" data-kid=\"19\">\n                SCORE\n            </h1>\n        </div>\n\n        \n        <div class=\"relative z-10 flex flex-col lg:flex-row items-center gap-16 lg:gap-32 w-full max-w-7xl mx-auto\" data-kid=\"20\">\n            <div class=\"hero-content max-w-3xl\" data-kid=\"21\">\n                <div class=\"hero-reveal mb-8 overflow-hidden\" data-kid=\"22\">\n                    <span class=\"inline-block text-[#50C878] text-xs font-bold tracking-[0.5em] uppercase\" data-kid=\"23\">Engine V4.2 Protocol</span>\n                </div>\n                <h2 class=\"hero-reveal text-6xl md:text-8xl lg:text-[10rem] font-serif font-medium leading-[0.85] mb-12\" data-kid=\"24\">\n                    <span class=\"text-white block\" data-kid=\"25\">ARENA</span>\n                    <span class=\"text-[#FFD700] italic block -mt-2\" data-kid=\"26\">ANALYTICS</span>\n                </h2>\n                <p class=\"hero-reveal text-lg md:text-xl text-white/40 max-w-md mb-16 leading-relaxed\" data-kid=\"27\">\n                    A cinematic scoring ecosystem crafted for elite tournament landscapes. Precision telemetry meets high-fashion data visualization.\n                </p>\n                <div class=\"hero-reveal flex items-center gap-8\" data-kid=\"28\">\n                    <button class=\"hero-cta-primary group relative px-12 py-5 bg-[#FFD700] text-[#010B13] font-bold rounded-sm overflow-hidden transition-all duration-500 hover:shadow-[0_0_60px_rgba(255,215,0,0.2)]\" data-kid=\"29\">\n                        <span class=\"relative z-10 uppercase tracking-widest text-xs\" data-kid=\"30\">Initialize System</span>\n                        <div class=\"absolute inset-0 bg-white translate-x-full group-hover:translate-x-0 transition-transform duration-500\" data-kid=\"31\"></div>\n                    </button>\n                    <div class=\"w-12 h-px bg-white/20 hidden md:block\" data-kid=\"32\"></div>\n                    <span class=\"text-[10px] text-white/30 uppercase tracking-[0.3em] hidden md:block\" data-kid=\"33\">Scroll to explore</span>\n                </div>\n            </div>\n\n            \n            <div class=\"hero-ball relative w-72 h-72 md:w-96 md:h-96 rounded-full ball-shadow bg-[radial-gradient(circle_at_30%_30%,#ff4d4d,#990000_60%,#4d0000)] overflow-hidden shrink-0\" data-kid=\"34\">\n                <div class=\"absolute inset-0 bg-[url('https://images.unsplash.com/photo-1666555038185-8323c553de64?auto=format&w=800&q=80')] opacity-20 mix-blend-overlay\" data-kid=\"35\"></div>\n                <div class=\"absolute top-[15%] left-[15%] w-[40%] h-[40%] bg-white/30 blur-3xl rounded-full\" data-kid=\"36\"></div>\n                \n                <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"37\">\n                    <div class=\"w-full h-3 bg-black/60 border-y border-white/10 flex items-center justify-around px-4\" data-kid=\"38\">\n                        <div class=\"w-1.5 h-1.5 bg-white/30 rounded-full shadow-[0_0_5px_white]\" data-kid=\"39\"></div>\n                        <div class=\"w-1.5 h-1.5 bg-white/30 rounded-full shadow-[0_0_5px_white]\" data-kid=\"40\"></div>\n                        <div class=\"w-1.5 h-1.5 bg-white/30 rounded-full shadow-[0_0_5px_white]\" data-kid=\"41\"></div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"absolute bottom-10 left-