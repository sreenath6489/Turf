      "html": "\n<section class=\"relative min-h-screen bg-[#FDF5E6] flex items-center justify-center p-6 md:p-12 font-['Fredoka'] overflow-x-clip\" data-kid=\"0\">\n    \n    <div class=\"fixed inset-0 pointer-events-none overflow-hidden select-none\" data-kid=\"1\">\n        <div class=\"absolute top-[-10%] left-[-5%] w-[40%] opacity-10 animate-pulse\" data-kid=\"2\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/gooey-molecule.svg\" class=\"w-full h-full\" style=\"filter: brightness(0) saturate(100%) invert(69%) sepia(84%) saturate(1682%) hue-rotate(1deg) brightness(105%) contrast(105%);\" data-kid=\"3\">\n        </div>\n        <div class=\"absolute bottom-[-15%] right-[-10%] w-[50%] opacity-10 animate-bounce\" style=\"animation-duration: 10s;\" data-kid=\"4\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/sbed/slow-blob.svg\" class=\"w-full h-full\" style=\"filter: brightness(0) saturate(100%) invert(48%) sepia(87%) saturate(1518%) hue-rotate(69deg) brightness(98%) contrast(92%);\" data-kid=\"5\">\n        </div>\n        \n        <i class=\"ti ti-star-filled absolute top-20 right-[15%] text-[#FFC40C] text-4xl opacity-20 animate-spin\" style=\"animation-duration: 8s;\" data-kid=\"6\"></i>\n        <i class=\"ti ti-star-filled absolute bottom-40 left-[10%] text-[#00BFFF] text-3xl opacity-20 animate-pulse\" data-kid=\"7\"></i>\n    </div>\n\n    \n    <div class=\"absolute inset-0 flex items-center justify-center pointer-events-none select-none z-0\" data-kid=\"8\">\n        <h1 class=\"text-[clamp(10rem,25vw,40rem)] font-bold text-[#4CBB17]/5 tracking-tighter uppercase whitespace-nowrap\" data-kid=\"9\">\n            PLAYBALL\n        </h1>\n    </div>\n\n    <style data-kid=\"10\">\n        @import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito+Sans:wght@400;600;700;800&display=swap');\n\n        .clay-container {\n            position: relative;\n            z-index: 10;\n            width: 100%;\n            max-width: 1240px;\n        }\n\n        .clay-card {\n            background: #ffffff;\n            border-radius: 56px;\n            box-shadow: \n                inset 0 -12px 20px rgba(0, 0, 0, 0.06),\n                inset 0 12px 20px rgba(255, 255, 255, 0.95),\n                0 30px 60px -15px rgba(0, 0, 0, 0.1);\n            border: 12px solid white;\n        }\n\n        .pitch-emblem-outer {\n            width: 440px;\n            height: 440px;\n            background: radial-gradient(circle at 30% 30%, #5ce11e, #4CBB17 70%);\n            border-radius: 50%;\n            border: 20px solid white;\n            box-shadow: \n                inset 0 -35px 50px rgba(0, 0, 0, 0.25),\n                inset 0 25px 35px rgba(255, 255, 255, 0.4),\n                0 45px 90px rgba(76, 187, 23, 0.3);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            position: relative;\n            overflow: visible;\n            /* No transitions here due to GSAP */\n        }\n\n        .pitch-lines {\n            position: absolute;\n            width: 190px;\n            height: 290px;\n            border: 10px solid rgba(255, 255, 255, 0.5);\n            border-radius: 12px;\n            background: rgba(255, 255, 255, 0.1);\n            filter: blur(1px);\n        }\n\n        .squish-btn {\n            cursor: pointer;\n            user-select: none;\n            touch-action: manipulation;\n        }\n\n        .btn-puffy-green {\n            background: #4CBB17;\n            color: white;\n            border-radius: 32px;\n            box-shadow: \n                inset 0 -8px 0 rgba(0, 0, 0, 0.2),\n                inset 0 8px 12px rgba(255, 255, 255, 0.3),\n                0 15px 30px rgba(76, 187, 23, 0.3);\n        }\n\n        .btn-puffy-yellow {\n            background: #FFC40C;\n            color: #433200;\n            border-radius: 28px;\n            box-shadow: \n                inset 0 -8px 0 rgba(0, 0, 0, 0.15),\n                inset 0 8px 12px rgba(255, 255, 255, 0.4),\n                0 15px 30px rgba(255, 196, 12, 0.3);\n        }\n\n        .btn-puffy-white {\n            background: white;\n            color: #333;\n            border-radius: 24px;\n            box-shadow: \n                inset 0 -6px 0 rgba(0, 0, 0, 0.05),\n                inset 0 6px 10px rgba(255, 255, 255, 1),\n                0 10px 20px rgba(0, 0, 0, 0.05);\n        }\n\n        .puffy-text {\n            text-shadow: 0 4px 0 rgba(0, 0, 0, 0.05);\n        }\n\n        .particle {\n            position: absolute;\n            pointer-events: none;\n            width: 12px;\n            height: 12px;\n            border-radius: 50%;\n            z-index: 100;\n        }\n    </style>\n\n    <div class=\"clay-container\" data-kid=\"11\">\n        \n        <div class=\"grid grid-cols-1 lg:grid-cols-4 auto-rows-auto lg:grid-rows-3 gap-6 lg:gap-8\" data-kid=\"12\">\n            \n            \n            <div class=\"clay-card col-span-1 row-span-1 p-8 flex flex-col items-center justify-center bg-[#e0f2fe]/40 border-[#e0f2fe]\" data-kid=\"13\">\n                <div class=\"w-16 h-16 bg-[#00BFFF] rounded-3xl flex items-center justify-center mb-3 shadow-[0_8px_16px_rgba(0,191,255,0.3)] border-4 border-white animate-bounce\" style=\"animation-duration: 3s;\" data-kid=\"14\">\n                    <i class=\"ti ti-bolt-filled text-white text-3xl\" data-kid=\"15\"></i>\n                </div>\n                <h1 class=\"text-[#00BFFF] font-bold text-xl uppercase tracking-tight puffy-text text-center\" data-kid=\"16\">TURF TOYBOX</h1>\n                <p class=\"text-[#00BFFF]/60 text-[10px] mt-1 font-['Nunito_Sans'] font-bold tracking-widest uppercase\" data-kid=\"17\">Cricket Companion</p>\n            </div>\n\n            \n            <div class=\"lg:col-span-2 lg:row-span-2 flex items-center justify-center relative py-12 lg:py-0 overflow-visible\" data-kid=\"18\">\n                <div class=\"pitch-emblem-outer group hover:scale-[1.02] transition-transform duration-700\" data-kid=\"19\">\n                    <div class=\"pitch-lines\" data-kid=\"20\"></div>\n                    <div class=\"relative w-full h-full flex items-center justify-center pointer-events-none overflow-hidden rounded-full bg-[#3fa313]\" data-kid=\"21\">\n                        <img src=\"https://images.unsplash.com/photo-1689481172416-dae28c4a08b4?auto=format&w=800&q=80&fit=crop\" alt=\"Cricket Pitch 3D\" class=\"w-full h-full object-cover mix-blend-screen scale-125 brightness-125 saturate-150\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n                    </div>\n                    \n                    <div class=\"absolute inset-0 pointer-events-none\" data-kid=\"23\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/sparkles.svg\" class=\"absolute top-10 left-10 w-12 animate-pulse\" data-kid=\"24\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/sparkles.svg\" class=\"absolute bottom-10 right-10 w-10 animate-bounce\" data-kid=\"25\">\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"clay-card col-span-1 lg:row-span-2 p-10 flex flex-col bg-[#fffbeb] border-[#fef3c7]\" data-kid=\"26\">\n                <div class=\"flex-1 space-y-6\" data-kid=\"27\">\n                    <div class=\"inline-block px-4 py-2 bg-[#FFC40C]/20 text-[#FFC40C] rounded-full text-xs font-bold tracking-tighter border-2 border-[#FFC40C]/30 uppercase\" data-kid=\"28\">\n                        Active League: Premia\n                    </div>\n                    <h2 class=\"text-4xl xl:text-5xl font-bold text-[#433200] leading-[1.1] puffy-text\" data-kid=\"29\">\n                        Ready to Score <span class=\"text-[#4CBB17]\" data-kid=\"30\">Big</span>?\n                    </h2>\n                    <p class=\"text-[#433200]/70 font-['Nunito_Sans'] font-medium text-lg leading-snug\" data-kid=\"31\">\n                        Experience the most physical cricket scoring app ever built.\n                    </p>\n                </div>\n                <div class=\"mt-8\" data-kid=\"32\">\n                    <button id=\"start-btn\" class=\"squish-btn btn-puffy-green w-full py-6 text-2xl font-bold flex items-center justify-center gap-3\" data-kid=\"33\">\n                        <span data-kid=\"34\">LET'S GO</span>\n                        <i class=\"ti ti-player-play-filled\" data-kid=\"35\"></i>\n                    </button>\n                </div>\n            </div>\n\n            \n            <div class=\"clay-card col-span-1 row-span-1 p-8 flex flex-col justify-between bg-[#f0f9ff]/50 border-[#e0f2fe] group\" data-kid=\"36\">\n                <div class=\"flex items-center gap-4\" data-kid=\"37\">\n                    <div class=\"w-14 h-14 bg-white rounded-2xl flex items-center justify-center border-4 border-[#00BFFF]/20 shadow-sm group-hover:bg-[#00BFFF] group-hover:text-white transition-all duration-300 animate-pulse\" style=\"animation-duration: 4s;\" data-kid=\"38\">\n                        <i class=\"ti ti-users text-3xl\" data-kid=\"39\"></i>\n                    </div>\n                    <div data-kid=\"40\">\n                        <h3 class=\"font-bold text-xl text-gray-800\" data-kid=\"41\">My Teams</h3>\n                        <p class=\"text-xs text-gray-400 font-medium\" data-kid=\"42\">12 Squads Saved</p>\n                    </div>\n                </div>\n                <button class=\"squish-btn btn-puffy-white py-3 font-bold text-gray-600 flex items-center justify-center gap-2\" data-kid=\"43\">\n                    Manage <i class=\"ti ti-chevron-right text-sm\" data-kid=\"44\"></i>\n                </button>\n            </div>\n\n            \n            <div class=\"clay-card col-span-1 row-span-1 p-8 flex flex-col justify-between bg-[#fffbeb]/50 border-[#fef3c7] group\" data-kid=\"45\">\n                <div class=\"flex items-center gap-4\" data-kid=\"46\">\n                    <div class=\"w-14 h-14 bg-white rounded-2xl flex items-center justify-center border-4 border-[#FFC40C]/20 shadow-sm group-hover:bg-[#FFC40C] group-hover:text-white transition-all duration-300\" data-kid=\"47\">\n                        <i class=\"ti ti-chart-bar text-3xl\" data-kid=\"48\"></i>\n                    </div>\n                    <div data-kid=\"49\">\n                        <h3 class=\"font-bold text-xl text-gray-800\" data-kid=\"50\">History</h3>\n                        <p class=\"text-xs text-gray-400 font-medium\" data-kid=\"51\">Last: Titans win</p>\n                    </div>\n                </div>\n                <button class=\"squish-btn btn-puffy-white py-3 font-bold text-gray-600 flex items-center justify-center gap-2\" data-kid=\"52\">\n                    Review <i class=\"ti ti-chevron-right text-sm\" data-kid=\"53\"></i>\n                </button>\n            </div>\n\n            \n            <div class=\"clay-card lg:col-span-2 row-span-1 p-8 flex items-center justify-between bg-[#f0fdf4] border-[#dcfce7]\" data-kid=\"54\">\n                <div class=\"flex items-center gap-8\" data-kid=\"55\">\n                    <div class=\"w-24 h-24 bg-white rounded-3xl flex items-center justify-center border-4 border-green-100 shadow-lg overflow-hidden shrink-0\" data-kid=\"56\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/glowing-star.svg\" class=\"w-16 h-16 object-contain animate-spin\" style=\"animation-duration: 4s;\" data-kid=\"57\">\n                    </div>\n                    <div class=\"max-w-xs\" data-kid=\"58\">\n                        <h3 class=\"font-bold text-2xl text-green-800 puffy-text\" data-kid=\"59\">The Toss</h3>\n                        <p class=\"text-green-700/60 text-sm font-medium mt-1\" data-kid=\"60\">Ready to flip the lucky coin? Let physics decide your fate!</p>\n                    </div>\n                </div>\n                <button class=\"squish-btn btn-puffy-yellow px-10 py-5 text-xl font-bold flex items-center gap-2 shrink-0\" data-kid=\"61\">\n                    FLIP COIN <i class=\"ti ti-coins\" data-kid=\"62\"></i>\n                </button>\n            </div>\n\n        </div>\n    </div>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"63\"></script>\n    <script type=\"module\" data-kid=\"64\">\n        import { animate as anime, spring as animeSpring } from 'https://esm.sh/animejs@4';\n        import { animate, spring } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n\n        // Animation for Buttons (Anime.js Spring Physics)\n        const buttons = document.querySelectorAll('.squish-btn');\n        const colors = ['#4CBB17', '#FFC40C', '#00BFFF', '#FF5733', '#C70039'];\n\n        const createConfetti = (btn) => {\n            const rect = btn.getBoundingClientRect();\n            for (let i = 0; i < 20; i++) {\n                const p = Object.assign(document.createElement('span'), { className: 'particle' });\n                p.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];\n                p.style.left = `${rect.left + rect.width / 2}px`;\n                p.style.top = `${rect.top + rect.height / 2}px`;\n                document.body.appendChild(p);\n\n                anime({\n                    targets: p,\n                    translateX: () => anime.random(-150, 150),\n                    translateY: () => anime.random(-250, -50),\n                    rotate: () => anime.random(0, 360),\n                    opacity: [1, 0],\n                    scale: [1, 0.2],\n                    duration: anime.random(800, 1500),\n                    easing: 'easeOutQuad',\n                    complete: () => p.remove()\n                });\n            }\n        };\n\n        buttons.forEach(btn => {\n            btn.addEventListener('pointerdown', () => {\n                anime(btn, {\n                    scale: 0.88,\n                    duration: 120,\n                    ease: 'outQuad'\n                });\n            });\n\n            btn.addEventListener('pointerup', () => {\n                anime(btn, {\n                    scale: 1,\n                    ease: animeSpring({ stiffness: 220, damping: 12, mass: 1 })\n                });\n                createConfetti(btn);\n            });\n\n            btn.addEventListener('pointerleave', () => {\n                anime(btn, {\n                    scale: 1,\n                    duration: 400,\n                    ease: animeSpring({ stiffness: 180, damping: 15 })\n                });\n            });\n        });\n\n        // Entrance animations for the grid tiles\n        gsap.from(\".clay-card\", {\n            opacity: 0,\n            y: 40,\n            scale: 0.95,\n            duration: 0.8,\n            stagger: 0.1,\n            ease: \"back.out(1.7)\",\n            delay: 0.2\n        });\n\n        gsap.from(\".pitch-emblem-outer\", {\n            scale: 0,\n            opacity: 0,\n            duration: 1.2,\n            ease: \"elastic.out(1, 0.5)\",\n            delay: 0.5\n        });\n    </script>\n\n    \n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"65\">\n</section>\n",
