      "html": "\n<section class=\"min-h-screen bg-[#000830] text-white font-sans overflow-hidden flex flex-col select-none\" data-kid=\"0\">\n  \n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n  \n  \n  <style data-kid=\"2\">\n    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=IBM+Plex+Sans:wght@400;500;700&display=swap');\n    \n    :root {\n      --vivid-royal: #0014A8;\n      --metallic-gold: #D4AF37;\n      --primary-scarlet: #E60026;\n      --deep-navy: #000830;\n    }\n\n    .font-sans { font-family: 'Plus Jakarta Sans', sans-serif; }\n    .font-mono { font-family: 'IBM Plex Sans', sans-serif; }\n\n    .preserve-3d { transform-style: preserve-3d; }\n    .backface-hidden { backface-visibility: hidden; }\n    \n    .diagonal-clip-left { clip-path: polygon(0 0, 100% 0, 45% 100%, 0 100%); }\n    .diagonal-clip-right { clip-path: polygon(100% 0, 100% 100%, 0 100%, 55% 0); }\n\n    .text-outline {\n      -webkit-text-stroke: 1px rgba(255, 255, 255, 0.15);\n      color: transparent;\n    }\n\n    .text-glow-gold { text-shadow: 0 0 10px rgba(212, 175, 55, 0.5); }\n    .text-glow-white { text-shadow: 0 0 15px rgba(255, 255, 255, 0.3); }\n    .coin-rim { box-shadow: inset 0 0 20px rgba(0,0,0,0.4), 0 0 0 4px rgba(212, 175, 55, 0.3); }\n\n    /* Custom scrollbar for webkit */\n    ::-webkit-scrollbar { width: 4px; }\n    ::-webkit-scrollbar-track { background: transparent; }\n    ::-webkit-scrollbar-thumb { background: var(--metallic-gold); border-radius: 10px; }\n  </style>\n\n  \n  <header class=\"h-20 flex items-center px-12 border-b border-white/5 bg-black/20 backdrop-blur-md relative z-50\" data-kid=\"3\">\n    <div class=\"flex items-center gap-4\" data-kid=\"4\">\n      <div class=\"w-10 h-10 bg-[var(--metallic-gold)] rounded flex items-center justify-center\" data-kid=\"5\">\n        <i class=\"ti ti-device-tv text-[var(--vivid-royal)] text-2xl\" data-kid=\"6\"></i>\n      </div>\n      <div data-kid=\"7\">\n        <h1 class=\"text-sm font-black uppercase tracking-widest text-[var(--metallic-gold)]\" data-kid=\"8\">Match Setup</h1>\n        <p class=\"text-[10px] text-white/40 uppercase tracking-[0.3em]\" data-kid=\"9\">Broadcast Pro Console</p>\n      </div>\n    </div>\n\n    <div class=\"flex-1 flex justify-center\" data-kid=\"10\">\n      <div class=\"flex items-center gap-12 relative\" data-kid=\"11\">\n        <div class=\"absolute top-1/2 left-0 w-full h-px bg-white/10 -translate-y-1/2\" data-kid=\"12\"></div>\n        \n        <div class=\"relative flex flex-col items-center gap-1\" data-kid=\"13\">\n          <div class=\"w-6 h-6 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-[10px] font-bold\" data-kid=\"14\">1</div>\n          <span class=\"text-[8px] uppercase tracking-widest text-white/40 absolute top-8\" data-kid=\"15\">Teams</span>\n        </div>\n        \n        <div class=\"relative flex flex-col items-center gap-1\" data-kid=\"16\">\n          <div class=\"w-6 h-6 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-[10px] font-bold\" data-kid=\"17\">2</div>\n          <span class=\"text-[8px] uppercase tracking-widest text-white/40 absolute top-8\" data-kid=\"18\">Captains</span>\n        </div>\n        \n        <div class=\"relative flex flex-col items-center gap-1\" data-kid=\"19\">\n          <div class=\"w-8 h-8 rounded-full bg-[var(--vivid-royal)] border-2 border-[var(--metallic-gold)] flex items-center justify-center text-xs font-black shadow-[0_0_15px_rgba(212,175,55,0.4)] z-10\" data-kid=\"20\">3</div>\n          <span class=\"text-[9px] uppercase tracking-widest text-[var(--metallic-gold)] font-bold absolute top-10 whitespace-nowrap\" data-kid=\"21\">The Toss</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"flex items-center gap-6\" data-kid=\"22\">\n      <div class=\"flex items-center gap-3 px-3 py-1 bg-red-600/10 border border-red-600/30 rounded-full\" data-kid=\"23\">\n         <div class=\"w-2 h-2 bg-red-600 rounded-full animate-pulse shadow-[0_0_8px_#E60026]\" data-kid=\"24\"></div>\n         <span class=\"text-[10px] font-black uppercase tracking-widest text-red-600\" data-kid=\"25\">Live</span>\n      </div>\n      <div class=\"flex flex-col items-end\" data-kid=\"26\">\n        <span class=\"text-[10px] text-white/40 uppercase\" data-kid=\"27\">Broadcast ID</span>\n        <span class=\"text-xs font-mono font-bold tracking-widest\" data-kid=\"28\">TPS-772-B</span>\n      </div>\n      <div class=\"w-8 h-8 rounded-full border border-white/10 flex items-center justify-center\" data-kid=\"29\">\n        <i class=\"ti ti-activity text-white/60\" data-kid=\"30\"></i>\n      </div>\n    </div>\n  </header>\n\n  \n  <main class=\"flex-1 relative flex overflow-hidden\" data-kid=\"31\">\n    \n    <div id=\"side-a\" class=\"absolute inset-0 w-3/4 h-full bg-[var(--vivid-royal)] diagonal-clip-left z-10 group\" data-kid=\"32\">\n      <img src=\"https://images.unsplash.com/photo-1774600551775-747997267949?auto=format&w=1440&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-30 mix-blend-overlay grayscale group-hover:grayscale-0 transition-all duration-1000\" alt=\"Stadium A\" decoding=\"async\" loading=\"lazy\" data-kid=\"33\">\n      \n      <div class=\"absolute inset-y-0 left-20 flex items-center max-w-xl\" data-kid=\"34\">\n        <div class=\"reveal-a translate-x-[-40px]\" data-kid=\"35\">\n          <h2 class=\"text-[10rem] font-black italic text-outline leading-none tracking-tighter mb-8 absolute -top-32 -left-12 pointer-events-none select-none opacity-40\" data-kid=\"36\">MUMBAI<br data-kid=\"37\">TITANS</h2>\n          <div class=\"relative z-10 flex items-start gap-8 bg-black/80 backdrop-blur-3xl border-l-8 border-[var(--metallic-gold)] border-t border-white/5 p-8 rounded-r-3xl shadow-[0_40px_100px_rgba(0,0,0,0.7)]\" data-kid=\"38\">\n            <div class=\"relative\" data-kid=\"39\">\n              <div class=\"w-32 h-32 rounded-xl overflow-hidden border-2 border-white/10 shadow-xl\" data-kid=\"40\">\n                <img src=\"https://i.pravatar.cc/300?u=a\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500\" alt=\"Captain A\" decoding=\"async\" loading=\"lazy\" data-kid=\"41\">\n              </div>\n              <div class=\"absolute -bottom-2 -right-2 w-8 h-8 bg-[var(--metallic-gold)] rounded flex items-center justify-center border border-[var(--vivid-royal)] shadow-lg\" data-kid=\"42\">\n                <i class=\"ti ti-award text-[var(--vivid-royal)] text-lg\" data-kid=\"43\"></i>\n              </div>\n            </div>\n            <div data-kid=\"44\">\n              <div class=\"inline-flex items-center gap-2 px-3 py-1 bg-[var(--metallic-gold)] text-[var(--vivid-royal)] rounded-full text-[10px] font-black uppercase tracking-widest mb-2\" data-kid=\"45\">\n                Team Captain\n              </div>\n              <h3 class=\"text-4xl font-black uppercase tracking-tight\" data-kid=\"46\">Rajesh Malhotra</h3>\n              <p class=\"text-white/60 font-medium tracking-wide\" data-kid=\"47\">Right-Handed Batsman | Lead Aggressor</p>\n              <div class=\"mt-4 flex gap-4\" data-kid=\"48\">\n                <div class=\"text-center\" data-kid=\"49\">\n                  <div class=\"text-[10px] text-white/40 uppercase\" data-kid=\"50\">Experience</div>\n                  <div class=\"text-sm font-bold\" data-kid=\"51\">120 Matches</div>\n                </div>\n                <div class=\"text-center\" data-kid=\"52\">\n                  <div class=\"text-[10px] text-white/40 uppercase\" data-kid=\"53\">Strike Rate</div>\n                  <div class=\"text-sm font-bold\" data-kid=\"54\">148.5</div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div id=\"side-b\" class=\"absolute inset-0 w-full h-full bg-[var(--deep-navy)] diagonal-clip-right z-0 group\" data-kid=\"55\">\n      <img src=\"https://images.unsplash.com/photo-1774600551361-1b7674d1e48c?auto=format&w=1440&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-20 mix-blend-overlay grayscale group-hover:grayscale-0 transition-all duration-1000\" alt=\"Stadium B\" decoding=\"async\" loading=\"lazy\" data-kid=\"56\">\n      \n      <div class=\"absolute inset-y-0 right-20 flex items-center text-right max-w-xl\" data-kid=\"57\">\n        <div class=\"reveal-b translate-x-[40px]\" data-kid=\"58\">\n          <h2 class=\"text-[10rem] font-black italic text-outline leading-none tracking-tighter mb-8 absolute -bottom-32 -right-12 pointer-events-none select-none opacity-40\" data-kid=\"59\">DELHI<br data-kid=\"60\">WARRIORS</h2>\n          <div class=\"relative z-10 flex flex-row-reverse items-start gap-8 bg-black/80 backdrop-blur-3xl border-r-8 border-white/40 border-t border-white/5 p-8 rounded-l-3xl shadow-[0_40px_100px_rgba(0,0,0,0.7)]\" data-kid=\"61\">\n            <div class=\"relative\" data-kid=\"62\">\n              <div class=\"w-32 h-32 rounded-xl overflow-hidden border-2 border-white/10 shadow-xl\" data-kid=\"63\">\n                <img src=\"https://i.pravatar.cc/300?u=b\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500\" alt=\"Captain B\" decoding=\"async\" loading=\"lazy\" data-kid=\"64\">\n              </div>\n              <div class=\"absolute -bottom-2 -left-2 w-8 h-8 bg-white rounded flex items-center justify-center border border-[var(--deep-navy)] shadow-lg\" data-kid=\"65\">\n                <i class=\"ti ti-shield text-[var(--deep-navy)] text-lg\" data-kid=\"66\"></i>\n              </div>\n            </div>\n            <div data-kid=\"67\">\n              <div class=\"inline-flex items-center gap-2 px-3 py-1 bg-white text-[var(--deep-navy)] rounded-full text-[10px] font-black uppercase tracking-widest mb-2\" data-kid=\"68\">\n                Team Captain\n              </div>\n              <h3 class=\"text-4xl font-black uppercase tracking-tight\" data-kid=\"69\">Vikram Singhania</h3>\n              <p class=\"text-white/60 font-medium tracking-wide\" data-kid=\"70\">Left-Arm Pacer | Strategic Mind</p>\n              <div class=\"mt-4 flex flex-row-reverse gap-4\" data-kid=\"71\">\n                <div class=\"text-center\" data-kid=\"72\">\n                  <div class=\"text-[10px] text-white/40 uppercase\" data-kid=\"73\">Experience</div>\n                  <div class=\"text-sm font-bold\" data-kid=\"74\">95 Matches</div>\n                </div>\n                <div class=\"text-center\" data-kid=\"75\">\n                  <div class=\"text-[10px] text-white/40 uppercase\" data-kid=\"76\">Econ Rate</div>\n                  <div class=\"text-sm font-bold\" data-kid=\"77\">6.82</div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div id=\"divider\" class=\"absolute inset-0 w-full h-full pointer-events-none z-20\" data-kid=\"78\">\n       <div class=\"absolute top-0 left-1/2 w-[3px] h-full bg-gradient-to-b from-transparent via-white/50 to-transparent -translate-x-1/2 rotate-[14deg] shadow-[0_0_50px_rgba(255,255,255,0.4)]\" data-kid=\"79\"></div>\n       \n       <div class=\"absolute top-12 left-1/2 -translate-x-1/2 w-24 h-24 bg-black/40 backdrop-blur-2xl rounded-full border border-white/10 flex items-center justify-center z-30 shadow-[0_0_40px_rgba(0,0,0,0.5)]\" data-kid=\"80\">\n          <span class=\"text-white font-black italic text-3xl tracking-widest text-glow-white\" data-kid=\"81\">VS</span>\n          <div class=\"absolute inset-2 rounded-full border border-dashed border-white/20 animate-spin-slow\" data-kid=\"82\"></div>\n       </div>\n    </div>\n\n    \n    <div class=\"absolute inset-0 flex items-center justify-center z-30 pointer-events-none\" data-kid=\"83\">\n      <div id=\"coin-wrapper\" class=\"relative\" data-kid=\"84\">\n        \n        <div id=\"coin-pulse\" class=\"absolute inset-0 bg-[var(--metallic-gold)]/30 rounded-full blur-2xl scale-150 animate-pulse\" data-kid=\"85\"></div>\n        \n        \n        <div id=\"coin\" class=\"w-72 h-72 preserve-3d cursor-pointer pointer-events-auto\" data-kid=\"86\">\n          \n          <div class=\"absolute inset-0 rounded-full bg-gradient-to-br from-[#FFD700] via-[#D4AF37] to-[#8B7355] border-[14px] border-[#B8860B] shadow-[inset_0_0_60px_rgba(0,0,0,0.6),0_40px_80px_rgba(0,0,0,0.7)] flex flex-col items-center justify-center backface-hidden\" data-kid=\"87\">\n            <div class=\"absolute inset-1 rounded-full border-[4px] border-white/30\" data-kid=\"88\"></div>\n            <div class=\"absolute inset-5 rounded-full border border-black/20\" data-kid=\"89\"></div>\n            <div class=\"relative\" data-kid=\"90\">\n               <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cut-diamond.svg\" class=\"w-32 h-32 text-[var(--vivid-royal)]\" style=\"filter: drop-shadow(0 6px 6px rgba(0,0,0,0.5));\" data-kid=\"91\">\n               <div class=\"absolute inset-0 bg-white/30 blur-2xl rounded-full -z-10\" data-kid=\"92\"></div>\n            </div>\n            <span class=\"text-[var(--vivid-royal)] text-sm font-black uppercase tracking-[0.5em] mt-4\" data-kid=\"93\">Heads</span>\n          </div>\n          \n          <div class=\"absolute inset-0 rounded-full bg-gradient-to-br from-[#FFD700] via-[#D4AF37] to-[#8B7355] border-[14px] border-[#B8860B] shadow-[inset_0_0_60px_rgba(0,0,0,0.6),0_40px_80px_rgba(0,0,0,0.7)] flex flex-col items-center justify-center backface-hidden [transform:rotateY(180deg)]\" data-kid=\"94\">\n            <div class=\"absolute inset-1 rounded-full border-[4px] border-white/30\" data-kid=\"95\"></div>\n            <div class=\"absolute inset-5 rounded-full border border-black/20\" data-kid=\"96\"></div>\n            <div class=\"relative\" data-kid=\"97\">\n               <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/circle-sparks.svg\" class=\"w-32 h-32 text-[var(--primary-scarlet)]\" style=\"filter: drop-shadow(0 6px 6px rgba(0,0,0,0.5));\" data-kid=\"98\">\n               <div class=\"absolute inset-0 bg-white/30 blur-2xl rounded-full -z-10\" data-kid=\"99\"></div>\n            </div>\n            <span class=\"text-[var(--primary-scarlet)] text-sm font-black uppercase tracking-[0.5em] mt-4\" data-kid=\"100\">Tails</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div id=\"win-overlay\" class=\"absolute inset-0 z-40 bg-black/80 backdrop-blur-3xl flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-500\" data-kid=\"101\">\n      <div id=\"win-content\" class=\"text-center\" data-kid=\"102\">\n        <div id=\"win-badge\" class=\"inline-flex items-center gap-3 px-6 py-2 bg-[var(--metallic-gold)] text-[var(--vivid-royal)] rounded-full text-sm font-black uppercase tracking-[0.3em] mb-6\" data-kid=\"103\">\n          <i class=\"ti ti-award\" data-kid=\"104\"></i> Toss Winner\n        </div>\n        <h4 id=\"win-team\" class=\"text-7xl font-black uppercase italic tracking-tighter mb-4 text-glow-gold\" data-kid=\"105\">MUMBAI TITANS</h4>\n        <p class=\"text-white/60 text-xl tracking-widest font-mono\" data-kid=\"106\">ELECT TO BAT FIRST</p>\n        \n        <div class=\"mt-12 flex gap-4 justify-center\" data-kid=\"107\">\n           <button class=\"px-8 py-3 bg-white text-[var(--vivid-royal)] rounded-lg font-black uppercase tracking-widest text-sm hover:scale-105 transition-transform\" data-kid=\"108\">Start Match</button>\n           <button class=\"px-8 py-3 border border-white/20 rounded-lg font-black uppercase tracking-widest text-sm hover:bg-white/10 transition-colors\" data-kid=\"109\">Re-Toss</button>\n        </div>\n      </div>\n    </div>\n  </main>\n\n  \n  <footer class=\"h-32 flex items-center justify-center bg-gradient-to-t from-black to-transparent relative z-50\" data-kid=\"110\">\n    <div id=\"toss-btn-container\" class=\"relative\" data-kid=\"111\">\n      <button id=\"toss-btn\" class=\"relative group px-16 py-6 bg-[var(--metallic-gold)] rounded-xl overflow-hidden shadow-[0_20px_40px_rgba(212,175,55,0.2)] hover:shadow-[0_25px_50px_rgba(212,175,55,0.4)] transition-all duration-300 transform active:scale-95\" data-kid=\"112\">\n        <div class=\"absolute inset-0 bg-white/30 translate-y-full group-hover:translate-y-0 transition-transform duration-500\" data-kid=\"113\"></div>\n        <div class=\"relative flex items-center gap-4 text-[var(--vivid-royal)]\" data-kid=\"114\">\n          <i class=\"ti ti-arrows-spin text-2xl animate-spin-slow\" data-kid=\"115\"></i>\n          <span class=\"text-xl font-black uppercase tracking-[0.25em]\" data-kid=\"116\">Initiate Toss Sequence</span>\n        </div>\n      </button>\n      \n      \n      <div class=\"absolute -inset-4 bg-[var(--metallic-gold)]/10 blur-xl rounded-2xl -z-10 group-hover:bg-[var(--metallic-gold)]/20 transition-all\" data-kid=\"117\"></div>\n    </div>\n  </footer>\n\n  \n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"118\"></script>\n  <script data-kid=\"119\">\n    document.addEventListener('DOMContentLoaded', () => {\n      // Initial Reveal Animation (#gsap-timeline-hero-intro style)\n      const tl = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.2 } });\n      \n      // Correcting GSAP usage: remove auto-hiding opacity from CSS and handle in JS\n      gsap.set(['.reveal-a', '.reveal-b'], { opacity: 0 });\n\n      tl.to('.reveal-a', { opacity: 1, x: 0, stagger: 0.2 }, 0.5)\n        .to('.reveal-b', { opacity: 1, x: 0, stagger: 0.2 }, 0.7)\n        .from('#coin', { scale: 0, rotateX: 45, duration: 1.5, ease: 'back.out(1.7)' }, 1)\n        .from('#divider', { scaleY: 0, transformOrigin: 'top', duration: 1 }, 1.2);\n\n      const tossBtn = document.getElementById('toss-btn');\n      const coin = document.getElementById('coin');\n      const sideA = document.getElementById('side-a');\n      const sideB = document.getElementById('side-b');\n      const winOverlay = document.getElementById('win-overlay');\n      const winContent = document.getElementById('win-content');\n      \n      let isSpinning = false;\n\n      tossBtn.addEventListener('click', () => {\n        if (isSpinning) return;\n        isSpinning = true;\n\n        // Sound placeholder / Haptic feedback feel\n        tossBtn.classList.add('pointer-events-none', 'opacity-50');\n        \n        const winningTeam = Math.random() > 0.5 ? 'MUMBAI TITANS' : 'DELHI WARRIORS';\n        const winRotation = winningTeam === 'MUMBAI TITANS' ? 1800 : 1980; // Multiples of 360 or 360 + 180\n\n        const spinTl = gsap.timeline({\n          onComplete: () => {\n            showWinner(winningTeam);\n          }\n        });\n\n        // 1. Initial Launch\n        spinTl.to(coin, { \n          y: -200, \n          scale: 1.3,\n          duration: 0.6, \n          ease: 'power2.out' \n        });\n\n        // 2. Rapid Spin\n        spinTl.to(coin, {\n          rotateY: winRotation,\n          duration: 2.5,\n          ease: 'power4.inOut'\n        }, 0);\n\n        // 3. Falling down\n        spinTl.to(coin, {\n          y: 0,\n          scale: 1,\n          duration: 0.8,\n          ease: 'bounce.out'\n        }, '-=0.8');\n\n        // 4. Background Effects\n        gsap.to([sideA, sideB], {\n          filter: 'blur(15px) saturate(0.5)',\n          duration: 1,\n          ease: 'power2.in'\n        });\n      });\n\n      function showWinner(team) {\n        document.getElementById('win-team').innerText = team;\n        \n        winOverlay.classList.remove('pointer-events-none');\n        winOverlay.classList.add('opacity-100');\n        \n        // Final Resolve (#gsap-blur-in)\n        gsap.from(winContent, {\n          opacity: 0,\n          filter: 'blur(30px)',\n          scale: 0.8,\n          duration: 1.5,\n          ease: 'power3.out'\n        });\n\n        // Highlight the side of the winner slightly\n        if (team === 'MUMBAI TITANS') {\n          gsap.to('#side-a', { filter: 'blur(0px) saturate(1.5)', duration: 0.5 });\n        } else {\n          gsap.to('#side-b', { filter: 'blur(0px) saturate(1.5)', duration: 0.5 });\n        }\n      }\n    });\n  </script>\n\n  <style data-kid=\"120\">\n    @keyframes spin-slow {\n      from { transform: rotate(0deg); }\n      to { transform: rotate(360deg); }\n    }\n    .animate-spin-slow {\n      animation: spin-slow 8s linear infinite;\n    }\n  </style>\n</section>\n",
