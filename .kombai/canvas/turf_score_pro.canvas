      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;700;900&family=Inconsolata:wght@400;700&display=swap');\n\n  :root {\n    --color-black: #100C08;\n    --color-green: #39FF14;\n    --color-magenta: #FF00FF;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--color-black);\n    color: white;\n    font-family: 'Inconsolata', monospace;\n    overflow-x: clip;\n  }\n\n  h1, h2, h3, .font-heading {\n    font-family: 'Big Shoulders Display', sans-serif;\n  }\n\n  /* Locomotive Scroll Styles */\n  [data-scroll-container] {\n    perspective: 1px;\n  }\n\n  /* Custom Cursor */\n  #custom-cursor {\n    width: 24px;\n    height: 24px;\n    background: var(--color-green);\n    border-radius: 0;\n    position: fixed;\n    pointer-events: none;\n    z-index: 9999;\n    transform: translate(-50%, -50%);\n    box-shadow: 0 0 20px var(--color-green);\n  }\n\n  /* Isometric Perspective Grid */\n  .vanishing-point-grid {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background-image: \n      linear-gradient(rgba(57, 255, 20, 0.4) 1px, transparent 1px),\n      linear-gradient(90deg, rgba(57, 255, 20, 0.4) 1px, transparent 1px);\n    background-size: 80px 80px;\n    transform: perspective(800px) rotateX(60deg) translateY(-10%);\n    transform-origin: top center;\n  }\n\n  .text-stroke {\n    -webkit-text-stroke: 2px var(--color-green);\n    color: transparent;\n  }\n\n  .brutalist-border {\n    border: 4px solid var(--color-black);\n    box-shadow: 8px 8px 0px var(--color-magenta);\n  }\n\n  .hard-offset-green {\n    box-shadow: 6px 6px 0px var(--color-green);\n  }\n\n  .hard-offset-magenta {\n    box-shadow: 6px 6px 0px var(--color-magenta);\n  }\n\n  .neon-glow-green {\n    box-shadow: 0 0 15px rgba(57, 255, 20, 0.4);\n  }\n\n  .neon-glow-magenta {\n    box-shadow: 0 0 15px rgba(255, 0, 255, 0.4);\n  }\n\n  /* Glitch Animation */\n  .glitch-hover:hover {\n    animation: glitch 0.3s cubic-bezier(.25,.46,.45,.94) both infinite;\n  }\n\n  @keyframes glitch {\n    0% { transform: translate(0); }\n    20% { transform: translate(-2px, 2px); }\n    40% { transform: translate(-2px, -2px); }\n    60% { transform: translate(2px, 2px); }\n    80% { transform: translate(2px, -2px); }\n    100% { transform: translate(0); }\n  }\n\n  .lenis.lenis-smooth {\n    height: auto;\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar {\n    width: 8px;\n  }\n  ::-webkit-scrollbar-track {\n    background: var(--color-black);\n  }\n  ::-webkit-scrollbar-thumb {\n    background: var(--color-green);\n  }\n\n  /* Wicket Animation */\n  .wicket-glow {\n    animation: wicket-pulse 2s infinite ease-in-out, flicker 4s infinite linear;\n  }\n\n  @keyframes flicker {\n    0%, 19.999%, 22%, 62.999%, 64%, 64.999%, 70%, 100% { opacity: 1; }\n    20%, 21.999%, 63%, 63.999%, 65%, 69.999% { opacity: 0.4; }\n  }\n\n  @keyframes wicket-pulse {\n    0%, 100% { box-shadow: 0 0 20px var(--color-magenta); }\n    50% { box-shadow: 0 0 50px var(--color-magenta), 0 0 80px var(--color-magenta); }\n  }\n\n  /* Shimmer for cards */\n  .holographic-shimmer {\n    background: linear-gradient(\n        110deg,\n        transparent 40%,\n        rgba(255, 255, 255, 0.1) 50%,\n        transparent 60%\n    );\n    background-size: 200% 100%;\n    animation: shimmer 5s infinite linear;\n  }\n\n  @keyframes shimmer {\n    to { background-position: 200% 0; }\n  }\n\n  .terminal-cursor {\n    display: inline-block;\n    width: 8px;\n    height: 18px;\n    background: var(--color-green);\n    animation: blink 1s step-end infinite;\n  }\n\n  @keyframes blink { 50% { opacity: 0; } }\n</style>\n\n<div id=\"custom-cursor\" data-kid=\"1\"></div>\n\n<main data-scroll-container class=\"bg-[var(--color-black)] min-h-screen overflow-x-clip\" data-kid=\"2\">\n  \n  \n  <section id=\"hero\" class=\"relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-10 border-b-8 border-[var(--color-green)] bg-[var(--color-black)]\" data-kid=\"3\">\n    \n    <div class=\"absolute inset-0 z-0\" data-kid=\"4\">\n        <div class=\"vanishing-point-grid opacity-40\" data-kid=\"5\"></div>\n    </div>\n    \n    <div class=\"z-10 w-full max-w-[1440px] relative\" data-kid=\"6\">\n      <div class=\"inline-block bg-[var(--color-magenta)] text-white px-6 py-2 mb-8 text-xl font-black uppercase tracking-[0.3em] border-4 border-white shadow-[8px_8px_0_var(--color-black)]\" data-kid=\"7\">\n        STATUS: OVERDRIVE_V2\n      </div>\n      <h1 class=\"text-[clamp(6rem,16vw,18rem)] font-black leading-[0.8] uppercase tracking-tighter text-[var(--color-green)] drop-shadow-[0_0_30px_rgba(57,255,20,0.5)]\" data-kid=\"8\">\n        TURF<br data-kid=\"9\">\n        <span class=\"text-stroke\" data-kid=\"10\">SCORE</span><br data-kid=\"11\">\n        PRO\n      </h1>\n      \n      <div class=\"flex flex-wrap items-center gap-16 mt-16\" data-kid=\"12\">\n        <div class=\"relative group\" data-kid=\"13\">\n            <div class=\"absolute inset-0 bg-[var(--color-magenta)] translate-x-3 translate-y-3\" data-kid=\"14\"></div>\n            <button class=\"relative bg-[var(--color-green)] text-[var(--color-black)] px-12 py-6 text-5xl font-black uppercase border-4 border-black cursor-pointer\" data-kid=\"15\">\n              Launch Arena\n            </button>\n        </div>\n        <div class=\"max-w-sm text-lg font-black text-[var(--color-green)] leading-tight uppercase tracking-widest border-l-8 border-[var(--color-magenta)] pl-8 bg-white/5 py-4\" data-kid=\"16\">\n            // NEURAL ENGINE ONLINE<br data-kid=\"17\">\n            // 60FPS ANALYTICS<br data-kid=\"18\">\n            // SYNTHWAVE BROADCAST\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute top-[10%] right-[-5%] text-[20rem] font-black text-white/5 uppercase select-none pointer-events-none rotate-12\" data-scroll data-scroll-speed=\