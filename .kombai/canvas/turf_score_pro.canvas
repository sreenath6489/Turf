      "html": "\n<div id=\"main-container\" data-scroll-container class=\"bg-[#000830] text-white selection:bg-[#D4AF37] selection:text-black min-h-screen overflow-x-clip\" data-kid=\"0\">\n    \n    \n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n        \n        :root {\n            --royal-blue: #0014A8;\n            --metallic-gold: #D4AF37;\n            --scarlet: #E60026;\n        }\n\n        body {\n            font-family: 'Plus Jakarta Sans', sans-serif;\n            background-color: #000830;\n        }\n\n        .font-broadcast {\n            font-family: 'IBM+Plex+Sans', sans-serif;\n        }\n\n        /* Broadcast Graphic Classes */\n        .broadcast-panel {\n            background: rgba(0, 8, 48, 0.85);\n            backdrop-filter: blur(12px);\n            border-left: 4px solid var(--metallic-gold);\n            box-shadow: 20px 0 50px rgba(0, 0, 0, 0.8);\n        }\n\n        .gold-gradient-text {\n            background: linear-gradient(180deg, #D4AF37 0%, #B38728 100%);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        .gold-accent-border {\n            border-color: rgba(212, 175, 55, 0.4);\n        }\n\n        .viewfinder-corner {\n            width: 40px;\n            height: 40px;\n            border: 2px solid rgba(255, 255, 255, 0.2);\n        }\n\n        .scanline-overlay {\n            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));\n            background-size: 100% 3px, 3px 100%;\n            pointer-events: none;\n        }\n\n        /* Locomotive / Scroll Customizations */\n        [data-scroll-container] {\n            perspective: 1px;\n        }\n\n        /* Custom Scrollbar for premium feel */\n        ::-webkit-scrollbar {\n            width: 6px;\n        }\n        ::-webkit-scrollbar-track {\n            background: #000830;\n        }\n        ::-webkit-scrollbar-thumb {\n            background: var(--metallic-gold);\n            border-radius: 10px;\n        }\n    </style>\n\n    \n    <header class=\"fixed top-0 left-0 w-full z-50 px-8 py-0 flex justify-between items-center bg-black/40 backdrop-blur-sm border-b border-white/10\" data-kid=\"2\">\n        <div class=\"flex items-center\" data-kid=\"3\">\n            <div class=\"bg-[#E60026] px-6 py-4 flex items-center gap-3\" data-kid=\"4\">\n                <div class=\"w-2 h-2 rounded-full bg-white animate-pulse\" data-kid=\"5\"></div>\n                <span class=\"text-xs font-bold tracking-[0.3em] uppercase text-white\" data-kid=\"6\">Live Broadcast</span>\n            </div>\n            <div class=\"px-6 py-4 border-r border-white/10 hidden lg:flex items-center gap-2\" data-kid=\"7\">\n                <span class=\"text-[10px] font-bold tracking-[0.1em] uppercase opacity-40\" data-kid=\"8\">Frequency</span>\n                <span class=\"text-xs font-broadcast font-bold tracking-widest text-[#D4AF37]\" data-kid=\"9\">440.12 MHZ</span>\n            </div>\n            <div class=\"px-6 py-4 hidden sm:flex items-center gap-2\" data-kid=\"10\">\n                <span class=\"text-[10px] font-bold tracking-[0.1em] uppercase opacity-40\" data-kid=\"11\">Signal</span>\n                <div class=\"flex gap-0.5 items-end h-3\" data-kid=\"12\">\n                    <div class=\"w-1 h-1 bg-[#D4AF37]\" data-kid=\"13\"></div>\n                    <div class=\"w-1 h-2 bg-[#D4AF37]\" data-kid=\"14\"></div>\n                    <div class=\"w-1 h-3 bg-[#D4AF37]\" data-kid=\"15\"></div>\n                    <div class=\"w-1 h-2 bg-white/20\" data-kid=\"16\"></div>\n                </div>\n            </div>\n        </div>\n        <div class=\"flex items-center divide-x divide-white/10\" data-kid=\"17\">\n            <div class=\"px-6 py-4 text-right\" data-kid=\"18\">\n                <span id=\"current-time\" class=\"text-sm font-broadcast font-bold tracking-widest text-white\" data-kid=\"19\">19:42:01</span>\n            </div>\n            <div class=\"px-6 py-4\" data-kid=\"20\">\n                <span class=\"text-[10px] font-bold tracking-[0.2em] uppercase text-white/60\" data-kid=\"21\">GTM +5:30</span>\n            </div>\n        </div>\n    </header>\n\n    \n    <section class=\"relative h-screen flex items-center overflow-hidden\" data-scroll-section data-kid=\"22\">\n        \n        \n        <div class=\"absolute inset-0 z-0 overflow-hidden\" data-kid=\"23\">\n            <div data-scroll data-scroll-speed=\"-1.5\" class=\"w-full h-full\" data-kid=\"24\">\n                <video src=\"https://videos.pexels.com/video-files/33923676/14395632_640_360_100fps.mp4\" poster=\"https://images.pexels.com/videos/33923676/cricket-33923676.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"absolute inset-0 w-full h-full object-cover opacity-80\" style=\"filter: contrast(1.1) brightness(0.8);\" data-kid=\"25\"></video>\n            </div>\n            <div class=\"absolute inset-0 bg-gradient-to-r from-black/80 via-black/20 to-transparent\" data-kid=\"26\"></div>\n            <div class=\"absolute inset-0 scanline-overlay opacity-10\" data-kid=\"27\"></div>\n            \n            \n            <div class=\"absolute top-24 left-6 viewfinder-corner border-t border-l border-white/30 hover:border-white transition-colors duration-700\" data-kid=\"28\"></div>\n            <div class=\"absolute top-24 right-6 viewfinder-corner border-t border-r border-white/30 hover:border-white transition-colors duration-700\" data-kid=\"29\"></div>\n            <div class=\"absolute bottom-20 left-6 viewfinder-corner border-b border-l border-white/30 hover:border-white transition-colors duration-700\" data-kid=\"30\"></div>\n            <div class=\"absolute bottom-20 right-6 viewfinder-corner border-b border-r border-white/30 hover:border-white transition-colors duration-700\" data-kid=\"31\"></div>\n        </div>\n\n        \n        <div id=\"hero-card\" class=\"relative z-10 broadcast-panel h-full w-full max-w-xl p-12 lg:p-20 flex flex-col justify-center\" data-kid=\"32\">\n            \n            \n            <div class=\"absolute -inset-full bg-gradient-to-r from-transparent via-white/5 to-transparent skew-x-12 translate-x-[-100%] transition-transform duration-[2000ms] group-hover:translate-x-[100%] pointer-events-none\" data-kid=\"33\"></div>\n\n            <div class=\"relative\" data-kid=\"34\">\n                \n                <div id=\"brand-badge\" class=\"mb-10 flex flex-col gap-4\" data-kid=\"35\">\n                    <div class=\"flex items-center justify-between mb-4\" data-kid=\"36\">\n                        <div class=\"flex items-center gap-2\" data-kid=\"37\">\n                            <div class=\"w-2 h-2 rounded-full bg-[#E60026] animate-pulse\" data-kid=\"38\"></div>\n                            <span class=\"text-[9px] font-bold tracking-[0.4em] uppercase text-[#E60026]\" data-kid=\"39\">REC</span>\n                        </div>\n                        <span class=\"text-[9px] font-bold tracking-[0.3em] uppercase text-white/20\" data-kid=\"40\">ISO: 400 | F/2.8</span>\n                    </div>\n                    <div class=\"flex items-center gap-6\" data-kid=\"41\">\n                        <div class=\"w-16 h-16 bg-[#D4AF37] p-0.5 rounded-sm shadow-[0_0_20px_rgba(212,175,55,0.2)]\" data-kid=\"42\">\n                            <div class=\"w-full h-full bg-[#000830] flex items-center justify-center\" data-kid=\"43\">\n                                <i class=\"ti ti-device-tv text-3xl text-[#D4AF37]\" data-kid=\"44\"></i>\n                            </div>\n                        </div>\n                        <div data-kid=\"45\">\n                            <span class=\"block text-[10px] font-bold tracking-[0.4em] uppercase text-white/40 mb-1\" data-kid=\"46\">Network Identity</span>\n                            <span class=\"block text-lg font-broadcast font-bold tracking-[0.2em] text-[#D4AF37]\" data-kid=\"47\">ETN-4K BROADCAST</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"mb-10\" data-kid=\"48\">\n                    <span id=\"headline-top\" class=\"block text-sm font-bold tracking-[0.6em] uppercase text-[#D4AF37] mb-4\" data-kid=\"49\">Professional Scoring System</span>\n                    <h1 id=\"headline-main\" class=\"text-6xl lg:text-8xl font-black tracking-[-0.05em] leading-[0.9] text-white uppercase\" data-kid=\"50\">\n                        ELITE<br data-kid=\"51\"><span class=\"gold-gradient-text\" data-kid=\"52\">TURF</span>\n                    </h1>\n                </div>\n\n                <p id=\"subheadline\" class=\"max-w-md text-base text-white/50 font-medium mb-12 tracking-wide uppercase leading-relaxed border-l-2 border-[#D4AF37]/30 pl-6\" data-kid=\"53\">\n                    Real-time analytics for professional turf matches. <span class=\"text-white/80\" data-kid=\"54\">Cinematic match tracking</span> and broadcast-ready scoreboards.\n                </p>\n\n                \n                <div id=\"hero-actions\" class=\"flex flex-col gap-4 w-full max-w-sm\" data-kid=\"55\">\n                    <button class=\"action-btn-primary group/btn relative w-full bg-[#D4AF37] text-black font-black py-5 px-8 flex items-center justify-between uppercase tracking-[0.2em] text-sm overflow-hidden transition-all hover:bg-white\" data-kid=\"56\">\n                        <span class=\"relative z-10 flex items-center gap-3\" data-kid=\"57\">\n                            <i class=\"ti ti-activity-heartbeat text-xl\" data-kid=\"58\"></i>\n                            Start Live Match\n                        </span>\n                        <i class=\"ti ti-chevron-right text-xl relative z-10 group-hover/btn:translate-x-2 transition-transform\" data-kid=\"59\"></i>\n                    </button>\n                    <button class=\"action-btn-secondary w-full border border-white/20 hover:border-[#D4AF37] text-white font-bold py-5 px-8 flex items-center justify-between uppercase tracking-[0.2em] text-sm backdrop-blur-md hover:bg-white/5 transition-all group/sec whitespace-nowrap\" data-kid=\"60\">\n                        <span class=\"flex items-center gap-3\" data-kid=\"61\">\n                            <i class=\"ti ti-users text-xl opacity-60\" data-kid=\"62\"></i>\n                            Manage Teams\n                        </span>\n                        <i class=\"ti ti-chevron-right text-xl opacity-20 group-hover/sec:opacity-100 group-hover/sec:translate-x-2 transition-all\" data-kid=\"63\"></i>\n                    </button>\n                </div>\n\n                \n                <div class=\"mt-16 pt-8 border-t border-white/5 flex flex-wrap gap-10\" data-kid=\"64\">\n                    <div class=\"flex flex-col gap-1.5\" data-kid=\"65\">\n                        <span class=\"text-[9px] font-bold tracking-[0.3em] uppercase text-white/30\" data-kid=\"66\">Latency</span>\n                        <span class=\"text-xs font-broadcast font-bold text-[#D4AF37] tracking-widest\" data-kid=\"67\">&lt; 15.2MS</span>\n                    </div>\n                    <div class=\"flex flex-col gap-1.5\" data-kid=\"68\">\n                        <span class=\"text-[9px] font-bold tracking-[0.3em] uppercase text-white/30\" data-kid=\"69\">Resolution</span>\n                        <span class=\"text-xs font-broadcast font-bold text-white tracking-widest\" data-kid=\"70\">3840 X 2160</span>\n                    </div>\n                    <div class=\"flex flex-col gap-1.5\" data-kid=\"71\">\n                        <span class=\"text-[9px] font-bold tracking-[0.3em] uppercase text-white/30\" data-kid=\"72\">Sync</span>\n                        <div class=\"flex items-center gap-2\" data-kid=\"73\">\n                            <div class=\"w-1.5 h-1.5 rounded-full bg-[#00FF00] shadow-[0_0_8px_#00FF00]\" data-kid=\"74\"></div>\n                            <span class=\"text-xs font-broadcast font-bold text-white tracking-widest uppercase\" data-kid=\"75\">ACTIVE</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"fixed bottom-0 left-0 w-full z-50 bg-[#0014A8]/90 backdrop-blur-xl border-t border-white/10 py-3\" data-kid=\"76\">\n        <div class=\"flex items-center overflow-hidden whitespace-nowrap\" data-kid=\"77\">\n            <div class=\"bg-[#E60026] text-white px-6 py-1 font-broadcast font-bold text-sm flex items-center gap-2 z-10 shadow-lg\" data-kid=\"78\">\n                <i class=\"ti ti-urgent\" data-kid=\"79\"></i>\n                LATEST\n            </div>\n            <div class=\"ticker-content flex gap-12 px-8 font-broadcast font-medium text-xs tracking-widest text-white/80 uppercase\" data-kid=\"80\">\n                <span data-kid=\"81\">• Team Strikers won by 4 wickets against Rising Stars</span>\n                <span data-kid=\"82\">• New Tournament: Premium League starts this Friday</span>\n                <span data-kid=\"83\">• Elite Turf Scoring App updated to v4.2.1</span>\n                <span data-kid=\"84\">• Player of the Week: Mark Anderson (98* off 42)</span>\n                <span data-kid=\"85\">• Live feed enabled for Ground A and Ground C</span>\n            </div>\n        </div>\n    </footer>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"86\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"87\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.min.js\" data-kid=\"88\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css\" data-kid=\"89\">\n\n    <script type=\"module\" data-kid=\"90\">\n        import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n        // Initialize Locomotive Scroll\n        const locoScroll = new LocomotiveScroll({\n            el: document.querySelector('[data-scroll-container]'),\n            smooth: true,\n            multiplier: 1.2\n        });\n\n        // Time Update\n        function updateTime() {\n            const now = new Date();\n            const timeStr = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });\n            document.getElementById('current-time').textContent = timeStr;\n        }\n        setInterval(updateTime, 1000);\n        updateTime();\n\n        // GSAP Animations\n        window.addEventListener('load', () => {\n            const tl = gsap.timeline({\n                defaults: { ease: \"power4.out\", duration: 1.5 }\n            });\n\n            // Hero Entrance Sequence\n            tl.from(\"#hero-card\", {\n                xPercent: -100,\n                duration: 1.5,\n                ease: \"power4.inOut\"\n            })\n            .from(\"#brand-badge\", {\n                y: -50,\n                opacity: 0,\n                scale: 0.8,\n                duration: 1\n            }, \"-=1.2\")\n            .from(\"#headline-top\", {\n                y: 30,\n                opacity: 0,\n                duration: 1\n            }, \"-=1\")\n            .from(\"#headline-main\", {\n                y: 50,\n                opacity: 0,\n                rotateX: -30,\n                transformOrigin: \"center top\",\n                duration: 1.2\n            }, \"-=0.8\")\n            .from(\"#subheadline\", {\n                y: 20,\n                opacity: 0,\n                duration: 1\n            }, \"-=0.8\")\n            .from(\"#hero-actions .action-btn-primary\", {\n                x: -50,\n                opacity: 0,\n                duration: 0.8\n            }, \"-=0.6\")\n            .from(\"#hero-actions .action-btn-secondary\", {\n                x: 50,\n                opacity: 0,\n                duration: 0.8\n            }, \"-=0.8\");\n\n            // Floating animations for background shapes\n            gsap.to(\"[data-scroll-speed]\", {\n                y: \"random(-20, 20)\",\n                x: \"random(-10, 10)\",\n                duration: \"random(3, 5)\",\n                repeat: -1,\n                yoyo: true,\n                ease: \"sine.inOut\"\n            });\n        });\n\n        // Motion.js Ticker Animation\n        const ticker = document.querySelector('.ticker-content');\n        animate(ticker, \n            { x: [0, -1000] }, \n            { duration: 30, repeat: Infinity, ease: \"linear\" }\n        );\n\n        // Hover Gesture Lifts\n        const buttons = document.querySelectorAll('.action-btn-primary, .action-btn-secondary');\n        buttons.forEach(btn => {\n            btn.addEventListener('mouseenter', () => {\n                animate(btn, { y: -8, scale: 1.05 }, { type: \"spring\", stiffness: 400, damping: 20 });\n            });\n            btn.addEventListener('mouseleave', () => {\n                animate(btn, { y: 0, scale: 1 }, { type: \"spring\", stiffness: 300, damping: 25 });\n            });\n        });\n    </script>\n</div>\n",
