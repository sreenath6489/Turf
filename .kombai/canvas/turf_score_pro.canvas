      "html": "\n<div class=\"main-container min-h-screen bg-[#010B13] text-white font-['Space_Grotesk'] overflow-x-clip selection:bg-[#66FF00] selection:text-black\" data-kid=\"0\">\n    \n    <div class=\"fixed inset-0 pointer-events-none z-0\" data-kid=\"1\">\n        <div class=\"absolute inset-0 opacity-15 bg-[url('https://images.unsplash.com/photo-1642436273796-28447b6d3f93?auto=format&w=1280&q=80&fit=crop')] bg-cover bg-center mix-blend-overlay\" data-kid=\"2\"></div>\n        <div id=\"ambient-particles\" class=\"absolute inset-0 opacity-40\" data-kid=\"3\"></div>\n        <div class=\"absolute inset-0 bg-gradient-to-b from-transparent via-[#010B13]/80 to-[#010B13]\" data-kid=\"4\"></div>\n    </div>\n\n    \n    <div class=\"fixed inset-0 pointer-events-none z-50 border-[24px] border-transparent\" data-kid=\"5\">\n        <div class=\"absolute top-0 left-0 w-32 h-32 border-l-2 border-t-2 border-[#66FF00]/30 rounded-tl-3xl\" data-kid=\"6\"></div>\n        <div class=\"absolute top-0 right-0 w-32 h-32 border-r-2 border-t-2 border-[#FF00CC]/30 rounded-tr-3xl\" data-kid=\"7\"></div>\n        <div class=\"absolute bottom-0 left-0 w-32 h-32 border-l-2 border-b-2 border-[#66FF00]/30 rounded-bl-3xl\" data-kid=\"8\"></div>\n        <div class=\"absolute bottom-0 right-0 w-32 h-32 border-r-2 border-b-2 border-[#FF00CC]/30 rounded-br-3xl\" data-kid=\"9\"></div>\n    </div>\n\n    \n    <section id=\"match-setup\" class=\"relative z-10 min-h-screen flex flex-col items-center justify-center p-6 md:p-12\" data-kid=\"10\">\n        \n        <div class=\"fixed inset-0 pointer-events-none z-20 opacity-[0.03] bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_2px,3px_100%]\" data-kid=\"11\"></div>\n\n        <div class=\"setup-header text-center mb-16\" data-kid=\"12\">\n            <h1 class=\"text-6xl md:text-8xl font-black italic tracking-tighter uppercase text-[#66FF00]/5 stroke-text\" style=\"-webkit-text-stroke: 1px rgba(102, 255, 0, 0.4);\" data-kid=\"13\">\n                Match <span class=\"text-[#66FF00] drop-shadow-[0_0_20px_#66FF00]\" data-kid=\"14\">Setup</span>\n            </h1>\n            <p class=\"text-white/40 tracking-[0.5em] uppercase text-xs mt-4\" data-kid=\"15\">Initialize Combat Protocol</p>\n        </div>\n\n        <div class=\"versus-container w-full max-w-7xl grid grid-cols-1 md:grid-cols-2 gap-24 lg:gap-32 relative\" data-kid=\"16\">\n            \n            <div class=\"absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-20 hidden md:block\" data-kid=\"17\">\n                <div class=\"vs-badge w-28 h-28 rounded-full bg-[#010B13]/90 border-4 border-white/20 flex items-center justify-center shadow-[0_0_40px_rgba(102,255,0,0.2)] overflow-hidden group\" data-kid=\"18\">\n                    <div class=\"absolute inset-0 bg-gradient-to-tr from-[#66FF00]/40 to-[#FF00CC]/40 animate-pulse\" data-kid=\"19\"></div>\n                    <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(0,0,0,0.5)_70%)]\" data-kid=\"20\"></div>\n                    <span class=\"text-5xl font-black italic relative z-10 bg-clip-text text-transparent bg-gradient-to-r from-[#66FF00] to-[#FF00CC] drop-shadow-[0_0_15px_rgba(102,255,0,0.6)]\" data-kid=\"21\">VS</span>\n                </div>\n            </div>\n\n            \n            <div class=\"team-card team-a relative group p-1 bg-[#1A1A1A] rounded-2xl overflow-hidden shadow-2xl transition-transform duration-500 hover:scale-[1.02] border border-white/5\" data-kid=\"22\">\n                <div class=\"absolute inset-0 opacity-20 bg-[url('https://images.unsplash.com/photo-1760112783577-c76fcab43695?auto=format&w=800&q=80&fit=crop')] bg-cover bg-center transition-transform duration-700 group-hover:scale-110\" data-kid=\"23\"></div>\n                <div class=\"absolute inset-0 bg-gradient-to-br from-white/5 to-transparent pointer-events-none\" data-kid=\"24\"></div>\n                <div class=\"relative z-10 bg-[#1A1A1A]/90 backdrop-blur-xl p-8 md:p-12 border border-[#66FF00]/20 rounded-2xl h-full flex flex-col\" data-kid=\"25\">\n                    <div class=\"flex items-center gap-6 mb-10\" data-kid=\"26\">\n                        <div class=\"w-16 h-16 rounded-2xl bg-[#66FF00]/10 border border-[#66FF00] flex items-center justify-center shadow-[0_0_20px_rgba(102,255,0,0.2)]\" data-kid=\"27\">\n                            <i class=\"ti ti-swords text-[#66FF00] text-3xl\" data-kid=\"28\"></i>\n                        </div>\n                        <div data-kid=\"29\">\n                            <h3 class=\"text-3xl font-black text-[#66FF00] tracking-wider uppercase\" data-kid=\"30\">Team A</h3>\n                            <p class=\"text-white/40 text-[10px] uppercase tracking-widest\" data-kid=\"31\">Primary Offensive</p>\n                        </div>\n                    </div>\n\n                    <div class=\"space-y-8 flex-grow\" data-kid=\"32\">\n                        <div class=\"hud-input relative\" data-kid=\"33\">\n                            <label class=\"text-[11px] uppercase tracking-[0.4em] text-[#66FF00]/80 mb-3 block font-bold\" data-kid=\"34\">Select Squad</label>\n                            <div class=\"relative bg-white/5 border-l-4 border-[#66FF00] p-4 group cursor-pointer hover:bg-[#66FF00]/5 transition-all\" data-kid=\"35\">\n                                <span class=\"text-xl font-bold uppercase tracking-widest\" data-kid=\"36\">Neon Strikers</span>\n                                <i class=\"ti ti-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-[#66FF00]\" data-kid=\"37\"></i>\n                            </div>\n                        </div>\n                        <div class=\"hud-input relative\" data-kid=\"38\">\n                            <label class=\"text-[11px] uppercase tracking-[0.4em] text-[#66FF00]/80 mb-3 block font-bold\" data-kid=\"39\">Captain Name</label>\n                            <input type=\"text\" value=\"CYBER-JAY\" class=\"w-full bg-white/5 border-l-4 border-[#66FF00]/30 focus:border-[#66FF00] p-4 text-xl font-bold uppercase tracking-widest outline-none transition-all focus:bg-[#66FF00]/5\" data-kid=\"40\">\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"team-card team-b relative group p-1 bg-[#1A1A1A] rounded-2xl overflow-hidden shadow-2xl transition-transform duration-500 hover:scale-[1.02] border border-white/5\" data-kid=\"41\">\n                <div class=\"absolute inset-0 opacity-20 bg-[url('https://images.unsplash.com/photo-1612098771116-1d6544b65409?auto=format&w=800&q=80&fit=crop')] bg-cover bg-center transition-transform duration-700 group-hover:scale-110\" data-kid=\"42\"></div>\n                <div class=\"absolute inset-0 bg-gradient-to-bl from-white/5 to-transparent pointer-events-none\" data-kid=\"43\"></div>\n                <div class=\"relative z-10 bg-[#1A1A1A]/90 backdrop-blur-xl p-8 md:p-12 border border-[#FF00CC]/20 rounded-2xl h-full flex flex-col text-right items-end\" data-kid=\"44\">\n                    <div class=\"flex items-center gap-6 mb-10 flex-row-reverse\" data-kid=\"45\">\n                        <div class=\"w-16 h-16 rounded-2xl bg-[#FF00CC]/10 border border-[#FF00CC] flex items-center justify-center shadow-[0_0_20px_rgba(255,0,204,0.2)]\" data-kid=\"46\">\n                            <i class=\"ti ti-swords text-[#FF00CC] text-3xl\" data-kid=\"47\"></i>\n                        </div>\n                        <div data-kid=\"48\">\n                            <h3 class=\"text-3xl font-black text-[#FF00CC] tracking-wider uppercase\" data-kid=\"49\">Team B</h3>\n                            <p class=\"text-white/40 text-[10px] uppercase tracking-widest\" data-kid=\"50\">Secondary Defense</p>\n                        </div>\n                    </div>\n\n                    <div class=\"space-y-8 w-full flex-grow\" data-kid=\"51\">\n                        <div class=\"hud-input relative\" data-kid=\"52\">\n                            <label class=\"text-[11px] uppercase tracking-[0.4em] text-[#FF00CC]/80 mb-3 block font-bold\" data-kid=\"53\">Select Squad</label>\n                            <div class=\"relative bg-white/5 border-r-4 border-[#FF00CC] p-4 group cursor-pointer hover:bg-[#FF00CC]/5 transition-all\" data-kid=\"54\">\n                                <span class=\"text-xl font-bold uppercase tracking-widest\" data-kid=\"55\">Plasma Matrix</span>\n                                <i class=\"ti ti-chevron-down absolute left-4 top-1/2 -translate-y-1/2 text-[#FF00CC]\" data-kid=\"56\"></i>\n                            </div>\n                        </div>\n                        <div class=\"hud-input relative\" data-kid=\"57\">\n                            <label class=\"text-[11px] uppercase tracking-[0.4em] text-[#FF00CC]/80 mb-3 block font-bold\" data-kid=\"58\">Captain Name</label>\n                            <input type=\"text\" value=\"ZERO-SUM\" class=\"w-full bg-white/5 border-r-4 border-[#FF00CC]/30 focus:border-[#FF00CC] p-4 text-xl font-bold uppercase tracking-widest outline-none transition-all text-right focus:bg-[#FF00CC]/5\" data-kid=\"59\">\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <button id=\"btn-proceed\" class=\"btn-octo mt-16 group relative px-16 py-6 bg-[#66FF00] text-black font-black uppercase tracking-[0.5em] text-sm overflow-hidden hover:shadow-[0_0_50px_rgba(102,255,0,0.4)] transition-all\" data-kid=\"60\">\n            <span class=\"relative z-10\" data-kid=\"61\">Proceed to Toss</span>\n            <div class=\"absolute inset-0 bg-white/30 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 skew-x-12\" data-kid=\"62\"></div>\n        </button>\n\n        \n        <div class=\"mt-12 opacity-20 text-[10px] tracking-[0.8em] uppercase flex items-center gap-4\" data-kid=\"63\">\n            <span class=\"w-2 h-2 rounded-full bg-[#66FF00] animate-pulse\" data-kid=\"64\"></span>\n            SYSTEM ONLINE: TURF SCORE PRO V4.0\n            <span class=\"w-2 h-2 rounded-full bg-[#FF00CC] animate-pulse\" data-kid=\"65\"></span>\n        </div>\n    </section>\n\n    \n    <section id=\"toss-screen\" class=\"fixed inset-0 z-40 bg-[#010B13] flex flex-col items-center justify-center p-8 hidden opacity-0 translate-y-10\" data-kid=\"66\">\n        <div class=\"toss-content w-full max-w-4xl text-center\" data-kid=\"67\">\n            <div class=\"mb-12\" data-kid=\"68\">\n                <h2 class=\"text-6xl font-black uppercase tracking-[0.2em] italic text-[#66FF00] drop-shadow-[0_0_20px_#66FF00]\" data-kid=\"69\">The Toss</h2>\n                <div class=\"flex items-center justify-center gap-4 mt-2\" data-kid=\"70\">\n                    <div class=\"h-[1px] w-20 bg-gradient-to-r from-transparent to-[#66FF00]\" data-kid=\"71\"></div>\n                    <p class=\"text-white/40 uppercase tracking-[0.4em] text-[10px]\" data-kid=\"72\">Call it in the air</p>\n                    <div class=\"h-[1px] w-20 bg-gradient-to-l from-transparent to-[#66FF00]\" data-kid=\"73\"></div>\n                </div>\n            </div>\n\n            \n            <div class=\"relative mx-auto w-80 h-80 md:w-96 md:h-96 rounded-full border-2 border-white/5 overflow-hidden shadow-[0_0_150px_rgba(102,255,0,0.1)] bg-black/80 flex items-center justify-center\" data-kid=\"74\">\n                <div class=\"absolute inset-0 bg-gradient-to-b from-transparent via-[#66FF00]/5 to-transparent pointer-events-none z-10\" data-kid=\"75\"></div>\n                <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#010B13_70%)] z-5 pointer-events-none\" data-kid=\"76\"></div>\n                \n                \n                <div id=\"coin-3d\" class=\"relative w-56 h-56 preserve-3d\" data-kid=\"77\">\n                    \n                    <div class=\"absolute inset-0 backface-hidden rounded-full border-[8px] border-[#66FF00] bg-black flex flex-col items-center justify-center shadow-[inset_0_0_40px_rgba(102,255,0,0.4),0_0_30px_rgba(102,255,0,0.2)]\" data-kid=\"78\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/cricket-game.svg\" class=\"w-24 h-24 mb-2\" decoding=\"async\" loading=\"lazy\" data-kid=\"79\">\n                        <span class=\"text-2xl font-black text-[#66FF00] tracking-widest italic\" data-kid=\"80\">HEADS</span>\n                    </div>\n                    \n                    <div class=\"absolute inset-0 backface-hidden rounded-full border-[8px] border-[#FF00CC] bg-black flex flex-col items-center justify-center shadow-[inset_0_0_40px_rgba(255,0,204,0.4),0_0_30px_rgba(255,0,204,0.2)] [transform:rotateY(180deg)]\" data-kid=\"81\">\n                        <div class=\"w-24 h-24 flex items-center justify-center mb-2\" data-kid=\"82\">\n                            <i class=\"ti ti-bowling text-7xl text-[#FF00CC]\" data-kid=\"83\"></i>\n                        </div>\n                        <span class=\"text-2xl font-black text-[#FF00CC] tracking-widest italic\" data-kid=\"84\">TAILS</span>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"mt-16 flex flex-col items-center gap-8\" data-kid=\"85\">\n                <div id=\"call-selector\" class=\"flex gap-4\" data-kid=\"86\">\n                    <button class=\"call-btn active px-8 py-3 border-2 border-[#66FF00] text-[#66FF00] font-bold uppercase tracking-widest bg-[#66FF00]/10 hover:bg-[#66FF00]/20 transition-all\" data-kid=\"87\">Heads</button>\n                    <button class=\"call-btn px-8 py-3 border-2 border-[#FF00CC]/30 text-[#FF00CC]/40 font-bold uppercase tracking-widest hover:border-[#FF00CC] hover:text-[#FF00CC] transition-all\" data-kid=\"88\">Tails</button>\n                </div>\n\n                <button id=\"btn-flip\" class=\"group relative px-20 py-5 bg-[#66FF00] text-black font-black uppercase tracking-[0.6em] text-sm overflow-hidden rounded-sm hover:shadow-[0_0_60px_rgba(102,255,0,0.5)] transition-all\" data-kid=\"89\">\n                    <span class=\"relative z-10\" data-kid=\"90\">Initiate Flip</span>\n                    <div class=\"absolute inset-0 bg-white/20 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 skew-x-12\" data-kid=\"91\"></div>\n                </button>\n            </div>\n        </div>\n    </section>\n\n    \n    <div id=\"result-overlay\" class=\"fixed inset-0 z-[60] bg-[#010B13]/95 backdrop-blur-2xl flex items-center justify-center p-6 hidden opacity-0\" data-kid=\"92\">\n        <div class=\"result-card w-full max-w-lg bg-[#1A1A1A] border-2 border-[#66FF00]/30 rounded-3xl p-12 text-center relative overflow-hidden\" data-kid=\"93\">\n            \n            <div class=\"absolute inset-0 opacity-10 pointer-events-none\" data-kid=\"94\">\n                <div class=\"absolute top-0 left-0 w-full h-full bg-[linear-gradient(45deg,transparent_25%,rgba(102,255,0,0.1)_50%,transparent_75%)] bg-[length:200%_200%] animate-pulse\" data-kid=\"95\"></div>\n            </div>\n\n            <div class=\"relative z-10\" data-kid=\"96\">\n                <div class=\"mb-8\" data-kid=\"97\">\n                    <div id=\"winner-icon-wrap\" class=\"w-32 h-32 mx-auto rounded-full border-4 border-[#66FF00] bg-[#66FF00]/10 flex items-center justify-center shadow-[0_0_40px_#66FF00]\" data-kid=\"98\">\n                        <i class=\"ti ti-trophy text-6xl text-[#66FF00]\" data-kid=\"99\"></i>\n                    </div>\n                </div>\n\n                <h2 id=\"winner-text\" class=\"text-5xl font-black uppercase tracking-tighter italic mb-2\" data-kid=\"100\">\n                    <span class=\"text-[#66FF00]\" data-kid=\"101\">Alpha</span> Wins!\n                </h2>\n                <p class=\"text-white/40 uppercase tracking-[0.4em] text-xs mb-10\" data-kid=\"102\">Decision Required</p>\n\n                <div class=\"grid grid-cols-2 gap-4\" data-kid=\"103\">\n                    <button class=\"decision-btn btn-octo group relative py-5 border-2 border-[#66FF00] text-[#66FF00] font-black uppercase tracking-widest overflow-hidden hover:bg-[#66FF00] hover:text-black transition-all\" data-kid=\"104\">\n                        <span class=\"relative z-10\" data-kid=\"105\">Bat First</span>\n                    </button>\n                    <button class=\"decision-btn btn-octo group relative py-5 border-2 border-[#FF00CC] text-[#FF00CC] font-black uppercase tracking-widest overflow-hidden hover:bg-[#FF00CC] hover:text-black transition-all\" data-kid=\"106\">\n                        <span class=\"relative z-10\" data-kid=\"107\">Bowl First</span>\n                    </button>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n<style data-kid=\"108\">\n@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n.preserve-3d { transform-style: preserve-3d; }\n.backface-hidden { backface-visibility: hidden; }\n\n.stroke-text {\n    /* Handled by inline tailwind classes if possible, or keeping minimal for contrast */\n}\n\n.btn-octo {\n    clip-path: polygon(10px 0%, calc(100% - 10px) 0%, 100% 10px, 100% calc(100% - 10px), calc(100% - 10px) 100%, 10px 100%, 0% calc(100% - 10px), 0% 10px);\n}\n\n.spark {\n    position: absolute;\n    width: 3px;\n    height: 3px;\n    background: #66FF00;\n    border-radius: 50%;\n    pointer-events: none;\n    box-shadow: 0 0 5px #66FF00;\n}\n\n.ambient-particle {\n    position: absolute;\n    width: 1px;\n    height: 1px;\n    background: #66FF00;\n    border-radius: 50%;\n    pointer-events: none;\n}\n\n#coin-3d {\n    transition: transform 0.1s ease-out;\n}\n\n.hud-input input:focus {\n    background: rgba(102, 255, 0, 0.05);\n}\n\n.call-btn.active {\n    box-shadow: 0 0 20px rgba(102, 255, 0, 0.2);\n}\n</style>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"109\"></script>\n<script type=\"module\" data-kid=\"110\">\n    import { animate } from 'https://esm.sh/animejs@4';\n\n    // --- SETUP AMBIENT PARTICLES ---\n    const particleContainer = document.getElementById('ambient-particles');\n    for (let i = 0; i < 60; i++) {\n        const p = document.createElement('div');\n        p.className = 'ambient-particle';\n        const size = Math.random() * 3 + 1;\n        p.style.width = size + 'px';\n        p.style.height = size + 'px';\n        p.style.left = Math.random() * 100 + '%';\n        p.style.top = Math.random() * 100 + '%';\n        p.style.opacity = Math.random() * 0.5;\n        p.style.backgroundColor = Math.random() > 0.5 ? '#66FF00' : '#FF00CC';\n        particleContainer.appendChild(p);\n\n        gsap.to(p, {\n            x: \"random(-150, 150)\",\n            y: \"random(-150, 150)\",\n            opacity: \"random(0, 0.6)\",\n            duration: \"random(4, 10)\",\n            repeat: -1,\n            yoyo: true,\n            ease: \"sine.inOut\"\n        });\n    }\n\n    // --- SCENE TRANSITIONS ---\n    const setupScene = document.getElementById('match-setup');\n    const tossScene = document.getElementById('toss-screen');\n    const btnProceed = document.getElementById('btn-proceed');\n\n    btnProceed.addEventListener('click', () => {\n        gsap.to(setupScene, {\n            autoAlpha: 0,\n            y: -50,\n            duration: 0.8,\n            ease: \"power4.inOut\",\n            onComplete: () => {\n                setupScene.classList.add('hidden');\n                tossScene.classList.remove('hidden');\n                gsap.to(tossScene, {\n                    autoAlpha: 1,\n                    y: 0,\n                    duration: 1,\n                    ease: \"power4.out\"\n                });\n            }\n        });\n    });\n\n    // --- CALL SELECTOR ---\n    const callBtns = document.querySelectorAll('.call-btn');\n    callBtns.forEach(btn => {\n        btn.addEventListener('click', () => {\n            callBtns.forEach(b => {\n                b.classList.remove('active');\n                b.style.borderColor = b.textContent === 'Heads' ? 'rgba(102, 255, 0, 0.3)' : 'rgba(255, 0, 204, 0.3)';\n                b.style.color = b.textContent === 'Heads' ? 'rgba(102, 255, 0, 0.4)' : 'rgba(255, 0, 204, 0.4)';\n                b.style.background = 'transparent';\n            });\n            btn.classList.add('active');\n            const isHeads = btn.textContent === 'Heads';\n            btn.style.borderColor = isHeads ? '#66FF00' : '#FF00CC';\n            btn.style.color = isHeads ? '#66FF00' : '#FF00CC';\n            btn.style.background = isHeads ? 'rgba(102, 255, 0, 0.1)' : 'rgba(255, 0, 204, 0.1)';\n        });\n    });\n\n    // --- COIN FLIP INTERACTION ---\n    const btnFlip = document.getElementById('btn-flip');\n    const coin3d = document.getElementById('coin-3d');\n    const resultOverlay = document.getElementById('result-overlay');\n    const winnerText = document.getElementById('winner-text');\n    let isFlipping = false;\n\n    btnFlip.addEventListener('click', () => {\n        if (isFlipping) return;\n        isFlipping = true;\n        btnFlip.disabled = true;\n        btnFlip.textContent = \"IN THE AIR...\";\n        btnFlip.style.opacity = \"0.5\";\n\n        const rotations = 8 + Math.floor(Math.random() * 8);\n        const winHeads = Math.random() > 0.5;\n        const finalRotationY = rotations * 180 + (winHeads ? 0 : 180);\n\n        // construct the 3D coin flip physics using anime.js\n        animate(coin3d, {\n            rotateY: finalRotationY,\n            translateY: [\n                { value: -450, duration: 1200, ease: 'out(3)' },\n                { value: 0, duration: 1500, ease: 'spring(1, 80, 10, 0)' }\n            ],\n            scale: [\n                { value: 1.5, duration: 1200, ease: 'out(3)' },\n                { value: 1, duration: 1500, ease: 'spring(1, 80, 10, 0)' }\n            ],\n            duration: 2700,\n            onComplete: () => {\n                // Neon Spark Bursts (#anime-click-confetti inspired)\n                const rect = coin3d.getBoundingClientRect();\n                const centerX = rect.left + rect.width / 2;\n                const centerY = rect.top + rect.height / 2;\n\n                for (let i = 0; i < 50; i++) {\n                    const spark = document.createElement('div');\n                    spark.className = 'spark';\n                    spark.style.left = centerX + 'px';\n                    spark.style.top = centerY + 'px';\n                    spark.style.backgroundColor = winHeads ? '#66FF00' : '#FF00CC';\n                    document.body.appendChild(spark);\n\n                    animate(spark, {\n                        translateX: (Math.random() - 0.5) * 800,\n                        translateY: (Math.random() - 0.5) * 800,\n                        opacity: [1, 0],\n                        scale: [3, 0],\n                        rotate: () => Math.random() * 360,\n                        duration: 1500 + Math.random() * 1000,\n                        ease: 'out(4)',\n                        onComplete: () => spark.remove()\n                    });\n                }\n\n                // Success Morph Sequence\n                setTimeout(() => {\n                    const winnerName = winHeads ? \"Alpha\" : \"Beta\";\n                    const winColor = winHeads ? \"#66FF00\" : \"#FF00CC\";\n                    winnerText.innerHTML = `<span style=\"color: ${winColor}\">${winnerName}</span> Wins!`;\n                    const iconWrap = document.getElementById('winner-icon-wrap');\n                    iconWrap.style.borderColor = winColor;\n                    iconWrap.style.boxShadow = `0 0 40px ${winColor}`;\n                    iconWrap.querySelector('i').style.color = winColor;\n\n                    resultOverlay.classList.remove('hidden');\n                    gsap.to(resultOverlay, {\n                        autoAlpha: 1,\n                        duration: 0.6,\n                        ease: \"power2.out\"\n                    });\n\n                    // Result Card Entrance\n                    gsap.from(\".result-card\", {\n                        scale: 0.8,\n                        y: 60,\n                        duration: 0.8,\n                        ease: \"back.out(1.7)\"\n                    });\n                }, 800);\n            }\n        });\n    });\n\n    // --- AMBIENT PULSES (#gsap-yoyo-ease) ---\n    gsap.to(\".setup-header h1\", {\n        scale: 1.05,\n        duration: 2,\n        ease: \"power2.in\",\n        yoyoEase: \"power2.out\",\n        yoyo: true,\n        repeat: -1\n    });\n\n    gsap.to(\".vs-badge\", {\n        boxShadow: \"0 0 40px rgba(102, 255, 0, 0.3)\",\n        borderColor: \"rgba(255, 255, 255, 0.2)\",\n        duration: 1.5,\n        repeat: -1,\n        yoyo: true,\n        ease: \"sine.inOut\"\n    });\n\n</script>\n",
