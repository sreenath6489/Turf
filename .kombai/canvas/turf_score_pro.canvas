      "html": "\n<div class=\"min-h-screen bg-[#FDF5E6] font-['Fredoka'] text-[#2D2D2D] select-none overflow-x-clip\" id=\"main-container\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@300..700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            --clay-shadow: 0 10px 20px rgba(0,0,0,0.08), inset 4px 4px 8px rgba(255,255,255,0.9), inset -4px -4px 8px rgba(0,0,0,0.05);\n            --clay-puffy: 0 20px 40px rgba(0,0,0,0.1), inset 8px 8px 16px rgba(255,255,255,1), inset -8px -8px 16px rgba(0,0,0,0.08);\n            --clay-sunken: inset 6px 6px 12px rgba(0,0,0,0.1), inset -6px -6px 12px rgba(255,255,255,0.8);\n        }\n\n        .clay-card {\n            background: #ffffff;\n            border-radius: 2.5rem;\n            box-shadow: var(--clay-shadow);\n            border-bottom: 8px solid #F1F1F1;\n            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n\n        .clay-card:hover {\n            transform: scale(1.02) translateY(-4px);\n        }\n\n        .clay-card:active {\n            transform: scale(0.98) translateY(4px);\n            border-bottom-width: 4px;\n        }\n\n        .clay-button {\n            background: #FFC40C;\n            box-shadow: 0 8px 0 #D4A30A, 0 12px 24px rgba(255,196,12,0.3);\n            border-radius: 1.5rem;\n        }\n\n        .clay-button:active {\n            transform: translateY(4px);\n            box-shadow: 0 4px 0 #D4A30A, 0 8px 16px rgba(255,196,12,0.2);\n        }\n\n        .slot-sunken {\n            box-shadow: var(--clay-sunken);\n            background: rgba(0,0,0,0.02);\n        }\n\n        .preserve-3d { transform-style: preserve-3d; }\n        .backface-hidden { backface-visibility: hidden; }\n\n        .particle {\n            position: absolute;\n            pointer-events: none;\n            width: 20px;\n            height: 20px;\n            z-index: 100;\n        }\n\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n    </style>\n\n\n<section id=\"setup-screen\" class=\"min-h-screen flex flex-col items-center py-12 px-6 gap-6 relative\" data-kid=\"2\">\n    \n    <div class=\"absolute top-20 left-10 text-[#FFC40C] opacity-30 animate-bounce\" data-kid=\"3\"><i class=\"ti ti-stars text-6xl\" data-kid=\"4\"></i></div>\n    <div class=\"absolute top-40 right-20 text-[#4CBB17] opacity-30 animate-pulse\" data-kid=\"5\"><i class=\"ti ti-ball-cricket text-8xl\" data-kid=\"6\"></i></div>\n    <div class=\"absolute bottom-40 left-20 text-[#00BFFF] opacity-20\" data-kid=\"7\"><i class=\"ti ti-cloud text-9xl\" data-kid=\"8\"></i></div>\n\n    <div class=\"text-center space-y-2 z-10\" data-kid=\"9\">\n        <h1 class=\"text-6xl font-black text-[#4CBB17] drop-shadow-sm tracking-tight\" data-kid=\"10\">Match Setup</h1>\n        <p class=\"text-[#8B7E66] text-xl font-medium\" data-kid=\"11\">Drag teams to their starting slots!</p>\n    </div>\n\n    \n    <div class=\"w-full max-w-5xl flex flex-col md:flex-row items-center justify-between gap-8 md:gap-0 mt-4 relative z-10\" data-kid=\"12\">\n        \n        <div id=\"home-slot\" class=\"w-72 h-96 rounded-[4rem] border-4 border-dashed border-[#00BFFF]/40 slot-sunken flex flex-col items-center justify-center gap-6 relative group\" data-kid=\"13\">\n            <div class=\"w-24 h-24 bg-[#00BFFF]/10 rounded-full flex items-center justify-center text-[#00BFFF] shadow-inner\" data-kid=\"14\">\n                <i class=\"ti ti-plus text-5xl\" data-kid=\"15\"></i>\n            </div>\n            <div class=\"text-center\" data-kid=\"16\">\n                <span class=\"text-[#00BFFF] font-black text-xl tracking-[0.2em] uppercase\" data-kid=\"17\">Home</span>\n                <p class=\"text-[#00BFFF]/50 text-xs font-bold mt-1\" data-kid=\"18\">HOST TEAM</p>\n            </div>\n            <div class=\"absolute -top-4 -right-4 bg-[#FFC40C] text-white px-6 py-2 rounded-full text-sm font-black shadow-[0_10px_20px_rgba(255,196,12,0.4)] rotate-12 border-b-4 border-[#D4A30A] z-20\" data-kid=\"19\">REQUIRED</div>\n        </div>\n\n        \n        <div class=\"relative flex items-center justify-center py-12\" data-kid=\"20\">\n            <div class=\"text-[12rem] font-black text-[#4CBB17]/5 leading-none select-none pointer-events-none drop-shadow-[0_10px_0_rgba(76,187,23,0.05)]\" data-kid=\"21\">VS</div>\n            <div class=\"absolute text-8xl font-black text-[#4CBB17]/40 tracking-widest pointer-events-none drop-shadow-[0_5px_0_rgba(76,187,23,0.1)]\" data-kid=\"22\">VS</div>\n            \n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/gooey-molecule.svg\" class=\"absolute w-64 h-64 opacity-10 blur-xl -z-10 text-[#4CBB17]\" style=\"filter: brightness(0) saturate(100%) invert(56%) sepia(85%) saturate(464%) hue-rotate(60deg) opacity(0.3);\" data-kid=\"23\">\n        </div>\n\n        \n        <div id=\"away-slot\" class=\"w-72 h-96 rounded-[4rem] border-4 border-dashed border-[#FFC40C]/40 slot-sunken flex flex-col items-center justify-center gap-6 relative group\" data-kid=\"24\">\n            <div class=\"w-24 h-24 bg-[#FFC40C]/10 rounded-full flex items-center justify-center text-[#FFC40C] shadow-inner\" data-kid=\"25\">\n                <i class=\"ti ti-plus text-5xl\" data-kid=\"26\"></i>\n            </div>\n            <div class=\"text-center\" data-kid=\"27\">\n                <span class=\"text-[#FFC40C] font-black text-xl tracking-[0.2em] uppercase\" data-kid=\"28\">Away</span>\n                <p class=\"text-[#FFC40C]/50 text-xs font-bold mt-1\" data-kid=\"29\">VISITORS</p>\n            </div>\n            <div class=\"absolute -top-4 -right-4 bg-[#FFC40C] text-white px-6 py-2 rounded-full text-sm font-black shadow-[0_10px_20px_rgba(255,196,12,0.4)] rotate-12 border-b-4 border-[#D4A30A] z-20\" data-kid=\"30\">REQUIRED</div>\n        </div>\n    </div>\n\n    \n    <div class=\"h-20 flex items-center justify-center z-20\" data-kid=\"31\">\n        <button id=\"btn-proceed\" class=\"clay-button opacity-0 invisible text-white px-12 py-5 text-2xl font-black uppercase tracking-widest flex items-center gap-4 cursor-pointer\" data-kid=\"32\">\n            Next: The Toss\n            <i class=\"ti ti-arrow-right text-3xl\" data-kid=\"33\"></i>\n        </button>\n    </div>\n\n    \n    <div class=\"w-full mt-auto relative pt-12 z-10\" data-kid=\"34\">\n        <div class=\"absolute inset-x-0 bottom-0 top-0 bg-white/60 backdrop-blur-md rounded-t-[5rem] shadow-[0_-25px_50px_rgba(0,0,0,0.05),inset_0_4px_0_rgba(255,255,255,0.8)] -z-10 border-t-2 border-white/20\" data-kid=\"35\"></div>\n        <h3 class=\"text-center text-[#8B7E66] mb-8 font-black text-xl uppercase tracking-[0.3em]\" data-kid=\"36\">Available Teams</h3>\n        <div id=\"teams-container\" class=\"flex gap-10 overflow-x-auto pb-16 px-16 snap-x no-scrollbar min-h-[160px]\" data-kid=\"37\">\n                \n                <div class=\"team-card flex-shrink-0 w-64 p-5 clay-card cursor-grab active:cursor-grabbing snap-center\" data-team=\"lions\" data-kid=\"38\">\n                    <div class=\"flex items-center gap-4\" data-kid=\"39\">\n                        <div class=\"w-16 h-16 bg-[#00BFFF] rounded-[1.25rem] shadow-inner overflow-hidden border-2 border-white/20\" data-kid=\"40\">\n                            <img src=\"https://i.pravatar.cc/150?u=lions\" class=\"w-full h-full object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"41\">\n                        </div>\n                        <div class=\"flex-1\" data-kid=\"42\">\n                            <h4 class=\"font-bold text-xl text-gray-800 leading-tight\" data-kid=\"43\">Lions XI</h4>\n                            <div class=\"flex items-center gap-1 mt-1\" data-kid=\"44\">\n                                <i class=\"ti ti-star-filled text-[#FFC40C] text-xs\" data-kid=\"45\"></i>\n                                <span class=\"text-[10px] text-gray-400 font-bold uppercase tracking-tighter\" data-kid=\"46\">Pro League</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"team-card flex-shrink-0 w-64 p-5 clay-card cursor-grab active:cursor-grabbing snap-center\" data-team=\"tigers\" data-kid=\"47\">\n                    <div class=\"flex items-center gap-4\" data-kid=\"48\">\n                        <div class=\"w-16 h-16 bg-[#FFC40C] rounded-[1.25rem] shadow-inner overflow-hidden border-2 border-white/20\" data-kid=\"49\">\n                            <img src=\"https://i.pravatar.cc/150?u=tigers\" class=\"w-full h-full object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"50\">\n                        </div>\n                        <div class=\"flex-1\" data-kid=\"51\">\n                            <h4 class=\"font-bold text-xl text-gray-800 leading-tight\" data-kid=\"52\">Tigers FC</h4>\n                            <div class=\"flex items-center gap-1 mt-1\" data-kid=\"53\">\n                                <i class=\"ti ti-star-filled text-[#FFC40C] text-xs\" data-kid=\"54\"></i>\n                                <span class=\"text-[10px] text-gray-400 font-bold uppercase tracking-tighter\" data-kid=\"55\">City Cup</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"team-card flex-shrink-0 w-64 p-5 clay-card cursor-grab active:cursor-grabbing snap-center\" data-team=\"eagles\" data-kid=\"56\">\n                    <div class=\"flex items-center gap-4\" data-kid=\"57\">\n                        <div class=\"w-16 h-16 bg-[#4CBB17] rounded-[1.25rem] shadow-inner overflow-hidden border-2 border-white/20\" data-kid=\"58\">\n                            <img src=\"https://i.pravatar.cc/150?u=eagles\" class=\"w-full h-full object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"59\">\n                        </div>\n                        <div class=\"flex-1\" data-kid=\"60\">\n                            <h4 class=\"font-bold text-xl text-gray-800 leading-tight\" data-kid=\"61\">Eagle Stars</h4>\n                            <div class=\"flex items-center gap-1 mt-1\" data-kid=\"62\">\n                                <i class=\"ti ti-star-filled text-[#FFC40C] text-xs\" data-kid=\"63\"></i>\n                                <span class=\"text-[10px] text-gray-400 font-bold uppercase tracking-tighter\" data-kid=\"64\">Elite</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"team-card flex-shrink-0 w-64 p-5 clay-card cursor-grab active:cursor-grabbing snap-center\" data-team=\"titans\" data-kid=\"65\">\n                    <div class=\"flex items-center gap-4\" data-kid=\"66\">\n                        <div class=\"w-16 h-16 bg-[#8E44AD] rounded-[1.25rem] shadow-inner overflow-hidden border-2 border-white/20\" data-kid=\"67\">\n                            <img src=\"https://i.pravatar.cc/150?u=titans\" class=\"w-full h-full object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"68\">\n                        </div>\n                        <div class=\"flex-1\" data-kid=\"69\">\n                            <h4 class=\"font-bold text-xl text-gray-800 leading-tight\" data-kid=\"70\">Titans</h4>\n                            <div class=\"flex items-center gap-1 mt-1\" data-kid=\"71\">\n                                <i class=\"ti ti-star-filled text-[#FFC40C] text-xs\" data-kid=\"72\"></i>\n                                <span class=\"text-[10px] text-gray-400 font-bold uppercase tracking-tighter\" data-kid=\"73\">League 2</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"toss-screen\" class=\"hidden fixed inset-0 z-[60] bg-[#4CBB17] flex flex-col items-center justify-center p-8 overflow-hidden\" data-kid=\"74\">\n        \n        <div class=\"absolute inset-0 pointer-events-none overflow-hidden\" data-kid=\"75\">\n            <img src=\"https://images.unsplash.com/photo-1679397113276-2717c52626a1?auto=format&w=800&q=80&fit=crop\" class=\"absolute -top-20 -left-20 w-[40rem] h-[40rem] opacity-20 blur-3xl animate-pulse\" loading=\"lazy\" decoding=\"async\" data-kid=\"76\">\n            <img src=\"https://images.unsplash.com/photo-1707647527198-835a741c14cf?auto=format&w=800&q=80&fit=crop\" class=\"absolute -bottom-20 -right-20 w-[40rem] h-[40rem] opacity-20 blur-3xl\" loading=\"lazy\" decoding=\"async\" data-kid=\"77\">\n            \n            \n            <div class=\"absolute top-[10%] left-[15%] text-4xl text-white/40 rotate-12\" data-kid=\"78\"><i class=\"ti ti-stars\" data-kid=\"79\"></i></div>\n            <div class=\"absolute bottom-[15%] right-[10%] text-6xl text-white/30 -rotate-12\" data-kid=\"80\"><i class=\"ti ti-stars\" data-kid=\"81\"></i></div>\n        </div>\n\n        <div class=\"relative z-10 flex flex-col items-center gap-16 w-full max-w-2xl text-center\" data-kid=\"82\">\n            <div class=\"space-y-4\" data-kid=\"83\">\n                <h2 class=\"text-6xl font-black text-white drop-shadow-lg uppercase tracking-tight\" data-kid=\"84\">Time for the Toss!</h2>\n                <p class=\"text-white/90 text-2xl font-medium max-w-md mx-auto\" data-kid=\"85\">Who's the lucky captain today? Swipe up to flip!</p>\n            </div>\n\n            \n            <div id=\"coin-stage\" class=\"relative w-80 h-80 flex items-center justify-center cursor-pointer\" data-kid=\"86\">\n                <div id=\"coin\" class=\"relative w-full h-full preserve-3d\" data-kid=\"87\">\n                    \n                    <div class=\"absolute inset-0 bg-[#FFC40C] rounded-full border-[12px] border-[#E5B00B] shadow-[0_25px_0_#B88A00,0_40px_60px_rgba(0,0,0,0.3),inset_6px_6px_0_rgba(255,255,255,0.4)] flex items-center justify-center backface-hidden\" data-kid=\"88\">\n                        <div class=\"text-[#8B6A00] text-[10rem] font-black drop-shadow-[0_4px_0_#D4A30A]\" data-kid=\"89\">H</div>\n                        <div class=\"absolute inset-6 border-4 border-dashed border-[#B88A00]/40 rounded-full\" data-kid=\"90\"></div>\n                    </div>\n                    \n                    <div class=\"absolute inset-0 bg-[#FDF5E6] rounded-full border-[12px] border-[#E6DDD0] shadow-[0_25px_0_#D1C9BC,0_40px_60px_rgba(0,0,0,0.3),inset_6px_6px_0_rgba(255,255,255,0.6)] flex items-center justify-center backface-hidden\" style=\"transform: rotateY(180deg);\" data-kid=\"91\">\n                        <div class=\"text-[#8B7E66] text-[10rem] font-black drop-shadow-[0_4px_0_#D1C9BC]\" data-kid=\"92\">T</div>\n                        <div class=\"absolute inset-6 border-4 border-dashed border-[#D1C9BC]/40 rounded-full\" data-kid=\"93\"></div>\n                    </div>\n                </div>\n                \n                \n                <div id=\"swipe-hint\" class=\"absolute -bottom-24 flex flex-col items-center gap-3 text-white\" data-kid=\"94\">\n                    <div class=\"w-12 h-20 bg-white/10 rounded-full flex flex-col items-center justify-start py-4 border-2 border-white/20\" data-kid=\"95\">\n                        <div class=\"w-3 h-3 bg-white rounded-full animate-bounce\" data-kid=\"96\"></div>\n                    </div>\n                    <span class=\"text-sm font-black uppercase tracking-widest opacity-80\" data-kid=\"97\">Swipe Up</span>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <div id=\"celebration-overlay\" class=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/40 backdrop-blur-md hidden transition-opacity duration-300 opacity-0\" data-kid=\"98\">\n        <div id=\"result-card\" class=\"bg-white p-16 rounded-[4rem] shadow-2xl flex flex-col items-center gap-8 scale-90 opacity-0 transform-gpu relative overflow-hidden\" data-kid=\"99\">\n            \n            <div class=\"absolute -top-10 -right-10 w-32 h-32 bg-[#4CBB17]/10 rounded-full blur-2xl\" data-kid=\"100\"></div>\n            <div class=\"absolute -bottom-10 -left-10 w-32 h-32 bg-[#FFC40C]/10 rounded-full blur-2xl\" data-kid=\"101\"></div>\n\n            <div class=\"w-32 h-32 bg-[#4CBB17] rounded-[2.5rem] flex items-center justify-center shadow-[0_12px_0_#3A9211] transform -rotate-6\" data-kid=\"102\">\n                <i class=\"ti ti-trophy text-white text-6xl\" data-kid=\"103\"></i>\n            </div>\n            \n            <div class=\"text-center\" data-kid=\"104\">\n                <p class=\"text-[#8B7E66] font-black uppercase tracking-[0.3em] mb-2\" data-kid=\"105\">The Winner is</p>\n                <h2 id=\"final-result\" class=\"text-8xl font-black text-[#4CBB17] drop-shadow-sm uppercase\" data-kid=\"106\">HEADS!</h2>\n            </div>\n\n            <p id=\"winner-caption\" class=\"text-gray-500 font-medium text-xl max-w-xs text-center\" data-kid=\"107\">Lions XI wins the toss and elects to bat!</p>\n\n            <button class=\"clay-button text-white px-12 py-5 text-2xl font-black uppercase tracking-widest mt-4\" data-kid=\"108\">\n                START MATCH\n            </button>\n        </div>\n    </div>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"109\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"110\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/Draggable.min.js\" data-kid=\"111\"></script>\n    <script type=\"module\" data-kid=\"112\">\n        import { animate, spring } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n        import { animate as animeAnimate, utils } from 'https://esm.sh/animejs@4';\n\n        gsap.registerPlugin(Draggable);\n\n        const homeSlot = document.getElementById('home-slot');\n        const awaySlot = document.getElementById('away-slot');\n        const proceedBtn = document.getElementById('btn-proceed');\n        const teamCards = document.querySelectorAll('.team-card');\n        const setupScreen = document.getElementById('setup-screen');\n        const tossScreen = document.getElementById('toss-screen');\n        const coin = document.getElementById('coin');\n        const celebrationOverlay = document.getElementById('celebration-overlay');\n        const resultCard = document.getElementById('result-card');\n\n        let filledSlots = { home: null, away: null };\n\n        // DRAG AND DROP SETUP\n        teamCards.forEach(card => {\n            Draggable.create(card, {\n                type: \"x,y\",\n                edgeResistance: 0.65,\n                bounds: window,\n                inertia: true,\n                onDragStart: function() {\n                    gsap.to(this.target, { scale: 1.15, zIndex: 100, rotation: 8, boxShadow: \"0 30px 60px rgba(0,0,0,0.25)\" });\n                },\n                onRelease: function() {\n                    const cardRect = this.target.getBoundingClientRect();\n                    const homeRect = homeSlot.getBoundingClientRect();\n                    const awayRect = awaySlot.getBoundingClientRect();\n\n                    let droppedIn = null;\n\n                    if (isOverlapping(cardRect, homeRect)) droppedIn = 'home';\n                    else if (isOverlapping(cardRect, awayRect)) droppedIn = 'away';\n\n                    if (droppedIn) {\n                        snapToSlot(this.target, droppedIn);\n                    } else {\n                        gsap.to(this.target, { x: 0, y: 0, scale: 1, rotation: 0, boxShadow: \"\", duration: 0.5, ease: \"elastic.out(1, 0.75)\" });\n                    }\n                }\n            });\n        });\n\n        function isOverlapping(rect1, rect2) {\n            return !(rect1.right < rect2.left || rect1.left > rect2.right || rect1.bottom < rect2.top || rect1.top > rect2.bottom);\n        }\n\n        function snapToSlot(element, slotId) {\n            const slot = slotId === 'home' ? homeSlot : awaySlot;\n            const slotRect = slot.getBoundingClientRect();\n            const elementRect = element.getBoundingClientRect();\n\n            // Check if slot already has a team\n            if (filledSlots[slotId]) {\n                const oldTeam = filledSlots[slotId];\n                gsap.to(oldTeam, { x: 0, y: 0, scale: 1, rotation: 0, duration: 0.5 });\n            }\n\n            filledSlots[slotId] = element;\n\n            const targetX = (slotRect.left + slotRect.width / 2) - (elementRect.left + elementRect.width / 2);\n            const targetY = (slotRect.top + slotRect.height / 2) - (elementRect.top + elementRect.height / 2);\n\n            gsap.to(element, { \n                x: `+=${targetX}`, \n                y: `+=${targetY}`, \n                scale: 0.85, \n                rotation: 0, \n                duration: 0.4, \n                ease: \"back.out(1.7)\",\n                onComplete: checkProceed\n            });\n\n            slot.classList.add('bg-white/10');\n            animate(slot, { scale: [1, 1.05, 1] }, { duration: 0.3 });\n        }\n\n        function checkProceed() {\n            if (filledSlots.home && filledSlots.away) {\n                proceedBtn.classList.remove('invisible');\n                gsap.to(proceedBtn, { opacity: 1, y: 0, duration: 0.5, ease: \"back.out(2)\" });\n            }\n        }\n\n        // TRANSITION TO TOSS\n        proceedBtn.addEventListener('click', () => {\n            gsap.to(setupScreen, { \n                opacity: 0, \n                y: -50, \n                duration: 0.6, \n                ease: \"power2.inOut\",\n                onComplete: () => {\n                    setupScreen.classList.add('hidden');\n                    tossScreen.classList.remove('hidden');\n                    gsap.from(tossScreen, { opacity: 0, y: 100, duration: 0.8, ease: \"power3.out\" });\n                }\n            });\n        });\n\n        // COIN FLIP INTERACTION\n        let isFlipping = false;\n        Draggable.create(\"#coin-stage\", {\n            type: \"y\",\n            bounds: { minY: -400, maxY: 0 },\n            onDrag: function() {\n                if(isFlipping) return;\n                const progress = Math.abs(this.y) / 400;\n                gsap.set(coin, { rotationX: -progress * 45, y: this.y * 0.2 });\n            },\n            onRelease: function() {\n                if(isFlipping) return;\n                if (this.y < -100) {\n                    performFlip();\n                } else {\n                    gsap.to(coin, { rotationX: 0, y: 0, duration: 0.5, ease: \"elastic.out(1, 0.3)\" });\n                }\n            }\n        });\n\n        function performFlip() {\n            isFlipping = true;\n            const result = Math.random() > 0.5 ? 'Heads' : 'Tails';\n            const rotations = 5 + Math.floor(Math.random() * 5); // 5-10 full rotations\n            const finalRotation = result === 'Heads' ? rotations * 360 : rotations * 360 + 180;\n\n            document.getElementById('swipe-hint').style.opacity = '0';\n\n            const tl = gsap.timeline({\n                onComplete: () => {\n                    showCelebration(result);\n                }\n            });\n\n            tl.to(coin, {\n                y: -300,\n                rotationX: finalRotation,\n                rotationY: rotations * 180,\n                duration: 1.2,\n                ease: \"power2.out\"\n            })\n            .to(coin, {\n                y: 0,\n                duration: 0.8,\n                ease: \"bounce.out\"\n            });\n        }\n\n        function showCelebration(result) {\n            document.getElementById('final-result').textContent = result.toUpperCase() + '!';\n            const homeTeamName = filledSlots.home.querySelector('h4').textContent;\n            const awayTeamName = filledSlots.away.querySelector('h4').textContent;\n            const winner = result === 'Heads' ? homeTeamName : awayTeamName;\n            document.getElementById('winner-caption').textContent = `${winner} wins the toss and elects to bat!`;\n\n            celebrationOverlay.classList.remove('hidden');\n            setTimeout(() => {\n                celebrationOverlay.classList.remove('opacity-0');\n                gsap.to(resultCard, { opacity: 1, scale: 1, duration: 0.6, ease: \"back.out(1.5)\" });\n                burstConfetti();\n            }, 100);\n        }\n\n        function burstConfetti() {\n            const container = document.getElementById('celebration-overlay');\n            const icons = ['✨', '⭐', '🏏', '🔥', '🏆'];\n            \n            for (let i = 0; i < 40; i++) {\n                const p = Object.assign(document.createElement('div'), { \n                    className: 'particle',\n                    innerHTML: `<span style=\"font-size: ${utils.random(20, 40)}px\">${icons[utils.random(0, icons.length - 1)]}</span>`\n                });\n                container.appendChild(p);\n                \n                // Position at center\n                const startX = window.innerWidth / 2;\n                const startY = window.innerHeight / 2;\n                gsap.set(p, { x: startX, y: startY, opacity: 1 });\n\n                animeAnimate(p, {\n                    x: startX + utils.random(-400, 400),\n                    y: startY + utils.random(-400, 400),\n                    rotate: utils.random(0, 720),\n                    opacity: [1, 0],\n                    scale: [0.5, 1.5],\n                    duration: utils.random(1000, 2000),\n                    ease: 'outExpo',\n                    onComplete: () => p.remove()\n                });\n            }\n        }\n    </script>\n</div>\n",
