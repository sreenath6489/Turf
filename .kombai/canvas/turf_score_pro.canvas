      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300..700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n:root {\n  --color-slate: #0B0E14;\n  --color-carbon: #1A2029;\n  --color-neon-green: #10B981;\n  --color-boundary-red: #DC2626;\n  --font-heading: 'Anton', sans-serif;\n  --font-body: 'Space Grotesk', sans-serif;\n}\n\nbody {\n  margin: 0;\n  background-color: var(--color-slate);\n  color: white;\n  font-family: var(--font-body);\n  overflow-x: clip;\n  line-height: 1.5;\n}\n\nh1, h2, h3, h4 {\n  font-family: var(--font-heading);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  line-height: 0.9;\n}\n\n.glass {\n  background: rgba(255, 255, 255, 0.03);\n  backdrop-filter: blur(16px);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.neon-border {\n  border: 1px solid var(--color-neon-green);\n  box-shadow: 0 0 15px rgba(16, 185, 129, 0.3);\n}\n\n.red-border {\n  border: 1px solid var(--color-boundary-red);\n  box-shadow: 0 0 15px rgba(220, 38, 38, 0.3);\n}\n\n/* Custom Cursor */\n#custom-cursor {\n  width: 20px;\n  height: 20px;\n  background: var(--color-neon-green);\n  border-radius: 50%;\n  position: fixed;\n  pointer-events: none;\n  z-index: 9999;\n  mix-blend-mode: screen;\n  box-shadow: 0 0 20px var(--color-neon-green);\n  transition: transform 0.1s ease-out;\n}\n\n/* Shimmer Animation */\n@keyframes holographic {\n  0% { background-position: 0% 50%; }\n  100% { background-position: 200% 50%; }\n}\n\n.holographic-card {\n  background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);\n  position: relative;\n  overflow: hidden;\n}\n\n.holographic-card::after {\n  content: '';\n  position: absolute;\n  top: 0; left: 0; right: 0; bottom: 0;\n  background: linear-gradient(45deg, transparent 20%, rgba(16, 185, 129, 0.1) 40%, transparent 60%, rgba(220, 38, 38, 0.1) 80%);\n  background-size: 200% 200%;\n  pointer-events: none;\n  animation: holographic 8s infinite linear;\n}\n\n.perspective-1000 {\n  perspective: 1000px;\n}\n\n@keyframes scan {\n  0% { top: 0; }\n  100% { top: 100%; }\n}\n\n/* Hide default scrollbar */\n::-webkit-scrollbar {\n  width: 6px;\n}\n::-webkit-scrollbar-track {\n  background: var(--color-slate);\n}\n::-webkit-scrollbar-thumb {\n  background: var(--color-carbon);\n  border-radius: 10px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: var(--color-neon-green);\n}\n</style>\n\n\n<div id=\"custom-cursor\" data-kid=\"1\"></div>\n\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"2\">\n\n<main class=\"relative\" data-kid=\"3\">\n    \n    <section id=\"hero\" class=\"relative h-screen overflow-hidden bg-black flex flex-col justify-end\" data-kid=\"4\">\n        \n        <div class=\"absolute inset-0 z-0\" data-kid=\"5\">\n            <img src=\"https://images.unsplash.com/photo-1750716413444-c8a957fcf35c?auto=format&w=1920&q=80&fit=crop\" class=\"w-full h-full object-cover opacity-30\" alt=\"Dark Stadium\" decoding=\"async\" loading=\"lazy\" data-kid=\"6\">\n            <div class=\"absolute inset-0 bg-gradient-to-b from-transparent via-black/40 to-black\" data-kid=\"7\"></div>\n        </div>\n\n        \n        <div class=\"absolute inset-0 z-10 bg-[radial-gradient(circle_at_50%_0%,rgba(255,255,255,0.08),transparent_60%)]\" data-kid=\"8\"></div>\n\n        \n        <div class=\"absolute inset-0 z-20 flex items-center justify-end pr-24 pointer-events-none\" data-kid=\"9\">\n            <div id=\"hero-ball\" class=\"relative w-[300px] md:w-[700px] aspect-square translate-y-24 rotate-12\" data-kid=\"10\">\n                <img src=\"https://images.pexels.com/photos/37043030/pexels-photo-37043030.jpeg?auto=compress&cs=tinysrgb&w=1200&q=80\" class=\"w-full h-full object-contain\" alt=\"Metallic Cricket Ball\" decoding=\"async\" loading=\"lazy\" data-kid=\"11\">\n                \n                <div class=\"absolute -bottom-10 left-1/2 -translate-x-1/2 w-4/5 h-20 bg-black/80 blur-3xl rounded-full\" data-kid=\"12\"></div>\n            </div>\n        </div>\n\n        \n        <div class=\"relative z-30 p-10 md:p-32 max-w-7xl w-full\" data-kid=\"13\">\n            <div id=\"hero-text\" class=\"mb-16 drop-shadow-[0_10px_30px_rgba(0,0,0,0.5)]\" data-kid=\"14\">\n                <div class=\"flex items-center gap-4 mb-6\" data-kid=\"15\">\n                    <span class=\"w-12 h-[2px] bg-[var(--color-neon-green)]\" data-kid=\"16\"></span>\n                    <span class=\"text-[var(--color-neon-green)] font-bold tracking-[0.4em] text-xs uppercase\" data-kid=\"17\">Version 1.0 // Midnight Turf</span>\n                </div>\n                <h1 class=\"text-[clamp(4.5rem,14vw,15rem)] italic leading-[0.8] text-white\" data-kid=\"18\">\n                    THE ARENA<br data-kid=\"19\">IS ALIVE.\n                </h1>\n                <p class=\"text-white/40 text-lg md:text-xl font-medium tracking-tight mt-10 max-w-lg font-mono leading-relaxed\" data-kid=\"20\">\n                    SCORING WILL NEVER BE THE SAME.<br data-kid=\"21\">\n                    <span class=\"text-white/80\" data-kid=\"22\">POWERED BY AI PRECISION.</span>\n                </p>\n            </div>\n\n            <div class=\"flex flex-col md:flex-row items-start md:items-center gap-12\" data-kid=\"23\">\n                <button id=\"cta-main\" class=\"group relative px-12 py-6 bg-[var(--color-neon-green)] text-black font-anton text-xl tracking-widest rounded-none overflow-hidden hover:pr-16 transition-all duration-300\" data-kid=\"24\">\n                    <span class=\"relative z-10\" data-kid=\"25\">LAUNCH SCOREKEEPER</span>\n                    <i class=\"ti ti-arrow-right absolute right-6 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-all duration-300\" data-kid=\"26\"></i>\n                </button>\n\n                <div class=\"flex items-center gap-6 group cursor-pointer\" data-kid=\"27\">\n                    <div id=\"toss-coin\" class=\"w-16 h-16 rounded-full glass border border-white/20 flex items-center justify-center group-hover:border-[var(--color-boundary-red)] group-hover:shadow-[0_0_20px_var(--color-boundary-red)] transition-all duration-500\" data-kid=\"28\">\n                        <span class=\"text-yellow-500 font-bold text-2xl\" data-kid=\"29\">¢</span>\n                    </div>\n                    <div class=\"space-y-1\" data-kid=\"30\">\n                        <span class=\"block text-[10px] font-bold tracking-[0.3em] text-white/30 uppercase\" data-kid=\"31\">Ready For Play</span>\n                        <span class=\"block text-xs font-bold tracking-[0.2em] text-white/70 uppercase\" data-kid=\"32\">Toss Coin</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"dashboard\" class=\"relative min-h-screen py-32 bg-[var(--color-slate)] overflow-hidden\" data-kid=\"33\">\n        <div class=\"max-w-7xl mx-auto px-10 md:px-24\" data-kid=\"34\">\n            <div class=\"grid grid-cols-12 gap-16 items-center\" data-kid=\"35\">\n                \n                <div class=\"col-span-12 lg:col-span-5\" data-kid=\"36\">\n                    <div id=\"dash-info\" data-kid=\"37\">\n                        <div class=\"w-20 h-1 bg-[var(--color-neon-green)] mb-10\" data-kid=\"38\"></div>\n                        <h2 class=\"text-6xl md:text-8xl mb-8\" data-kid=\"39\">LIVE ENGINE</h2>\n                        <p class=\"text-white/50 text-xl leading-relaxed mb-12\" data-kid=\"40\">\n                            A glassmorphic command center that updates at the speed of light. Tracking every swing, every impact, every run.\n                        </p>\n                        \n                        <div class=\"grid grid-cols-2 gap-6\" data-kid=\"41\">\n                            <div class=\"glass p-8 rounded-none border-l-4 border-[var(--color-neon-green)]\" data-kid=\"42\">\n                                <div class=\"text-4xl font-anton text-white mb-2 stat\" data-target=\"148\" data-kid=\"43\">0</div>\n                                <div class=\"text-[10px] text-white/40 uppercase tracking-widest\" data-kid=\"44\">Bat Speed (KM/H)</div>\n                            </div>\n                            <div class=\"glass p-8 rounded-none border-l-4 border-[var(--color-boundary-red)]\" data-kid=\"45\">\n                                <div class=\"text-4xl font-anton text-white mb-2\" data-kid=\"46\">SIX!</div>\n                                <div class=\"text-[10px] text-white/40 uppercase tracking-widest\" data-kid=\"47\">Impact Alert</div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"col-span-12 lg:col-span-7 relative perspective-1000\" data-kid=\"48\">\n                    \n                    <div id=\"cricket-bat\" class=\"absolute -right-24 -top-20 w-96 h-auto z-40 opacity-95 pointer-events-none rotate-[15deg]\" data-kid=\"49\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/cricket-bat.svg\" class=\"w-full h-full\" style=\"filter: invert(1) drop-shadow(0 20px 40px rgba(0,0,0,0.9)) drop-shadow(0 0 30px rgba(16, 185, 129, 0.2));\" alt=\"3D Cricket Bat\" data-kid=\"50\">\n                    </div>\n\n                    <div id=\"live-dashboard\" class=\"relative z-30 glass p-10 md:p-14 rounded-[40px] border border-white/10 [transform:perspective(2000px)_rotateY(-15deg)_rotateX(5deg)] shadow-[0_50px_100px_rgba(0,0,0,0.8)] -ml-20\" data-kid=\"51\">\n                        \n                        <div class=\"flex justify-between items-start mb-16\" data-kid=\"52\">\n                            <div data-kid=\"53\">\n                                <div class=\"flex items-center gap-3 mb-2\" data-kid=\"54\">\n                                    <div class=\"w-2 h-2 bg-red-600 rounded-full animate-pulse\" data-kid=\"55\"></div>\n                                    <span class=\"text-[10px] uppercase font-bold tracking-widest text-white/40\" data-kid=\"56\">Live Final</span>\n                                </div>\n                                <h3 class=\"text-3xl\" data-kid=\"57\">SYDNEY THUNDER vs SCO</h3>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"58\">\n                                <div class=\"text-xs text-white/30 uppercase mb-1\" data-kid=\"59\">Overs</div>\n                                <div class=\"text-2xl font-bold\" data-kid=\"60\">18.4</div>\n                            </div>\n                        </div>\n\n                        <div class=\"flex items-center gap-10 mb-16\" data-kid=\"61\">\n                            <div data-kid=\"62\">\n                                <div class=\"text-xs text-white/30 uppercase mb-2\" data-kid=\"63\">Current Score</div>\n                                <div class=\"text-8xl font-bold tracking-tighter\" data-kid=\"64\">214<span class=\"text-white/20\" data-kid=\"65\">/</span>3</div>\n                            </div>\n                            <div class=\"flex-1\" data-kid=\"66\">\n                                <div class=\"h-2 w-full bg-white/5 rounded-full overflow-hidden mb-2\" data-kid=\"67\">\n                                    <div class=\"h-full bg-[var(--color-neon-green)] w-[82%]\" data-kid=\"68\"></div>\n                                </div>\n                                <div class=\"flex justify-between text-[10px] font-bold uppercase tracking-widest text-white/40\" data-kid=\"69\">\n                                    <span data-kid=\"70\">Win Prob</span>\n                                    <span data-kid=\"71\">82%</span>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"flex gap-4\" data-kid=\"72\">\n                            <div class=\"w-12 h-12 rounded-full glass flex items-center justify-center font-bold\" data-kid=\"73\">4</div>\n                            <div class=\"w-12 h-12 rounded-full glass flex items-center justify-center font-bold\" data-kid=\"74\">1</div>\n                            <div class=\"w-12 h-12 rounded-full glass border-[var(--color-boundary-red)] text-[var(--color-boundary-red)] flex items-center justify-center font-bold\" data-kid=\"75\">6</div>\n                            <div class=\"w-12 h-12 rounded-full bg-white text-black flex items-center justify-center font-bold\" data-kid=\"76\">W</div>\n                            <div class=\"w-12 h-12 rounded-full glass flex items-center justify-center font-bold\" data-kid=\"77\">0</div>\n                            <div class=\"w-12 h-12 rounded-full glass flex items-center justify-center font-bold\" data-kid=\"78\">1</div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"soundscape\" class=\"relative py-48 bg-black overflow-hidden\" data-kid=\"79\">\n        <div class=\"absolute inset-0 z-0 opacity-10\" data-kid=\"80\">\n            <img src=\"https://images.pexels.com/photos/34140996/pexels-photo-34140996.jpeg?auto=compress&cs=tinysrgb&w=1200&q=80\" class=\"w-full h-full object-cover\" alt=\"Background\" decoding=\"async\" loading=\"lazy\" data-kid=\"81\">\n        </div>\n        \n        <div class=\"relative z-10 max-w-7xl mx-auto px-10\" data-kid=\"82\">\n            <div class=\"flex flex-col md:flex-row justify-between items-end mb-32 gap-12\" data-kid=\"83\">\n                <div class=\"text-left\" data-kid=\"84\">\n                    <span class=\"text-[var(--color-boundary-red)] font-bold tracking-[0.5em] text-xs uppercase block mb-4\" data-kid=\"85\">AI Voice Engine // V3.0</span>\n                    <h2 class=\"text-7xl md:text-9xl italic\" data-kid=\"86\">THE SOUNDSCAPE</h2>\n                </div>\n                <p class=\"text-white/40 max-w-md text-right md:text-left text-lg font-mono\" data-kid=\"87\">\n                    IMMERSIVE AUDIO RECONSTRUCTION. EXPERIENCE EVERY IMPACT IN ULTRA-FIDELITY.\n                </p>\n            </div>\n\n            <div class=\"flex flex-col md:flex-row justify-center items-center gap-12 md:gap-32 mb-40\" data-kid=\"88\">\n                \n                <div class=\"relative group cursor-pointer w-48 h-80\" data-kid=\"89\">\n                    <img src=\"https://images.unsplash.com/photo-1759733841123-b8e1d75ee45c?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-contain filter grayscale group-hover:grayscale-0 transition-all duration-700\" alt=\"Wickets\" decoding=\"async\" loading=\"lazy\" data-kid=\"90\">\n                    <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-neon-green)]/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-3xl\" data-kid=\"91\"></div>\n                    <div class=\"absolute -inset-4 border border-[var(--color-neon-green)]/0 group-hover:border-[var(--color-neon-green)]/40 transition-all duration-700 rounded-3xl scale-95 group-hover:scale-105\" data-kid=\"92\"></div>\n                </div>\n\n                \n                <div id=\"ai-mic\" class=\"relative w-56 h-56 rounded-full glass flex items-center justify-center group cursor-pointer border-2 border-white/5 hover:border-[var(--color-neon-green)]/50 transition-all duration-500 shadow-[0_0_50px_rgba(16,185,129,0.1)]\" data-kid=\"93\">\n                    <div class=\"absolute inset-0 rounded-full border border-[var(--color-neon-green)]/20 animate-ping\" style=\"animation-duration: 3s;\" data-kid=\"94\"></div>\n                    <div class=\"absolute inset-[-10px] rounded-full border border-[var(--color-neon-green)]/10 animate-ping\" style=\"animation-duration: 5s;\" data-kid=\"95\"></div>\n                    <i class=\"ti ti-microphone-2 text-7xl text-[var(--color-neon-green)] drop-shadow-[0_0_15px_rgba(16,185,129,0.5)]\" data-kid=\"96\"></i>\n                </div>\n\n                \n                <div class=\"relative group cursor-pointer w-48 h-80\" data-kid=\"97\">\n                    <img src=\"https://images.unsplash.com/photo-1759733841123-b8e1d75ee45c?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-contain filter grayscale group-hover:grayscale-0 transition-all duration-700 rotate-y-180\" alt=\"Wickets\" decoding=\"async\" loading=\"lazy\" data-kid=\"98\">\n                    <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-boundary-red)]/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-3xl\" data-kid=\"99\"></div>\n                    <div class=\"absolute -inset-4 border border-[var(--color-boundary-red)]/0 group-hover:border-[var(--color-boundary-red)]/40 transition-all duration-700 rounded-3xl scale-95 group-hover:scale-105\" data-kid=\"100\"></div>\n                </div>\n            </div>\n\n            \n            <div class=\"flex flex-col md:flex-row gap-8\" data-kid=\"101\">\n                <div class=\"flex-[1.5] glass p-12 group hover:border-[var(--color-neon-green)]/50 transition-all cursor-pointer relative overflow-hidden\" data-kid=\"102\">\n                    <div class=\"absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity\" data-kid=\"103\">\n                        <i class=\"ti ti-waveform text-8xl\" data-kid=\"104\"></i>\n                    </div>\n                    <div class=\"text-[10px] text-white/30 mb-8 font-mono tracking-[0.4em] uppercase\" data-kid=\"105\">Pack // 01 // Broadcast High</div>\n                    <h4 class=\"text-4xl mb-6\" data-kid=\"106\">RAVI SHASTRI MODE</h4>\n                    <p class=\"text-white/50 text-lg leading-relaxed max-w-md\" data-kid=\"107\">The legendary voice of cricket. High-octane, stadium-shaking reactions to every boundary and wicket.</p>\n                </div>\n                <div class=\"flex-1 space-y-8\" data-kid=\"108\">\n                    <div class=\"glass p-10 group hover:border-[var(--color-boundary-red)]/50 transition-all cursor-pointer bg-white/[0.02]\" data-kid=\"109\">\n                        <h4 class=\"text-2xl mb-4\" data-kid=\"110\">DARK ANALYST</h4>\n                        <p class=\"text-sm text-white/40 font-mono\" data-kid=\"111\">Precision metrics meeting technical insight. AI-driven depth for every delivery.</p>\n                    </div>\n                    <div class=\"glass p-10 group hover:border-white/30 transition-all cursor-pointer\" data-kid=\"112\">\n                        <h4 class=\"text-2xl mb-4\" data-kid=\"113\">GLOBAL FEED</h4>\n                        <p class=\"text-sm text-white/40 font-mono\" data-kid=\"114\">Professional, neutral, and clear. The standard for international turf coverage.</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"cards\" class=\"relative py-32 bg-[var(--color-slate)] overflow-hidden\" data-kid=\"115\">\n        <div class=\"max-w-7xl mx-auto px-10\" data-kid=\"116\">\n            <div class=\"text-center mb-24\" data-kid=\"117\">\n                <h2 class=\"text-7xl italic mb-6\" data-kid=\"118\">THE ROSTER</h2>\n                <p class=\"text-white/40 max-w-xl mx-auto\" data-kid=\"119\">Interactive holographic trading cards for every performance. Drag to explore, flip for data.</p>\n            </div>\n\n            \n            <div id=\"cards-deck\" class=\"relative h-[600px] flex items-center justify-center perspective-1000\" data-kid=\"120\">\n                \n                <div class=\"player-card absolute w-[300px] h-[420px] holographic-card rounded-3xl glass p-8 cursor-pointer -rotate-[15deg] -translate-x-32 z-10 hover:z-50\" data-tilt data-kid=\"121\">\n                    <div class=\"h-56 bg-white/5 rounded-2xl mb-8 relative overflow-hidden\" data-kid=\"122\">\n                        <img src=\"https://images.unsplash.com/photo-1750716413341-fd5d93296a76?auto=format&w=400&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale opacity-60 hover:opacity-100 transition-opacity\" decoding=\"async\" loading=\"lazy\" data-kid=\"123\">\n                        <div class=\"absolute bottom-4 left-4 px-3 py-1 glass text-[10px] font-bold tracking-widest rounded-full uppercase\" data-kid=\"124\">Pacer</div>\n                    </div>\n                    <h4 class=\"text-3xl mb-1\" data-kid=\"125\">M. STARC</h4>\n                    <div class=\"text-[10px] text-white/30 tracking-[0.4em] uppercase mb-8\" data-kid=\"126\">Australia // Elite</div>\n                    <div class=\"flex justify-between items-end border-t border-white/5 pt-6\" data-kid=\"127\">\n                        <div class=\"text-5xl font-anton text-[var(--color-neon-green)]\" data-kid=\"128\">94</div>\n                        <div class=\"text-[10px] text-right text-white/40 uppercase font-mono\" data-kid=\"129\">Pwr Index</div>\n                    </div>\n                </div>\n\n                \n                <div class=\"player-card absolute w-[320px] h-[450px] holographic-card rounded-3xl glass p-8 cursor-pointer z-30 shadow-[0_40px_80px_rgba(0,0,0,0.8)] scale-105 border-white/20 hover:z-50\" data-tilt data-kid=\"130\">\n                    <div class=\"h-60 bg-white/5 rounded-2xl mb-8 relative overflow-hidden\" data-kid=\"131\">\n                        <img src=\"https://images.unsplash.com/photo-1750716413444-c8a957fcf35c?auto=format&w=400&q=80&fit=crop\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"132\">\n                        <div class=\"absolute bottom-4 left-4 px-4 py-2 glass text-[10px] font-bold bg-[var(--color-neon-green)] text-black rounded-full uppercase tracking-widest\" data-kid=\"133\">Captain</div>\n                    </div>\n                    <h4 class=\"text-4xl mb-1\" data-kid=\"134\">VIRAT K.</h4>\n                    <div class=\"text-[10px] text-white/40 tracking-[0.4em] uppercase mb-8 font-bold\" data-kid=\"135\">India // Legend</div>\n                    <div class=\"flex justify-between items-end border-t border-white/10 pt-6\" data-kid=\"136\">\n                        <div class=\"text-6xl font-anton text-white\" data-kid=\"137\">99</div>\n                        <div class=\"text-[10px] text-right text-white/40 uppercase font-mono\" data-kid=\"138\">Elite Score</div>\n                    </div>\n                </div>\n\n                \n                <div class=\"player-card absolute w-[300px] h-[420px] holographic-card rounded-3xl glass p-8 cursor-pointer rotate-[15deg] translate-x-32 z-10 hover:z-50\" data-tilt data-kid=\"139\">\n                    <div class=\"h-56 bg-white/5 rounded-2xl mb-8 relative overflow-hidden\" data-kid=\"140\">\n                        <img src=\"https://images.unsplash.com/photo-1750716413756-b66624b64ce4?auto=format&w=400&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale opacity-60 hover:opacity-100 transition-opacity\" decoding=\"async\" loading=\"lazy\" data-kid=\"141\">\n                        <div class=\"absolute bottom-4 left-4 px-3 py-1 glass text-[10px] font-bold tracking-widest rounded-full uppercase\" data-kid=\"142\">All-Rounder</div>\n                    </div>\n                    <h4 class=\"text-3xl mb-1\" data-kid=\"143\">R. JADEJA</h4>\n                    <div class=\"text-[10px] text-white/30 tracking-[0.4em] uppercase mb-8\" data-kid=\"144\">India // Elite</div>\n                    <div class=\"flex justify-between items-end border-t border-white/5 pt-6\" data-kid=\"145\">\n                        <div class=\"text-5xl font-anton text-[var(--color-neon-green)]\" data-kid=\"146\">92</div>\n                        <div class=\"text-[10px] text-right text-white/40 uppercase font-mono\" data-kid=\"147\">Skill Pwr</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"exporter\" class=\"relative py-32 bg-black overflow-hidden\" data-kid=\"148\">\n        <div class=\"max-w-7xl mx-auto px-10\" data-kid=\"149\">\n            <div class=\"grid grid-cols-12 gap-16 items-center\" data-kid=\"150\">\n                <div class=\"col-span-12 lg:col-span-6\" data-kid=\"151\">\n                    <h2 class=\"text-6xl md:text-8xl mb-8\" data-kid=\"152\">POSTER GENERATOR</h2>\n                    <p class=\"text-white/50 text-xl mb-12\" data-kid=\"153\">Export your match highlights in cinematic high-definition posters. One click to share your glory.</p>\n                    \n                    <div class=\"space-y-4\" data-kid=\"154\">\n                        <div class=\"glass p-6 flex items-center justify-between group cursor-pointer hover:bg-white/10 transition-colors\" data-kid=\"155\">\n                            <div class=\"flex items-center gap-6\" data-kid=\"156\">\n                                <i class=\"ti ti-grip-vertical text-white/20\" data-kid=\"157\"></i>\n                                <span class=\"font-bold tracking-widest uppercase\" data-kid=\"158\">Match Summary Poster</span>\n                            </div>\n                            <span class=\"text-[var(--color-neon-green)] font-mono text-xs\" data-kid=\"159\">4K READY</span>\n                        </div>\n                        <div class=\"glass p-6 flex items-center justify-between group cursor-pointer hover:bg-white/10 transition-colors\" data-kid=\"160\">\n                            <div class=\"flex items-center gap-6\" data-kid=\"161\">\n                                <i class=\"ti ti-grip-vertical text-white/20\" data-kid=\"162\"></i>\n                                <span class=\"font-bold tracking-widest uppercase\" data-kid=\"163\">Player MVP Card</span>\n                            </div>\n                            <span class=\"text-[var(--color-neon-green)] font-mono text-xs\" data-kid=\"164\">ULTRA HD</span>\n                        </div>\n                    </div>\n\n                    <button class=\"mt-12 w-full py-6 bg-white text-black font-anton text-2xl tracking-widest hover:bg-[var(--color-neon-green)] transition-all\" data-kid=\"165\">\n                        GENERATE SQUAD POSTER\n                    </button>\n                </div>\n\n                <div class=\"col-span-12 lg:col-span-6 flex justify-center\" data-kid=\"166\">\n                    <div class=\"relative w-full aspect-[3/4] max-w-md glass rounded-3xl overflow-hidden shadow-[0_0_100px_rgba(16,185,129,0.15)] border border-white/10\" data-kid=\"167\">\n                        \n                        <div class=\"absolute inset-0 z-10 pointer-events-none bg-[linear-gradient(rgba(16,185,129,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(16,185,129,0.05)_1px,transparent_1px)] bg-[size:40px_40px]\" data-kid=\"168\"></div>\n                        <div class=\"absolute top-0 left-0 w-full h-[2px] bg-[var(--color-neon-green)] z-20 shadow-[0_0_15px_var(--color-neon-green)] animate-[scan_4s_infinite_linear]\" data-kid=\"169\"></div>\n                        \n                        <video src=\"https://videos.pexels.com/video-files/36570934/15505105_360_640_59fps.mp4\" poster=\"https://images.pexels.com/videos/36570934/pexels-photo-36570934.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1200&w=630\" autoplay muted loop playsinline class=\"w-full h-full object-cover opacity-80\" data-kid=\"170\">\n                        </video>\n                        <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/20\" data-kid=\"171\"></div>\n                        <div class=\"absolute bottom-10 left-10\" data-kid=\"172\">\n                            <h4 class=\"text-4xl text-white\" data-kid=\"173\">READY TO PRINT</h4>\n                            <div class=\"flex items-center gap-2 mt-2\" data-kid=\"174\">\n                                <div class=\"w-3 h-3 rounded-full bg-[var(--color-neon-green)]\" data-kid=\"175\"></div>\n                                <span class=\"text-xs font-mono uppercase text-white/60\" data-kid=\"176\">System Online</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"py-20 bg-[var(--color-slate)] border-t border-white/5\" data-kid=\"177\">\n        <div class=\"max-w-7xl mx-auto px-10 flex flex-col md:flex-row justify-between items-center gap-10\" data-kid=\"178\">\n            <div data-kid=\"179\">\n                <h3 class=\"text-4xl mb-2\" data-kid=\"180\">TURF SCORE PRO</h3>\n                <p class=\"text-white/20 text-xs font-mono uppercase tracking-[0.3em]\" data-kid=\"181\">The future of local cricket analytics</p>\n            </div>\n            \n            <div class=\"flex gap-12 text-sm font-bold tracking-[0.2em] uppercase text-white/40\" data-kid=\"182\">\n                <a href=\"#\" class=\"hover:text-[var(--color-neon-green)] transition-colors\" data-kid=\"183\">Privacy</a>\n                <a href=\"#\" class=\"hover:text-[var(--color-neon-green)] transition-colors\" data-kid=\"184\">Terms</a>\n                <a href=\"#\" class=\"hover:text-[var(--color-neon-green)] transition-colors\" data-kid=\"185\">Contact</a>\n            </div>\n\n            <div class=\"flex gap-6\" data-kid=\"186\">\n                <div class=\"w-12 h-12 rounded-full glass flex items-center justify-center cursor-pointer hover:bg-[var(--color-neon-green)] hover:text-black transition-all duration-300\" data-kid=\"187\">\n                    <i class=\"ti ti-brand-x text-xl\" data-kid=\"188\"></i>\n                </div>\n                <div class=\"w-12 h-12 rounded-full glass flex items-center justify-center cursor-pointer hover:bg-[var(--color-neon-green)] hover:text-black transition-all duration-300\" data-kid=\"189\">\n                    <i class=\"ti ti-brand-discord text-xl\" data-kid=\"190\"></i>\n                </div>\n            </div>\n        </div>\n    </footer>\n</main>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"191\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"192\"></script>\n<script type=\"module\" data-kid=\"193\">\nimport Lenis from \"https://esm.sh/lenis@1\"\nimport { animate, scroll, inView } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\ngsap.registerPlugin(ScrollTrigger);\n\n// Initialize Lenis\nconst lenis = new Lenis({\n  autoRaf: true,\n  lerp: 0.1\n});\n\n// Custom Cursor\nconst cursor = document.getElementById('custom-cursor');\ndocument.addEventListener('mousemove', (e) => {\n    gsap.to(cursor, {\n        x: e.clientX - 10,\n        y: e.clientY - 10,\n        duration: 0.2,\n        ease: \"power2.out\"\n    });\n});\n\n// Hover cursor effects\ndocument.querySelectorAll('button, a, .group').forEach(el => {\n    el.addEventListener('mouseenter', () => {\n        gsap.to(cursor, { scale: 2.5, backgroundColor: \"rgba(16, 185, 129, 0.2)\", backdropFilter: \"blur(2px)\", border: \"1px solid var(--color-neon-green)\" });\n    });\n    el.addEventListener('mouseleave', () => {\n        gsap.to(cursor, { scale: 1, backgroundColor: \"var(--color-neon-green)\", backdropFilter: \"none\", border: \"none\" });\n    });\n});\n\n// Hero Animations\ngsap.from(\"#hero-text h1\", {\n    opacity: 0,\n    y: 100,\n    duration: 1.5,\n    ease: \"power4.out\",\n    delay: 0.5\n});\n\ngsap.from(\"#hero-ball\", {\n    scale: 0.5,\n    opacity: 0,\n    duration: 2,\n    ease: \"expo.out\",\n    delay: 0.2\n});\n\n// Parallax Ball on Scroll\ngsap.to(\"#hero-ball\", {\n    y: 200,\n    scale: 1.2,\n    scrollTrigger: {\n        trigger: \"#hero\",\n        start: \"top top\",\n        end: \"bottom top\",\n        scrub: true\n    }\n});\n\n// Dashboard Animations\ngsap.from(\"#live-dashboard\", {\n    rotateY: 0,\n    rotateX: 0,\n    opacity: 0,\n    x: 100,\n    scrollTrigger: {\n        trigger: \"#dashboard\",\n        start: \"top center\",\n        end: \"center center\",\n        scrub: 1\n    }\n});\n\n// Bat Swing Animation\ngsap.to(\"#cricket-bat\", {\n    rotate: -45,\n    x: 100,\n    y: 50,\n    scrollTrigger: {\n        trigger: \"#dashboard\",\n        start: \"top center\",\n        end: \"bottom center\",\n        scrub: 1\n    }\n});\n\n// Count Up stats\ninView(\".stat\", el => {\n    const target = parseInt(el.dataset.target);\n    animate(0, target, {\n        duration: 2,\n        onUpdate: v => el.textContent = Math.round(v)\n    });\n});\n\n// Wicket Vibrations on hover micro-interactions\nconst mic = document.getElementById('ai-mic');\nmic.addEventListener('pointerenter', () => {\n    animate(mic, { scale: [1, 1.1, 0.9, 1.05, 1], duration: 500 });\n});\n\n// Card Hover Tilt (Simplified Vanilla implementation for performance)\ndocument.querySelectorAll('.player-card').forEach(card => {\n    card.addEventListener('mousemove', e => {\n        const rect = card.getBoundingClientRect();\n        const x = e.clientX - rect.left;\n        const y = e.clientY - rect.top;\n        const xc = rect.width / 2;\n        const yc = rect.height / 2;\n        const dx = (x - xc) / xc;\n        const dy = (y - yc) / yc;\n        \n        gsap.to(card, {\n            rotateY: dx * 10,\n            rotateX: -dy * 10,\n            duration: 0.5,\n            ease: \"power2.out\"\n        });\n    });\n    \n    card.addEventListener('mouseleave', () => {\n        gsap.to(card, {\n            rotateY: 0,\n            rotateX: 0,\n            duration: 0.5,\n            ease: \"power2.out\"\n        });\n    });\n});\n</script>\n",
