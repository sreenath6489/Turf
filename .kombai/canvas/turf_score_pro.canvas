ta-scroll-speed=\"0.5\" data-kid=\"144\">\n        <div class=\"bg-[var(--color-green)] text-[var(--color-black)] p-4 text-xl font-black uppercase flex justify-between items-center border-4 border-black\" data-kid=\"145\">\n            <span data-kid=\"146\">tsp_v2_deployment_core.exe</span>\n            <div class=\"flex gap-3\" data-kid=\"147\">\n                <div class=\"w-5 h-5 border-4 border-black\" data-kid=\"148\"></div>\n                <div class=\"w-5 h-5 border-4 border-black bg-black\" data-kid=\"149\"></div>\n            </div>\n        </div>\n        <div class=\"bg-[var(--color-black)] border-4 border-t-0 border-[var(--color-green)] p-12 font-mono text-[var(--color-green)] text-xl leading-relaxed shadow-[15px_15px_0_var(--color-magenta)] relative overflow-hidden\" data-kid=\"150\">\n            <div class=\"absolute inset-0 pointer-events-none bg-[repeating-linear-gradient(transparent,transparent_2px,rgba(0,0,0,0.1)_2px,rgba(0,0,0,0.1)_4px)] opacity-50 z-20\" data-kid=\"151\"></div>\n            <div id=\"terminal-log\" class=\"space-y-3 mb-12 h-80 overflow-hidden font-black uppercase\" data-kid=\"152\">\n                \n            </div>\n            <div class=\"flex items-center gap-6 border-t-2 border-[var(--color-green)] pt-8\" data-kid=\"153\">\n                <span class=\"text-[var(--color-magenta)] font-black\" data-kid=\"154\">root@arena:~$</span>\n                <span id=\"terminal-input\" class=\"font-black\" data-kid=\"155\"></span>\n                <span class=\"terminal-cursor\" data-kid=\"156\"></span>\n            </div>\n            \n            <div class=\"mt-16\" data-kid=\"157\">\n                <div class=\"relative group inline-block\" data-kid=\"158\">\n                    <div class=\"absolute inset-0 bg-white translate-x-2 translate-y-2\" data-kid=\"159\"></div>\n                    <button id=\"deploy-btn\" class=\"relative bg-[var(--color-magenta)] text-white px-12 py-6 text-3xl font-black uppercase border-4 border-black cursor-pointer\" data-kid=\"160\">\n                        Export Squad Poster\n                    </button>\n                </div>\n            </div>\n        </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-[var(--color-green)] text-[var(--color-black)] py-32 px-10 relative z-20 border-t-8 border-black\" data-kid=\"161\">\n    <div class=\"max-w-[1440px] mx-auto flex flex-col lg:flex-row justify-between items-end gap-24\" data-kid=\"162\">\n        <div class=\"text-[clamp(6rem,15vw,12rem)] font-black uppercase tracking-tighter leading-[0.75] text-left border-l-[20px] border-black pl-12\" data-kid=\"163\">\n            ARENA<br data-kid=\"164\">IS<br data-kid=\"165\">ALIVE\n        </div>\n        <div class=\"flex flex-col items-end gap-8 uppercase font-black text-right w-full lg:w-auto\" data-kid=\"166\">\n            <a href=\"#\" class=\"text-6xl hover:bg-black hover:text-[var(--color-green)] px-4 transition-all\" data-kid=\"167\">TOSS_COIN</a>\n            <a href=\"#\" class=\"text-6xl hover:bg-black hover:text-[var(--color-green)] px-4 transition-all\" data-kid=\"168\">DOCS_V2</a>\n            <a href=\"#\" class=\"text-6xl hover:bg-black hover:text-[var(--color-green)] px-4 transition-all\" data-kid=\"169\">CONTACT</a>\n            <div class=\"mt-16 text-lg font-black tracking-widest border-t-4 border-black pt-4\" data-kid=\"170\">\n                © 2024 TURF SCORE PRO // VARIANT 02 // ARCADE PITCH\n            </div>\n        </div>\n    </div>\n  </footer>\n\n</main>\n\n  <script src=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.min.js\" data-kid=\"171\"></script>\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css\" data-kid=\"172\">\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"173\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"174\"></script>\n  <script type=\"module\" data-kid=\"175\">\n    // GSAP Plugins\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Locomotive Scroll v5\n    const locomotiveScroll = new LocomotiveScroll({\n        lenisOptions: {\n            duration: 1.2,\n            lerp: 0.1,\n            smoothWheel: true,\n        }\n    });\n\n  // Custom Cursor\n  const cursor = document.getElementById('custom-cursor');\n  window.addEventListener('mousemove', (e) => {\n    gsap.to(cursor, {\n        x: e.clientX,\n        y: e.clientY,\n        duration: 0.1,\n        ease: 'power2.out'\n    });\n  });\n\n  // Equalizer Animation\n  const eq = document.getElementById('equalizer');\n  const barCount = 110;\n  const bars = [];\n  for(let i=0; i<barCount; i++) {\n    const bar = document.createElement('div');\n    bar.className = 'w-2 bg-[var(--color-green)] neon-glow-green flex-grow';\n    bar.style.height = '20px';\n    eq.appendChild(bar);\n    bars.push(bar);\n  }\n\n  function animateBars() {\n    bars.forEach((bar, index) => {\n        gsap.to(bar, {\n            height: Math.random() * 250 + 20,\n            duration: Math.random() * 0.4 + 0.2,\n            ease: 'sine.inOut',\n            repeat: -1,\n            yoyo: true,\n            delay: index * 0.01\n        });\n    });\n  }\n\n  ScrollTrigger.create({\n    trigger: \"#soundscape\",\n    start: \"top center\",\n    onEnter: () => animateBars()\n  });\n\n  // Stat Counters\n  document.querySelectorAll(\".stat-counter\").forEach(counter => {\n      ScrollTrigger.create({\n        trigger: counter,\n        start: \"top bottom\",\n        onEnter: () => {\n            const endValue = parseInt(counter.dataset.target);\n            gsap.to(counter, {\n                innerHTML: endValue,\n                duration: 2.5,\n                snap: { innerHTML: 1 },\n                ease: 'power4.out'\n            });\n        }\n      });\n  });\n\n  // Terminal Logic\n  const terminalLog = document.getElementById('terminal-log');\n  const terminalInput = document.getElementById('terminal-input');\n  const logs = [\n    \"[SYSTEM] BOOTING TURF_SCORE_PRO V2.0...\",\n    \"[SYSTEM] LOADING NEURAL ASSETS...\",\n    \"[SYSTEM] CONNECTING TO STADIUM FEED #04...\",\n    \"[SYSTEM] HANDSHAKE SUCCESSFUL.\",\n    \"[SYSTEM] FETCHING PLAYER DATA...\",\n    \"[LOG] Striker-01: READY\",\n    \"[LOG] Wicket-X: READY\",\n    \"[LOG] The Wall: READY\",\n    \"[SYSTEM] WAITING FOR USER INPUT...\"\n  ];\n\n  let logIndex = 0;\n  function typeLog() {\n    if (logIndex < logs.length) {\n        const div = document.createElement('div');\n        div.textContent = logs[logIndex];\n        terminalLog.appendChild(div);\n        terminalLog.scrollTop = terminalLog.scrollHeight;\n        logIndex++;\n        setTimeout(typeLog, 600);\n    }\n  }\n  \n  const inputCmd = \"tsp-deploy --target='SQUAD_POSTER'\";\n  let charIndex = 0;\n  function typeInput() {\n    if (charIndex < inputCmd.length) {\n        terminalInput.textContent += inputCmd[charIndex];\n        charIndex++;\n        setTimeout(typeInput, 80);\n    }\n  }\n\n  ScrollTrigger.create({\n    trigger: \"#terminal\",\n    start: \"top center\",\n    onEnter: () => {\n        typeLog();\n        setTimeout(typeInput, 5000);\n    }\n  });\n\n  // Physics Button Reaction\n  const deployBtn = document.getElementById('deploy-btn');\n  deployBtn.addEventListener('mousedown', () => {\n    gsap.to(deployBtn, { scale: 0.94, duration: 0.1 });\n  });\n  deployBtn.addEventListener('mouseup', () => {\n    gsap.to(deployBtn, { scale: 1, duration: 0.5, ease: 'elastic.out(1, 0.4)' });\n  });\n\n  // Magnetic Button Effect\n  document.querySelectorAll('button').forEach(btn => {\n    btn.addEventListener('mousemove', (e) => {\n        const { left, top, width, height } = btn.getBoundingClientRect();\n        const x = e.clientX - left - width / 2;\n        const y = e.clientY - top - height / 2;\n        gsap.to(btn, { x: x * 0.2, y: y * 0.2, duration: 0.3 });\n    });\n    btn.addEventListener('mouseleave', () => {\n        gsap.to(btn, { x: 0, y: 0, duration: 0.5, ease: 'power3.out' });\n    });\n  });\n\n  // Glitch Effect Intensity\n  const glitchElements = document.querySelectorAll('.glitch-hover');\n  glitchElements.forEach(el => {\n    el.addEventListener('mouseenter', () => {\n        gsap.to(el, { x: \"+=2\", y: \"-=2\", duration: 0.05, repeat: 10, yoyo: true });\n    });\n  });\n\n</script>\n\n<style data-kid=\"176\">\n  @keyframes grow {\n    from { width: 0%; }\n    to { width: 100%; }\n  }\n  @keyframes scanline {\n    from { top: 0%; }\n    to { top: 100%; }\n  }\n  .vertical-rl {\n    writing-mode: vertical-rl;\n  }\n</style>\n",
