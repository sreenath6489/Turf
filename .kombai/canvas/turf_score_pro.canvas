      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --color-fern: #4CBB17;\n        --color-lace: #FDF5E6;\n        --color-yellow: #FFC40C;\n        --color-blue: #00BFFF;\n        --clay-shadow-raised: 12px 12px 24px rgba(0, 0, 0, 0.08), -12px -12px 24px rgba(255, 255, 255, 1);\n        --clay-shadow-pressed: inset 6px 6px 12px rgba(0, 0, 0, 0.1), inset -6px -6px 12px rgba(255, 255, 255, 0.8);\n    }\n\n    body {\n        margin: 0;\n        font-family: 'Fredoka', sans-serif;\n        background-color: var(--color-lace);\n        color: #2d3436;\n        overflow-x: clip;\n    }\n\n    .clay-card {\n        background: var(--color-lace);\n        box-shadow: var(--clay-shadow-raised);\n        border: 4px solid white;\n        border-radius: 40px;\n    }\n\n    .clay-btn {\n        transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        cursor: pointer;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        user-select: none;\n        position: relative;\n        overflow: hidden;\n    }\n\n    /* Candy colored button styles */\n    .btn-yellow {\n        background: #FFC40C;\n        box-shadow: 0 18px 0 #d9a700, 0 20px 40px rgba(255, 196, 12, 0.4);\n        border: 4px solid rgba(255,255,255,0.4);\n    }\n    .btn-yellow:active {\n        box-shadow: 0 6px 0 #d9a700, 0 8px 15px rgba(255, 196, 12, 0.2);\n        transform: translateY(12px) scale(0.98);\n    }\n\n    .btn-blue {\n        background: #00BFFF;\n        box-shadow: 0 18px 0 #0096c7, 0 20px 40px rgba(0, 191, 255, 0.4);\n        border: 4px solid rgba(255,255,255,0.4);\n    }\n    .btn-blue:active {\n        box-shadow: 0 6px 0 #0096c7, 0 8px 15px rgba(0, 191, 255, 0.2);\n        transform: translateY(12px) scale(0.98);\n    }\n\n    .btn-green {\n        background: #4CBB17;\n        box-shadow: 0 18px 0 #388e3c, 0 20px 40px rgba(76, 187, 23, 0.4);\n        border: 4px solid rgba(255,255,255,0.4);\n    }\n    .btn-green:active {\n        box-shadow: 0 6px 0 #388e3c, 0 8px 15px rgba(76, 187, 23, 0.2);\n        transform: translateY(12px) scale(0.98);\n    }\n\n    .btn-red {\n        background: #ff4757;\n        box-shadow: 0 18px 0 #c0392b, 0 20px 40px rgba(255, 71, 87, 0.4);\n        border: 4px solid rgba(255,255,255,0.4);\n    }\n    .btn-red:active {\n        box-shadow: 0 6px 0 #c0392b, 0 8px 15px rgba(255, 71, 87, 0.2);\n        transform: translateY(12px) scale(0.98);\n    }\n\n    /* Marble styling */\n    .marble {\n        width: 64px;\n        height: 64px;\n        border-radius: 50%;\n        border: 4px solid white;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-weight: 900;\n        color: white;\n        font-size: 1.5rem;\n        box-shadow: inset -6px -6px 12px rgba(0,0,0,0.2), 6px 12px 20px rgba(0,0,0,0.15);\n        position: absolute;\n        text-shadow: 0 2px 0 rgba(0,0,0,0.2);\n    }\n\n    /* Celebration Overlays */\n    .celebration-overlay {\n        position: fixed;\n        inset: 0;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        z-index: 1000;\n        pointer-events: none;\n        opacity: 0;\n        visibility: hidden;\n    }\n\n    .celebration-text {\n        font-size: 15rem;\n        font-weight: 900;\n        color: white;\n        text-shadow: 0 10px 0 #000, 0 20px 0 rgba(0,0,0,0.1);\n        -webkit-text-stroke: 8px black;\n        transform: scale(0.5) rotate(-10deg);\n    }\n\n    .shake-target {\n        transform-origin: center;\n    }\n\n    .particle {\n        position: absolute;\n        width: 12px;\n        height: 12px;\n        pointer-events: none;\n        z-index: 2000;\n    }\n\n    /* Progress bar animation */\n    @keyframes pulse-glow {\n        0%, 100% { opacity: 0.6; }\n        50% { opacity: 1; }\n    }\n    .health-bar-glow {\n        animation: pulse-glow 2s infinite ease-in-out;\n    }\n</style>\n\n<div id=\"main-app\" class=\"shake-target min-h-screen p-8 flex flex-col gap-8 max-w-[1440px] mx-auto\" data-kid=\"1\">\n    \n    <header class=\"flex flex-col gap-4\" data-kid=\"2\">\n        <div class=\"flex justify-between items-center\" data-kid=\"3\">\n            <div class=\"flex items-center gap-4\" data-kid=\"4\">\n                <div class=\"w-16 h-16 clay-card flex items-center justify-center text-3xl\" data-kid=\"5\">🏏</div>\n                <div data-kid=\"6\">\n                    <h1 class=\"text-3xl font-black text-[var(--color-fern)] tracking-tight\" data-kid=\"7\">TURF SCORE PRO</h1>\n                    <p class=\"text-sm font-bold text-gray-500 uppercase tracking-widest\" data-kid=\"8\">Match #42 • Final Over Thriller</p>\n                </div>\n            </div>\n            <div class=\"flex gap-4\" data-kid=\"9\">\n                <div class=\"bg-white px-6 py-2 rounded-2xl flex items-center gap-2 shadow-[0_6px_0_#e2e8f0,0_10px_20px_rgba(0,0,0,0.05)] border-2 border-white\" data-kid=\"10\">\n                    <span class=\"w-3 h-3 rounded-full bg-red-500 animate-pulse shadow-[0_0_8px_red]\" data-kid=\"11\"></span>\n                    <span class=\"font-black text-sm uppercase text-gray-700\" data-kid=\"12\">Live Stream</span>\n                </div>\n                <button class=\"w-12 h-12 bg-white rounded-2xl text-2xl flex items-center justify-center shadow-[0_6px_0_#e2e8f0,0_10px_20px_rgba(0,0,0,0.05)] border-2 border-white hover:translate-y-[2px] active:translate-y-[4px] active:shadow-[0_2px_0_#e2e8f0] transition-all\" data-kid=\"13\">\n                    <i class=\"ti ti-settings\" data-kid=\"14\"></i>\n                </button>\n            </div>\n        </div>\n\n        \n        <div class=\"relative h-28 bg-white/40 rounded-[35px] border-6 border-white overflow-hidden shadow-[inset_0_4px_15px_rgba(0,0,0,0.1)]\" data-kid=\"15\">\n            \n            <div class=\"absolute inset-y-0 left-0 bg-gradient-to-r from-[var(--color-fern)] to-[#a3e635] w-[74%] rounded-r-[35px] transition-all duration-500 ease-out shadow-[10px_0_30px_rgba(76,187,23,0.4)]\" data-kid=\"16\">\n                <div class=\"absolute inset-0 bg-white/20 health-bar-glow\" data-kid=\"17\"></div>\n            </div>\n            \n            <div class=\"relative z-10 h-full flex justify-between items-center px-12\" data-kid=\"18\">\n                <div class=\"flex flex-col\" data-kid=\"19\">\n                    <div class=\"flex items-baseline gap-2\" data-kid=\"20\">\n                        <span id=\"runs\" class=\"text-7xl font-black text-white drop-shadow-[0_6px_0_rgba(0,0,0,0.4)]\" data-kid=\"21\">148</span>\n                        <span class=\"text-4xl font-black text-white drop-shadow-[0_4px_0_rgba(0,0,0,0.3)]\" data-kid=\"22\">/ 4</span>\n                    </div>\n                    <span class=\"text-base font-black text-white uppercase tracking-widest drop-shadow-md\" data-kid=\"23\">Wanderers CC</span>\n                </div>\n\n                <div class=\"text-center\" data-kid=\"24\">\n                    <div class=\"bg-black/40 backdrop-blur-md px-6 py-2 rounded-full border border-white/30 shadow-lg\" data-kid=\"25\">\n                        <span class=\"text-2xl font-black text-white tracking-widest\" data-kid=\"26\">19.2 OVERS</span>\n                    </div>\n                </div>\n\n                <div class=\"flex flex-col items-end\" data-kid=\"27\">\n                    <div class=\"bg-black/40 px-5 py-1.5 rounded-2xl backdrop-blur-md mb-1 shadow-lg border border-white/20\" data-kid=\"28\">\n                        <span class=\"text-4xl font-black text-white drop-shadow-md\" data-kid=\"29\">TARGET: 165</span>\n                    </div>\n                    <span class=\"text-sm font-black text-[#2d3436] bg-[var(--color-yellow)] px-4 py-1 rounded-full uppercase tracking-widest shadow-[0_4px_0_#d9a700]\" data-kid=\"30\">17 runs needed in 4 balls</span>\n                </div>\n            </div>\n        </div>\n    </header>\n\n    \n    <main class=\"grid grid-cols-12 gap-8 flex-1 items-start\" data-kid=\"31\">\n        \n        \n        <div class=\"col-span-8 space-y-8\" data-kid=\"32\">\n            <div class=\"clay-card p-10 bg-white/80\" data-kid=\"33\">\n                <div class=\"flex justify-between items-center mb-10\" data-kid=\"34\">\n                    <h2 class=\"text-2xl font-black text-gray-700 flex items-center gap-3\" data-kid=\"35\">\n                        <i class=\"ti ti-zap text-[var(--color-yellow)] text-3xl\" data-kid=\"36\"></i>\n                        SCORING CONSOLE\n                    </h2>\n                    <div class=\"flex gap-3\" data-kid=\"37\">\n                        <span class=\"px-4 py-2 bg-[var(--color-blue)]/10 text-[var(--color-blue)] font-bold rounded-xl border-2 border-[var(--color-blue)]/20\" data-kid=\"38\">Batter: S. Curran (42*)</span>\n                    </div>\n                </div>\n\n                \n                <div class=\"grid grid-cols-3 gap-8\" data-kid=\"39\">\n                    <div onclick=\"addScore(1)\" class=\"clay-btn btn-yellow h-44 rounded-[45px] text-7xl font-black text-white border-4 border-white/30 drop-shadow-[0_4px_0_rgba(0,0,0,0.3)]\" data-kid=\"40\">1</div>\n                    <div onclick=\"addScore(2)\" class=\"clay-btn btn-yellow h-44 rounded-[45px] text-7xl font-black text-white border-4 border-white/30 drop-shadow-[0_4px_0_rgba(0,0,0,0.3)]\" data-kid=\"41\">2</div>\n                    <div onclick=\"addScore(3)\" class=\"clay-btn btn-yellow h-44 rounded-[45px] text-7xl font-black text-white border-4 border-white/30 drop-shadow-[0_4px_0_rgba(0,0,0,0.3)]\" data-kid=\"42\">3</div>\n                    \n                    \n                    <div onclick=\"addScore(4)\" class=\"clay-btn btn-blue h-44 rounded-[45px] text-9xl font-black text-white border-6 border-white/40 group drop-shadow-[0_5px_0_rgba(0,0,0,0.4)]\" data-kid=\"43\">\n                        <span class=\"group-hover:scale-110 transition-transform\" data-kid=\"44\">4</span>\n                    </div>\n                    <div onclick=\"addScore(6)\" class=\"clay-btn btn-green h-44 rounded-[45px] text-9xl font-black text-white border-6 border-white/40 group drop-shadow-[0_5px_0_rgba(0,0,0,0.4)]\" data-kid=\"45\">\n                        <span class=\"group-hover:scale-110 transition-transform\" data-kid=\"46\">6</span>\n                    </div>\n                    \n                    \n                    <div onclick=\"addScore('W')\" class=\"clay-btn btn-red h-44 rounded-[45px] text-6xl font-black text-white border-4 border-white/30 drop-shadow-[0_4px_0_rgba(0,0,0,0.3)]\" data-kid=\"47\">OUT</div>\n                </div>\n\n                \n                <div class=\"mt-12 grid grid-cols-4 gap-6\" data-kid=\"48\">\n                    <button class=\"h-20 bg-white rounded-3xl text-xl font-black text-gray-600 shadow-[0_8px_0_#e2e8f0,0_10px_20px_rgba(0,0,0,0.05)] border-2 border-white hover:translate-y-[2px] active:translate-y-[6px] active:shadow-[0_2px_0_#e2e8f0] transition-all\" data-kid=\"49\">0 (Dot)</button>\n                    <button class=\"h-20 bg-[var(--color-blue)]/10 rounded-3xl text-xl font-black text-[var(--color-blue)] shadow-[0_8px_0_#bae6fd,0_10px_20px_rgba(0,191,255,0.1)] border-2 border-white hover:translate-y-[2px] active:translate-y-[6px] active:shadow-[0_2px_0_#bae6fd] transition-all\" data-kid=\"50\">Wide</button>\n                    <button class=\"h-20 bg-[var(--color-yellow)]/10 rounded-3xl text-xl font-black text-[var(--color-yellow)] shadow-[0_8px_0_#fef08a,0_10px_20px_rgba(255,196,12,0.1)] border-2 border-white hover:translate-y-[2px] active:translate-y-[6px] active:shadow-[0_2px_0_#fef08a] transition-all\" data-kid=\"51\">No Ball</button>\n                    <button class=\"h-20 bg-gray-100 rounded-3xl text-gray-400 hover:text-red-500 shadow-[0_8px_0_#d1d5db,0_10px_20px_rgba(0,0,0,0.05)] border-2 border-white hover:translate-y-[2px] active:translate-y-[6px] active:shadow-[0_2px_0_#d1d5db] transition-all\" data-kid=\"52\">\n                        <i class=\"ti ti-arrow-back-up text-3xl font-black\" data-kid=\"53\"></i>\n                    </button>\n                </div>\n            </div>\n\n            \n            <div class=\"grid grid-cols-2 gap-8\" data-kid=\"54\">\n                <div class=\"clay-card p-6 flex items-center gap-6\" data-kid=\"55\">\n                    <img src=\"https://i.pravatar.cc/100?u=bat\" class=\"w-16 h-16 rounded-full border-4 border-[var(--color-fern)]\" decoding=\"async\" loading=\"lazy\" data-kid=\"56\">\n                    <div data-kid=\"57\">\n                        <p class=\"text-xs font-black text-gray-400 uppercase\" data-kid=\"58\">On Strike</p>\n                        <h4 class=\"text-xl font-bold\" data-kid=\"59\">Sam Curran</h4>\n                        <p class=\"text-[var(--color-fern)] font-black text-lg\" data-kid=\"60\">48 (22) <span class=\"text-sm text-gray-400 ml-1\" data-kid=\"61\">SR: 218.1</span></p>\n                    </div>\n                </div>\n                <div class=\"clay-card p-6 flex items-center gap-6\" data-kid=\"62\">\n                    <img src=\"https://i.pravatar.cc/100?u=bowl\" class=\"w-16 h-16 rounded-full border-4 border-red-400\" decoding=\"async\" loading=\"lazy\" data-kid=\"63\">\n                    <div data-kid=\"64\">\n                        <p class=\"text-xs font-black text-gray-400 uppercase\" data-kid=\"65\">Bowling</p>\n                        <h4 class=\"text-xl font-bold\" data-kid=\"66\">Rashid Khan</h4>\n                        <p class=\"text-red-500 font-black text-lg\" data-kid=\"67\">3.2 - 0 - 28 - 2</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"col-span-4 clay-card p-8 bg-white min-h-[700px] flex flex-col\" data-kid=\"68\">\n            <h3 class=\"text-2xl font-black text-[var(--color-blue)] mb-8 flex items-center gap-2\" data-kid=\"69\">\n                <i class=\"ti ti-timeline\" data-kid=\"70\"></i> BALL TIMELINE\n            </h3>\n            \n            <div id=\"snake-container\" class=\"relative flex-1 bg-[var(--color-lace)]/50 rounded-[30px] overflow-hidden border-2 border-white/50\" data-kid=\"71\">\n                \n                <svg class=\"absolute inset-0 w-full h-full\" preserveAspectRatio=\"none\" data-kid=\"72\">\n                    \n                    <path d=\"M 180,50 Q 300,50 300,150 T 180,250 T 60,350 T 180,450 T 300,550\" fill=\"none\" stroke=\"#00BFFF\" stroke-width=\"44\" stroke-linecap=\"round\" opacity=\"0.05\" data-kid=\"73\"></path>\n                    <path id=\"snake-path\" d=\"M 180,50 Q 300,50 300,150 T 180,250 T 60,350 T 180,450 T 300,550\" fill=\"none\" stroke=\"#00BFFF\" stroke-width=\"38\" stroke-linecap=\"round\" stroke-dasharray=\"2 100\" opacity=\"0.25\" data-kid=\"74\"></path>\n                </svg>\n\n                \n                <div id=\"marbles-layer\" class=\"relative w-full h-full\" data-kid=\"75\">\n                    \n                    <div class=\"marble btn-green border-4 border-white\" style=\"top: 18px; left: 148px; z-index: 10;\" data-kid=\"76\">6</div>\n                    <div class=\"marble btn-yellow border-4 border-white\" style=\"top: 85px; left: 235px; z-index: 9;\" data-kid=\"77\">1</div>\n                    <div class=\"marble btn-red border-4 border-white\" style=\"top: 175px; left: 240px; z-index: 8;\" data-kid=\"78\">W</div>\n                    <div class=\"marble btn-blue border-4 border-white\" style=\"top: 265px; left: 140px; z-index: 7;\" data-kid=\"79\">4</div>\n                    <div class=\"marble btn-yellow border-4 border-white !opacity-70\" style=\"top: 345px; left: 45px; z-index: 6;\" data-kid=\"80\">2</div>\n                    <div class=\"marble btn-yellow border-4 border-white !opacity-50\" style=\"top: 430px; left: 115px; z-index: 5;\" data-kid=\"81\">1</div>\n                    <div class=\"marble btn-green border-4 border-white !opacity-40\" style=\"top: 485px; left: 235px; z-index: 4;\" data-kid=\"82\">1</div>\n                    <div class=\"marble bg-gray-300 !text-gray-400 !opacity-30 border-4 border-white\" style=\"top: 525px; left: 180px; z-index: 3;\" data-kid=\"83\">.</div>\n                </div>\n            </div>\n\n            <div class=\"mt-8 p-6 bg-[var(--color-lace)] rounded-3xl border-2 border-white text-center\" data-kid=\"84\">\n                <p class=\"text-xs font-black text-gray-400 uppercase tracking-widest mb-1\" data-kid=\"85\">Last Over</p>\n                <div class=\"flex justify-center gap-2\" data-kid=\"86\">\n                    <span class=\"w-8 h-8 rounded-full bg-white flex items-center justify-center font-bold text-xs shadow-sm\" data-kid=\"87\">1</span>\n                    <span class=\"w-8 h-8 rounded-full bg-white flex items-center justify-center font-bold text-xs shadow-sm\" data-kid=\"88\">1</span>\n                    <span class=\"w-8 h-8 rounded-full bg-white flex items-center justify-center font-bold text-xs shadow-sm\" data-kid=\"89\">6</span>\n                    <span class=\"w-8 h-8 rounded-full bg-white flex items-center justify-center font-bold text-xs shadow-sm\" data-kid=\"90\">0</span>\n                    <span class=\"w-8 h-8 rounded-full bg-white flex items-center justify-center font-bold text-xs shadow-sm\" data-kid=\"91\">2</span>\n                    <span class=\"w-8 h-8 rounded-full bg-white flex items-center justify-center font-bold text-xs shadow-sm text-red-500\" data-kid=\"92\">W</span>\n                </div>\n            </div>\n        </div>\n    </main>\n</div>\n\n\n<div id=\"six-celebration\" class=\"celebration-overlay bg-[#4CBB17]/40 backdrop-blur-md\" data-kid=\"93\">\n    <div class=\"celebration-text\" data-kid=\"94\">SIX!</div>\n</div>\n\n<div id=\"four-celebration\" class=\"celebration-overlay bg-[#00BFFF]/40 backdrop-blur-md\" data-kid=\"95\">\n    <div class=\"celebration-text\" data-kid=\"96\">FOUR!</div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"97\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"98\"></script>\n<script type=\"module\" data-kid=\"99\">\n    import { animate, spring } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    // Scoring Functionality\n    window.addScore = function(value) {\n        // 1. Boundary Celebrations\n        if (value === 6) {\n            triggerCelebration('six-celebration');\n            screenShake();\n        } else if (value === 4) {\n            triggerCelebration('four-celebration');\n            screenShake(0.5);\n        }\n\n        // 2. Confetti on every hit\n        createConfetti(event.clientX, event.clientY);\n\n        // 3. Update Score Animation\n        const runsEl = document.getElementById('runs');\n        const currentRuns = parseInt(runsEl.innerText);\n        if(!isNaN(value)) {\n            gsap.to(runsEl, {\n                innerText: currentRuns + value,\n                duration: 0.5,\n                snap: { innerText: 1 },\n                ease: \"power2.out\"\n            });\n        }\n    }\n\n    function triggerCelebration(id) {\n        const overlay = document.getElementById(id);\n        const text = overlay.querySelector('.celebration-text');\n        \n        gsap.set(overlay, { autoAlpha: 1 });\n        gsap.fromTo(text, \n            { scale: 0, rotate: -30, opacity: 0 },\n            { scale: 1.2, rotate: 10, opacity: 1, duration: 0.6, ease: \"back.out(1.7)\" }\n        );\n\n        // Auto hide\n        gsap.to(overlay, { \n            autoAlpha: 0, \n            duration: 0.4, \n            delay: 1.2,\n            onComplete: () => gsap.set(text, { scale: 0 })\n        });\n    }\n\n    function screenShake(intensity = 1) {\n        const target = document.querySelector('.shake-target');\n        gsap.to(target, {\n            x: `random(-${20 * intensity}, ${20 * intensity})`,\n            y: `random(-${20 * intensity}, ${20 * intensity})`,\n            duration: 0.05,\n            repeat: 10,\n            yoyo: true,\n            onComplete: () => gsap.set(target, { x: 0, y: 0 })\n        });\n    }\n\n    function createConfetti(x, y) {\n        const colors = ['#FFC40C', '#4CBB17', '#00BFFF', '#ff4757', '#ffffff'];\n        for (let i = 0; i < 30; i++) {\n            const p = document.createElement('div');\n            p.className = 'particle';\n            p.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];\n            p.style.left = x + 'px';\n            p.style.top = y + 'px';\n            p.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';\n            document.body.appendChild(p);\n\n            const destinationX = (Math.random() - 0.5) * 400;\n            const destinationY = (Math.random() - 0.5) * 400;\n\n            gsap.to(p, {\n                x: destinationX,\n                y: destinationY,\n                rotation: Math.random() * 720,\n                opacity: 0,\n                scale: 0,\n                duration: 0.6 + Math.random() * 0.8,\n                ease: \"power2.out\",\n                onComplete: () => p.remove()\n            });\n        }\n    }\n\n    // Initialize Marble positions along the snake path if we had more time/data\n    // For now, they are statically positioned in the HTML to match the path visually.\n</script>\n",
