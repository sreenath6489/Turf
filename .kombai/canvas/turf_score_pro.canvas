>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <aside id=\"sidebar-right\" class=\"w-80 broadcast-panel border-l border-white/10 flex flex-col z-20\" data-kid=\"120\">\n            <div class=\"panel-header flex justify-between items-center\" data-kid=\"121\">\n                <h3 class=\"text-xs font-extrabold uppercase tracking-widest text-white/50\" data-kid=\"122\">Match Sequence</h3>\n                <span class=\"text-[10px] font-bold text-[#D4AF37] bg-[#D4AF37]/10 px-2 py-1 rounded\" data-kid=\"123\">OVR 18</span>\n            </div>\n\n            <div class=\"flex-1 overflow-y-auto p-6 space-y-3 custom-scrollbar border-b border-white/10\" data-kid=\"124\">\n                    <div class=\"flex items-center justify-between p-3 bg-white/5 rounded-xl border border-white/5\" data-kid=\"125\">\n                        <span class=\"text-xs font-bold text-white/30 tracking-widest\" data-kid=\"126\">18.6</span>\n                        <div class=\"flex items-center gap-4\" data-kid=\"127\">\n                            <span class=\"text-sm font-bold text-white/60 italic\" data-kid=\"128\">Inside Edge</span>\n                            <span class=\"w-10 h-10 rounded-full bg-white/10 flex items-center justify-center font-black text-lg border border-white/10\" data-kid=\"129\">4</span>\n                        </div>\n                    </div>\n                    <div class=\"flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/5\" data-kid=\"130\">\n                        <span class=\"text-xs font-bold text-white/30 tracking-widest\" data-kid=\"131\">18.5</span>\n                        <div class=\"flex items-center gap-4\" data-kid=\"132\">\n                            <span class=\"text-sm font-bold text-white/60 italic\" data-kid=\"133\">Square Cut</span>\n                            <span class=\"w-10 h-10 rounded-full bg-white/10 flex items-center justify-center font-black text-lg border border-white/10\" data-kid=\"134\">1</span>\n                        </div>\n                    </div>\n                    <div class=\"flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/5\" data-kid=\"135\">\n                        <span class=\"text-xs font-bold text-white/30 tracking-widest\" data-kid=\"136\">18.4</span>\n                        <div class=\"flex items-center gap-4\" data-kid=\"137\">\n                            <span class=\"text-sm font-bold text-[#E60026] italic\" data-kid=\"138\">Clean Bowled</span>\n                            <span class=\"w-10 h-10 rounded-full bg-[#E60026] flex items-center justify-center font-black text-lg shadow-lg shadow-[#E60026]/30\" data-kid=\"139\">W</span>\n                        </div>\n                    </div>\n                    <div class=\"flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/5\" data-kid=\"140\">\n                        <span class=\"text-xs font-bold text-white/30 tracking-widest\" data-kid=\"141\">18.3</span>\n                        <div class=\"flex items-center gap-4\" data-kid=\"142\">\n                            <span class=\"text-sm font-bold text-white/60 italic\" data-kid=\"143\">Push to Long-on</span>\n                            <span class=\"w-10 h-10 rounded-full bg-white/10 flex items-center justify-center font-black text-lg border border-white/10\" data-kid=\"144\">1</span>\n                        </div>\n                    </div>\n                    <div class=\"flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/5\" data-kid=\"145\">\n                        <span class=\"text-xs font-bold text-white/30 tracking-widest\" data-kid=\"146\">18.2</span>\n                        <div class=\"flex items-center gap-4\" data-kid=\"147\">\n                            <span class=\"text-sm font-bold text-[#D4AF37] italic\" data-kid=\"148\">Massive 6</span>\n                            <span class=\"w-10 h-10 rounded-full bg-[#D4AF37] flex items-center justify-center font-black text-lg text-[#000830] shadow-lg shadow-[#D4AF37]/30\" data-kid=\"149\">6</span>\n                        </div>\n                    </div>\n                </div>\n\n            <div class=\"p-6\" data-kid=\"150\">\n                <h4 class=\"text-[10px] font-extrabold text-white/40 uppercase tracking-[0.2em] mb-4\" data-kid=\"151\">Run Rate Analysis</h4>\n                <div class=\"flex items-end gap-2 h-16 mb-8\" data-kid=\"152\">\n                    <div class=\"flex-1 bg-white/10 h-[60%] rounded-sm\" data-kid=\"153\"></div>\n                    <div class=\"flex-1 bg-[#D4AF37] h-[90%] rounded-sm\" data-kid=\"154\"></div>\n                    <div class=\"flex-1 bg-white/10 h-[45%] rounded-sm\" data-kid=\"155\"></div>\n                    <div class=\"flex-1 bg-white/10 h-[75%] rounded-sm\" data-kid=\"156\"></div>\n                    <div class=\"flex-1 bg-[#E60026] h-[30%] rounded-sm\" data-kid=\"157\"></div>\n                </div>\n\n                <h4 class=\"text-[10px] font-extrabold text-white/40 uppercase tracking-[0.2em] mb-4\" data-kid=\"158\">Victory Probability</h4>\n                <div class=\"h-4 bg-white/5 rounded flex overflow-hidden mb-2\" data-kid=\"159\">\n                    <div class=\"bg-[#0014A8] w-[65%] border-r border-white/20\" data-kid=\"160\"></div>\n                    <div class=\"bg-[#D4AF37] w-[35%]\" data-kid=\"161\"></div>\n                </div>\n                <div class=\"flex justify-between text-[11px] font-black uppercase tracking-widest\" data-kid=\"162\">\n                    <span data-kid=\"163\">Titans 65%</span>\n                    <span class=\"text-[#D4AF37]\" data-kid=\"164\">Kings 35%</span>\n                </div>\n            </div>\n        </aside>\n    </main>\n\n    \n    <footer class=\"relative z-30 bg-black border-t border-white/20 h-24 px-8 flex items-center justify-between shadow-2xl\" data-kid=\"165\">\n        <div class=\"flex items-center gap-4\" data-kid=\"166\">\n            <div class=\"flex flex-col\" data-kid=\"167\">\n                <span class=\"text-[10px] font-bold text-white/30 uppercase\" data-kid=\"168\">Direct Access</span>\n                <span class=\"text-xs font-black text-[#D4AF37] uppercase\" data-kid=\"169\">Scoring Panel</span>\n            </div>\n            <div class=\"h-10 w-[1px] bg-white/10 mx-4\" data-kid=\"170\"></div>\n            <div id=\"scoring-dock\" class=\"flex items-center gap-2\" data-kid=\"171\">\n                <button class=\"score-btn w-12 h-12 rounded border border-white/10 hover:bg-white/10 flex items-center justify-center font-black text-xl transition-all\" data-kid=\"172\">0</button>\n                <button class=\"score-btn w-12 h-12 rounded border border-white/10 hover:bg-white/10 flex items-center justify-center font-black text-xl transition-all\" data-kid=\"173\">1</button>\n                <button class=\"score-btn w-12 h-12 rounded border border-white/10 hover:bg-white/10 flex items-center justify-center font-black text-xl transition-all\" data-kid=\"174\">2</button>\n                <button class=\"score-btn w-12 h-12 rounded border border-white/10 hover:bg-white/10 flex items-center justify-center font-black text-xl transition-all\" data-kid=\"175\">3</button>\n                <button class=\"score-btn w-14 h-14 rounded bg-[#D4AF37] flex items-center justify-center font-black text-2xl text-black shadow-lg\" data-kid=\"176\">4</button>\n                <button class=\"score-btn w-14 h-14 rounded bg-[#D4AF37] flex items-center justify-center font-black text-2xl text-black shadow-lg\" data-kid=\"177\">6</button>\n                <div class=\"w-[1px] h-10 bg-white/10 mx-2\" data-kid=\"178\"></div>\n                <button class=\"score-btn px-4 h-12 rounded border border-white/10 hover:bg-white/10 flex items-center justify-center font-bold text-xs uppercase transition-all\" data-kid=\"179\">Wide</button>\n                <button class=\"score-btn px-4 h-12 rounded border border-white/10 hover:bg-white/10 flex items-center justify-center font-bold text-xs uppercase transition-all\" data-kid=\"180\">No Ball</button>\n                <button class=\"score-btn px-8 h-14 rounded bg-[#E60026] flex items-center justify-center font-black text-lg uppercase tracking-widest shadow-lg\" data-kid=\"181\">Wicket</button>\n            </div>\n        </div>\n\n        <div class=\"flex items-center gap-6\" data-kid=\"182\">\n            <div class=\"text-right\" data-kid=\"183\">\n                <div class=\"text-xs font-bold text-white/40 uppercase tracking-widest\" data-kid=\"184\">Time (GMT)</div>\n                <div class=\"text-xl font-black\" data-kid=\"185\">21:44:12</div>\n            </div>\n            <div class=\"h-10 w-[1px] bg-white/20\" data-kid=\"186\"></div>\n            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/cricket.svg\" class=\"w-10 h-10 opacity-60\" alt=\"Logo\" data-kid=\"187\">\n        </div>\n    </footer>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"188\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/TextPlugin.min.js\" data-kid=\"189\"></script>\n    <script type=\"module\" data-kid=\"190\">\n        import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n        gsap.registerPlugin(TextPlugin);\n\n        // Entrance Animations\n        window.addEventListener('DOMContentLoaded', () => {\n            const tl = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.2 } });\n\n            tl.from(\"#main-header\", { autoAlpha: 0, y: -50, scale: 0.9 })\n              .from(\"#partnership-card\", { autoAlpha: 0, x: -100, rotateY: 20 }, \"-=0.8\")\n              .from(\"#bowler-card\", { autoAlpha: 0, x: -100, rotateY: 20 }, \"-=1.0\")\n              .from(\"#recent-balls\", { autoAlpha: 0, x: 100, rotateY: -20 }, \"-=1.2\")\n              .from(\"#wagon-wheel\", { autoAlpha: 0, scale: 0.5, rotate: -45 }, \"-=1.0\")\n              .from(\"#event-bubble\", { autoAlpha: 0, y: 50, scale: 0.8 }, \"-=0.5\")\n              .from(\"#scoring-dock\", { autoAlpha: 0, y: 100 }, \"-=1.0\");\n\n            // Example Score Updates Sequence\n            setTimeout(() => {\n                updateScore(188, 4, \"18.5\", \"9.94\");\n            }, 3000);\n        });\n\n        function updateScore(score, wickets, overs, crr) {\n            gsap.to(\"#score-main\", {\n                duration: 1.5,\n                text: score.toString(),\n                ease: \"none\",\n                snap: { text: 1 }\n            });\n            gsap.to(\"#wickets-main\", {\n                duration: 0.8,\n                text: wickets.toString(),\n                ease: \"power2.inOut\"\n            });\n            gsap.to(\"#overs-main\", {\n                duration: 1,\n                text: `${overs} OVERS`,\n                ease: \"none\"\n            });\n            gsap.to(\"#crr-display\", {\n                duration: 1.5,\n                text: crr,\n                ease: \"power2.out\"\n            });\n            \n            // Pulse the update\n            gsap.fromTo(\"#score-main\", { scale: 1.2 }, { scale: 1, duration: 0.5 });\n        }\n\n        // Hover Gesture implementations with Motion\n        document.querySelectorAll('.score-btn').forEach(btn => {\n            btn.addEventListener('mouseenter', () => {\n                animate(btn, { scale: 1.05, y: -5 }, { type: \"spring\", stiffness: 400, damping: 10 });\n            });\n            btn.addEventListener('mouseleave', () => {\n                animate(btn, { scale: 1, y: 0 }, { type: \"spring\", stiffness: 300, damping: 20 });\n            });\n            btn.addEventListener('mousedown', () => {\n                animate(btn, { scale: 0.95 }, { duration: 0.1 });\n            });\n            btn.addEventListener('mouseup', () => {\n                animate(btn, { scale: 1.05 }, { duration: 0.1 });\n            });\n        });\n    </script>\n</div>\n",
