font-serif italic font-bold text-2xl tracking-tight text-white\" data-kid=\"220\">Turf Score Pro</span>\n                    </div>\n                    <p class=\"text-white/40 leading-relaxed mb-10\" data-kid=\"221\">\n                        Redefining the digital boundary. The world's most sophisticated real-time cricket scoring and analytics platform for the modern elite.\n                    </p>\n                    <div class=\"flex gap-6\" data-kid=\"222\">\n                        <a href=\"#\" class=\"w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-[#FFD700] hover:border-[#FFD700] transition-all\" data-kid=\"223\"><i class=\"ti ti-brand-instagram\" data-kid=\"224\"></i></a>\n                        <a href=\"#\" class=\"w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-[#FFD700] hover:border-[#FFD700] transition-all\" data-kid=\"225\"><i class=\"ti ti-brand-x\" data-kid=\"226\"></i></a>\n                        <a href=\"#\" class=\"w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-[#FFD700] hover:border-[#FFD700] transition-all\" data-kid=\"227\"><i class=\"ti ti-brand-linkedin\" data-kid=\"228\"></i></a>\n                    </div>\n                </div>\n\n                <div class=\"grid grid-cols-2 md:grid-cols-3 gap-20\" data-kid=\"229\">\n                    <div class=\"space-y-6\" data-kid=\"230\">\n                        <h5 class=\"text-[10px] uppercase tracking-[0.3em] font-bold text-white\" data-kid=\"231\">The Engine</h5>\n                        <ul class=\"space-y-4 text-white/40 text-sm\" data-kid=\"232\">\n                            <li data-kid=\"233\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"234\">Live Telemetry</a></li>\n                            <li data-kid=\"235\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"236\">Ball Tracking</a></li>\n                            <li data-kid=\"237\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"238\">Win Predictor</a></li>\n                            <li data-kid=\"239\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"240\">API Access</a></li>\n                        </ul>\n                    </div>\n                    <div class=\"space-y-6\" data-kid=\"241\">\n                        <h5 class=\"text-[10px] uppercase tracking-[0.3em] font-bold text-white\" data-kid=\"242\">Archetypes</h5>\n                        <ul class=\"space-y-4 text-white/40 text-sm\" data-kid=\"243\">\n                            <li data-kid=\"244\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"245\">Elite Cards</a></li>\n                            <li data-kid=\"246\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"247\">Squad Creator</a></li>\n                            <li data-kid=\"248\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"249\">Tournament Docs</a></li>\n                            <li data-kid=\"250\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"251\">Leaderboards</a></li>\n                        </ul>\n                    </div>\n                    <div class=\"space-y-6 col-span-2 md:col-span-1\" data-kid=\"252\">\n                        <h5 class=\"text-[10px] uppercase tracking-[0.3em] font-bold text-white\" data-kid=\"253\">Newsletter</h5>\n                        <p class=\"text-xs text-white/40 mb-4\" data-kid=\"254\">Elite scouting reports delivered weekly.</p>\n                        <div class=\"relative\" data-kid=\"255\">\n                            <input type=\"email\" placeholder=\"Email address\" class=\"w-full bg-white/5 border border-white/10 px-6 py-4 rounded-full text-sm focus:outline-none focus:border-[#FFD700] transition-colors\" data-kid=\"256\">\n                            <button class=\"absolute right-2 top-2 w-10 h-10 bg-[#FFD700] text-[#010B13] rounded-full flex items-center justify-center font-bold hover:bg-white transition-colors\" data-kid=\"257\"><i class=\"ti ti-arrow-right\" data-kid=\"258\"></i></button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"mt-32 pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"259\">\n                <span class=\"text-[10px] uppercase tracking-widest text-white/20\" data-kid=\"260\">© 2026 Turf Score Pro // All Rights Reserved</span>\n                <div class=\"flex gap-10 text-[10px] uppercase tracking-widest text-white/20\" data-kid=\"261\">\n                    <a href=\"#\" class=\"hover:text-white\" data-kid=\"262\">Privacy</a>\n                    <a href=\"#\" class=\"hover:text-white\" data-kid=\"263\">Terms</a>\n                    <a href=\"#\" class=\"hover:text-white\" data-kid=\"264\">Security</a>\n                </div>\n            </div>\n        </div>\n    </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"265\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"266\"></script>\n    <script type=\"module\" data-kid=\"267\">\n    import Lenis from \"https://esm.sh/lenis@1\";\n    \n    gsap.registerPlugin(ScrollTrigger);\n\n    // Initialize Lenis with correct GSAP sync\n    const lenis = new Lenis();\n\n    lenis.on('scroll', ScrollTrigger.update);\n\n    gsap.ticker.add((time) => {\n        lenis.raf(time * 1000);\n    });\n\n    gsap.ticker.lagSmoothing(0);\n\n    // GSAP Animations\n    \n    // Hero Animations\n    gsap.from(\".hero-ball\", {\n        scale: 0.8,\n        opacity: 0,\n        y: 100,\n        duration: 1.5,\n        ease: \"power4.out\"\n    });\n\n    gsap.from(\".hero-reveal\", {\n        opacity: 0,\n        y: 40,\n        stagger: 0.2,\n        duration: 1.2,\n        ease: \"power3.out\",\n        delay: 0.5\n    });\n\n    gsap.to(\".hero-bg-text\", {\n        scrollTrigger: {\n            trigger: \"#hero\",\n            start: \"top top\",\n            end: \"bottom top\",\n            scrub: true\n        },\n        y: 200,\n        opacity: 0.1\n    });\n\n    // Dashboard Animations\n    gsap.from(\".dashboard-sidebar\", {\n        scrollTrigger: {\n            trigger: \"#dashboard\",\n            start: \"top 80%\",\n            toggleActions: \"play none none reverse\"\n        },\n        opacity: 0,\n        x: -50,\n        duration: 1\n    });\n\n    gsap.from(\".dashboard-card\", {\n        scrollTrigger: {\n            trigger: \".dashboard-scroll\",\n            start: \"top 90%\",\n            toggleActions: \"play none none reverse\"\n        },\n        opacity: 0,\n        y: 100,\n        stagger: 0.15,\n        duration: 1.2,\n        ease: \"power4.out\"\n    });\n\n    // Soundscape Animations\n    gsap.from(\".soundscape-header\", {\n        scrollTrigger: {\n            trigger: \"#soundscape\",\n            start: \"top 70%\"\n        },\n        opacity: 0,\n        y: 50,\n        duration: 1\n    });\n\n    gsap.from(\".wicket-orbit-1\", {\n        scrollTrigger: {\n            trigger: \"#soundscape\",\n            start: \"top 50%\",\n            scrub: 1\n        },\n        x: -500,\n        rotation: -45,\n        ease: \"none\"\n    });\n\n    gsap.from(\".wicket-orbit-2\", {\n        scrollTrigger: {\n            trigger: \"#soundscape\",\n            start: \"top 50%\",\n            scrub: 1\n        },\n        x: 500,\n        rotation: 45,\n        ease: \"none\"\n    });\n\n    // Cards Animations\n    gsap.from(\".magazine-container\", {\n        scrollTrigger: {\n            trigger: \"#cards\",\n            start: \"top 80%\"\n        },\n        opacity: 0,\n        y: 100,\n        duration: 1.5,\n        ease: \"power4.out\"\n    });\n\n    // Exporter Animations\n    gsap.from(\".exporter-header\", {\n        scrollTrigger: {\n            trigger: \"#exporter\",\n            start: \"top 80%\"\n        },\n        opacity: 0,\n        y: 40,\n        duration: 1\n    });\n\n    gsap.from(\".exporter-mockup\", {\n        scrollTrigger: {\n            trigger: \"#exporter\",\n            start: \"top 70%\"\n        },\n        opacity: 0,\n        scale: 0.95,\n        duration: 1.5,\n        ease: \"power3.out\"\n    });\n\n    // Velocity Distortion Simulation\n    lenis.on('scroll', ({ velocity }) => {\n        const dist = Math.abs(velocity) * 0.05;\n        gsap.to(\".hero-ball\", {\n            skewY: velocity * 0.01,\n            scale: 1 + dist * 0.001,\n            duration: 0.5,\n            overwrite: true\n        });\n    });\n\n</script>\n",
