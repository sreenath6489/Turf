      "html": "\n<div class=\"bg-[#010B13] min-h-screen font-['Space_Grotesk'] text-white overflow-x-clip selection:bg-[#66FF00] selection:text-black\" data-kid=\"0\">\n    \n    <div class=\"fixed inset-0 pointer-events-none z-0\" data-kid=\"1\">\n        <img src=\"https://images.unsplash.com/photo-1642436273796-28447b6d3f93?auto=format&w=1920&q=80&fit=crop\" class=\"w-full h-full object-cover opacity-10 mix-blend-overlay\" decoding=\"async\" loading=\"lazy\" data-kid=\"2\">\n        <div id=\"particle-container\" class=\"absolute inset-0\" data-kid=\"3\"></div>\n        <div class=\"absolute inset-0 bg-gradient-to-t from-[#010B13] via-transparent to-[#010B13]/80\" data-kid=\"4\"></div>\n        <div class=\"absolute inset-0 scanline opacity-30\" data-kid=\"5\"></div>\n    </div>\n\n    \n    <main class=\"relative z-10 max-w-[1440px] mx-auto min-h-screen flex flex-col p-6 lg:p-10 pb-24 gap-8\" data-kid=\"6\">\n        \n        \n        <header class=\"w-full border-y border-white/10 bg-[#1A1A1A]/40 backdrop-blur-md py-4 overflow-hidden relative\" data-kid=\"7\">\n            <div class=\"absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#010B13] to-transparent z-10\" data-kid=\"8\"></div>\n            <div class=\"absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#010B13] to-transparent z-10\" data-kid=\"9\"></div>\n            <div class=\"marquee-track flex gap-20 whitespace-nowrap\" data-kid=\"10\">\n                <div class=\"flex items-center gap-10\" data-kid=\"11\">\n                    <span class=\"flex items-center gap-2\" data-kid=\"12\"><i class=\"ti ti-trophy text-[#66FF00]\" data-kid=\"13\"></i> TURF SCORE PRO LEAGUE 2024</span>\n                    <span class=\"text-white/40\" data-kid=\"14\">//</span>\n                    <span class=\"flex items-center gap-2\" data-kid=\"15\"><i class=\"ti ti-swords text-[#FF00CC]\" data-kid=\"16\"></i> CYBER TITANS VS NEON KNIGHTS</span>\n                    <span class=\"text-white/40\" data-kid=\"17\">//</span>\n                    <span class=\"flex items-center gap-2\" data-kid=\"18\"><i class=\"ti ti-activity text-[#66FF00]\" data-kid=\"19\"></i> TARGET: 214 RUNS</span>\n                    <span class=\"text-white/40\" data-kid=\"20\">//</span>\n                    <span class=\"text-[#FF00CC]\" data-kid=\"21\">LIVE BROADCAST FROM SECTOR 7 CRICKET TURF</span>\n                </div>\n                \n                <div class=\"flex items-center gap-10\" data-kid=\"22\">\n                    <span class=\"flex items-center gap-2\" data-kid=\"23\"><i class=\"ti ti-trophy text-[#66FF00]\" data-kid=\"24\"></i> TURF SCORE PRO LEAGUE 2024</span>\n                    <span class=\"text-white/40\" data-kid=\"25\">//</span>\n                    <span class=\"flex items-center gap-2\" data-kid=\"26\"><i class=\"ti ti-swords text-[#FF00CC]\" data-kid=\"27\"></i> CYBER TITANS VS NEON KNIGHTS</span>\n                    <span class=\"text-white/40\" data-kid=\"28\">//</span>\n                    <span class=\"flex items-center gap-2\" data-kid=\"29\"><i class=\"ti ti-activity text-[#66FF00]\" data-kid=\"30\"></i> TARGET: 214 RUNS</span>\n                    <span class=\"text-white/40\" data-kid=\"31\">//</span>\n                    <span class=\"text-[#FF00CC]\" data-kid=\"32\">LIVE BROADCAST FROM SECTOR 7 CRICKET TURF</span>\n                </div>\n            </div>\n        </header>\n\n        \n        <div class=\"flex-grow grid grid-cols-12 gap-8\" data-kid=\"33\">\n            \n            \n            <aside class=\"col-span-3 flex flex-col gap-6 hidden lg:flex\" data-kid=\"34\">\n                <div class=\"hud-card p-6 border border-white/5 bg-[#1A1A1A]/60 backdrop-blur-sm rounded-lg relative overflow-hidden\" data-kid=\"35\">\n                    <div class=\"absolute top-0 right-0 p-2 opacity-10\" data-kid=\"36\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/nested-hexagons.svg\" class=\"w-16 h-16\" style=\"filter: invert(1);\" data-kid=\"37\">\n                    </div>\n                    <h3 class=\"text-[#66FF00] text-xs font-bold uppercase tracking-widest mb-4 flex items-center gap-2\" data-kid=\"38\">\n                        <span class=\"w-2 h-2 bg-[#66FF00] rounded-full animate-pulse\" data-kid=\"39\"></span> Striker\n                    </h3>\n                    <div class=\"space-y-4\" data-kid=\"40\">\n                        <div class=\"flex justify-between items-end border-b border-white/5 pb-2\" data-kid=\"41\">\n                            <div data-kid=\"42\">\n                                <p class=\"text-lg font-bold\" data-kid=\"43\">X. RAVEN</p>\n                                <p class=\"text-[10px] text-white/40 uppercase\" data-kid=\"44\">Sector 7 Elite</p>\n                            </div>\n                            <p class=\"text-2xl font-black text-[#66FF00]\" data-kid=\"45\">52<span class=\"text-sm font-normal text-white/40\" data-kid=\"46\"> (24)</span></p>\n                        </div>\n                        <div class=\"grid grid-cols-2 gap-4 text-xs\" data-kid=\"47\">\n                            <div data-kid=\"48\">\n                                <p class=\"text-white/40 uppercase\" data-kid=\"49\">SR</p>\n                                <p class=\"font-mono text-[#66FF00]\" data-kid=\"50\">216.6</p>\n                            </div>\n                            <div data-kid=\"51\">\n                                <p class=\"text-white/40 uppercase\" data-kid=\"52\">4s / 6s</p>\n                                <p class=\"font-mono\" data-kid=\"53\">4 / 3</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"hud-card p-6 border border-white/5 bg-[#1A1A1A]/60 backdrop-blur-sm rounded-lg relative flex-grow\" data-kid=\"54\">\n                    <h3 class=\"text-white/40 text-xs font-bold u