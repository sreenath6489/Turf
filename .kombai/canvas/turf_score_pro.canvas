      "html": "<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n:root {\n    --ink-black: #010B13;\n    --sky-blue: #00BFFF;\n    --electric-green: #00FF40;\n}\n\n.font-sora { font-family: 'Sora', sans-serif; }\n\n/* Glassmorphism */\n.glass {\n    background: rgba(255, 255, 255, 0.05);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.glass-nav {\n    background: rgba(1, 11, 19, 0.0);\n    backdrop-filter: blur(0px);\n    transition: all 0.4s ease;\n}\n\n.glass-nav.scrolled {\n    background: rgba(1, 11, 19, 0.85);\n    backdrop-filter: blur(12px);\n    border-bottom: 1px solid rgba(0, 191, 255, 0.2);\n}\n\n/* Spotlights */\n.spotlight {\n    position: absolute;\n    width: 900px;\n    height: 1400px;\n    background: conic-gradient(from 180deg at 50% 0%, transparent 155deg, rgba(0, 191, 255, 0.15) 180deg, transparent 205deg);\n    filter: blur(100px);\n    pointer-events: none;\n    z-index: 1;\n}\n\n.spotlight-1 { top: -20%; left: -10%; transform: rotate(25deg); }\n.spotlight-2 { top: -20%; right: -10%; transform: rotate(-25deg); }\n\n/* Turf Platform */\n.turf-patch {\n    width: min(90vw, 1000px);\n    height: 450px;\n    background: linear-gradient(135deg, #0a2d10 0%, #051a08 100%);\n    transform: rotateX(55deg);\n    border: 4px solid var(--electric-green);\n    box-shadow: \n        0 0 120px rgba(0, 255, 64, 0.2),\n        inset 0 0 150px rgba(0, 0, 0, 0.8);\n    position: relative;\n    overflow: hidden;\n}\n\n.turf-patch::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background-image: \n        repeating-linear-gradient(90deg, transparent 0, transparent 50px, rgba(255,255,255,0.04) 50px, rgba(255,255,255,0.04) 51px),\n        repeating-linear-gradient(0deg, transparent 0, transparent 50px, rgba(255,255,255,0.04) 50px, rgba(255,255,255,0.04) 51px);\n}\n\n/* UI Elements */\n.btn-primary {\n    background: var(--electric-green);\n    color: black;\n    box-shadow: 0 10px 40px rgba(0, 255, 64, 0.25);\n}\n\n.peephole-circle {\n    clip-path: circle(150px at 50% 50%);\n}\n\n.lenis.lenis-smooth {\n    scroll-behavior: auto !important;\n}\n\n.lenis.lenis-smooth [data-lenis-prevent] {\n    overscroll-behavior: contain;\n}\n\n.lenis.lenis-stopped {\n    overflow: hidden;\n}\n\n.lenis.lenis-scrolling iframe {\n    pointer-events: none;\n}\n</style>\n\n<div id=\"app-root\" class=\"bg-[#010B13] text-white min-h-screen selection:bg-sky-blue/30 overflow-x-clip\" data-kid=\"1\">\n    \n    \n    <nav id=\"main-nav\" class=\"fixed top-0 left-0 w-full z-100 flex items-center justify-between px-6 md:px-12 py-6 glass-nav\" data-kid=\"2\">\n        <div class=\"flex items-center gap-4\" data-kid=\"3\">\n            <div class=\"w-12 h-12 bg-gradient-to-br from-[#00BFFF] to-[#00FF40] rounded-2xl flex items-center justify-center shadow-xl\" data-kid=\"4\">\n                <i class=\"ti ti-trophy-filled text-black text-2xl\" data-kid=\"5\"></i>\n            </div>\n            <span class=\"font-sora font-extrabold text-2xl tracking-tighter\" data-kid=\"6\">TURF<span class=\"text-[#00BFFF]\" data-kid=\"7\">SCORE</span>PRO</span>\n        </div>\n        \n        <div class=\"hidden lg:flex items-center gap-10\" data-kid=\"8\">\n            <a href=\"#\" class=\"text-xs font-black tracking-[0.2em] hover:text-[#00BFFF] transition-colors\" data-kid=\"9\">LIVE FEED</a>\n            <a href=\"#\" class=\"text-xs font-black tracking-[0.2em] hover:text-[#00BFFF] transition-colors\" data-kid=\"10\">TOURNAMENTS</a>\n            <a href=\"#\" class=\"text-xs font-black tracking-[0.2em] hover:text-[#00BFFF] transition-colors\" data-kid=\"11\">SCOUTING</a>\n            <a href=\"#\" class=\"text-xs font-black tracking-[0.2em] hover:text-[#00BFFF] transition-colors\" data-kid=\"12\">PRICING</a>\n        </div>\n\n        <button class=\"btn-primary px-10 py-3.5 rounded-full font-black text-xs uppercase tracking-widest hover:scale-105 transition-transform\" data-kid=\"13\">GET STARTED</button>\n    </nav>\n\n    \n    <section class=\"relative min-h-screen flex flex-col items-center justify-center pt-32 pb-40\" data-scroll-section data-kid=\"14\">\n        <div class=\"spotlight spotlight-1\" data-kid=\"15\"></div>\n        <div class=\"spotlight spotlight-2\" data-kid=\"16\"></div>\n        \n        <div class=\"relative z-10 text-center flex flex-col items-center\" data-kid=\"17\">\n            <div class=\"glass px-8 py-2.5 rounded-full inline-flex items-center gap-4 mb-16 border-[#00BFFF]/40\" data-scroll data-scroll-speed=\"1.2\" data-kid=\"18\">\n                <div class=\"w-2.5 h-2.5 rounded-full bg-[#00FF40] shadow-[0_0_15px_#00FF40] animate-pulse\" data-kid=\"19\"></div>\n                <span class=\"font-mono text-xl tracking-[0.5em] text-[#00BFFF] font-black uppercase\" data-kid=\"20\">LIVE MATCH CENTER</span>\n            </div>\n            \n            <h1 class=\"font-sora text-6xl md:text-[11rem] font-black leading-tight tracking-[-0.05em] text-white mb-16 hero-title opacity-0\" data-kid=\"21\">\n                EVERY<br data-kid=\"22\">SECOND<br data-kid=\"23\">COUNTS\n            </h1>\n            \n            <p class=\"max-w-2xl text-white/70 text-2xl font-medium leading-relaxed mb-24 px-6\" data-scroll data-scroll-speed=\"1.5\" data-kid=\"24\">\n                Precision live-scoring, hyper-local heatmaps, and total squad dominance. Your pitch, our data.\n            </p>\n        </div>\n\n        <div class=\"turf-container w-full flex justify-center mt-[-100px]\" data-scroll data-scroll-speed=\"-2\" data-kid=\"25\">\n            <div class=\"turf-patch\" data-kid=\"26\">\n                <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(0,255,64,0.1),transparent_70%)]\" data-kid=\"27\"></div>\n                <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 border-2 border-white/20 rounded-full\" data-kid=\"28\"></div>\n                <div class=\"absolute inset-x-0 top-1/2 h-[1px] bg-white/20\" data-kid=\"29\"></div>\n                <div class=\"absolute inset-y-0 left-1/2 w-[1px] bg-white/20\" data-kid=\"30\"></div>\n                <div class=\"absolute top-8 left-1/2 -translate-x-1/2 w-56 h-28 border-2 border-white/20\" data-kid=\"31\"></div>\n                <div class=\"absolute bottom-8 left-1/2 -translate-x-1/2 w-56 h-28 border-2 border-white/20\" data-kid=\"32\"></div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"relative py-48 px-6 md:px-24\" data-scroll-section id=\"features-section\" data-kid=\"33\">\n        <div class=\"container mx-auto\" data-kid=\"34\">\n            <div class=\"max-w-4xl mb-48\" data-scroll data-scroll-speed=\"0.8\" data-kid=\"35\">\n                <h2 class=\"font-sora text-6xl md:text-9xl font-black mb-10 text-white tracking-tighter uppercase leading-none\" data-kid=\"36\">DOMINATE THE<br data-kid=\"37\"><span class=\"text-[#00BFFF]\" data-kid=\"38\">NUMBERS</span></h2>\n                <div class=\"w-32 h-3 bg-[#00FF40] rounded-full shadow-[0_0_20px_rgba(0,255,64,0.4)]\" data-kid=\"39\"></div>\n            </div>\n\n            \n            <div class=\"absolute right-[10%] top-0 w-80 h-full pointer-events-none z-0\" id=\"ball-scroll-path\" data-kid=\"40\">\n                <div class=\"sticky top-1/3\" id=\"football-float\" data-kid=\"41\">\n                    <img src=\"https://images.unsplash.com/photo-1574629810360-7efbbe195018?auto=format&w=800&q=80&fit=crop\" class=\"w-64 h-64 rounded-full border-[10px] border-white/5 shadow-[0_0_100px_rgba(0,0,0,0.8)] blur-[0.5px] grayscale hover:grayscale-0 transition-all duration-1000\" alt=\"Football Asset\" data-kid=\"42\">\n                </div>\n            </div>\n\n            \n            <div class=\"relative flex flex-col gap-24 max-w-6xl mx-auto z-10\" data-kid=\"43\">\n                \n                <div class=\"glass p-12 md:p-20 rounded-[5rem] w-full md:w-[90%] feature-reveal shadow-[0_0_50px_rgba(0,191,255,0.05)] border-blue-500/10\" data-scroll data-scroll-speed=\"1.1\" data-kid=\"44\">\n                    <div class=\"flex flex-col lg:flex-row lg:items-center gap-12\" data-kid=\"45\">\n                        <div class=\"w-28 h-28 rounded-[2rem] bg-[#00BFFF]/20 flex items-center justify-center shrink-0 shadow-[0_0_30px_rgba(0,191,255,0.2)]\" data-kid=\"46\">\n                            <i class=\"ti ti-activity-heartbeat text-6xl text-[#00BFFF]\" data-kid=\"47\"></i>\n                        </div>\n                        <div data-kid=\"48\">\n                            <span class=\"text-[#00BFFF] font-black text-sm uppercase tracking-[0.4em] block mb-4\" data-kid=\"49\">REAL-TIME LOGGING</span>\n                            <h3 class=\"font-sora text-5xl md:text-6xl font-extrabold mb-8 text-white leading-tight\" data-kid=\"50\">Match Timeline</h3>\n                            <p class=\"text-xl md:text-2xl text-white/80 leading-relaxed mb-0\" data-kid=\"51\">\n                                Every substitution, card, and clinical finish captured with millisecond accuracy. Our dynamic feed keeps your audience locked into the action.\n                            </p>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"glass p-12 md:p-20 rounded-[5rem] w-full md:w-[90%] self-end feature-reveal shadow-[0_0_50px_rgba(0,255,64,0.05)] border-green-500/10\" data-scroll data-scroll-speed=\"1.3\" data-kid=\"52\">\n                    <div class=\"flex flex-col lg:flex-row lg:items-center gap-12\" data-kid=\"53\">\n                        <div class=\"w-28 h-28 rounded-[2rem] bg-[#00FF40]/20 flex items-center justify-center shrink-0 shadow-[0_0_30px_rgba(0,255,64,0.2)]\" data-kid=\"54\">\n                            <i class=\"ti ti-prism text-6xl text-[#00FF40]\" data-kid=\"55\"></i>\n                        </div>\n                        <div data-kid=\"56\">\n                            <span class=\"text-[#00FF40] font-black text-sm uppercase tracking-[0.4em] block mb-4\" data-kid=\"57\">SPATIAL INTEL</span>\n                            <h3 class=\"font-sora text-5xl md:text-6xl font-extrabold mb-8 text-white leading-tight\" data-kid=\"58\">Heat Visualization</h3>\n                            <p class=\"text-xl md:text-2xl text-white/80 leading-relaxed mb-12\" data-kid=\"59\">\n                                Tactical field analysis powered by AI spatial tracking. Identify density zones and player fatigue before they impact the score.\n                            </p>\n                            <div class=\"h-64 w-full bg-black/50 rounded-[3rem] border border-white/10 overflow-hidden relative\" data-kid=\"60\">\n                                <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_30%_40%,rgba(0,255,64,0.3),transparent_50%)]\" data-kid=\"61\"></div>\n                                <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_70%_60%,rgba(0,191,255,0.2),transparent_40%)]\" data-kid=\"62\"></div>\n                                <div class=\"absolute bottom-8 right-12 text-6xl font-black text-[#00FF40] italic opacity-80\" data-kid=\"63\">98.4%</div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"glass p-12 md:p-20 rounded-[5rem] w-full md:w-[90%] feature-reveal shadow-[0_0_50px_rgba(0,191,255,0.05)] border-blue-500/10\" data-scroll data-scroll-speed=\"1.1\" data-kid=\"64\">\n                    <div class=\"flex flex-col lg:flex-row lg:items-center gap-12\" data-kid=\"65\">\n                        <div class=\"w-28 h-28 rounded-[2rem] bg-[#00BFFF]/20 flex items-center justify-center shrink-0 shadow-[0_0_30px_rgba(0,191,255,0.2)]\" data-kid=\"66\">\n                            <i class=\"ti ti-users-plus text-6xl text-[#00BFFF]\" data-kid=\"67\"></i>\n                        </div>\n                        <div data-kid=\"68\">\n                            <span class=\"text-[#00BFFF] font-black text-sm uppercase tracking-[0.4em] block mb-4\" data-kid=\"69\">PLAYER HUB</span>\n                            <h3 class=\"font-sora text-5xl md:text-6xl font-extrabold mb-8 text-white leading-tight\" data-kid=\"70\">Roster Management</h3>\n                            <p class=\"text-xl md:text-2xl text-white/80 leading-relaxed mb-12\" data-kid=\"71\">\n                                Centralized database for every player on your pitch. Track careers, career goals, and win rates with ease.\n                            </p>\n                            <div class=\"flex flex-wrap gap-4\" data-kid=\"72\">\n                                <div class=\"flex -space-x-8\" data-kid=\"73\">\n                                    <img src=\"https://i.pravatar.cc/150?u=a\" class=\"w-20 h-20 rounded-full border-8 border-[#010B13] shadow-xl\" data-kid=\"74\">\n                                    <img src=\"https://i.pravatar.cc/150?u=b\" class=\"w-20 h-20 rounded-full border-8 border-[#010B13] shadow-xl\" data-kid=\"75\">\n                                    <img src=\"https://i.pravatar.cc/150?u=c\" class=\"w-20 h-20 rounded-full border-8 border-[#010B13] shadow-xl\" data-kid=\"76\">\n                                </div>\n                                <div class=\"w-20 h-20 rounded-full bg-white/10 border-8 border-[#010B13] flex items-center justify-center text-xl font-black\" data-kid=\"77\">+240</div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"relative h-screen bg-black flex items-center justify-center overflow-hidden\" id=\"cta-trigger\" data-scroll-section data-kid=\"78\">\n        <div class=\"absolute inset-0 z-0 peephole-circle\" id=\"peephole-mask\" data-kid=\"79\">\n            <video class=\"w-full h-full object-cover\" autoplay muted loop playsinline poster=\"https://images.pexels.com/videos/17834313/4k-drone-footage-areal-footage-dji-dji-mini-17834313.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" data-kid=\"80\">\n                <source src=\"https://videos.pexels.com/video-files/17834313/17834313-hd_1280_720_30fps.mp4\" type=\"video/mp4\" data-kid=\"81\">\n            </video>\n            <div class=\"absolute inset-0 bg-black/60\" data-kid=\"82\"></div>\n        </div>\n\n        <div class=\"relative z-10 text-center px-6 opacity-0 translate-y-20 cta-reveal\" data-kid=\"83\">\n            <h2 class=\"font-sora text-6xl md:text-[10rem] font-black leading-none mb-20 tracking-tighter text-white\" data-kid=\"84\">THE STAGE<br data-kid=\"85\">IS SET</h2>\n            <button class=\"btn-primary px-16 py-8 rounded-full text-2xl font-black uppercase tracking-[0.3em] group relative overflow-hidden\" data-kid=\"86\">\n                <span class=\"relative z-10 group-hover:tracking-[0.4em] transition-all duration-300\" data-kid=\"87\">STEP ONTO THE PITCH</span>\n                <div class=\"absolute inset-0 bg-white/20 -translate-x-full group-hover:translate-x-0 transition-transform duration-500\" data-kid=\"88\"></div>\n            </button>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-black py-32 px-12 border-t border-white/5\" data-scroll-section data-kid=\"89\">\n        <div class=\"container mx-auto flex flex-col md:flex-row justify-between items-start gap-20\" data-kid=\"90\">\n            <div class=\"max-w-xs\" data-kid=\"91\">\n                <div class=\"flex items-center gap-4 mb-8\" data-kid=\"92\">\n                    <div class=\"w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center\" data-kid=\"93\">\n                        <i class=\"ti ti-stadium-2 text-[#00FF40] text-xl\" data-kid=\"94\"></i>\n                    </div>\n                    <span class=\"font-sora font-extrabold text-2xl tracking-tighter uppercase\" data-kid=\"95\">TSP</span>\n                </div>\n                <p class=\"text-white/40 leading-relaxed font-medium\" data-kid=\"96\">\n                    The premier operating system for the world's most elite turf arenas. Precision. Power. Performance.\n                </p>\n            </div>\n            \n            <div class=\"grid grid-cols-2 md:grid-cols-3 gap-20\" data-kid=\"97\">\n                <div class=\"flex flex-col gap-6\" data-kid=\"98\">\n                    <span class=\"text-[10px] font-black tracking-[0.4em] text-white/20 uppercase\" data-kid=\"99\">PRODUCT</span>\n                    <a href=\"#\" class=\"text-sm font-bold hover:text-[#00BFFF] transition-colors\" data-kid=\"100\">FEATURES</a>\n                    <a href=\"#\" class=\"text-sm font-bold hover:text-[#00BFFF] transition-colors\" data-kid=\"101\">LIVE DEMO</a>\n                    <a href=\"#\" class=\"text-sm font-bold hover:text-[#00BFFF] transition-colors\" data-kid=\"102\">PRICING</a>\n                </div>\n                <div class=\"flex flex-col gap-6\" data-kid=\"103\">\n                    <span class=\"text-[10px] font-black tracking-[0.4em] text-white/20 uppercase\" data-kid=\"104\">COMPANY</span>\n                    <a href=\"#\" class=\"text-sm font-bold hover:text-[#00BFFF] transition-colors\" data-kid=\"105\">ABOUT</a>\n                    <a href=\"#\" class=\"text-sm font-bold hover:text-[#00BFFF] transition-colors\" data-kid=\"106\">PARTNERS</a>\n                    <a href=\"#\" class=\"text-sm font-bold hover:text-[#00BFFF] transition-colors\" data-kid=\"107\">SUPPORT</a>\n                </div>\n                <div class=\"flex flex-col gap-6\" data-kid=\"108\">\n                    <span class=\"text-[10px] font-black tracking-[0.4em] text-white/20 uppercase\" data-kid=\"109\">CONNECT</span>\n                    <a href=\"#\" class=\"text-sm font-bold hover:text-[#00BFFF] transition-colors\" data-kid=\"110\">TWITTER</a>\n                    <a href=\"#\" class=\"text-sm font-bold hover:text-[#00BFFF] transition-colors\" data-kid=\"111\">DISCORD</a>\n                    <a href=\"#\" class=\"text-sm font-bold hover:text-[#00BFFF] transition-colors\" data-kid=\"112\">LINKEDIN</a>\n                </div>\n            </div>\n        </div>\n        <div class=\"container mx-auto mt-32 pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"113\">\n            <p class=\"text-white/20 text-[10px] font-black tracking-widest uppercase\" data-kid=\"114\">© 2024 TSP SYSTEMS. ALL RIGHTS RESERVED.</p>\n            <div class=\"flex items-center gap-6\" data-kid=\"115\">\n                <div class=\"w-1.5 h-1.5 rounded-full bg-[#00FF40]\" data-kid=\"116\"></div>\n                <span class=\"text-[10px] font-black tracking-widest text-white/40 uppercase\" data-kid=\"117\">SYSTEMS OPERATIONAL</span>\n            </div>\n        </div>\n    </footer>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"118\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"119\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.min.js\" data-kid=\"120\"></script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css\" data-kid=\"121\">\n\n<script type=\"module\" data-kid=\"122\">\n    import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    // 1. Initialize Locomotive Scroll (v5 is a wrapper for Lenis)\n    const locoScroll = new LocomotiveScroll({\n        lenisOptions: {\n            smoothWheel: true,\n            duration: 1.2,\n            lerp: 0.1\n        }\n    });\n\n    // 2. GSAP Initialization\n    gsap.registerPlugin(ScrollTrigger);\n\n    // 3. Navbar Scroll Effect\n    window.addEventListener('scroll', () => {\n        const nav = document.getElementById('main-nav');\n        if (window.scrollY > 50) {\n            nav.classList.add('scrolled');\n        } else {\n            nav.classList.remove('scrolled');\n        }\n    });\n\n    // 4. Hero Reveal (Native GSAP since no proxy is needed for v5)\n    gsap.to(\".hero-title\", {\n        autoAlpha: 1,\n        y: 0,\n        filter: \"blur(0px)\",\n        duration: 1.8,\n        ease: \"power4.out\",\n        delay: 0.4\n    });\n\n    // 5. Feature Card Batch Reveals\n    gsap.utils.toArray(\".feature-reveal\").forEach((card, i) => {\n        gsap.from(card, {\n            scrollTrigger: {\n                trigger: card,\n                start: \"top 85%\",\n                toggleActions: \"play none none reverse\"\n            },\n            autoAlpha: 0,\n            y: 80,\n            duration: 1,\n            ease: \"power2.out\"\n        });\n    });\n\n    // 6. Parallax Ball (Motion.dev)\n    scroll(\n        animate(\"#football-float img\", { \n            rotate: 1440,\n            y: [0, 1000]\n        }, { ease: \"linear\" }),\n        { \n            target: document.querySelector(\"#features-section\"),\n            offset: [\"start end\", \"end start\"]\n        }\n    );\n\n    // 7. Peephole Section Animation\n    const peepholeTL = gsap.timeline({\n        scrollTrigger: {\n            trigger: \"#cta-trigger\",\n            start: \"top top\",\n            end: \"+=150%\",\n            scrub: 1,\n            pin: true\n        }\n    });\n\n    peepholeTL\n        .to(\"#peephole-mask\", {\n            clipPath: \"circle(100% at 50% 50%)\",\n            duration: 2,\n            ease: \"none\"\n        })\n        .to(\".cta-reveal\", {\n            autoAlpha: 1,\n            y: 0,\n            duration: 1,\n            ease: \"power3.out\"\n        }, \"-=0.5\");\n\n</script>\n",
