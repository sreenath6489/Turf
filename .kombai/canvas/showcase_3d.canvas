      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;900&display=swap');\n  \n  :root {\n    --color-turf: #10B981;\n    --color-sky: #1E293B;\n    --color-amber: #F59E0B;\n    --color-bg: #0F172A;\n    --glass-bg: rgba(30, 41, 59, 0.4);\n    --glass-border: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    margin: 0;\n    background-color: var(--color-bg);\n    color: white;\n    font-family: 'Outfit', sans-serif;\n    overflow-x: clip;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  #three-container {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100vh;\n    z-index: 1;\n    pointer-events: none;\n  }\n\n  .content-overlay {\n    position: relative;\n    z-index: 10;\n    width: 100%;\n  }\n\n  section {\n    min-height: 100vh;\n    width: 100%;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    padding: 0 8%;\n    box-sizing: border-box;\n    position: relative;\n  }\n\n  .hud-panel {\n    background: rgba(15, 23, 42, 0.85);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);\n    position: relative;\n    border-left: 4px solid var(--color-turf);\n  }\n\n  .hud-panel::after {\n    content: \"\";\n    position: absolute;\n    top: 0; left: 0; width: 100%; height: 100%;\n    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255, 255, 255, 0.01) 3px);\n    pointer-events: none;\n  }\n\n  .btn-primary {\n    background: var(--color-turf);\n    color: var(--color-bg);\n    font-weight: 900;\n    padding: 1.25rem 2.5rem;\n    border-radius: 1rem;\n    box-shadow: 0 0 40px rgba(16, 185, 129, 0.4);\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    cursor: pointer;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n  }\n\n  .btn-primary:hover {\n    transform: scale(1.05) translateY(-2px);\n    box-shadow: 0 0 60px rgba(16, 185, 129, 0.6);\n  }\n\n  .stat-card {\n    background: rgba(255, 255, 255, 0.03);\n    border: 1px solid rgba(255, 255, 255, 0.05);\n    border-radius: 20px;\n    padding: 1.5rem;\n    transition: all 0.3s ease;\n  }\n\n  .stat-card:hover {\n    background: rgba(255, 255, 255, 0.07);\n    border-color: rgba(255, 255, 255, 0.15);\n  }\n\n  .momentum-bar {\n    width: 6px;\n    height: 20px;\n    background: var(--color-turf);\n    border-radius: 3px;\n    opacity: 0.3;\n    animation: momentumPulse 2s ease-in-out infinite;\n  }\n\n  @keyframes momentumPulse {\n    0%, 100% { height: 12px; opacity: 0.2; }\n    50% { height: 24px; opacity: 1; box-shadow: 0 0 10px var(--color-turf); }\n  }\n\n  /* Custom Range Sliders */\n  input[type=\"range\"] {\n    -webkit-appearance: none;\n    width: 100%;\n    background: transparent;\n    cursor: pointer;\n  }\n  input[type=\"range\"]::-webkit-slider-runnable-track {\n    background: rgba(255, 255, 255, 0.1);\n    height: 4px;\n    border-radius: 2px;\n  }\n  input[type=\"range\"]::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    height: 16px;\n    width: 16px;\n    background: var(--color-amber);\n    border-radius: 2px;\n    margin-top: -6px;\n    box-shadow: 0 0 10px var(--color-amber);\n  }\n\n  .holographic-glow {\n    position: absolute;\n    width: 100%;\n    height: 100%;\n    top: 0;\n    left: 0;\n    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, transparent 50%, rgba(16, 185, 129, 0.1) 100%);\n    pointer-events: none;\n    border-radius: inherit;\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 8px; }\n  ::-webkit-scrollbar-track { background: var(--color-bg); }\n  ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 4px; }\n  ::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }\n</style>\n\n<div id=\"three-container\" data-kid=\"1\"></div>\n\n<div class=\"content-overlay\" data-kid=\"2\">\n  \n  <section id=\"hero\" class=\"items-start justify-end pb-32\" data-kid=\"3\">\n    <div class=\"max-w-4xl relative z-10 px-8\" data-kid=\"4\">\n      <div class=\"flex items-center gap-3 mb-6\" data-kid=\"5\">\n        <span class=\"px-3 py-1 bg-red-600 text-white text-[10px] font-bold uppercase tracking-widest\" data-kid=\"6\">Live Broadcast</span>\n        <span class=\"text-white/40 text-[10px] font-bold uppercase tracking-widest\" data-kid=\"7\">Scene // 01 . Stadium Overview</span>\n      </div>\n      \n      <div class=\"relative inline-block mb-8\" data-kid=\"8\">\n        <div class=\"absolute -top-4 -left-4 w-8 h-8 border-t-2 border-l-2 border-[var(--color-turf)] opacity-40\" data-kid=\"9\"></div>\n        <div class=\"absolute -bottom-4 -right-4 w-8 h-8 border-b-2 border-r-2 border-[var(--color-turf)] opacity-40\" data-kid=\"10\"></div>\n        <h1 class=\"text-[clamp(3rem,8vw,7rem)] font-bold leading-[0.9] tracking-tighter\" data-kid=\"11\">\n          STEP INTO THE<br data-kid=\"12\">\n          <span class=\"text-[var(--color-turf)]\" data-kid=\"13\">DIGITAL TURF</span>\n        </h1>\n      </div>\n      \n      <div class=\"flex items-center gap-6\" data-kid=\"14\">\n        <button class=\"btn-primary rounded-none\" data-kid=\"15\">Initialize Stadium</button>\n        <div id=\"coin-toss\" class=\"flex items-center gap-3 group cursor-pointer border border-white/10 px-6 py-4 bg-white/5\" data-kid=\"16\">\n          <i class=\"ti ti-currency-bitcoin text-xl text-[var(--color-amber)]\" data-kid=\"17\"></i>\n          <span class=\"text-[10px] font-bold tracking-widest uppercase opacity-60\" data-kid=\"18\">Toss Coin</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"scoreboard\" class=\"pt-20\" data-kid=\"19\">\n    <div class=\"hud-panel w-full max-w-7xl px-8 py-6 grid grid-cols-12 gap-8 items-center border-l-8 border-[var(--color-turf)]\" data-kid=\"20\">\n      <div class=\"col-span-4 space-y-2\" data-kid=\"21\">\n        <div class=\"flex items-center gap-3\" data-kid=\"22\">\n          <span class=\"text-[10px] font-bold text-white/30 uppercase tracking-[0.3em]\" data-kid=\"23\">Grand Finale</span>\n          <span class=\"w-2 h-2 bg-emerald-500 rounded-full animate-pulse\" data-kid=\"24\"></span>\n        </div>\n        <h2 class=\"text-3xl font-bold tracking-tighter\" data-kid=\"25\">MUMBAI TITANS <span class=\"text-white/20\" data-kid=\"26\">vs</span> DELHI WOLVES</h2>\n      </div>\n\n      <div class=\"col-span-3 grid grid-cols-2 gap-4\" data-kid=\"27\">\n        <div class=\"space-y-1\" data-kid=\"28\">\n          <span class=\"text-[9px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"29\">Win Prob.</span>\n          <div class=\"text-2xl font-bold\" data-kid=\"30\">64.2%</div>\n        </div>\n        <div class=\"space-y-1\" data-kid=\"31\">\n          <span class=\"text-[9px] font-bold text-white/30 uppercase tracking-widest\" data-kid=\"32\">Run Rate</span>\n          <div class=\"text-2xl font-bold\" data-kid=\"33\">10.04</div>\n        </div>\n      </div>\n\n      <div class=\"col-span-2 flex flex-col items-center justify-center border-x border-white/5\" data-kid=\"34\">\n        <div id=\"live-score\" class=\"text-5xl font-black tracking-tighter text-[var(--color-amber)]\" data-kid=\"35\">184/4</div>\n        <span class=\"text-[9px] font-bold text-white/40 uppercase mt-1\" data-kid=\"36\">Over 18.2</span>\n      </div>\n\n      <div class=\"col-span-3 flex gap-2\" data-kid=\"37\">\n        <button onclick=\"triggerHit(4)\" class=\"flex-1 py-3 bg-[var(--color-turf)]/10 border border-[var(--color-turf)]/30 text-[var(--color-turf)] font-bold text-sm\" data-kid=\"38\">BOUNDARY 4</button>\n        <button onclick=\"triggerHit(6)\" class=\"flex-1 py-3 bg-amber-500/10 border border-amber-500/30 text-amber-500 font-bold text-sm\" data-kid=\"39\">MAXIMUM 6</button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"sounds\" class=\"items-end justify-center\" data-kid=\"40\">\n    <div class=\"hud-panel w-96 p-8 space-y-10 border-l-0 border-r-8 border-[var(--color-amber)]\" data-kid=\"41\">\n      <div class=\"flex items-center gap-4\" data-kid=\"42\">\n        <div class=\"w-12 h-12 bg-amber-500/10 flex items-center justify-center text-amber-500 border border-amber-500/30\" data-kid=\"43\">\n          <i class=\"ti ti-microphone text-2xl\" data-kid=\"44\"></i>\n        </div>\n        <div data-kid=\"45\">\n          <h3 class=\"text-xl font-bold tracking-tight uppercase\" data-kid=\"46\">Sound Deck</h3>\n          <p class=\"text-[9px] font-bold text-white/40 tracking-widest uppercase\" data-kid=\"47\">System // Audio.v4</p>\n        </div>\n      </div>\n\n      <div class=\"space-y-8\" data-kid=\"48\">\n        <div class=\"space-y-3\" data-kid=\"49\">\n          <div class=\"flex justify-between text-[9px] font-bold uppercase tracking-widest text-white/40\" data-kid=\"50\">\n            <span data-kid=\"51\">Crowd Noise</span>\n            <span class=\"text-emerald-500\" data-kid=\"52\">Active</span>\n          </div>\n          <input type=\"range\" value=\"85\" data-kid=\"53\">\n        </div>\n        <div class=\"space-y-3\" data-kid=\"54\">\n          <div class=\"flex justify-between text-[9px] font-bold uppercase tracking-widest text-white/40\" data-kid=\"55\">\n            <span data-kid=\"56\">Spatial Audio</span>\n            <span class=\"text-amber-500\" data-kid=\"57\">100%</span>\n          </div>\n          <input type=\"range\" value=\"100\" data-kid=\"58\">\n        </div>\n      </div>\n\n      <button onclick=\"triggerWicket()\" class=\"w-full py-4 border border-red-500/30 bg-red-500/5 text-red-500 font-bold text-[10px] uppercase tracking-widest hover:bg-red-500/20 transition-all\" data-kid=\"59\">\n        Force Wicket Event\n      </button>\n    </div>\n  </section>\n\n  \n  <section id=\"roster\" data-kid=\"60\">\n    <div class=\"text-center space-y-4 mb-24 bg-slate-900/60 p-8 border border-white/5 backdrop-blur-md\" data-kid=\"61\">\n      <h2 class=\"text-6xl font-bold tracking-tighter\" data-kid=\"62\">CHAMPIONS GALLERY</h2>\n      <div class=\"flex items-center justify-center gap-4\" data-kid=\"63\">\n        <span class=\"h-px w-12 bg-emerald-500\" data-kid=\"64\"></span>\n        <p class=\"text-white/40 font-bold uppercase tracking-[0.4em] text-[10px]\" data-kid=\"65\">Holographic Roster Data</p>\n        <span class=\"h-px w-12 bg-emerald-500\" data-kid=\"66\"></span>\n      </div>\n    </div>\n    \n    <div class=\"flex items-center gap-12 mb-12\" data-kid=\"67\">\n      <button class=\"w-14 h-14 bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[var(--color-turf)] hover:text-slate-950 transition-all cursor-pointer\" data-kid=\"68\"><i class=\"ti ti-chevron-left\" data-kid=\"69\"></i></button>\n      <div class=\"flex flex-col items-center\" data-kid=\"70\">\n        <span class=\"text-[10px] font-bold text-white/20 tracking-widest mb-2\" data-kid=\"71\">SCROLL TO INSPECT</span>\n        <div class=\"w-px h-12 bg-gradient-to-b from-emerald-500 to-transparent\" data-kid=\"72\"></div>\n      </div>\n      <button class=\"w-14 h-14 bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[var(--color-turf)] hover:text-slate-950 transition-all cursor-pointer\" data-kid=\"73\"><i class=\"ti ti-chevron-right\" data-kid=\"74\"></i></button>\n    </div>\n  </section>\n\n  \n  <section id=\"finish\" data-kid=\"75\">\n    <div class=\"hud-panel w-full max-w-6xl p-16 grid grid-cols-2 gap-12 relative overflow-hidden border-l-0 border-r-8 border-[var(--color-turf)]\" data-kid=\"76\">\n      \n      <div class=\"space-y-10\" data-kid=\"77\">\n        <h2 class=\"text-6xl font-black italic tracking-tighter leading-none\" data-kid=\"78\">THE<br data-kid=\"79\"><span class=\"text-[var(--color-turf)]\" data-kid=\"80\">FINISH LINE</span></h2>\n        <p class=\"text-white/40 text-lg font-light leading-relaxed\" data-kid=\"81\">Your journey through the pitch summarized in a cinematic poster. Drag and drop 3D badges to customize your win.</p>\n        \n        <div class=\"space-y-6\" data-kid=\"82\">\n          <span class=\"text-[10px] font-black text-white/30 uppercase tracking-[0.3em]\" data-kid=\"83\">Signature Assets</span>\n          <div class=\"flex gap-4\" data-kid=\"84\">\n            <div class=\"w-24 h-24 rounded-2xl glass-hud flex items-center justify-center cursor-grab active:scale-90 transition-all border-white/20 group\" data-kid=\"85\">\n              <i class=\"ti ti-trophy text-4xl text-[var(--color-amber)] group-hover:drop-shadow-[0_0_15px_rgba(245,158,11,0.5)]\" data-kid=\"86\"></i>\n            </div>\n            <div class=\"w-24 h-24 rounded-2xl glass-hud flex items-center justify-center cursor-grab active:scale-90 transition-all border-white/20 group\" data-kid=\"87\">\n              <i class=\"ti ti-award text-4xl text-[var(--color-turf)] group-hover:drop-shadow-[0_0_15px_rgba(16,185,129,0.5)]\" data-kid=\"88\"></i>\n            </div>\n            <div class=\"w-24 h-24 rounded-2xl glass-hud flex items-center justify-center cursor-grab active:scale-90 transition-all border-white/20 group\" data-kid=\"89\">\n              <i class=\"ti ti-star-filled text-4xl text-white group-hover:drop-shadow-[0_0_15px_rgba(255,255,255,0.5)]\" data-kid=\"90\"></i>\n            </div>\n          </div>\n        </div>\n\n        <button class=\"w-full py-6 rounded-2xl bg-white text-[var(--color-bg)] font-black text-xl hover:scale-[0.98] transition-all shadow-2xl uppercase tracking-widest\" data-kid=\"91\">\n          Generate Poster\n        </button>\n      </div>\n\n      <div class=\"aspect-[4/5] bg-white rounded-3xl p-12 text-[var(--color-bg)] shadow-[0_50px_100px_rgba(0,0,0,0.5)] relative overflow-hidden flex flex-col border-[12px] border-white\" data-kid=\"92\">\n        <div class=\"absolute top-0 left-0 w-full h-4 bg-[var(--color-turf)]\" data-kid=\"93\"></div>\n        \n        <div class=\"flex justify-between items-start mb-12\" data-kid=\"94\">\n          <h3 class=\"text-5xl font-black italic tracking-tighter\" data-kid=\"95\">M.V.P</h3>\n          <div class=\"text-right\" data-kid=\"96\">\n            <div class=\"text-[10px] font-black uppercase tracking-widest opacity-40\" data-kid=\"97\">Final Score</div>\n            <div class=\"text-3xl font-black\" data-kid=\"98\">184/4</div>\n          </div>\n        </div>\n\n        <div class=\"flex-grow rounded-3xl border-4 border-dashed border-slate-200 flex flex-col items-center justify-center gap-4 bg-slate-50/50\" data-kid=\"99\">\n          <i class=\"ti ti-plus text-5xl opacity-20\" data-kid=\"100\"></i>\n          <span class=\"text-[10px] font-black opacity-30 uppercase tracking-[0.3em]\" data-kid=\"101\">Place 3D Asset</span>\n        </div>\n\n        <div class=\"mt-12 space-y-6\" data-kid=\"102\">\n          <div class=\"flex justify-between border-b-2 border-slate-100 pb-3\" data-kid=\"103\">\n            <span class=\"font-bold text-xl uppercase tracking-tight\" data-kid=\"104\">Sid Khan</span>\n            <span class=\"font-black text-xl\" data-kid=\"105\">74 <span class=\"text-slate-400 font-bold\" data-kid=\"106\">(42)</span></span>\n          </div>\n          <div class=\"flex justify-between border-b-2 border-slate-100 pb-3\" data-kid=\"107\">\n            <span class=\"font-bold text-xl uppercase tracking-tight\" data-kid=\"108\">Virat K.</span>\n            <span class=\"font-black text-xl\" data-kid=\"109\">48 <span class=\"text-slate-400 font-bold\" data-kid=\"110\">(29)</span></span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/0.160.0/three.min.js\" data-kid=\"111\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"112\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"113\"></script>\n<script data-kid=\"114\">gsap.registerPlugin(ScrollTrigger);</script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"115\">\n\n<script data-kid=\"116\">\n\n  // --- THREE.JS SCENE SETUP ---\n  const container = document.getElementById('three-container');\n  const scene = new THREE.Scene();\n  scene.background = new THREE.Color('#0F172A');\n  scene.fog = new THREE.FogExp2('#0F172A', 0.015);\n  \n  const camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.1, 1000);\n  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });\n  renderer.setSize(window.innerWidth, window.innerHeight);\n  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n  renderer.shadowMap.enabled = true;\n  renderer.shadowMap.type = THREE.PCFSoftShadowMap;\n  container.appendChild(renderer.domElement);\n\n  // LIGHTING (Cinematic Floodlights)\n  const ambientLight = new THREE.AmbientLight(0xffffff, 0.8);\n  scene.add(ambientLight);\n\n  const directionalLight = new THREE.DirectionalLight(0xffffff, 3);\n  directionalLight.position.set(20, 40, 20);\n  scene.add(directionalLight);\n\n  const fillLight = new THREE.PointLight(0xffffff, 1000);\n  fillLight.position.set(-10, 10, 10);\n  scene.add(fillLight);\n\n  // Floodlight Utility\n  function createFloodlight(x, y, z, targetX, targetY, targetZ) {\n    const spotLight = new THREE.SpotLight(0xffffff, 4000);\n    spotLight.position.set(x, y, z);\n    spotLight.angle = Math.PI / 4.5;\n    spotLight.penumbra = 0.6;\n    spotLight.decay = 1.2;\n    spotLight.distance = 250;\n    spotLight.castShadow = true;\n    spotLight.shadow.mapSize.width = 1024;\n    spotLight.shadow.mapSize.height = 1024;\n    \n    const target = new THREE.Object3D();\n    target.position.set(targetX, targetY, targetZ);\n    scene.add(target);\n    spotLight.target = target;\n    \n    scene.add(spotLight);\n    \n    // Volumetric Beam Simulation (Refined)\n    const coneGeom = new THREE.ConeGeometry(12, 80, 32, 1, true);\n    const coneMat = new THREE.MeshBasicMaterial({\n      color: 0xffffff,\n      transparent: true,\n      opacity: 0.08,\n      side: THREE.DoubleSide,\n      blending: THREE.AdditiveBlending,\n      depthWrite: false\n    });\n    const beam = new THREE.Mesh(coneGeom, coneMat);\n    beam.position.copy(spotLight.position);\n    beam.lookAt(target.position);\n    beam.rotateX(Math.PI / 2);\n    beam.translateY(-30);\n    scene.add(beam);\n\n    return spotLight;\n  }\n\n  // Position floodlights at corners\n  createFloodlight(30, 40, 30, 0, 0, 0);\n  createFloodlight(-30, 40, 30, 0, 0, 0);\n  createFloodlight(30, 40, -30, 0, 0, 0);\n  createFloodlight(-30, 40, -30, 0, 0, 0);\n\n  // GROUND (Turf)\n  const turfTex = new THREE.TextureLoader().load('https://images.unsplash.com/photo-1544914379-806667cd9489?auto=format&w=2000&q=80&fit=crop');\n  turfTex.wrapS = turfTex.wrapT = THREE.RepeatWrapping;\n  turfTex.repeat.set(20, 20);\n  \n  const ground = new THREE.Mesh(\n    new THREE.PlaneGeometry(200, 200),\n    new THREE.MeshStandardMaterial({ \n      map: turfTex, \n      color: '#064E3B', \n      roughness: 0.8,\n      metalness: 0.1\n    })\n  );\n  ground.rotation.x = -Math.PI / 2;\n  ground.receiveShadow = true;\n  scene.add(ground);\n\n  // GRASS INSTANCING (High Density)\n  const grassCount = 25000;\n  const grassBlade = new THREE.PlaneGeometry(0.12, 0.5);\n  const grassMat = new THREE.MeshStandardMaterial({ color: '#10B981', side: THREE.DoubleSide });\n  const instancedGrass = new THREE.InstancedMesh(grassBlade, grassMat, grassCount);\n  const dummy = new THREE.Object3D();\n\n  for (let i = 0; i < grassCount; i++) {\n    dummy.position.set((Math.random() - 0.5) * 80, 0.25, (Math.random() - 0.5) * 80);\n    dummy.rotation.y = Math.random() * Math.PI;\n    dummy.rotation.x = (Math.random() - 0.5) * 0.2;\n    dummy.scale.set(1, Math.random() * 0.5 + 0.5, 1);\n    dummy.updateMatrix();\n    instancedGrass.setMatrixAt(i, dummy.matrix);\n  }\n  instancedGrass.receiveShadow = true;\n  scene.add(instancedGrass);\n\n  // --- INTERACTIVE MODELS ---\n  \n  // 1. HERO BALL\n  const ballGroup = new THREE.Group();\n  const ballTex = new THREE.TextureLoader().load('https://images.pexels.com/photos/30401509/pexels-photo-30401509.jpeg?auto=compress&cs=tinysrgb&w=800&q=80');\n  const ball = new THREE.Mesh(\n    new THREE.SphereGeometry(1.2, 64, 64),\n    new THREE.MeshStandardMaterial({ \n      map: ballTex, \n      roughness: 0.2, \n      metalness: 0.4,\n      emissive: '#10B981',\n      emissiveIntensity: 0.1\n    })\n  );\n\n  // Rim light for ball\n  const ballRim = new THREE.PointLight(0xffffff, 100, 10);\n  ballRim.position.set(0, 2, 4);\n  ballGroup.add(ballRim);\n  ball.castShadow = true;\n  ball.receiveShadow = true;\n  ballGroup.add(ball);\n  ballGroup.position.set(0, 0.8, 0);\n  scene.add(ballGroup);\n\n  // 2. COIN (Hero secondary)\n  const coin = new THREE.Mesh(\n    new THREE.CylinderGeometry(0.7, 0.7, 0.12, 64),\n    new THREE.MeshStandardMaterial({ color: '#F59E0B', metalness: 0.95, roughness: 0.05 })\n  );\n  coin.position.set(5, 5, -5);\n  coin.rotation.z = Math.PI / 2;\n  scene.add(coin);\n\n  // 3. BAT (Scoreboard section)\n  const batContainer = new THREE.Group();\n  const batBlade = new THREE.Mesh(\n    new THREE.BoxGeometry(0.5, 2.2, 0.2),\n    new THREE.MeshStandardMaterial({ color: '#E5C49F', roughness: 0.7 })\n  );\n  const handle = new THREE.Mesh(\n    new THREE.CylinderGeometry(0.1, 0.1, 1),\n    new THREE.MeshStandardMaterial({ color: '#111' })\n  );\n  handle.position.y = 1.5;\n  batContainer.add(batBlade, handle);\n  batContainer.position.set(12, 5, 12);\n  batContainer.castShadow = true;\n  scene.add(batContainer);\n\n  // 4. STUMPS (Sounds section)\n  const stumps = new THREE.Group();\n  for (let i = -1; i <= 1; i++) {\n    const s = new THREE.Mesh(\n      new THREE.CylinderGeometry(0.1, 0.1, 2.5, 32),\n      new THREE.MeshStandardMaterial({ color: '#F59E0B', metalness: 0.6, roughness: 0.2 })\n    );\n    s.position.x = i * 0.45;\n    s.castShadow = true;\n    stumps.add(s);\n  }\n  stumps.position.set(-15, 1.25, 0);\n  scene.add(stumps);\n\n  // 5. CARDS (Roster section)\n  const gallery = new THREE.Group();\n  const cardTex = new THREE.TextureLoader().load('https://images.unsplash.com/photo-1544914379-806667cd9489?auto=format&w=800&q=80&fit=crop');\n  for (let i = 0; i < 10; i++) {\n    const card = new THREE.Mesh(\n      new THREE.PlaneGeometry(3, 4.5),\n      new THREE.MeshStandardMaterial({ \n        color: '#ffffff', \n        transparent: true, \n        opacity: 0.9, \n        side: THREE.DoubleSide,\n        emissive: '#3b82f6',\n        emissiveIntensity: 0.1\n      })\n    );\n    const angle = (i / 10) * Math.PI * 2;\n    card.position.set(Math.cos(angle) * 10, 3.5, Math.sin(angle) * 10);\n    card.lookAt(0, 3.5, 0);\n    gallery.add(card);\n  }\n  gallery.position.set(0, 0, -30);\n  scene.add(gallery);\n\n  // --- CAMERA PATHWAY ---\n  camera.position.set(-10, 5, 15);\n  camera.lookAt(0, 2, 0);\n\n  const mainTimeline = gsap.timeline({\n    scrollTrigger: {\n      trigger: \".content-overlay\",\n      start: \"top top\",\n      end: \"bottom bottom\",\n      scrub: 1.5\n    }\n  });\n\n  // Camera Motion Points\n  // 1. Move to Bat (Scoreboard)\n  mainTimeline.to(camera.position, { x: 12, y: 8, z: 20, ease: \"power2.inOut\" }, 0);\n  mainTimeline.to(camera.rotation, { x: -0.1, y: 0.2, ease: \"power2.inOut\" }, 0);\n\n  // 2. Move to Stumps (Sounds)\n  mainTimeline.to(camera.position, { x: -15, y: 4, z: 8, ease: \"power2.inOut\" }, 1);\n  mainTimeline.to(camera.rotation, { y: 1.4, x: -0.2, ease: \"power2.inOut\" }, 1);\n\n  // 3. Move to Gallery (Roster)\n  mainTimeline.to(camera.position, { x: 0, y: 5, z: -25, ease: \"power2.inOut\" }, 2);\n  mainTimeline.to(camera.rotation, { y: 0, x: -0.3, ease: \"power2.inOut\" }, 2);\n\n  // 4. Finale (Top Down)\n  mainTimeline.to(camera.position, { x: 0, y: 60, z: -5, ease: \"power3.inOut\" }, 3);\n  mainTimeline.to(camera.rotation, { x: -Math.PI / 2, ease: \"power3.inOut\" }, 3);\n\n  // --- INTERACTION FUNCTIONS ---\n  window.triggerHit = function(runs) {\n    gsap.to(batContainer.rotation, { z: -Math.PI / 1.5, duration: 0.12, yoyo: true, repeat: 1, ease: \"power2.in\" });\n    const scoreEl = document.getElementById('live-score');\n    let [score, wickets] = scoreEl.innerText.split('/');\n    scoreEl.innerText = `${parseInt(score) + runs}/${wickets}`;\n    gsap.from(scoreEl, { scale: 1.2, duration: 0.3, ease: \"elastic.out\" });\n  };\n\n  window.triggerWicket = function() {\n    stumps.children.forEach((s, idx) => {\n      gsap.to(s.position, { \n        x: s.position.x + (idx - 1) * 4, \n        y: 12, \n        z: s.position.z + (Math.random() - 0.5) * 8, \n        duration: 1.2, \n        ease: \"power3.out\" \n      });\n      gsap.to(s.rotation, { x: 4, z: 4, duration: 1.5 });\n    });\n  };\n\n  document.getElementById('coin-toss').addEventListener('click', () => {\n    gsap.to(coin.position, { y: 15, duration: 0.8, ease: \"power2.out\", yoyo: true, repeat: 1 });\n    gsap.to(coin.rotation, { x: coin.rotation.x + Math.PI * 16, duration: 1.6, ease: \"expo.out\" });\n  });\n\n  // RENDER LOOP\n  function animate() {\n    requestAnimationFrame(animate);\n    ball.rotation.y += 0.01;\n    gallery.rotation.y += 0.003;\n    renderer.render(scene, camera);\n  }\n\n  window.addEventListener('resize', () => {\n    camera.aspect = window.innerWidth / window.innerHeight;\n    camera.updateProjectionMatrix();\n    renderer.setSize(window.innerWidth, window.innerHeight);\n  });\n\n  animate();\n</script>\n",
