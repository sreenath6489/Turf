        "config": {}
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    margin: 0;\n    padding: 0;\n    overflow-x: hidden;\n    background-color: #0F172A;\n    font-family: 'Outfit', sans-serif;\n    color: #F8FAFC;\n  }\n\n  canvas {\n    display: block;\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100vw;\n    height: 100vh;\n    z-index: 1;\n  }\n\n  .ui-layer {\n    position: relative;\n    z-index: 10;\n    pointer-events: none;\n  }\n\n  .section {\n    height: 100vh;\n    width: 100%;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    padding: 0 10%;\n    pointer-events: none;\n  }\n\n  .interactive {\n    pointer-events: auto;\n  }\n\n  .glass-panel {\n    background: rgba(248, 256, 252, 0.05);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    border-radius: 1.5rem;\n  }\n\n  .led-screen {\n    background: #000;\n    border: 8px solid #334155;\n    box-shadow: 0 0 20px rgba(251, 191, 36, 0.2);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .led-screen::after {\n    content: \"\";\n    position: absolute;\n    top: 0; left: 0; right: 0; bottom: 0;\n    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));\n    background-size: 100% 4px, 3px 100%;\n    pointer-events: none;\n  }\n\n  .tactile-btn {\n    transition: transform 0.1s cubic-bezier(0.4, 0, 0.2, 1);\n    box-shadow: 0 4px 0 #1E293B;\n  }\n\n  .tactile-btn:active {\n    transform: translateY(4px);\n    box-shadow: 0 0 0 #1E293B;\n  }\n\n  .letterbox-top, .letterbox-bottom {\n    position: fixed;\n    left: 0;\n    width: 100%;\n    height: 10%;\n    background: #0F172A;\n    z-index: 20;\n    pointer-events: none;\n  }\n\n  .letterbox-top { top: 0; }\n  .letterbox-bottom { bottom: 0; }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: #FBBF24; border-radius: 10px; }\n</style>\n\n\n<div id=\"letterbox-top\" class=\"letterbox-top opacity-0\" data-kid=\"1\"></div>\n<div id=\"letterbox-bottom\" class=\"letterbox-bottom opacity-0\" data-kid=\"2\"></div>\n\n<canvas id=\"stadium-canvas\" data-kid=\"3\"></canvas>\n\n<div class=\"ui-layer\" data-kid=\"4\">\n  \n  <section class=\"section\" data-kid=\"5\">\n    <div class=\"max-w-2xl text-left\" id=\"hero-content\" data-kid=\"6\">\n      <h1 class=\"text-8xl font-extrabold leading-tight text-[#F8FAFC] tracking-tighter uppercase italic\" data-kid=\"7\">\n        Turf Score <span class=\"text-[#FBBF24]\" data-kid=\"8\">Pro</span>\n      </h1>\n      <p class=\"text-xl mt-6 text-[#94A3B8] max-w-lg\" data-kid=\"9\">\n        The most immersive 3D cricket experience ever created. Fly through the stadium, track live scores, and feel the roar of the crowd.\n      </p>\n      <div class=\"mt-10 flex gap-6\" data-kid=\"10\">\n        <button class=\"interactive px-10 py-5 bg-[#FBBF24] text-[#0F172A] font-bold rounded-full uppercase tracking-widest hover:scale-105 transition-transform\" data-kid=\"11\">\n          Step Into the Turf\n        </button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"section items-center\" data-kid=\"12\">\n    <div class=\"w-full max-w-4xl\" id=\"scoreboard-ui\" data-kid=\"13\">\n      <div class=\"led-screen rounded-2xl p-8 flex flex-col items-center\" data-kid=\"14\">\n        <div class=\"flex justify-between w-full border-b border-white/10 pb-4 mb-6\" data-kid=\"15\">\n          <span class=\"text-[#FBBF24] font-bold text-lg uppercase tracking-widest\" data-kid=\"16\">Live Match: IND vs AUS</span>\n          <span class=\"text-white/60 font-mono\" data-kid=\"17\">Overs: 18.4</span>\n        </div>\n        <div class=\"text-9xl font-mono text-[#FBBF24] tracking-widest mb-4\" id=\"live-score\" data-kid=\"18\">\n          245/4\n        </div>\n        <div class=\"grid grid-cols-4 gap-6 w-full mt-10\" data-kid=\"19\">\n          <button class=\"interactive tactile-btn bg-white/5 border border-white/10 p-6 rounded-xl text-center group\" onclick=\"addScore(1)\" data-kid=\"20\">\n            <span class=\"block text-4xl font-bold group-hover:text-[#FBBF24] transition-colors\" data-kid=\"21\">1</span>\n            <span class=\"text-xs text-white/40 uppercase mt-2\" data-kid=\"22\">Single</span>\n          </button>\n          <button class=\"interactive tactile-btn bg-white/5 border border-white/10 p-6 rounded-xl text-center group\" onclick=\"addScore(2)\" data-kid=\"23\">\n            <span class=\"block text-4xl font-bold group-hover:text-[#FBBF24] transition-colors\" data-kid=\"24\">2</span>\n            <span class=\"text-xs text-white/40 uppercase mt-2\" data-kid=\"25\">Double</span>\n          </button>\n          <button class=\"interactive tactile-btn bg-white/5 border border-white/10 p-6 rounded-xl text-center group\" onclick=\"addScore(4)\" data-kid=\"26\">\n            <span class=\"block text-4xl font-bold text-orange-400 group-hover:text-[#FBBF24] transition-colors\" data-kid=\"27\">4</span>\n            <span class=\"text-xs text-white/40 uppercase mt-2\" data-kid=\"28\">Boundary</span>\n          </button>\n          <button class=\"interactive tactile-btn bg-white/5 border border-white/10 p-6 rounded-xl text-center group\" onclick=\"addScore(6)\" data-kid=\"29\">\n            <span class=\"block text-4xl font-bold text-[#FBBF24] transition-colors\" data-kid=\"30\">6</span>\n            <span class=\"text-xs text-white/40 uppercase mt-2\" data-kid=\"31\">Maximum</span>\n          </button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"section items-end\" data-kid=\"32\">\n    <div class=\"w-full max-w-md p-8 glass-panel\" id=\"sound-ui\" data-kid=\"33\">\n      <h2 class=\"text-3xl font-bold mb-6 flex items-center gap-3 text-[#FBBF24]\" data-kid=\"34\">\n        <i class=\"ti ti-microphone text-4xl\" data-kid=\"35\"></i> Commentary Box\n      </h2>\n      <div class=\"space-y-6\" data-kid=\"36\">\n        <div class=\"interactive group p-4 rounded-xl border border-white/5 hover:border-[#FBBF24]/30 bg-white/5 cursor-pointer flex items-center justify-between\" data-kid=\"37\">\n          <div data-kid=\"38\">\n            <h3 class=\"font-bold\" data-kid=\"39\">AI Ravi Shastri</h3>\n            <p class=\"text-xs text-white/40 italic\" data-kid=\"40\">\"It goes like a tracer bullet!\"</p>\n          </div>\n          <i class=\"ti ti-player-play text-2xl text-[#FBBF24]\" data-kid=\"41\"></i>\n        </div>\n        <div class=\"interactive group p-4 rounded-xl border border-white/5 hover:border-[#FBBF24]/30 bg-white/5 cursor-pointer flex items-center justify-between\" data-kid=\"42\">\n          <div data-kid=\"43\">\n            <h3 class=\"font-bold\" data-kid=\"44\">Stadium Roar</h3>\n            <p class=\"text-xs text-white/40 italic\" data-kid=\"45\">80,000 screaming fans</p>\n          </div>\n          <i class=\"ti ti-broadcast text-2xl text-white/40 group-hover:text-[#FBBF24]\" data-kid=\"46\"></i>\n        </div>\n        <div class=\"interactive group p-4 rounded-xl border border-white/5 hover:border-[#FBBF24]/30 bg-white/5 cursor-pointer flex items-center justify-between\" data-kid=\"47\">\n          <div data-kid=\"48\">\n            <h3 class=\"font-bold\" data-kid=\"49\">Stump Smash</h3>\n            <p class=\"text-xs text-white/40 italic\" data-kid=\"50\">Realistic physics impact</p>\n          </div>\n          <i class=\"ti ti-award text-2xl text-white/40 group-hover:text-[#FBBF24]\" data-kid=\"51\"></i>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"section\" data-kid=\"52\">\n    <div id=\"roster-ui\" class=\"w-full\" data-kid=\"53\">\n      <h2 class=\"text-6xl font-black italic tracking-tighter mb-12 uppercase text-[#FBBF24]\" data-kid=\"54\">The Gold Gallery</h2>\n      <div class=\"flex gap-8 overflow-x-hidden\" id=\"card-scroll-container\" data-kid=\"55\">\n        \n        <div class=\"interactive p-6 glass-panel min-w-[300px] border-[#FBBF24]/20\" data-kid=\"56\">\n          <div class=\"h-64 rounded-xl bg-gradient-to-br from-slate-800 to-slate-900 mb-4 overflow-hidden relative\" data-kid=\"57\">\n            <img src=\"https://images.pexels.com/photos/29047136/pexels-photo-29047136.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"w-full h-full object-cover opacity-60\" decoding=\"async\" loading=\"lazy\" data-kid=\"58\">\n            <div class=\"absolute bottom-4 left-4\" data-kid=\"59\">\n              <span class=\"bg-[#FBBF24] text-[#0F172A] px-2 py-1 text-xs font-bold rounded\" data-kid=\"60\">MVP</span>\n            </div>\n          </div>\n          <h3 class=\"text-2xl font-bold uppercase tracking-tight\" data-kid=\"61\">Virat Kohli</h3>\n          <p class=\"text-[#94A3B8] text-sm mb-4\" data-kid=\"62\">Master Blaster • Captain</p>\n          <div class=\"flex justify-between text-xs font-mono text-white/60\" data-kid=\"63\">\n            <span data-kid=\"64\">SR: 145.2</span>\n            <span data-kid=\"65\">AVG: 52.8</span>\n          </div>\n        </div>\n        \n        <div class=\"interactive p-6 glass-panel min-w-[300px] opacity-40 grayscale\" data-kid=\"66\">\n          <div class=\"h-64 rounded-xl bg-slate-800 mb-4 overflow-hidden\" data-kid=\"67\">\n             <img src=\"https://images.pexels.com/photos/20652472/pexels-photo-20652472.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"w-full h-full object-cover opacity-60\" decoding=\"async\" loading=\"lazy\" data-kid=\"68\">\n          </div>\n          <h3 class=\"text-2xl font-bold uppercase tracking-tight\" data-kid=\"69\">Jasprit Bumrah</h3>\n          <p class=\"text-[#94A3B8] text-sm mb-4\" data-kid=\"70\"> Yorker King • Fast</p>\n           <div class=\"flex justify-between text-xs font-mono text-white/60\" data-kid=\"71\">\n            <span data-kid=\"72\">WKT: 24</span>\n            <span data-kid=\"73\">ECON: 6.2</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"section items-center\" data-kid=\"74\">\n    <div class=\"w-full max-w-5xl flex gap-10\" id=\"wrap-ui\" data-kid=\"75\">\n      <div class=\"flex-1 glass-panel p-10\" data-kid=\"76\">\n        <h2 class=\"text-4xl font-bold mb-8 text-[#FBBF24]\" data-kid=\"77\">Post-Match Summary</h2>\n        <div class=\"grid grid-cols-2 gap-8\" data-kid=\"78\">\n          <div class=\"p-6 bg-white/5 rounded-2xl border border-white/10\" data-kid=\"79\">\n            <span class=\"text-white/40 uppercase text-xs font-bold tracking-widest mb-2 block\" data-kid=\"80\">Orange Cap</span>\n            <div class=\"text-2xl font-bold\" data-kid=\"81\">V. Kohli (112*)</div>\n          </div>\n          <div class=\"p-6 bg-white/5 rounded-2xl border border-white/10\" data-kid=\"82\">\n            <span class=\"text-white/40 uppercase text-xs font-bold tracking-widest mb-2 block\" data-kid=\"83\">Purple Cap</span>\n            <div class=\"text-2xl font-bold\" data-kid=\"84\">J. Bumrah (3/42)</div>\n          </div>\n        </div>\n        <div class=\"mt-10 p-8 border-2 border-dashed border-[#FBBF24]/30 rounded-2xl text-center\" data-kid=\"85\">\n          <p class=\"text-white/60 mb-6 italic\" data-kid=\"86\">Drag and drop 3D badges to create your custom highlight poster.</p>\n          <button class=\"interactive px-8 py-4 bg-[#FBBF24] text-[#0F172A] font-bold rounded-lg uppercase text-sm tracking-widest\" data-kid=\"87\">\n            Export Poster (PNG)\n          </button>\n        </div>\n      </div>\n      <div class=\"w-1/3 space-y-4\" data-kid=\"88\">\n        <div class=\"interactive p-4 glass-panel border-[#FBBF24]/40 flex items-center gap-4\" data-kid=\"89\">\n          <div class=\"w-12 h-12 rounded bg-[#FBBF24] flex items-center justify-center text-[#0F172A]\" data-kid=\"90\">\n            <i class=\"ti ti-award text-2xl\" data-kid=\"91\"></i>\n          </div>\n          <span class=\"font-bold uppercase tracking-tight\" data-kid=\"92\">Championship Badge</span>\n        </div>\n        <div class=\"interactive p-4 glass-panel flex items-center gap-4 opacity-60\" data-kid=\"93\">\n          <div class=\"w-12 h-12 rounded bg-slate-700 flex items-center justify-center text-white\" data-kid=\"94\">\n            <i class=\"ti ti-star text-2xl\" data-kid=\"95\"></i>\n          </div>\n          <span class=\"font-bold uppercase tracking-tight\" data-kid=\"96\">Star Performer</span>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js\" data-kid=\"97\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"98\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"99\"></script>\n\n<script data-kid=\"100\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // --- THREE.JS SCENE SETUP ---\n  const canvas = document.querySelector('#stadium-canvas');\n  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });\n  renderer.setSize(window.innerWidth, window.innerHeight);\n  renderer.setPixelRatio(window.devicePixelRatio);\n  renderer.shadowMap.enabled = true;\n  renderer.toneMapping = THREE.ACESFilmicToneMapping;\n\n  const scene = new THREE.Scene();\n  const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);\n  camera.position.set(0, 0.5, 5);\n\n  // Lighting (Golden Hour Bloom)\n  const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);\n  scene.add(ambientLight);\n\n  const sunLight = new THREE.DirectionalLight(0xFBBF24, 1.8);\n  sunLight.position.set(10, 5, 5);\n  sunLight.castShadow = true;\n  sunLight.shadow.mapSize.width = 2048;\n  sunLight.shadow.mapSize.height = 2048;\n  scene.add(sunLight);\n\n  // Environment fog for depth\n  scene.fog = new THREE.FogExp2(0x0F172A, 0.05);\n\n  // --- MOCK MODELS ---\n\n  // Grass Floor\n  const grassTexture = new THREE.TextureLoader().load('https://images.pexels.com/photos/11255754/pexels-photo-11255754.jpeg?auto=compress&cs=tinysrgb&w=1440&q=80');\n  grassTexture.wrapS = grassTexture.wrapT = THREE.RepeatWrapping;\n  grassTexture.repeat.set(20, 20);\n  const floor = new THREE.Mesh(\n    new THREE.PlaneGeometry(100, 100),\n    new THREE.MeshStandardMaterial({ map: grassTexture, roughness: 0.8 })\n  );\n  floor.rotation.x = -Math.PI / 2;\n  floor.receiveShadow = true;\n  scene.add(floor);\n\n  // Section 1: 3D Cricket Ball\n  const ballGroup = new THREE.Group();\n  const ballGeom = new THREE.SphereGeometry(0.12, 64, 64);\n  const ballMat = new THREE.MeshStandardMaterial({ color: 0x991b1b, roughness: 0.3 });\n  const ball = new THREE.Mesh(ballGeom, ballMat);\n  ball.castShadow = true;\n  ball.position.y = 0.12;\n  ballGroup.add(ball);\n  ballGroup.position.set(-2, 0, 0);\n  scene.add(ballGroup);\n\n  // Section 1: 3D Gold Coin\n  const coinGeom = new THREE.CylinderGeometry(0.3, 0.3, 0.05, 32);\n  const coinMat = new THREE.MeshStandardMaterial({ color: 0xFBBF24, metalness: 0.8, roughness: 0.2 });\n  const coin = new THREE.Mesh(coinGeom, coinMat);\n  coin.rotation.x = Math.PI / 2;\n  coin.position.set(2, 1, 0);\n  coin.castShadow = true;\n  scene.add(coin);\n\n  // Section 2: Jumbotron Structure\n  const jumbotron = new THREE.Group();\n  const screenMesh = new THREE.Mesh(\n    new THREE.BoxGeometry(4, 2.5, 0.2),\n    new THREE.MeshStandardMaterial({ color: 0x1e293b })\n  );\n  screenMesh.position.y = 4;\n  jumbotron.add(screenMesh);\n  jumbotron.position.z = -10;\n  scene.add(jumbotron);\n\n  // Section 3: Commentary Desk & Stumps\n  const stumps = new THREE.Group();\n  for(let i=0; i<3; i++) {\n    const stump = new THREE.Mesh(\n      new THREE.CylinderGeometry(0.02, 0.02, 0.7, 16),\n      new THREE.MeshStandardMaterial({ color: 0xf3f4f6 })\n    );\n    stump.position.x = (i - 1) * 0.1;\n    stump.position.y = 0.35;\n    stumps.add(stump);\n  }\n  stumps.position.set(5, 0, -20);\n  scene.add(stumps);\n\n  const desk = new THREE.Mesh(\n    new THREE.BoxGeometry(2, 0.8, 1),\n    new THREE.MeshStandardMaterial({ color: 0xffffff })\n  );\n  desk.position.set(3, 0.4, -20);\n  scene.add(desk);\n\n  // Section 4: Locker Room Walls\n  const lockerWall = new THREE.Mesh(\n    new THREE.PlaneGeometry(10, 5),\n    new THREE.MeshStandardMaterial({ color: 0x1e293b, roughness: 0.9 })\n  );\n  lockerWall.position.set(0, 2.5, -40);\n  scene.add(lockerWall);\n\n  // --- ANIMATION TIMELINE (Scroll Triggered) ---\n  const tl = gsap.timeline({\n    scrollTrigger: {\n      trigger: \"body\",\n      start: \"top top\",\n      end: \"bottom bottom\",\n      scrub: 1.5,\n    }\n  });\n\n  // Camera Path through sections\n  tl.to(camera.position, { x: 0, y: 1.5, z: 2, duration: 1 }) // To Section 1 (Close up)\n    .to(camera.rotation, { x: -0.2, duration: 1 }, \"<\")\n    .to(\"#letterbox-top, #letterbox-bottom\", { opacity: 1, duration: 0.2 }, 0)\n    \n    .to(camera.position, { x: 0, y: 3, z: -5, duration: 1 }) // To Section 2 (Jumbotron)\n    .to(camera.rotation, { x: 0.1, duration: 1 }, \"<\")\n    .to(\"#letterbox-top, #letterbox-bottom\", { opacity: 0, duration: 0.2 }, 1)\n\n    .to(camera.position, { x: 4, y: 1, z: -18, duration: 1 }) // To Section 3 (Desk)\n    .to(camera.rotation, { y: -Math.PI / 4, duration: 1 }, \"<\")\n\n    .to(camera.position, { x: 0, y: 1.8, z: -35, duration: 1 }) // To Section 4 (Locker)\n    .to(camera.rotation, { y: 0, x: 0, duration: 1 }, \"<\")\n\n    .to(camera.position, { x: 0, y: 15, z: -10, duration: 1 }) // To Section 5 (Birds Eye)\n    .to(camera.rotation, { x: -Math.PI / 2, duration: 1 }, \"<\");\n\n  // Parallax / Hover effects\n  window.addEventListener('mousemove', (e) => {\n    const x = (e.clientX / window.innerWidth - 0.5) * 0.1;\n    const y = (e.clientY / window.innerHeight - 0.5) * 0.1;\n    gsap.to(camera.position, {\n      x: camera.position.x + x,\n      y: camera.position.y - y,\n      duration: 1,\n      ease: \"power2.out\"\n    });\n    \n    // Coin tilt\n    gsap.to(coin.rotation, {\n      y: coin.rotation.y + x * 5,\n      x: Math.PI / 2 + y * 5,\n      duration: 1\n    });\n  });\n\n  // Coin Flip Interaction\n  let isFlipping = false;\n  window.addEventListener('click', (e) => {\n    if(camera.position.z > 0 && !isFlipping) {\n       isFlipping = true;\n       gsap.to(coin.rotation, {\n         y: \"+=\" + Math.PI * 8,\n         duration: 1.5,\n         ease: \"power4.inOut\",\n         onComplete: () => isFlipping = false\n       });\n       gsap.to(coin.position, {\n         y: 2.5,\n         duration: 0.75,\n         yoyo: true,\n         repeat: 1,\n         ease: \"power2.out\"\n       });\n    }\n  });\n\n  // Score UI update logic\n  function addScore(runs) {\n    const scoreEl = document.getElementById('live-score');\n    let [runsCount, wickets] = scoreEl.innerText.split('/');\n    runsCount = parseInt(runsCount) + runs;\n    scoreEl.innerText = `${runsCount}/${wickets}`;\n    \n    // Animate bat swing in 3D (Simulated)\n    gsap.to(ballGroup.position, {\n      z: \"-=50\",\n      x: \"+=\" + (Math.random() - 0.5) * 20,\n      duration: 2,\n      ease: \"power2.out\",\n      onComplete: () => {\n        ballGroup.position.set(-2, 0, 0);\n      }\n    });\n\n    if(runs === 6) {\n      // Trigger Golden Flash\n      gsap.to(sunLight, { intensity: 4, duration: 0.1, yoyo: true, repeat: 1 });\n    }\n  }\n\n  // Animation Loop\n  function animate() {\n    requestAnimationFrame(animate);\n    \n    // Idle animations\n    ball.rotation.y += 0.01;\n    if(!isFlipping) coin.rotation.y += 0.005;\n    \n    renderer.render(scene, camera);\n  }\n  animate();\n\n  // Resize handler\n  window.addEventListener('resize', () => {\n    camera.aspect = window.innerWidth / window.innerHeight;\n    camera.updateProjectionMatrix();\n    renderer.setSize(window.innerWidth, window.innerHeight);\n  });\n</script>",
