      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Outfit:wght@300;400;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    margin: 0;\n    overflow-x: hidden;\n    background-color: #FFFFF0;\n    color: #0B0E14;\n    font-family: 'Outfit', sans-serif;\n  }\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n\n  #webgl-canvas {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100vh;\n    z-index: 1;\n    pointer-events: none;\n  }\n\n  section {\n    position: relative;\n    height: 100vh;\n    width: 100%;\n    z-index: 10;\n    display: flex;\n    align-items: center;\n    padding: 0 8%;\n  }\n\n  .rotary-dial {\n    width: 320px;\n    height: 320px;\n    border-radius: 50%;\n    border: 1px solid #D4AF37;\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .rotary-item {\n    position: absolute;\n    width: 54px;\n    height: 54px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-radius: 50%;\n    background: #FFFFF0;\n    border: 1px solid #D4AF37;\n    color: #0B0E14;\n    font-size: 1.4rem;\n    transition: all 0.4s ease;\n  }\n\n  .rotary-item:hover {\n    background: #D4AF37;\n    color: #FFFFF0;\n    transform: scale(1.15);\n    box-shadow: 0 0 25px rgba(212, 175, 55, 0.4);\n  }\n\n  .score-btn {\n    transition: all 0.4s cubic-bezier(0.2, 1, 0.3, 1);\n  }\n\n  .score-btn:hover {\n    background: #0B0E14;\n    color: #FFFFF0;\n    transform: translateY(-4px);\n    box-shadow: 0 10px 20px rgba(11, 14, 20, 0.15);\n  }\n\n  .polaroid-card {\n    min-width: 320px;\n    height: 420px;\n    background: #FFFFF0;\n    border: 1px solid #D4AF37/20;\n    padding: 24px;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n    transition: transform 0.6s cubic-bezier(0.2, 1, 0.3, 1);\n    box-shadow: 0 4px 15px rgba(0,0,0,0.05);\n  }\n\n  /* Section-specific scroll classes */\n  .section-overlay {\n    opacity: 0;\n    transform: translateY(40px);\n    transition: all 1s cubic-bezier(0.2, 1, 0.3, 1);\n  }\n\n  .is-visible .section-overlay {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  ::-webkit-scrollbar { display: none; }\n</style>\n\n<div id=\"smooth-wrapper\" data-kid=\"1\">\n  <div id=\"smooth-content\" data-kid=\"2\">\n    \n    \n    <div id=\"webgl-canvas\" data-kid=\"3\"></div>\n\n    \n    <section id=\"hero\" class=\"flex flex-col lg:flex-row items-center justify-between is-visible\" data-kid=\"4\">\n      <div class=\"w-full lg:w-[45%] bg-[#FFFFF0] p-16 lg:p-24 z-20 h-full flex flex-col justify-center border-r border-[#D4AF37]/10\" data-kid=\"5\">\n        <span class=\"text-[#D4AF37] uppercase tracking-[0.6em] text-xs font-bold mb-8 block\" data-kid=\"6\">Est. 2024</span>\n        <h1 class=\"font-serif text-8xl lg:text-[10rem] font-black leading-[0.85] mb-8 text-[#0B0E14]\" data-kid=\"7\">\n          TURF<br data-kid=\"8\">SCORE<br data-kid=\"9\"><span class=\"text-[#D4AF37]\" data-kid=\"10\">PRO</span>\n        </h1>\n        <p class=\"text-xl max-w-sm mb-12 text-[#0B0E14]/60 font-light leading-relaxed tracking-wide\" data-kid=\"11\">\n          Ultra-modern minimalism meets the timeless heritage of the Lord's pavilion.\n        </p>\n        <button class=\"w-fit px-12 py-6 bg-[#0B0E14] text-[#FFFFF0] rounded-none font-semibold uppercase tracking-widest text-sm hover:bg-[#D4AF37] transition-all duration-500 relative group overflow-hidden\" data-kid=\"12\">\n          <span class=\"relative z-10\" data-kid=\"13\">Step Into the Turf</span>\n          <div class=\"absolute inset-0 bg-[#D4AF37] translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out\" data-kid=\"14\"></div>\n        </button>\n      </div>\n      \n      <div class=\"hidden lg:flex w-[55%] h-full items-center justify-center relative\" data-kid=\"15\">\n        <div id=\"toss-trigger\" class=\"w-40 h-40 rounded-full border border-[#D4AF37] flex items-center justify-center cursor-pointer group z-30 bg-[#FFFFF0]/40 backdrop-blur-md\" data-kid=\"16\">\n          <div class=\"w-32 h-32 rounded-full bg-[#D4AF37] flex items-center justify-center text-[#FFFFF0] text-4xl font-bold transition-transform duration-700 group-hover:rotate-[360deg] shadow-xl\" data-kid=\"17\">\n            <i class=\"ti ti-coin\" data-kid=\"18\"></i>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"scoreboard\" class=\"flex flex-col items-center justify-center\" data-kid=\"19\">\n      <div class=\"section-overlay w-full max-w-6xl px-8\" data-kid=\"20\">\n        <div class=\"grid grid-cols-12 gap-0 border-t border-b border-[#D4AF37]/20 py-16\" data-kid=\"21\">\n          <div class=\"col-span-12 lg:col-span-4 lg:border-r border-[#D4AF37]/20 px-12 py-4\" data-kid=\"22\">\n            <h3 class=\"uppercase tracking-[0.3em] text-[10px] font-bold text-[#D4AF37] mb-4\" data-kid=\"23\">MATCH STATUS</h3>\n            <div class=\"font-serif text-[7rem] leading-none text-[#0B0E14]\" data-kid=\"24\">184<span class=\"text-3xl opacity-30 ml-2\" data-kid=\"25\">/4</span></div>\n          </div>\n          <div class=\"col-span-12 lg:col-span-5 lg:border-r border-[#D4AF37]/20 px-12 py-4 flex flex-col justify-center\" data-kid=\"26\">\n            <div class=\"flex justify-between items-end mb-6\" data-kid=\"27\">\n              <span class=\"uppercase tracking-[0.3em] text-[10px] font-bold text-[#0B0E14]/40\" data-kid=\"28\">WIN PROBABILITY</span>\n              <span class=\"font-serif text-4xl text-[#D4AF37]\" data-kid=\"29\">72%</span>\n            </div>\n            <div class=\"w-full h-[1px] bg-[#0B0E14]/10 relative\" data-kid=\"30\">\n              <div class=\"absolute top-0 left-0 h-[2px] -translate-y-[0.5px] bg-[#D4AF37]\" style=\"width: 72%\" data-kid=\"31\"></div>\n            </div>\n          </div>\n          <div class=\"col-span-12 lg:col-span-3 px-12 py-4 flex flex-col justify-center\" data-kid=\"32\">\n            <h3 class=\"uppercase tracking-[0.3em] text-[10px] font-bold text-[#D4AF37] mb-4\" data-kid=\"33\">RUN RATE</h3>\n            <div class=\"font-serif text-6xl text-[#0B0E14]\" data-kid=\"34\">9.20</div>\n          </div>\n        </div>\n        \n        <div class=\"mt-16 flex justify-end gap-8\" data-kid=\"35\">\n          <button class=\"score-btn w-20 h-20 border border-[#0B0E14]/10 flex items-center justify-center font-serif text-2xl\" data-runs=\"1\" data-kid=\"36\">1</button>\n          <button class=\"score-btn w-20 h-20 border border-[#0B0E14]/10 flex items-center justify-center font-serif text-2xl\" data-runs=\"4\" data-kid=\"37\">4</button>\n          <button class=\"score-btn w-20 h-20 border border-[#0B0E14]/10 flex items-center justify-center font-serif text-2xl\" data-runs=\"6\" data-kid=\"38\">6</button>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"sounds\" class=\"flex flex-col items-center justify-center\" data-kid=\"39\">\n      <div class=\"section-overlay text-center\" data-kid=\"40\">\n        <span class=\"text-[#D4AF37] uppercase tracking-[0.4em] text-[10px] font-bold mb-8 block\" data-kid=\"41\">Aural Experience</span>\n        <h2 class=\"font-serif text-7xl mb-16 tracking-tight\" data-kid=\"42\">THE COMMENTARY BOX</h2>\n        \n        <div class=\"rotary-dial mx-auto\" id=\"sound-dial\" data-kid=\"43\">\n          <div class=\"rotary-item\" style=\"top: -27px; left: 133px;\" title=\"Stadium Roar\" data-kid=\"44\"><i class=\"ti ti-users\" data-kid=\"45\"></i></div>\n          <div class=\"rotary-item\" style=\"top: 55px; right: -27px;\" title=\"Ravi Shastri\" data-kid=\"46\"><i class=\"ti ti-microphone\" data-kid=\"47\"></i></div>\n          <div class=\"rotary-item\" style=\"bottom: 55px; right: -27px;\" title=\"Stump Smash\" data-kid=\"48\"><i class=\"ti ti-cricket\" data-kid=\"49\"></i></div>\n          <div class=\"rotary-item\" style=\"bottom: -27px; left: 133px;\" title=\"Applause\" data-kid=\"50\"><i class=\"ti ti-medal\" data-kid=\"51\"></i></div>\n          <div class=\"rotary-item\" style=\"bottom: 55px; left: -27px;\" title=\"Umpire\" data-kid=\"52\"><i class=\"ti ti-hand-stop\" data-kid=\"53\"></i></div>\n          <div class=\"rotary-item\" style=\"top: 55px; left: -27px;\" title=\"Wicket\" data-kid=\"54\"><i class=\"ti ti-stump\" data-kid=\"55\"></i></div>\n          \n          <div class=\"w-[140px] h-[140px] border border-[#D4AF37]/20 rounded-full flex items-center justify-center bg-[#FFFFF0] shadow-inner\" data-kid=\"56\">\n            <i class=\"ti ti-broadcast text-5xl text-[#D4AF37] animate-pulse\" data-kid=\"57\"></i>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"roster\" class=\"flex items-end pb-32\" data-kid=\"58\">\n      <div class=\"section-overlay w-full\" data-kid=\"59\">\n        <div class=\"max-w-xl mb-20\" data-kid=\"60\">\n          <h2 class=\"font-serif text-8xl mb-6\" data-kid=\"61\">GOLD ROSTER</h2>\n          <div class=\"h-[1px] w-40 bg-[#D4AF37] mb-8\" data-kid=\"62\"></div>\n          <p class=\"text-[#0B0E14]/50 font-light text-xl leading-relaxed\" data-kid=\"63\">\n            Handpicked icons of the modern game, preserved in holographic gold polaroids upon the hallowed turf.\n          </p>\n        </div>\n        \n        <div class=\"flex gap-12 overflow-x-auto pb-16 scroll-smooth snap-x\" data-kid=\"64\">\n          <div class=\"polaroid-card snap-center group cursor-pointer hover:border-[#D4AF37]\" data-kid=\"65\">\n            <span class=\"text-[#D4AF37] font-serif text-3xl mb-4\" data-kid=\"66\">01</span>\n            <h3 class=\"font-serif text-5xl uppercase leading-none mb-2\" data-kid=\"67\">V. KOHLI</h3>\n            <p class=\"text-[10px] tracking-[0.3em] text-[#0B0E14]/40 uppercase font-bold\" data-kid=\"68\">LEGENDARY BATSMAN</p>\n            <div class=\"mt-8 flex justify-between items-end\" data-kid=\"69\">\n              <div class=\"text-[10px] font-bold text-[#D4AF37]\" data-kid=\"70\">IND / BATTING</div>\n              <i class=\"ti ti-chevron-right text-[#D4AF37] opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"71\"></i>\n            </div>\n          </div>\n          <div class=\"polaroid-card snap-center group cursor-pointer hover:border-[#D4AF37] opacity-30\" data-kid=\"72\">\n            <span class=\"text-[#D4AF37] font-serif text-3xl mb-4\" data-kid=\"73\">02</span>\n            <h3 class=\"font-serif text-5xl uppercase leading-none mb-2\" data-kid=\"74\">R. SHARMA</h3>\n            <p class=\"text-[10px] tracking-[0.3em] text-[#0B0E14]/40 uppercase font-bold\" data-kid=\"75\">MASTER CAPTAIN</p>\n            <div class=\"mt-8 flex justify-between items-end\" data-kid=\"76\">\n              <div class=\"text-[10px] font-bold text-[#D4AF37]\" data-kid=\"77\">IND / OPENER</div>\n            </div>\n          </div>\n          <div class=\"polaroid-card snap-center group cursor-pointer hover:border-[#D4AF37] opacity-30\" data-kid=\"78\">\n            <span class=\"text-[#D4AF37] font-serif text-3xl mb-4\" data-kid=\"79\">03</span>\n            <h3 class=\"font-serif text-5xl uppercase leading-none mb-2\" data-kid=\"80\">B. STOKES</h3>\n            <p class=\"text-[10px] tracking-[0.3em] text-[#0B0E14]/40 uppercase font-bold\" data-kid=\"81\">ALL-ROUND ICON</p>\n            <div class=\"mt-8 flex justify-between items-end\" data-kid=\"82\">\n              <div class=\"text-[10px] font-bold text-[#D4AF37]\" data-kid=\"83\">ENG / ALL-ROUND</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"wrap\" class=\"flex flex-col items-center justify-center bg-[#0B0E14] text-[#FFFFF0]\" data-kid=\"84\">\n      <div class=\"section-overlay text-center w-full max-w-5xl px-8\" data-kid=\"85\">\n        <span class=\"text-[#D4AF37] uppercase tracking-[0.6em] text-[10px] font-black mb-10 block\" data-kid=\"86\">FINALE WRAP-UP</span>\n        <h2 class=\"font-serif text-[9rem] leading-[0.9] mb-20 tracking-tighter\" data-kid=\"87\">CHAMPIONSHIP<br data-kid=\"88\"><span class=\"text-[#D4AF37]\" data-kid=\"89\">HERITAGE</span></h2>\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-12 mb-24\" data-kid=\"90\">\n          <div class=\"p-12 border border-[#FFFFF0]/5 flex flex-col items-center group cursor-pointer hover:border-[#D4AF37]/50 transition-all duration-700 bg-[#FFFFF0]/[0.02]\" data-kid=\"91\">\n            <i class=\"ti ti-award text-6xl text-[#D4AF37] mb-6 group-hover:scale-110 transition-transform\" data-kid=\"92\"></i>\n            <h4 class=\"font-serif text-2xl tracking-wide\" data-kid=\"93\">MVP TROPHY</h4>\n          </div>\n          <div class=\"p-12 border border-[#FFFFF0]/5 flex flex-col items-center group cursor-pointer hover:border-[#D4AF37]/50 transition-all duration-700 bg-[#FFFFF0]/[0.02]\" data-kid=\"94\">\n            <i class=\"ti ti-trophy text-6xl text-[#D4AF37] mb-6 group-hover:scale-110 transition-transform\" data-kid=\"95\"></i>\n            <h4 class=\"font-serif text-2xl tracking-wide\" data-kid=\"96\">ORANGE CAP</h4>\n          </div>\n          <div class=\"p-12 border border-[#FFFFF0]/5 flex flex-col items-center group cursor-pointer hover:border-[#D4AF37]/50 transition-all duration-700 bg-[#FFFFF0]/[0.02]\" data-kid=\"97\">\n            <i class=\"ti ti-medal-2 text-6xl text-[#D4AF37] mb-6 group-hover:scale-110 transition-transform\" data-kid=\"98\"></i>\n            <h4 class=\"font-serif text-2xl tracking-wide\" data-kid=\"99\">PURPLE CAP</h4>\n          </div>\n        </div>\n        \n        <button class=\"relative inline-block px-16 py-8 border border-[#D4AF37] group cursor-pointer overflow-hidden transition-all hover:shadow-[0_0_40px_rgba(212,175,55,0.2)]\" data-kid=\"100\">\n          <span class=\"font-serif text-3xl relative z-10 text-[#D4AF37] group-hover:text-[#0B0E14] transition-colors duration-500 uppercase tracking-widest\" data-kid=\"101\">Generate Poster</span>\n          <div class=\"absolute inset-0 bg-[#D4AF37] translate-x-[-101%] group-hover:translate-x-0 transition-transform duration-700 cubic-bezier(0.2, 1, 0.3, 1)\" data-kid=\"102\"></div>\n        </button>\n      </div>\n    </section>\n\n  </div>\n</div>\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/0.160.0/three.min.js\" data-kid=\"103\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"104\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"105\"></script>\n\n<script data-kid=\"106\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // THREE.JS SETUP\n  const scene = new THREE.Scene();\n  const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);\n  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });\n  renderer.setSize(window.innerWidth, window.innerHeight);\n  renderer.setPixelRatio(window.devicePixelRatio);\n  document.getElementById('webgl-canvas').appendChild(renderer.domElement);\n\n  // LIGHTING (Bright, High-end Studio)\n  const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);\n  scene.add(ambientLight);\n  const spotLight = new THREE.SpotLight(0xffffff, 1.5);\n  spotLight.position.set(10, 20, 10);\n  scene.add(spotLight);\n\n  // STADIUM TURF\n  const turfGeometry = new THREE.PlaneGeometry(200, 200);\n  const turfMaterial = new THREE.MeshStandardMaterial({ \n    color: 0x10B981, \n    roughness: 0.9,\n    metalness: 0.05\n  });\n  const turf = new THREE.Mesh(turfGeometry, turfMaterial);\n  turf.rotation.x = -Math.PI / 2;\n  scene.add(turf);\n\n  // CRICKET BALL (Red Leather)\n  const ballGeometry = new THREE.SphereGeometry(1.2, 128, 128);\n  const ballMaterial = new THREE.MeshStandardMaterial({ \n    color: 0x8b0000, \n    roughness: 0.3,\n    metalness: 0.4\n  });\n  const ball = new THREE.Mesh(ballGeometry, ballMaterial);\n  ball.position.set(4, 1.2, 0);\n  scene.add(ball);\n\n  // STUMPS (Broadcast Sounds - Golden Metallic)\n  const stumpsGroup = new THREE.Group();\n  const stumpGeom = new THREE.CylinderGeometry(0.12, 0.12, 3.5, 32);\n  const goldMat = new THREE.MeshStandardMaterial({ \n    color: 0xD4AF37, \n    roughness: 0.2,\n    metalness: 0.9 \n  });\n  for(let i = 0; i < 3; i++) {\n    const s = new THREE.Mesh(stumpGeom, goldMat);\n    s.position.x = (i - 1) * 0.45;\n    s.position.y = 1.75;\n    stumpsGroup.add(s);\n  }\n  stumpsGroup.position.set(-15, 0, -25);\n  scene.add(stumpsGroup);\n\n  // POLAROID CARDS (Roster)\n  const polaroids = [];\n  for(let i = 0; i < 5; i++) {\n    const pGeom = new THREE.PlaneGeometry(4, 5);\n    const pMat = new THREE.MeshStandardMaterial({ color: 0xFFFFF0, side: THREE.DoubleSide });\n    const p = new THREE.Mesh(pGeom, pMat);\n    p.position.set(15 + (i * 8), 0.1, -50);\n    p.rotation.x = -Math.PI / 2;\n    scene.add(p);\n    polaroids.push(p);\n  }\n\n  camera.position.z = 12;\n  camera.position.y = 3;\n\n  // RENDER LOOP\n  function animate() {\n    requestAnimationFrame(animate);\n    ball.rotation.y += 0.003;\n    renderer.render(scene, camera);\n  }\n  animate();\n\n  // GSAP SCROLL JOURNEY\n  const cameraPath = gsap.timeline({\n    scrollTrigger: {\n      trigger: \"#smooth-wrapper\",\n      start: \"top top\",\n      end: \"bottom bottom\",\n      scrub: 2,\n    }\n  });\n\n  // Section 1 -> 2: Lift and Rotate Top-Down\n  cameraPath.to(camera.position, { x: 0, y: 30, z: 5, ease: \"none\" })\n    .to(camera.rotation, { x: -Math.PI / 2.1, ease: \"none\" }, 0);\n\n  // Section 2 -> 3: Swoop to Macro Stumps\n  cameraPath.to(camera.position, { x: -15, y: 3, z: -20, ease: \"none\" })\n    .to(camera.rotation, { x: -0.2, y: Math.PI / 3, z: 0, ease: \"none\" });\n\n  // Section 3 -> 4: Glide over Polaroids\n  cameraPath.to(camera.position, { x: 25, y: 2, z: -45, ease: \"none\" })\n    .to(camera.rotation, { x: -0.5, y: 0, z: 0, ease: \"none\" });\n\n  // Section 4 -> 5: Wide Drone Shot\n  cameraPath.to(camera.position, { x: 0, y: 60, z: 20, ease: \"none\" })\n    .to(camera.rotation, { x: -Math.PI / 2.5, ease: \"none\" });\n\n  // INTERACTIONS\n  const tossBtn = document.getElementById('toss-trigger');\n  tossBtn.addEventListener('click', () => {\n    gsap.to(ball.position, { y: 6, duration: 0.6, ease: \"power2.out\", yoyo: true, repeat: 1 });\n    gsap.to(ball.rotation, { x: \"+=10\", z: \"+=5\", duration: 1.2 });\n  });\n\n  const items = document.querySelectorAll('.rotary-item');\n  const dial = document.getElementById('sound-dial');\n  items.forEach((item, index) => {\n    item.addEventListener('mouseenter', () => {\n      gsap.to(dial, { rotation: index * 60, duration: 0.8, ease: \"back.out(1.7)\" });\n      // Shake stumps\n      stumpsGroup.children.forEach(s => {\n        gsap.to(s.rotation, { z: (Math.random() - 0.5) * 0.1, duration: 0.1, yoyo: true, repeat: 3 });\n      });\n    });\n  });\n\n  // Reveal transitions\n  document.querySelectorAll('section').forEach(sec => {\n    ScrollTrigger.create({\n      trigger: sec,\n      start: \"top 60%\",\n      onEnter: () => sec.classList.add('is-visible'),\n      onLeaveBack: () => sec.classList.remove('is-visible')\n    });\n  });\n\n  window.addEventListener('resize', () => {\n    camera.aspect = window.innerWidth / window.innerHeight;\n    camera.updateProjectionMatrix();\n    renderer.setSize(window.innerWidth, window.innerHeight);\n  });\n</script>",
