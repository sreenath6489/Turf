      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;900&display=swap');\n  \n  :root {\n    --color-gold: #F59E0B;\n    --color-gold-glow: rgba(245, 158, 11, 0.3);\n    --color-bg: #0A0705; /* Deep warm black */\n    --color-turf-warm: #3F6212; /* Warm olive green */\n    --font-outfit: 'Outfit', sans-serif;\n  }\n\n  body {\n    margin: 0;\n    background-color: var(--color-bg);\n    font-family: var(--font-outfit);\n    color: white;\n    overflow-x: clip;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  #canvas-container {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100vh;\n    z-index: 1;\n    pointer-events: none;\n  }\n\n  .content-overlay {\n    position: relative;\n    z-index: 10;\n    width: 100%;\n  }\n\n  section {\n    padding: 6rem 8%;\n    position: relative;\n    display: flex;\n    flex-direction: column;\n  }\n\n  .hero-section { min-height: 100vh; justify-content: center; }\n\n  /* New diversified structural panels */\n  .panel-glass {\n    background: rgba(20, 15, 10, 0.6);\n    backdrop-filter: blur(24px);\n    border: 1px solid rgba(245, 158, 11, 0.2);\n    border-radius: 32px;\n  }\n\n  .panel-flat {\n    background: rgba(255, 255, 255, 0.02);\n    border-top: 1px solid rgba(255, 255, 255, 0.05);\n    border-radius: 24px;\n  }\n\n  .glass-ui::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background: linear-gradient(90deg, transparent, rgba(245, 158, 11, 0.4), transparent);\n  }\n\n  .momentum-bar {\n    width: 6px;\n    background: var(--color-gold);\n    border-radius: 3px;\n    filter: drop-shadow(0 0 8px var(--color-gold-glow));\n  }\n\n  /* Custom range slider with visible track */\n  input[type=\"range\"] {\n    -webkit-appearance: none;\n    appearance: none;\n    background: rgba(245, 158, 11, 0.1);\n    height: 5px;\n    border-radius: 2px;\n    outline: none;\n    border: 1px solid rgba(255,255,255,0.05);\n  }\n\n  input[type=\"range\"]::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    width: 14px;\n    height: 14px;\n    background: var(--color-gold);\n    border-radius: 50%;\n    cursor: pointer;\n    box-shadow: 0 0 15px var(--color-gold);\n    border: 2px solid white;\n  }\n\n  /* Typography Enhancements */\n  .text-shadow-gold {\n    text-shadow: 0 0 30px rgba(245, 158, 11, 0.5), 0 0 60px rgba(245, 158, 11, 0.2);\n  }\n\n  /* Force box-border and basic layout without global reset */\n  body, section, div, h1, h2, h3, p, button, input {\n    box-sizing: border-box;\n  }\n\n  .glow-score {\n    text-shadow: 0 0 40px rgba(245, 158, 11, 0.4);\n    letter-spacing: -0.05em;\n  }\n\n  .metallic-badge {\n    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(245, 158, 11, 0.05) 50%, rgba(255,255,255,0.02) 100%);\n    border: 1px solid rgba(245, 158, 11, 0.3);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .metallic-badge::after {\n    content: '';\n    position: absolute;\n    top: -50%;\n    left: -50%;\n    width: 200%;\n    height: 200%;\n    background: linear-gradient(45deg, transparent 0%, rgba(255,255,255,0.1) 50%, transparent 100%);\n    transform: rotate(45deg);\n    pointer-events: none;\n  }\n\n  .holographic-glow {\n    position: relative;\n  }\n  .holographic-glow::after {\n    content: '';\n    position: absolute;\n    inset: -2px;\n    background: linear-gradient(45deg, transparent, rgba(245, 158, 11, 0.2), transparent);\n    z-index: -1;\n    filter: blur(10px);\n    opacity: 0;\n    transition: opacity 0.3s;\n  }\n  .holographic-glow:hover::after {\n    opacity: 1;\n  }\n\n  .btn-gold {\n    background: linear-gradient(135deg, #F59E0B 0%, #B45309 100%);\n    color: black;\n    font-weight: 800;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    padding: 1.25rem 2.5rem;\n    border-radius: 9999px;\n    box-shadow: 0 0 30px rgba(245, 158, 11, 0.3);\n    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n    border: 1px solid rgba(255, 255, 255, 0.2);\n  }\n\n  .btn-gold:hover {\n    transform: translateY(-2px) scale(1.02);\n    box-shadow: 0 0 50px rgba(245, 158, 11, 0.5);\n  }\n\n  .badge-container:hover .badge-icon {\n    transform: translateY(-5px) rotate(5deg);\n  }\n  \n  .badge-icon {\n    transition: transform 0.3s ease;\n  }\n\n  /* Hide scrollbar but keep functionality */\n  body::-webkit-scrollbar {\n    display: none;\n  }\n  body {\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n  }\n</style>\n\n\n<div id=\"canvas-container\" data-kid=\"1\"></div>\n\n\n<div class=\"content-overlay\" data-kid=\"2\">\n  \n  \n  <section id=\"hero\" class=\"hero-section\" data-kid=\"3\">\n    <div class=\"max-w-4xl space-y-6\" data-kid=\"4\">\n      <div class=\"flex items-center gap-4 text-orange-500\" data-kid=\"5\">\n        <div class=\"w-8 h-[1px] bg-orange-500\" data-kid=\"6\"></div>\n        <span class=\"font-bold tracking-widest text-xs uppercase\" data-kid=\"7\">Live Stadium Feed • Finale 2026</span>\n      </div>\n      \n      <h1 class=\"text-[clamp(4rem,12vw,10rem)] font-black leading-[0.8] tracking-tighter text-shadow-gold\" data-kid=\"8\">\n        GOLDEN<br data-kid=\"9\">\n        <span class=\"text-[var(--color-gold)]\" data-kid=\"10\">FINALE</span>\n      </h1>\n      \n      <p class=\"text-2xl text-white/50 max-w-2xl leading-relaxed font-light\" data-kid=\"11\">\n        A premium cinematic journey under the amber sky. Master the turf with real-time physics and broadcast-grade spatial analytics.\n      </p>\n      \n      <div class=\"flex items-center gap-8 pt-8\" data-kid=\"12\">\n        <button class=\"btn-gold\" data-kid=\"13\">\n          Enter The Turf\n        </button>\n        \n        <button id=\"coin-trigger\" class=\"flex items-center gap-4 group\" data-kid=\"14\">\n          <div class=\"w-14 h-14 rounded-full panel-glass flex items-center justify-center border-gold/30 group-hover:scale-110 transition-transform\" data-kid=\"15\">\n            <i class=\"ti ti-coins text-2xl text-[var(--color-gold)]\" data-kid=\"16\"></i>\n          </div>\n          <div class=\"text-left\" data-kid=\"17\">\n            <span class=\"block text-[10px] font-black uppercase tracking-widest opacity-40\" data-kid=\"18\">Interactive</span>\n            <span class=\"font-bold text-sm\" data-kid=\"19\">Toss Coin</span>\n          </div>\n        </button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"scoreboard\" class=\"items-center\" data-kid=\"20\">\n    <div class=\"panel-glass w-full max-w-6xl p-12 flex flex-col gap-12\" data-kid=\"21\">\n      <div class=\"flex flex-col md:flex-row justify-between items-start md:items-end gap-8 pb-8 border-b border-white/5\" data-kid=\"22\">\n        <div class=\"space-y-4\" data-kid=\"23\">\n          <div class=\"bg-orange-500/10 border border-orange-500/20 px-3 py-1 rounded-md inline-block\" data-kid=\"24\">\n            <span class=\"text-orange-500 font-bold text-[10px] uppercase tracking-wider\" data-kid=\"25\">Championship Finale</span>\n          </div>\n          <h2 class=\"text-6xl font-black italic tracking-tight uppercase\" data-kid=\"26\">Mumbai Titans <span class=\"text-white/10 not-italic mx-1\" data-kid=\"27\">v</span> Delhi Wolves</h2>\n        </div>\n        <div class=\"text-right\" data-kid=\"28\">\n          <div class=\"text-9xl font-black text-[var(--color-gold)] leading-none tabular-nums glow-score\" id=\"score-val\" data-kid=\"29\">192/4</div>\n          <div class=\"text-sm font-bold opacity-30 mt-4 uppercase tracking-[0.1em]\" data-kid=\"30\">Over 19.4 • REQ 11.5 RR</div>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-4 gap-8\" data-kid=\"31\">\n        <div class=\"panel-flat p-8 group\" data-kid=\"32\">\n          <span class=\"text-xs font-bold opacity-30 uppercase block mb-4\" data-kid=\"33\">Win Prob.</span>\n          <div class=\"flex items-end gap-2\" data-kid=\"34\">\n            <span class=\"text-5xl font-black\" data-kid=\"35\">78</span>\n            <span class=\"text-xl text-orange-500 font-bold mb-1\" data-kid=\"36\">%</span>\n          </div>\n        </div>\n        \n        <div class=\"panel-flat p-8 group\" data-kid=\"37\">\n          <span class=\"text-xs font-bold opacity-30 uppercase block mb-4\" data-kid=\"38\">Stadium Roar</span>\n          <div class=\"flex items-end gap-2 h-12\" data-kid=\"39\">\n            <div class=\"momentum-bar h-1/2 animate-[bounce_1s_infinite]\" data-kid=\"40\"></div>\n            <div class=\"momentum-bar h-full animate-[bounce_0.8s_infinite]\" data-kid=\"41\"></div>\n            <div class=\"momentum-bar h-2/3 animate-[bounce_1.2s_infinite]\" data-kid=\"42\"></div>\n            <div class=\"momentum-bar h-5/6 animate-[bounce_0.9s_infinite]\" data-kid=\"43\"></div>\n          </div>\n        </div>\n\n        <div class=\"panel-flat p-8 group\" data-kid=\"44\">\n          <span class=\"text-xs font-bold opacity-30 uppercase block mb-4\" data-kid=\"45\">Ball Speed</span>\n          <div class=\"flex items-baseline gap-2\" data-kid=\"46\">\n            <span class=\"text-5xl font-black tabular-nums\" data-kid=\"47\">148</span>\n            <span class=\"text-xs opacity-40 font-bold\" data-kid=\"48\">KMPH</span>\n          </div>\n        </div>\n\n        <div class=\"panel-flat p-8 group\" data-kid=\"49\">\n          <span class=\"text-xs font-bold opacity-30 uppercase block mb-4\" data-kid=\"50\">Required</span>\n          <div class=\"flex items-baseline gap-2\" data-kid=\"51\">\n            <span class=\"text-5xl font-black tabular-nums\" data-kid=\"52\">12</span>\n            <span class=\"text-xs opacity-40 font-bold\" data-kid=\"53\">OFF 3</span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"flex justify-between items-center pt-4\" data-kid=\"54\">\n         <div class=\"flex gap-4\" data-kid=\"55\">\n            <button onclick=\"triggerBat(1)\" class=\"w-12 h-12 rounded-lg panel-flat flex items-center justify-center font-bold hover:bg-gold/10 transition-colors\" data-kid=\"56\">1</button>\n            <button onclick=\"triggerBat(4)\" class=\"w-12 h-12 rounded-lg panel-flat flex items-center justify-center font-black text-gold border border-gold/30 hover:bg-gold/20 transition-colors\" data-kid=\"57\">4</button>\n            <button onclick=\"triggerBat(6)\" class=\"w-12 h-12 rounded-lg panel-flat flex items-center justify-center font-black text-gold border border-gold bg-gold/10 hover:bg-gold/30 transition-colors\" data-kid=\"58\">6</button>\n         </div>\n         <div class=\"text-right max-w-xs\" data-kid=\"59\">\n           <p class=\"text-xs text-white/30 italic\" data-kid=\"60\">\"Pure drama here at the finale. Every ball is an event.\"</p>\n         </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"environment\" class=\"flex flex-row gap-20 items-stretch\" data-kid=\"61\">\n    \n    <div class=\"w-1/3 flex flex-col justify-center\" data-kid=\"62\">\n       <div class=\"panel-glass p-12 space-y-10 h-fit\" data-kid=\"63\">\n          <div class=\"flex items-center gap-4\" data-kid=\"64\">\n            <i class=\"ti ti-flare text-4xl text-gold\" data-kid=\"65\"></i>\n            <h3 class=\"text-3xl font-black tracking-tight uppercase\" data-kid=\"66\">Broadcast Deck</h3>\n          </div>\n          \n          <div class=\"space-y-12\" data-kid=\"67\">\n            <div class=\"space-y-4\" data-kid=\"68\">\n              <label class=\"flex justify-between text-xs font-bold uppercase opacity-40\" data-kid=\"69\">\n                <span data-kid=\"70\">Sunset Glow</span>\n                <span class=\"text-gold\" data-kid=\"71\">Peak</span>\n              </label>\n              <input type=\"range\" class=\"w-full\" value=\"100\" data-kid=\"72\">\n            </div>\n            <div class=\"space-y-4\" data-kid=\"73\">\n              <label class=\"flex justify-between text-xs font-bold uppercase opacity-40\" data-kid=\"74\">\n                <span data-kid=\"75\">Arena Ambience</span>\n                <span class=\"text-gold\" data-kid=\"76\">Immersive</span>\n              </label>\n              <input type=\"range\" class=\"w-full\" value=\"85\" data-kid=\"77\">\n            </div>\n          </div>\n\n          <button onclick=\"triggerWicket()\" class=\"w-full py-5 rounded-xl border border-red-500/40 text-red-400 font-black uppercase text-xs tracking-widest hover:bg-red-500 hover:text-white transition-all\" data-kid=\"78\">\n            Simulate Wicket Event\n          </button>\n       </div>\n    </div>\n\n    \n    <div class=\"w-2/3 flex flex-col justify-center gap-12\" data-kid=\"79\">\n      <div class=\"space-y-4\" data-kid=\"80\">\n        <h2 class=\"text-6xl font-black italic tracking-tighter uppercase\" data-kid=\"81\">Legends Selection</h2>\n        <p class=\"text-white/30 text-xl font-light\" data-kid=\"82\">Interactive cards synced with the 3D stadium environment.</p>\n      </div>\n      \n      <div class=\"grid grid-cols-2 gap-6\" data-kid=\"83\">\n         <div class=\"panel-flat p-8 flex items-center gap-6 hover:translate-y-[-5px] transition-transform cursor-pointer\" data-kid=\"84\">\n           <div class=\"w-16 h-16 rounded-full bg-linear-to-br from-gold/40 to-orange-900 overflow-hidden border-2 border-gold/20\" data-kid=\"85\">\n             <img src=\"https://i.pravatar.cc/100?u=virat\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"86\">\n           </div>\n           <div data-kid=\"87\">\n             <span class=\"block text-xl font-black\" data-kid=\"88\">VIRAT K.</span>\n             <span class=\"text-xs text-gold font-bold uppercase\" data-kid=\"89\">Captain • 82 Runs</span>\n           </div>\n         </div>\n         <div class=\"panel-flat p-8 flex items-center gap-6 hover:translate-y-[-5px] transition-transform cursor-pointer\" data-kid=\"90\">\n           <div class=\"w-16 h-16 rounded-full bg-linear-to-br from-gold/40 to-orange-900 overflow-hidden border-2 border-gold/20\" data-kid=\"91\">\n             <img src=\"https://i.pravatar.cc/100?u=rohit\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"92\">\n           </div>\n           <div data-kid=\"93\">\n             <span class=\"block text-xl font-black\" data-kid=\"94\">ROHIT S.</span>\n             <span class=\"text-xs text-gold font-bold uppercase\" data-kid=\"95\">Opener • 45 Runs</span>\n           </div>\n         </div>\n      </div>\n      \n      <div class=\"flex gap-4\" data-kid=\"96\">\n        <button class=\"w-14 h-14 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/5 transition-colors\" data-kid=\"97\"><i class=\"ti ti-arrow-left\" data-kid=\"98\"></i></button>\n        <button class=\"w-14 h-14 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/5 transition-colors\" data-kid=\"99\"><i class=\"ti ti-arrow-right\" data-kid=\"100\"></i></button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"finale\" class=\"items-center\" data-kid=\"101\">\n    <div class=\"glass-ui w-full max-w-5xl p-12 grid grid-cols-2 gap-20\" data-kid=\"102\">\n      <div class=\"space-y-10\" data-kid=\"103\">\n        <div class=\"space-y-4\" data-kid=\"104\">\n          <h2 class=\"text-6xl font-black leading-tight italic tracking-tighter\" data-kid=\"105\">GOLDEN<br data-kid=\"106\">LEGACY</h2>\n          <p class=\"text-white/40 text-lg leading-relaxed font-light\" data-kid=\"107\">\n            The match concludes. Preserve your favorite moments with a commemorative 3D-infused digital poster.\n          </p>\n        </div>\n        \n        <div class=\"space-y-6\" data-kid=\"108\">\n          <span class=\"text-[10px] font-black opacity-30 uppercase tracking-[0.3em]\" data-kid=\"109\">Signature Assets</span>\n          <div class=\"flex gap-6\" data-kid=\"110\">\n            <div class=\"badge-container group cursor-pointer\" data-kid=\"111\">\n              <div class=\"w-24 h-24 rounded-3xl metallic-badge flex items-center justify-center group-hover:bg-gold/10 transition-all\" data-kid=\"112\">\n                <i class=\"ti ti-trophy text-4xl text-gold badge-icon\" data-kid=\"113\"></i>\n              </div>\n            </div>\n            <div class=\"badge-container group cursor-pointer\" data-kid=\"114\">\n              <div class=\"w-24 h-24 rounded-3xl metallic-badge flex items-center justify-center group-hover:bg-gold/10 transition-all\" data-kid=\"115\">\n                <i class=\"ti ti-medal text-4xl text-orange-400 badge-icon\" data-kid=\"116\"></i>\n              </div>\n            </div>\n            <div class=\"badge-container group cursor-pointer\" data-kid=\"117\">\n              <div class=\"w-24 h-24 rounded-3xl metallic-badge flex items-center justify-center group-hover:bg-gold/10 transition-all\" data-kid=\"118\">\n                <i class=\"ti ti-crown text-4xl text-yellow-200 badge-icon\" data-kid=\"119\"></i>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <button class=\"btn-gold w-full mt-4\" data-kid=\"120\">\n          Export Finale Poster\n        </button>\n      </div>\n\n      <div class=\"relative group\" data-kid=\"121\">\n        <div class=\"absolute -inset-2 bg-linear-to-r from-gold/50 to-orange-500/50 rounded-[40px] blur-3xl opacity-20 group-hover:opacity-40 transition duration-1000\" data-kid=\"122\"></div>\n        <div class=\"relative aspect-[4/5] bg-white rounded-[32px] p-12 flex flex-col shadow-2xl overflow-hidden text-black\" data-kid=\"123\">\n          <div class=\"absolute top-0 left-0 w-full h-3 bg-orange-600\" data-kid=\"124\"></div>\n          \n          <div class=\"flex justify-between items-start mb-16\" data-kid=\"125\">\n            <div class=\"space-y-1\" data-kid=\"126\">\n              <span class=\"block text-[10px] font-black text-black/30 uppercase tracking-[0.2em]\" data-kid=\"127\">Man of the Match</span>\n              <h3 class=\"text-5xl font-black italic\" data-kid=\"128\">ROHIT SHARMA</h3>\n            </div>\n            <div class=\"text-right\" data-kid=\"129\">\n              <span class=\"block text-[10px] font-black text-black/30 uppercase tracking-[0.2em]\" data-kid=\"130\">Strike Rate</span>\n              <div class=\"text-3xl font-black tabular-nums\" data-kid=\"131\">186.4</div>\n            </div>\n          </div>\n\n          <div class=\"flex-grow relative rounded-3xl overflow-hidden bg-slate-50 border border-slate-100 p-6 flex items-center justify-center\" data-kid=\"132\">\n             <div class=\"absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]\" data-kid=\"133\"></div>\n             <i class=\"ti ti-trophy text-[8rem] text-orange-600/10 absolute -bottom-10 -right-10 rotate-12\" data-kid=\"134\"></i>\n             <div class=\"z-10 text-center space-y-4\" data-kid=\"135\">\n                <div class=\"w-32 h-32 rounded-full bg-white shadow-xl mx-auto border-4 border-orange-500 flex items-center justify-center overflow-hidden\" data-kid=\"136\">\n                   <img src=\"https://i.pravatar.cc/150?u=rohit\" class=\"w-full h-full object-cover\" data-kid=\"137\">\n                </div>\n                <div data-kid=\"138\">\n                   <span class=\"block font-black text-2xl\" data-kid=\"139\">82 (44)</span>\n                   <span class=\"text-[10px] font-black uppercase tracking-widest text-black/40\" data-kid=\"140\">Total Contribution</span>\n                </div>\n             </div>\n          </div>\n\n          <div class=\"mt-12 grid grid-cols-3 gap-4\" data-kid=\"141\">\n            <div class=\"text-center p-4 bg-slate-50 rounded-xl\" data-kid=\"142\">\n               <span class=\"block text-[9px] font-bold text-black/30 uppercase\" data-kid=\"143\">4s</span>\n               <span class=\"text-2xl font-black\" data-kid=\"144\">8</span>\n            </div>\n            <div class=\"text-center p-4 bg-slate-50 rounded-xl\" data-kid=\"145\">\n               <span class=\"block text-[9px] font-bold text-black/30 uppercase\" data-kid=\"146\">6s</span>\n               <span class=\"text-2xl font-black\" data-kid=\"147\">5</span>\n            </div>\n            <div class=\"text-center p-4 bg-slate-50 rounded-xl border-l-4 border-orange-500\" data-kid=\"148\">\n               <span class=\"block text-[9px] font-bold text-black/30 uppercase\" data-kid=\"149\">MVP Score</span>\n               <span class=\"text-2xl font-black\" data-kid=\"150\">9.8</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n</div>\n\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/0.160.0/three.min.js\" data-kid=\"151\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"152\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"153\"></script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"154\">\n\n<script data-kid=\"155\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // --- THREE.JS SCENE ---\n  const container = document.getElementById('canvas-container');\n  const scene = new THREE.Scene();\n  \n  // Sunset Gradient Background\n  const skyCanvas = document.createElement('canvas');\n  skyCanvas.width = 256;\n  skyCanvas.height = 256;\n  const ctx = skyCanvas.getContext('2d');\n  const grad = ctx.createLinearGradient(0, 0, 0, 256);\n  grad.addColorStop(0, '#1A0F05'); // Top\n  grad.addColorStop(0.5, '#4B2504'); // Mid\n  grad.addColorStop(1, '#8B4513'); // Horizon\n  ctx.fillStyle = grad;\n  ctx.fillRect(0, 0, 256, 256);\n  scene.background = new THREE.CanvasTexture(skyCanvas);\n  \n  // Golden Hour Fog\n  scene.fog = new THREE.FogExp2('#4B2504', 0.025);\n  \n  const camera = new THREE.PerspectiveCamera(65, window.innerWidth / window.innerHeight, 0.1, 1000);\n  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true, powerPreference: \"high-performance\" });\n  renderer.setSize(window.innerWidth, window.innerHeight);\n  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n  renderer.shadowMap.enabled = true;\n  renderer.shadowMap.type = THREE.PCFSoftShadowMap;\n  renderer.toneMapping = THREE.ReinhardToneMapping;\n  renderer.toneMappingExposure = 1.2;\n  container.appendChild(renderer.domElement);\n\n  // LIGHTING - GOLDEN HOUR\n  const ambientLight = new THREE.AmbientLight(0xFFE4B5, 0.6);\n  scene.add(ambientLight);\n\n  const sunLight = new THREE.DirectionalLight(0xF59E0B, 3.5);\n  sunLight.position.set(20, 10, 20);\n  sunLight.castShadow = true;\n  sunLight.shadow.mapSize.width = 4096;\n  sunLight.shadow.mapSize.height = 4096;\n  sunLight.shadow.camera.near = 0.5;\n  sunLight.shadow.camera.far = 50;\n  sunLight.shadow.camera.left = -20;\n  sunLight.shadow.camera.right = 20;\n  sunLight.shadow.camera.top = 20;\n  sunLight.shadow.camera.bottom = -20;\n  scene.add(sunLight);\n\n  // Backlight for edge glow\n  const rimLight = new THREE.PointLight(0xFFFFFF, 1.5, 50);\n  rimLight.position.set(-10, 5, -10);\n  scene.add(rimLight);\n\n  // MATERIALS & TEXTURES\n  const textureLoader = new THREE.TextureLoader();\n  const grassTex = textureLoader.load('https://images.unsplash.com/photo-1544914379-806667cd9489?auto=format&w=1440&q=80&fit=crop');\n  grassTex.wrapS = grassTex.wrapT = THREE.RepeatWrapping;\n  grassTex.repeat.set(40, 40);\n\n  const ballTex = textureLoader.load('https://images.pexels.com/photos/30401509/pexels-photo-30401509.jpeg?auto=compress&cs=tinysrgb&w=800&q=80');\n\n  // Ground\n  const groundGeo = new THREE.PlaneGeometry(200, 200);\n  const groundMat = new THREE.MeshStandardMaterial({ \n    map: grassTex, \n    color: '#3F6212', \n    roughness: 0.8,\n    metalness: 0.1\n  });\n  const ground = new THREE.Mesh(groundGeo, groundMat);\n  ground.rotation.x = -Math.PI / 2;\n  ground.receiveShadow = true;\n  scene.add(ground);\n\n  // GRASS INSTANCING (Warming up the stadium)\n  const grassCount = 20000;\n  const grassBladeGeo = new THREE.PlaneGeometry(0.12, 0.7);\n  const grassBladeMat = new THREE.MeshStandardMaterial({ \n    color: '#4D7C0F', \n    side: THREE.DoubleSide,\n    transparent: true,\n    alphaTest: 0.5\n  });\n  const instancedGrass = new THREE.InstancedMesh(grassBladeGeo, grassBladeMat, grassCount);\n  const grassDummy = new THREE.Object3D();\n\n  for (let i = 0; i < grassCount; i++) {\n    grassDummy.position.set((Math.random() - 0.5) * 80, 0.35, (Math.random() - 0.5) * 80);\n    grassDummy.rotation.y = Math.random() * Math.PI;\n    grassDummy.rotation.x = (Math.random() - 0.5) * 0.2;\n    grassDummy.scale.set(1, Math.random() * 0.5 + 0.5, 1);\n    grassDummy.updateMatrix();\n    instancedGrass.setMatrixAt(i, grassDummy.matrix);\n  }\n  scene.add(instancedGrass);\n\n  // 1. HERO OBJECTS\n  const ball = new THREE.Mesh(\n    new THREE.SphereGeometry(0.5, 48, 48),\n    new THREE.MeshStandardMaterial({ map: ballTex, roughness: 0.2, metalness: 0.2 })\n  );\n  ball.position.set(0, 0.5, 0);\n  ball.castShadow = true;\n  scene.add(ball);\n\n  const coin = new THREE.Mesh(\n    new THREE.CylinderGeometry(0.7, 0.7, 0.08, 64),\n    new THREE.MeshStandardMaterial({ \n      color: '#F59E0B', \n      metalness: 1, \n      roughness: 0.1,\n      emissive: '#B45309',\n      emissiveIntensity: 0.1\n    })\n  );\n  coin.position.set(3, 2.5, -3);\n  coin.rotation.z = Math.PI / 2;\n  coin.castShadow = true;\n  scene.add(coin);\n\n  // 2. SCOREBOARD OBJECT (CRICKET BAT)\n  const batGroup = new THREE.Group();\n  const batBlade = new THREE.Mesh(\n    new THREE.BoxGeometry(0.45, 2.2, 0.18),\n    new THREE.MeshStandardMaterial({ \n      color: '#D4B483', \n      roughness: 0.6,\n      metalness: 0.05\n    })\n  );\n  const batHandle = new THREE.Mesh(\n    new THREE.CylinderGeometry(0.09, 0.09, 1.0),\n    new THREE.MeshStandardMaterial({ color: '#111', roughness: 0.3 })\n  );\n  batHandle.position.y = 1.6;\n  batGroup.add(batBlade, batHandle);\n  batGroup.position.set(12, 6, 15); // Out of initial view\n  batGroup.castShadow = true;\n  scene.add(batGroup);\n\n  // 3. ENVIRONMENT OBJECTS (STUMPS)\n  const stumps = new THREE.Group();\n  const stumpMat = new THREE.MeshStandardMaterial({ \n    color: '#F59E0B', \n    metalness: 0.9, \n    roughness: 0.05,\n    emissive: '#B45309',\n    emissiveIntensity: 0.2\n  });\n  for (let i = -1; i <= 1; i++) {\n    const s = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.08, 2.4, 32), stumpMat);\n    s.position.x = i * 0.38;\n    s.castShadow = true;\n    stumps.add(s);\n  }\n  stumps.position.set(-15, 1.2, 5); // Position for environment section\n  scene.add(stumps);\n\n  // 4. ROSTER CARDS (HOLOGRAPHIC) - Integrated with actual HTML Roster\n  const cardGroup = new THREE.Group();\n  const cardGeo = new THREE.PlaneGeometry(3, 4.5);\n  for (let i = 0; i < 10; i++) {\n    const cardMat = new THREE.MeshStandardMaterial({ \n      color: '#FFFFFF', \n      transparent: true, \n      opacity: 0.2, \n      side: THREE.DoubleSide,\n      metalness: 0.9,\n      roughness: 0.05\n    });\n    const card = new THREE.Mesh(cardGeo, cardMat);\n    const angle = (i / 10) * Math.PI * 2;\n    const radius = 12;\n    card.position.set(Math.cos(angle) * radius, 4, Math.sin(angle) * radius);\n    card.lookAt(0, 4, 0);\n    cardGroup.add(card);\n  }\n  cardGroup.position.set(0, 0, -35);\n  scene.add(cardGroup);\n\n  // --- CAMERA JOURNEY ---\n  camera.position.set(0, 2, 8);\n  camera.lookAt(0, 0.5, 0);\n\n  const tl = gsap.timeline({\n    scrollTrigger: {\n      trigger: \".content-overlay\",\n      start: \"top top\",\n      end: \"bottom bottom\",\n      scrub: 2,\n      invalidateOnRefresh: true\n    }\n  });\n\n  // To Scoreboard\n  tl.to(camera.position, { x: 10, y: 7, z: 20, ease: \"power2.inOut\" }, 0);\n  tl.to(camera.rotation, { x: -0.2, y: 0.4, ease: \"power2.inOut\" }, 0);\n\n  // To Environment\n  tl.to(camera.position, { x: -12, y: 3, z: 12, ease: \"power2.inOut\" }, 1);\n  tl.to(camera.rotation, { x: 0, y: -0.8, ease: \"power2.inOut\" }, 1);\n\n  // To Roster\n  tl.to(camera.position, { x: 0, y: 4, z: -25, ease: \"power2.inOut\" }, 2);\n  tl.to(camera.rotation, { x: -0.1, y: 0, ease: \"power2.inOut\" }, 2);\n\n  // To Finale (Top Down View of Stadium)\n  tl.to(camera.position, { x: 0, y: 60, z: 0, ease: \"expo.inOut\" }, 3);\n  tl.to(camera.rotation, { x: -Math.PI / 2, y: 0, ease: \"expo.inOut\" }, 3);\n  tl.to(sunLight.position, { x: 0, y: 20, z: 0, ease: \"power2.inOut\" }, 3);\n\n  // --- INTERACTION LOGIC ---\n  window.triggerBat = (runs) => {\n    gsap.to(batGroup.rotation, { z: -Math.PI / 1.5, duration: 0.12, yoyo: true, repeat: 1, ease: \"power4.out\" });\n    const scoreEl = document.getElementById('score-val');\n    let [c, w] = scoreEl.innerText.split('/');\n    scoreEl.innerText = `${parseInt(c) + runs}/${w}`;\n    \n    // Quick flash effect on HUD - Ensure no CSS transition conflicts\n    gsap.fromTo(\"#score-val\", \n      { scale: 1.3, color: \"#FFFFFF\" }, \n      { scale: 1, color: \"#F59E0B\", duration: 0.6, ease: \"elastic.out(1, 0.3)\" }\n    );\n  };\n\n  window.triggerWicket = () => {\n    stumps.children.forEach((s, i) => {\n      gsap.to(s.position, { \n        x: s.position.x + (i - 1) * 3, \n        y: 12, \n        z: s.position.z + (Math.random() - 0.5) * 10, \n        duration: 1.2, \n        ease: \"power3.out\" \n      });\n      gsap.to(s.rotation, { \n        x: Math.random() * 10, \n        z: Math.random() * 10, \n        duration: 1.5 \n      });\n    });\n    \n    // Reset after delay\n    setTimeout(() => {\n      stumps.children.forEach((s, i) => {\n        gsap.to(s.position, { x: i * 0.38, y: 0, z: 0, duration: 1, ease: \"back.out\" });\n        gsap.to(s.rotation, { x: 0, z: 0, duration: 1 });\n      });\n    }, 3000);\n  };\n\n  document.getElementById('coin-trigger').addEventListener('click', () => {\n    gsap.to(coin.position, { y: 8, duration: 0.6, yoyo: true, repeat: 1, ease: \"power2.out\" });\n    gsap.to(coin.rotation, { x: coin.rotation.x + Math.PI * 10, duration: 1.2, ease: \"power2.inOut\" });\n  });\n\n  // RENDER LOOP\n  function animate() {\n    requestAnimationFrame(animate);\n    \n    const time = Date.now() * 0.001;\n    \n    // Subtle float & rotate\n    ball.rotation.y += 0.003;\n    ball.position.y = 0.5 + Math.sin(time * 2) * 0.05;\n    \n    cardGroup.rotation.y += 0.0015;\n    \n    // Constant golden rotation for the coin with subtle pulse\n    coin.rotation.y += 0.015;\n    coin.scale.setScalar(1 + Math.sin(time * 4) * 0.02);\n    \n    renderer.render(scene, camera);\n  }\n\n  window.addEventListener('resize', () => {\n    camera.aspect = window.innerWidth / window.innerHeight;\n    camera.updateProjectionMatrix();\n    renderer.setSize(window.innerWidth, window.innerHeight);\n  });\n\n  animate();\n</script>\n",
