        "config": {}
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Inter:wght@400;600&display=swap');\n  \n  :root {\n    --color-turf: #10B981;\n    --color-slate: #1E293B;\n    --color-gold: #F59E0B;\n    --color-bg: #0B0E14;\n  }\n\n  body {\n    margin: 0;\n    background-color: var(--color-bg);\n    font-family: 'Inter', sans-serif;\n    color: white;\n    overflow-x: hidden;\n  }\n\n  #canvas-container {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100vh;\n    z-index: 1;\n  }\n\n  .content-overlay {\n    position: relative;\n    z-index: 10;\n    width: 100%;\n  }\n\n  section {\n    height: 100vh;\n    width: 100%;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    padding: 0 5%;\n    box-sizing: border-box;\n  }\n\n  .glass-hud {\n    background: rgba(255, 255, 255, 0.05);\n    backdrop-filter: blur(24px) saturate(180%);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    border-radius: 32px;\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);\n  }\n\n  .momentum-pulse {\n    width: 4px;\n    height: 20px;\n    background: var(--color-turf);\n    animation: pulse 1.5s ease-in-out infinite;\n  }\n\n  @keyframes pulse {\n    0%, 100% { height: 10px; opacity: 0.5; }\n    50% { height: 30px; opacity: 1; }\n  }\n\n  input[type=\"range\"] {\n    -webkit-appearance: none;\n    background: rgba(255, 255, 255, 0.1);\n    height: 4px;\n    border-radius: 2px;\n  }\n\n  input[type=\"range\"]::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    width: 16px;\n    height: 16px;\n    background: var(--color-gold);\n    border-radius: 50%;\n    cursor: pointer;\n    box-shadow: 0 0 10px var(--color-gold);\n  }\n\n  .holographic-card {\n    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%);\n    border: 1px solid rgba(255,255,255,0.2);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .holographic-card::after {\n    content: '';\n    position: absolute;\n    top: -50%;\n    left: -50%;\n    width: 200%;\n    height: 200%;\n    background: linear-gradient(45deg, transparent 0%, rgba(255,255,255,0.1) 50%, transparent 100%);\n    transform: rotate(45deg);\n    transition: 0.5s;\n  }\n\n  .holographic-card:hover::after {\n    left: 100%;\n  }\n</style>\n\n\n<div id=\"canvas-container\" data-kid=\"1\"></div>\n\n\n<div class=\"content-overlay\" data-kid=\"2\">\n  \n  \n  <section id=\"hero\" class=\"items-start\" data-kid=\"3\">\n    <div class=\"max-w-4xl\" data-kid=\"4\">\n      <div class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 mb-8\" data-kid=\"5\">\n        <span class=\"w-2 h-2 rounded-full bg-red-500 animate-ping\" data-kid=\"6\"></span>\n        <span class=\"text-xs font-bold tracking-widest uppercase opacity-60\" data-kid=\"7\">Season 2026 Live</span>\n      </div>\n      <h1 class=\"font-['Outfit'] text-[clamp(4rem,10vw,8rem)] font-bold leading-[0.9] tracking-tighter mb-8\" data-kid=\"8\">\n        STEP INTO<br data-kid=\"9\">\n        <span class=\"text-[var(--color-turf)]\" data-kid=\"10\">THE TURF</span>\n      </h1>\n      <p class=\"text-xl text-white/50 max-w-lg mb-12\" data-kid=\"11\">\n        A seamless 3D journey through the stadium. Experience realistic physics, spatial audio commentary, and AI-driven insights.\n      </p>\n      <div class=\"flex items-center gap-8\" data-kid=\"12\">\n        <button class=\"bg-[var(--color-turf)] text-[var(--color-bg)] font-black px-10 py-5 rounded-full text-lg shadow-[0_0_40px_rgba(16,185,129,0.4)] hover:scale-105 transition-transform\" data-kid=\"13\">\n          ENTER STADIUM\n        </button>\n        <div id=\"coin-btn\" class=\"flex flex-col items-center gap-2 cursor-pointer group\" data-kid=\"14\">\n          <div class=\"w-14 h-14 rounded-full bg-[var(--color-gold)] flex items-center justify-center shadow-[0_0_20px_rgba(245,158,11,0.5)] group-hover:scale-110 transition-transform\" data-kid=\"15\">\n            <i class=\"ti ti-coins text-2xl text-[var(--color-bg)]\" data-kid=\"16\"></i>\n          </div>\n          <span class=\"text-[10px] font-bold tracking-widest uppercase opacity-40\" data-kid=\"17\">Toss Coin</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"scoreboard\" data-kid=\"18\">\n    <div class=\"glass-hud w-full max-w-6xl p-10 grid grid-cols-12 gap-10\" data-kid=\"19\">\n      <div class=\"col-span-8 space-y-12\" data-kid=\"20\">\n        <div class=\"flex justify-between items-start\" data-kid=\"21\">\n          <div class=\"space-y-1\" data-kid=\"22\">\n            <span class=\"text-[var(--color-turf)] font-bold text-xs tracking-widest uppercase\" data-kid=\"23\">Championship Final</span>\n            <h2 class=\"text-5xl font-['Outfit'] font-black italic\" data-kid=\"24\">MUMBAI TITANS vs DELHI WOLVES</h2>\n          </div>\n          <div class=\"text-right\" data-kid=\"25\">\n            <div class=\"text-7xl font-black font-['Outfit'] text-[var(--color-gold)]\" id=\"score-display\" data-kid=\"26\">184/4</div>\n            <div class=\"text-sm font-bold opacity-40\" data-kid=\"27\">OVER 18.2</div>\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-4 gap-6\" data-kid=\"28\">\n          <div class=\"bg-white/5 p-6 rounded-2xl border border-white/5\" data-kid=\"29\">\n            <div class=\"text-[10px] font-bold opacity-40 uppercase mb-3\" data-kid=\"30\">Win Prob.</div>\n            <div class=\"text-3xl font-black\" data-kid=\"31\">64%</div>\n            <div class=\"w-full h-1.5 bg-white/10 rounded-full mt-4 overflow-hidden\" data-kid=\"32\">\n              <div class=\"h-full bg-[var(--color-turf)] w-[64%]\" data-kid=\"33\"></div>\n            </div>\n          </div>\n          <div class=\"bg-white/5 p-6 rounded-2xl border border-white/5\" data-kid=\"34\">\n            <div class=\"text-[10px] font-bold opacity-40 uppercase mb-3\" data-kid=\"35\">Momentum</div>\n            <div class=\"flex items-end gap-1 h-8\" data-kid=\"36\">\n              <div class=\"momentum-pulse\" style=\"animation-delay: 0.1s\" data-kid=\"37\"></div>\n              <div class=\"momentum-pulse\" style=\"animation-delay: 0.3s\" data-kid=\"38\"></div>\n              <div class=\"momentum-pulse\" style=\"animation-delay: 0.5s\" data-kid=\"39\"></div>\n              <div class=\"momentum-pulse\" style=\"animation-delay: 0.2s\" data-kid=\"40\"></div>\n              <div class=\"momentum-pulse\" style=\"animation-delay: 0.4s\" data-kid=\"41\"></div>\n            </div>\n          </div>\n          <div class=\"bg-white/5 p-6 rounded-2xl border border-white/5\" data-kid=\"42\">\n            <div class=\"text-[10px] font-bold opacity-40 uppercase mb-3\" data-kid=\"43\">RR</div>\n            <div class=\"text-3xl font-black\" data-kid=\"44\">10.04</div>\n            <div class=\"text-[10px] text-[var(--color-turf)] font-bold mt-1\" data-kid=\"45\">▲ 0.45</div>\n          </div>\n          <div class=\"bg-white/5 p-6 rounded-2xl border border-white/5\" data-kid=\"46\">\n            <div class=\"text-[10px] font-bold opacity-40 uppercase mb-3\" data-kid=\"47\">Proj. Score</div>\n            <div class=\"text-3xl font-black\" data-kid=\"48\">212</div>\n            <div class=\"text-[10px] opacity-40 font-bold mt-1\" data-kid=\"49\">BASED ON AI</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"col-span-4 border-l border-white/10 pl-10 flex flex-col justify-center space-y-8\" data-kid=\"50\">\n        <div class=\"text-center\" data-kid=\"51\">\n          <span class=\"text-xs font-bold opacity-40 uppercase tracking-widest mb-6 block\" data-kid=\"52\">Physics Trigger</span>\n          <div class=\"grid grid-cols-2 gap-4\" data-kid=\"53\">\n            <button onclick=\"swingBat(1)\" class=\"h-16 rounded-xl bg-white/5 border border-white/10 font-black text-xl hover:bg-white/10 transition-colors\" data-kid=\"54\">1</button>\n            <button onclick=\"swingBat(2)\" class=\"h-16 rounded-xl bg-white/5 border border-white/10 font-black text-xl hover:bg-white/10 transition-colors\" data-kid=\"55\">2</button>\n            <button onclick=\"swingBat(4)\" class=\"h-16 rounded-xl bg-[var(--color-gold)]/20 border border-[var(--color-gold)]/50 font-black text-xl text-[var(--color-gold)] hover:bg-[var(--color-gold)]/30 transition-colors\" data-kid=\"56\">4</button>\n            <button onclick=\"swingBat(6)\" class=\"h-16 rounded-xl bg-[var(--color-turf)]/20 border border-[var(--color-turf)]/50 font-black text-xl text-[var(--color-turf)] hover:bg-[var(--color-turf)]/30 transition-colors\" data-kid=\"57\">6</button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"sounds\" class=\"items-end\" data-kid=\"58\">\n    <div class=\"glass-hud w-96 p-8 space-y-10\" data-kid=\"59\">\n      <div class=\"flex items-center gap-4\" data-kid=\"60\">\n        <div class=\"w-14 h-14 rounded-2xl bg-[var(--color-gold)]/20 flex items-center justify-center text-[var(--color-gold)]\" data-kid=\"61\">\n          <i class=\"ti ti-microphone text-3xl\" data-kid=\"62\"></i>\n        </div>\n        <div data-kid=\"63\">\n          <h3 class=\"font-['Outfit'] text-2xl font-bold\" data-kid=\"64\">Sound Deck</h3>\n          <p class=\"text-xs font-bold opacity-40 uppercase tracking-tighter\" data-kid=\"65\">Broadcast HUD Mode</p>\n        </div>\n      </div>\n\n      <div class=\"space-y-8\" data-kid=\"66\">\n        <div class=\"space-y-4\" data-kid=\"67\">\n          <div class=\"flex justify-between items-center\" data-kid=\"68\">\n            <span class=\"text-[10px] font-black opacity-40 uppercase\" data-kid=\"69\">Stadium Roar</span>\n            <span class=\"text-[10px] font-black text-[var(--color-turf)] uppercase\" data-kid=\"70\">Immersive</span>\n          </div>\n          <input type=\"range\" class=\"w-full\" value=\"80\" data-kid=\"71\">\n        </div>\n        <div class=\"space-y-4\" data-kid=\"72\">\n          <div class=\"flex justify-between items-center\" data-kid=\"73\">\n            <span class=\"text-[10px] font-black opacity-40 uppercase\" data-kid=\"74\">AI Shastri Comm.</span>\n            <span class=\"text-[10px] font-black opacity-40 uppercase\" data-kid=\"75\">Offline</span>\n          </div>\n          <input type=\"range\" class=\"w-full opacity-30\" value=\"0\" data-kid=\"76\">\n        </div>\n        <div class=\"space-y-4\" data-kid=\"77\">\n          <div class=\"flex justify-between items-center\" data-kid=\"78\">\n            <span class=\"text-[10px] font-black opacity-40 uppercase\" data-kid=\"79\">Stump Smash</span>\n            <span class=\"text-[10px] font-black text-[var(--color-gold)] uppercase\" data-kid=\"80\">On Event</span>\n          </div>\n          <input type=\"range\" class=\"w-full\" value=\"100\" data-kid=\"81\">\n        </div>\n      </div>\n\n      <button onclick=\"hitWicket()\" class=\"w-full py-5 rounded-2xl bg-white/5 border border-white/10 font-bold hover:bg-red-500/20 hover:border-red-500/50 transition-all text-sm uppercase tracking-widest\" data-kid=\"82\">\n        Manual Wicket Trigger\n      </button>\n    </div>\n  </section>\n\n  \n  <section id=\"roster\" data-kid=\"83\">\n    <div class=\"text-center space-y-4 mb-auto pt-20\" data-kid=\"84\">\n      <h2 class=\"text-6xl font-['Outfit'] font-black\" data-kid=\"85\">CHAMPIONS CAROUSEL</h2>\n      <p class=\"text-white/40 font-bold uppercase tracking-widest text-sm\" data-kid=\"86\">Interactive Holographic Roster</p>\n    </div>\n    <div class=\"flex gap-4 mb-20\" data-kid=\"87\">\n      <button class=\"w-16 h-16 rounded-full glass-hud flex items-center justify-center text-2xl hover:bg-white/10 transition-colors\" data-kid=\"88\"><i class=\"ti ti-chevron-left\" data-kid=\"89\"></i></button>\n      <button class=\"w-16 h-16 rounded-full glass-hud flex items-center justify-center text-2xl hover:bg-white/10 transition-colors\" data-kid=\"90\"><i class=\"ti ti-chevron-right\" data-kid=\"91\"></i></button>\n    </div>\n  </section>\n\n  \n  <section id=\"wrap\" data-kid=\"92\">\n    <div class=\"glass-hud w-full max-w-5xl p-12 grid grid-cols-2 gap-16\" data-kid=\"93\">\n      <div class=\"space-y-8\" data-kid=\"94\">\n        <h2 class=\"text-5xl font-['Outfit'] font-black leading-tight\" data-kid=\"95\">THE FINISH LINE</h2>\n        <p class=\"text-white/40 text-lg\" data-kid=\"96\">Your match, your highlights. Drag and drop 3D badges to create your commemorative poster.</p>\n        \n        <div class=\"space-y-4\" data-kid=\"97\">\n          <span class=\"text-[10px] font-black opacity-40 uppercase tracking-widest\" data-kid=\"98\">Match Assets</span>\n          <div class=\"flex gap-4\" data-kid=\"99\">\n            <div class=\"w-20 h-20 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center cursor-grab active:cursor-grabbing hover:bg-white/10 transition-all\" data-kid=\"100\">\n              <i class=\"ti ti-trophy text-3xl text-[var(--color-gold)]\" data-kid=\"101\"></i>\n            </div>\n            <div class=\"w-20 h-20 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center cursor-grab active:cursor-grabbing hover:bg-white/10 transition-all\" data-kid=\"102\">\n              <i class=\"ti ti-award text-3xl text-[var(--color-turf)]\" data-kid=\"103\"></i>\n            </div>\n            <div class=\"w-20 h-20 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center cursor-grab active:cursor-grabbing hover:bg-white/10 transition-all\" data-kid=\"104\">\n              <i class=\"ti ti-star text-3xl text-white\" data-kid=\"105\"></i>\n            </div>\n          </div>\n        </div>\n\n        <button class=\"w-full py-5 rounded-full bg-white text-[var(--color-bg)] font-black text-lg hover:scale-[0.98] transition-transform\" data-kid=\"106\">\n          GENERATE POSTER\n        </button>\n      </div>\n\n      <div class=\"aspect-[4/5] bg-white rounded-3xl p-10 text-[var(--color-bg)] shadow-2xl relative overflow-hidden flex flex-col\" data-kid=\"107\">\n        <div class=\"absolute top-0 left-0 w-full h-3 bg-[var(--color-turf)]\" data-kid=\"108\"></div>\n        <div class=\"flex justify-between items-start mb-10\" data-kid=\"109\">\n          <h3 class=\"text-4xl font-['Outfit'] font-black\" data-kid=\"110\">MVP</h3>\n          <div class=\"text-right\" data-kid=\"111\">\n            <div class=\"text-xs font-black uppercase opacity-40\" data-kid=\"112\">Final Score</div>\n            <div class=\"text-2xl font-black\" data-kid=\"113\">184/4</div>\n          </div>\n        </div>\n\n        <div class=\"flex-grow rounded-2xl border-4 border-dashed border-[var(--color-bg)]/10 flex flex-col items-center justify-center space-y-4\" data-kid=\"114\">\n          <i class=\"ti ti-plus text-5xl opacity-20\" data-kid=\"115\"></i>\n          <span class=\"text-xs font-black opacity-30 uppercase tracking-widest\" data-kid=\"116\">Drop 3D Badge Here</span>\n        </div>\n\n        <div class=\"mt-10 space-y-4\" data-kid=\"117\">\n          <div class=\"flex justify-between border-b border-[var(--color-bg)]/10 pb-2\" data-kid=\"118\">\n            <span class=\"font-bold\" data-kid=\"119\">SID KHAN</span>\n            <span class=\"font-black\" data-kid=\"120\">74 (42)</span>\n          </div>\n          <div class=\"flex justify-between border-b border-[var(--color-bg)]/10 pb-2\" data-kid=\"121\">\n            <span class=\"font-bold\" data-kid=\"122\">VIRAT K.</span>\n            <span class=\"font-black\" data-kid=\"123\">48 (29)</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/0.160.0/three.min.js\" data-kid=\"124\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/gsap.min.js\" data-kid=\"125\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/ScrollTrigger.min.js\" data-kid=\"126\"></script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"127\">\n\n<script data-kid=\"128\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // --- THREE.JS SCENE SETUP ---\n  const container = document.getElementById('canvas-container');\n  const scene = new THREE.Scene();\n  scene.background = new THREE.Color('#0B0E14');\n  scene.fog = new THREE.FogExp2('#0B0E14', 0.02);\n  \n  const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);\n  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });\n  renderer.setSize(window.innerWidth, window.innerHeight);\n  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n  renderer.shadowMap.enabled = true;\n  renderer.shadowMap.type = THREE.PCFSoftShadowMap;\n  container.appendChild(renderer.domElement);\n\n  // LIGHTING\n  const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);\n  scene.add(ambientLight);\n\n  const mainLight = new THREE.DirectionalLight(0xffffff, 1.2);\n  mainLight.position.set(10, 20, 10);\n  mainLight.castShadow = true;\n  mainLight.shadow.mapSize.width = 2048;\n  mainLight.shadow.mapSize.height = 2048;\n  scene.add(mainLight);\n\n  // TEXTURES\n  const textureLoader = new THREE.TextureLoader();\n  const grassTex = textureLoader.load('https://images.unsplash.com/photo-1544914379-806667cd9489?auto=format&w=1440&q=80&fit=crop');\n  grassTex.wrapS = grassTex.wrapT = THREE.RepeatWrapping;\n  grassTex.repeat.set(50, 50);\n\n  const ballTex = textureLoader.load('https://images.pexels.com/photos/30401509/pexels-photo-30401509.jpeg?auto=compress&cs=tinysrgb&w=800&q=80');\n\n  // GROUND\n  const ground = new THREE.Mesh(\n    new THREE.PlaneGeometry(300, 300),\n    new THREE.MeshStandardMaterial({ map: grassTex, color: '#064E3B', roughness: 1 })\n  );\n  ground.rotation.x = -Math.PI / 2;\n  ground.receiveShadow = true;\n  scene.add(ground);\n\n  // GRASS INSTANCING\n  const grassCount = 15000;\n  const grassBlade = new THREE.PlaneGeometry(0.1, 0.6);\n  const grassMat = new THREE.MeshStandardMaterial({ color: '#10B981', side: THREE.DoubleSide });\n  const instancedGrass = new THREE.InstancedMesh(grassBlade, grassMat, grassCount);\n  const dummy = new THREE.Object3D();\n\n  for (let i = 0; i < grassCount; i++) {\n    dummy.position.set((Math.random() - 0.5) * 60, 0.3, (Math.random() - 0.5) * 60);\n    dummy.rotation.y = Math.random() * Math.PI;\n    dummy.scale.set(1, Math.random() * 0.5 + 0.5, 1);\n    dummy.updateMatrix();\n    instancedGrass.setMatrixAt(i, dummy.matrix);\n  }\n  scene.add(instancedGrass);\n\n  // SECTION 1: HERO BALL & COIN\n  const ball = new THREE.Mesh(\n    new THREE.SphereGeometry(0.5, 32, 32),\n    new THREE.MeshStandardMaterial({ map: ballTex, roughness: 0.3 })\n  );\n  ball.position.set(0, 0.5, 0);\n  ball.castShadow = true;\n  scene.add(ball);\n\n  const coin = new THREE.Mesh(\n    new THREE.CylinderGeometry(0.6, 0.6, 0.1, 32),\n    new THREE.MeshStandardMaterial({ color: '#F59E0B', metalness: 0.9, roughness: 0.1 })\n  );\n  coin.position.set(2.5, 2, -2);\n  coin.rotation.z = Math.PI / 2;\n  scene.add(coin);\n\n  // SECTION 2: SCOREKEEPER BAT\n  const batGroup = new THREE.Group();\n  const batBlade = new THREE.Mesh(\n    new THREE.BoxGeometry(0.4, 1.8, 0.15),\n    new THREE.MeshStandardMaterial({ color: '#E5C49F', roughness: 0.8 })\n  );\n  const batHandle = new THREE.Mesh(\n    new THREE.CylinderGeometry(0.08, 0.08, 0.8),\n    new THREE.MeshStandardMaterial({ color: '#222' })\n  );\n  batHandle.position.y = 1.3;\n  batGroup.add(batBlade, batHandle);\n  batGroup.position.set(5, 5, 8);\n  scene.add(batGroup);\n\n  // SECTION 3: STUMPS\n  const stumps = new THREE.Group();\n  for (let i = -1; i <= 1; i++) {\n    const s = new THREE.Mesh(\n      new THREE.CylinderGeometry(0.08, 0.08, 2.2),\n      new THREE.MeshStandardMaterial({ color: '#F59E0B', metalness: 0.5, roughness: 0.2 })\n    );\n    s.position.x = i * 0.35;\n    s.castShadow = true;\n    stumps.add(s);\n  }\n  stumps.position.set(-8, 1.1, -5);\n  scene.add(stumps);\n\n  // SECTION 4: CARDS\n  const cards = new THREE.Group();\n  for (let i = 0; i < 8; i++) {\n    const card = new THREE.Mesh(\n      new THREE.PlaneGeometry(2, 3),\n      new THREE.MeshStandardMaterial({ color: '#fff', transparent: true, opacity: 0.8, side: THREE.DoubleSide })\n    );\n    const angle = (i / 8) * Math.PI * 2;\n    card.position.set(Math.cos(angle) * 6, 2.5, Math.sin(angle) * 6);\n    card.lookAt(0, 2.5, 0);\n    cards.add(card);\n  }\n  cards.position.set(0, 0, -20);\n  scene.add(cards);\n\n  // --- CAMERA JOURNEY (GSAP) ---\n  camera.position.set(0, 1.5, 6);\n  camera.lookAt(0, 0.5, 0);\n\n  const mainTimeline = gsap.timeline({\n    scrollTrigger: {\n      trigger: \".content-overlay\",\n      start: \"top top\",\n      end: \"bottom bottom\",\n      scrub: 1.5\n    }\n  });\n\n  // To Scorekeeper\n  mainTimeline.to(camera.position, { x: 5, y: 6, z: 12, ease: \"power1.inOut\" }, 0);\n  mainTimeline.to(camera.rotation, { x: -0.3, ease: \"power1.inOut\" }, 0);\n\n  // To Sounds\n  mainTimeline.to(camera.position, { x: -6, y: 2, z: 0, ease: \"power1.inOut\" }, 1);\n  mainTimeline.to(camera.rotation, { y: 1.5, ease: \"power1.inOut\" }, 1);\n\n  // To Roster\n  mainTimeline.to(camera.position, { x: 0, y: 3, z: -14, ease: \"power1.inOut\" }, 2);\n  mainTimeline.to(camera.rotation, { y: 0, x: -0.1, ease: \"power1.inOut\" }, 2);\n\n  // To Match Wrap (Top Down)\n  mainTimeline.to(camera.position, { x: 0, y: 40, z: -5, ease: \"power2.inOut\" }, 3);\n  mainTimeline.to(camera.rotation, { x: -Math.PI / 2, ease: \"power2.inOut\" }, 3);\n\n  // --- INTERACTION LOGIC ---\n  window.swingBat = function(runs) {\n    gsap.to(batGroup.rotation, { z: -Math.PI / 2, duration: 0.15, yoyo: true, repeat: 1 });\n    const scoreEl = document.getElementById('score-display');\n    let [c, w] = scoreEl.innerText.split('/');\n    scoreEl.innerText = `${parseInt(c) + runs}/${w}`;\n  };\n\n  window.hitWicket = function() {\n    stumps.children.forEach((s, idx) => {\n      gsap.to(s.position, { \n        x: s.position.x + (idx - 1) * 2, \n        y: 8, \n        z: s.position.z + (Math.random() - 0.5) * 5, \n        duration: 1, \n        ease: \"power2.out\" \n      });\n      gsap.to(s.rotation, { x: 5, z: 5, duration: 1.2 });\n    });\n  };\n\n  document.getElementById('coin-btn').addEventListener('click', () => {\n    gsap.to(coin.rotation, { x: coin.rotation.x + Math.PI * 12, duration: 1.5, ease: \"expo.out\" });\n    gsap.to(coin.position, { y: 5, duration: 0.75, yoyo: true, repeat: 1, ease: \"power2.out\" });\n  });\n\n  // RENDER LOOP\n  function animate() {\n    requestAnimationFrame(animate);\n    ball.rotation.y += 0.005;\n    cards.rotation.y += 0.002;\n    renderer.render(scene, camera);\n  }\n\n  window.addEventListener('resize', () => {\n    camera.aspect = window.innerWidth / window.innerHeight;\n    camera.updateProjectionMatrix();\n    renderer.setSize(window.innerWidth, window.innerHeight);\n  });\n\n  animate();\n</script>",
