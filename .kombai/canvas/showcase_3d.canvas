      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;900&display=swap');\n  \n  :root {\n    --color-turf: #10B981;\n    --color-gold: #F59E0B;\n    --color-sky: #E0F2FE;\n    --color-slate: #0F172A;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    font-family: 'Outfit', sans-serif;\n    background-color: var(--color-sky);\n    color: var(--color-slate);\n    overflow-x: clip;\n  }\n\n  #canvas-container {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100vh;\n    z-index: 0;\n    pointer-events: none;\n  }\n\n  .content-layer {\n    position: relative;\n    z-index: 10;\n  }\n\n  section {\n    width: 100%;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    padding: 8rem 8%;\n    box-sizing: border-box;\n    position: relative;\n  }\n\n  .glass-card {\n    background: white;\n    border: 1px solid #F1F5F9;\n    border-radius: 3rem;\n    box-shadow: 0 25px 70px -15px rgba(15, 23, 42, 0.1);\n  }\n\n  .premium-hud {\n    background: rgba(15, 23, 42, 0.03);\n    border: 1px solid rgba(15, 23, 42, 0.05);\n    backdrop-filter: blur(12px);\n    border-radius: 2rem;\n  }\n\n  .gold-accent {\n    color: var(--color-gold);\n    text-shadow: 0 0 15px rgba(245, 158, 11, 0.3);\n  }\n\n  .btn-primary {\n    background: var(--color-turf);\n    color: white;\n    padding: 1.25rem 2.5rem;\n    border-radius: 1.25rem;\n    font-weight: 900;\n    font-size: 1.125rem;\n    box-shadow: 0 10px 30px -5px rgba(16, 185, 129, 0.4);\n    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);\n  }\n\n  .btn-primary:hover {\n    transform: translateY(-4px) scale(1.02);\n    box-shadow: 0 15px 40px -5px rgba(16, 185, 129, 0.5);\n  }\n\n  /* Custom range slider */\n  input[type=\"range\"] {\n    -webkit-appearance: none;\n    width: 100%;\n    height: 6px;\n    background: rgba(0,0,0,0.05);\n    border-radius: 5px;\n    outline: none;\n  }\n  input[type=\"range\"]::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    width: 20px;\n    height: 20px;\n    background: var(--color-gold);\n    border-radius: 50%;\n    cursor: pointer;\n    box-shadow: 0 0 10px rgba(245, 158, 11, 0.5);\n  }\n\n  .poster-dropzone {\n    border: 3px dashed rgba(0,0,0,0.1);\n    transition: all 0.3s ease;\n  }\n  .poster-dropzone:hover {\n    border-color: var(--color-turf);\n    background: rgba(16, 185, 129, 0.03);\n  }\n\n  .momentum-bar {\n    width: 6px;\n    background: var(--color-turf);\n    border-radius: 3px;\n    animation: bounce 1s infinite ease-in-out;\n  }\n\n  @keyframes bounce {\n    0%, 100% { height: 10px; opacity: 0.5; }\n    50% { height: 25px; opacity: 1; }\n  }\n\n  .lenis.lenis-smooth {\n    scroll-behavior: auto !important;\n  }\n\n  html.lenis {\n    height: auto;\n  }\n</style>\n\n<div id=\"canvas-container\" data-kid=\"1\"></div>\n\n<div class=\"content-layer\" data-kid=\"2\">\n  \n  <section id=\"hero\" class=\"items-center text-center min-h-[100vh]\" data-kid=\"3\">\n    <div class=\"max-w-4xl\" data-kid=\"4\">\n      <div class=\"inline-flex items-center gap-4 px-6 py-2 rounded-xl bg-white border-2 border-slate-100 mb-12 shadow-sm\" data-kid=\"5\">\n        <div class=\"flex items-center gap-1.5\" data-kid=\"6\">\n          <span class=\"w-1.5 h-1.5 rounded-full bg-red-500\" data-kid=\"7\"></span>\n          <span class=\"w-1.5 h-1.5 rounded-full bg-red-500 opacity-50\" data-kid=\"8\"></span>\n          <span class=\"w-1.5 h-1.5 rounded-full bg-red-500 opacity-20\" data-kid=\"9\"></span>\n        </div>\n        <span class=\"text-[12px] font-bold tracking-[0.3em] uppercase text-slate-400\" data-kid=\"10\">Championship Series 2026</span>\n      </div>\n      \n      <h1 class=\"text-[clamp(4rem,9vw,9rem)] font-black leading-[0.95] tracking-tight mb-12 text-slate-900\" data-kid=\"11\">\n        HIGH NOON<br data-kid=\"12\">\n        <span class=\"text-[var(--color-turf)] italic\" data-kid=\"13\">SUPREMACY</span>\n      </h1>\n      \n      <p class=\"text-xl text-slate-600/80 font-medium max-w-lg mb-12 leading-relaxed\" data-kid=\"14\">\n        The ultimate test of grit and skill under the blazing summer sun. Experience cricket redefined in high-fidelity 3D.\n      </p>\n\n      <div class=\"flex items-center gap-10\" data-kid=\"15\">\n        <button class=\"btn-primary\" data-kid=\"16\">ENTER STADIUM</button>\n        <div id=\"coin-trigger\" class=\"flex flex-col items-center gap-3 cursor-pointer group\" data-kid=\"17\">\n          <div class=\"w-16 h-16 rounded-full bg-gradient-to-tr from-[var(--color-gold)] to-yellow-300 flex items-center justify-center shadow-xl shadow-amber-200 group-hover:scale-110 transition-transform\" data-kid=\"18\">\n            <i class=\"ti ti-coins text-3xl text-white\" data-kid=\"19\"></i>\n          </div>\n          <span class=\"text-[10px] font-bold tracking-widest uppercase text-slate-400\" data-kid=\"20\">Toss Coin</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"scoreboard\" class=\"items-center\" data-kid=\"21\">\n    <div class=\"glass-card w-full max-w-6xl p-14 grid grid-cols-12 gap-16 border-slate-200\" data-kid=\"22\">\n      <div class=\"col-span-8 space-y-14\" data-kid=\"23\">\n        <div class=\"flex justify-between items-end border-b-2 border-slate-50 pb-8\" data-kid=\"24\">\n          <div data-kid=\"25\">\n            <div class=\"flex items-center gap-3 mb-4\" data-kid=\"26\">\n              <i class=\"ti ti-trophy text-[var(--color-turf)] text-2xl\" data-kid=\"27\"></i>\n              <span class=\"text-slate-400 font-bold text-sm uppercase tracking-[0.2em]\" data-kid=\"28\">Grand Final Match</span>\n            </div>\n            <h2 class=\"text-5xl font-bold text-slate-900 tracking-tight\" data-kid=\"29\">MUMBAI TITANS <span class=\"text-slate-900/20 mx-4\" data-kid=\"30\">VS</span> DELHI WOLVES</h2>\n          </div>\n          <div class=\"text-right\" data-kid=\"31\">\n            <div id=\"score-text\" class=\"text-8xl font-black text-[var(--color-gold)] leading-[0.8]\" data-kid=\"32\">192/4</div>\n            <div class=\"text-xs font-bold text-slate-300 mt-4 tracking-widest uppercase\" data-kid=\"33\">OVER 18.2 • TARGET 214</div>\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-4 gap-8\" data-kid=\"34\">\n          <div class=\"space-y-4\" data-kid=\"35\">\n            <div class=\"flex items-center gap-2 text-slate-400\" data-kid=\"36\">\n              <i class=\"ti ti-trending-up text-lg\" data-kid=\"37\"></i>\n              <span class=\"text-[10px] font-bold uppercase tracking-wider\" data-kid=\"38\">Win Prob.</span>\n            </div>\n            <div class=\"text-4xl font-bold text-slate-900\" data-kid=\"39\">68%</div>\n            <div class=\"w-full h-1.5 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"40\">\n              <div class=\"h-full bg-[var(--color-turf)] w-[68%]\" data-kid=\"41\"></div>\n            </div>\n          </div>\n          <div class=\"bg-slate-50/50 p-6 rounded-3xl border border-slate-100/50\" data-kid=\"42\">\n            <div class=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-4\" data-kid=\"43\">Momentum</div>\n            <div class=\"flex items-end gap-1.5 h-10\" data-kid=\"44\">\n              <div class=\"momentum-bar\" style=\"animation-delay: 0.1s\" data-kid=\"45\"></div>\n              <div class=\"momentum-bar\" style=\"animation-delay: 0.3s\" data-kid=\"46\"></div>\n              <div class=\"momentum-bar\" style=\"animation-delay: 0.5s\" data-kid=\"47\"></div>\n              <div class=\"momentum-bar\" style=\"animation-delay: 0.2s\" data-kid=\"48\"></div>\n              <div class=\"momentum-bar\" style=\"animation-delay: 0.4s\" data-kid=\"49\"></div>\n              <div class=\"momentum-bar\" style=\"animation-delay: 0.6s\" data-kid=\"50\"></div>\n            </div>\n          </div>\n          <div class=\"bg-slate-50/50 p-6 rounded-3xl border border-slate-100/50\" data-kid=\"51\">\n            <div class=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-4\" data-kid=\"52\">Current RR</div>\n            <div class=\"text-4xl font-bold text-slate-900\" data-kid=\"53\">10.47</div>\n            <div class=\"text-[10px] text-[var(--color-turf)] font-bold mt-2 flex items-center gap-1\" data-kid=\"54\">\n              <i class=\"ti ti-arrow-up-right\" data-kid=\"55\"></i> 0.32 LAST OVER\n            </div>\n          </div>\n          <div class=\"bg-slate-50/50 p-6 rounded-3xl border border-slate-100/50\" data-kid=\"56\">\n            <div class=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-4\" data-kid=\"57\">AI Prediction</div>\n            <div class=\"text-4xl font-bold text-slate-900\" data-kid=\"58\">224</div>\n            <div class=\"text-[10px] text-slate-400 font-bold mt-2 uppercase tracking-tight\" data-kid=\"59\">Projected</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"col-span-4 border-l border-white/80 pl-12 flex flex-col justify-center space-y-10\" data-kid=\"60\">\n        <div class=\"text-center\" data-kid=\"61\">\n          <span class=\"text-xs font-black text-slate-400 uppercase tracking-[0.2em] mb-8 block\" data-kid=\"62\">Bat Interaction</span>\n          <div class=\"grid grid-cols-2 gap-4\" data-kid=\"63\">\n            <button onclick=\"swingBat(1)\" class=\"h-16 rounded-2xl bg-white border border-slate-100 font-black text-2xl text-slate-700 hover:shadow-lg transition-all\" data-kid=\"64\">1</button>\n            <button onclick=\"swingBat(2)\" class=\"h-16 rounded-2xl bg-white border border-slate-100 font-black text-2xl text-slate-700 hover:shadow-lg transition-all\" data-kid=\"65\">2</button>\n            <button onclick=\"swingBat(4)\" class=\"h-16 rounded-2xl bg-amber-50 border border-amber-100 font-black text-2xl text-[var(--color-gold)] hover:bg-amber-100 transition-all\" data-kid=\"66\">4</button>\n            <button onclick=\"swingBat(6)\" class=\"h-16 rounded-2xl bg-emerald-50 border border-emerald-100 font-black text-2xl text-[var(--color-turf)] hover:bg-emerald-100 transition-all\" data-kid=\"67\">6</button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  \n    <div class=\"grid grid-cols-2 gap-20 w-full max-w-6xl items-center\" data-kid=\"68\">\n      <div class=\"space-y-8\" data-kid=\"69\">\n        <h2 class=\"text-6xl font-black text-slate-900 tracking-tighter leading-[0.9]\" data-kid=\"70\">BROADCAST<br data-kid=\"71\"><span class=\"text-slate-400\" data-kid=\"72\">DIRECTOR HUD</span></h2>\n        <p class=\"text-xl text-slate-500 max-w-md leading-relaxed\" data-kid=\"73\">Manipulate the stadium atmosphere in real-time. Control spatial audio and physics-driven triggers from the elite broadcast desk.</p>\n        <button class=\"flex items-center gap-4 px-8 py-4 bg-white border-2 border-slate-100 rounded-2xl font-bold text-slate-700 hover:border-slate-200 transition-all\" data-kid=\"74\">\n          <i class=\"ti ti-headphones-filled text-[var(--color-turf)]\" data-kid=\"75\"></i>\n          ENABLE SPATIAL AUDIO\n        </button>\n      </div>\n      <div class=\"glass-card w-full max-w-md p-10 space-y-10 ml-auto border-slate-100\" data-kid=\"76\">\n        <div class=\"flex items-center gap-5\" data-kid=\"77\">\n          <div class=\"w-16 h-16 rounded-[1.5rem] bg-slate-900 flex items-center justify-center text-white\" data-kid=\"78\">\n            <i class=\"ti ti-adjustments-horizontal text-4xl\" data-kid=\"79\"></i>\n          </div>\n          <div data-kid=\"80\">\n            <h3 class=\"text-2xl font-bold text-slate-900\" data-kid=\"81\">Live Mixer</h3>\n            <p class=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest\" data-kid=\"82\">Audio Profile: Summer Final</p>\n          </div>\n        </div>\n\n        <div class=\"space-y-8\" data-kid=\"83\">\n        <div class=\"space-y-4\" data-kid=\"84\">\n          <div class=\"flex justify-between items-center\" data-kid=\"85\">\n            <div class=\"flex items-center gap-2\" data-kid=\"86\">\n              <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-turf)]\" data-kid=\"87\"></span>\n              <span class=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest\" data-kid=\"88\">Stadium Roar</span>\n            </div>\n            <span class=\"text-[10px] font-black text-[var(--color-turf)] uppercase\" data-kid=\"89\">Immersive</span>\n          </div>\n          <input type=\"range\" value=\"85\" data-kid=\"90\">\n        </div>\n        <div class=\"space-y-4\" data-kid=\"91\">\n          <div class=\"flex justify-between items-center\" data-kid=\"92\">\n            <span class=\"text-[10px] font-black text-slate-400 uppercase tracking-widest\" data-kid=\"93\">Commentary (AI)</span>\n            <span class=\"text-[10px] font-black text-slate-300 uppercase\" data-kid=\"94\">Standby</span>\n          </div>\n          <input type=\"range\" value=\"0\" class=\"opacity-40\" data-kid=\"95\">\n        </div>\n        <div class=\"space-y-4\" data-kid=\"96\">\n          <div class=\"flex justify-between items-center\" data-kid=\"97\">\n            <span class=\"text-[10px] font-black text-slate-400 uppercase tracking-widest\" data-kid=\"98\">Physics Audio</span>\n            <span class=\"text-[10px] font-black text-[var(--color-gold)] uppercase\" data-kid=\"99\">On Interaction</span>\n          </div>\n          <input type=\"range\" value=\"100\" data-kid=\"100\">\n        </div>\n      </div>\n\n      <button onclick=\"knockWicket()\" class=\"w-full py-5 rounded-2xl bg-slate-900 text-white font-black text-sm uppercase tracking-[0.2em] hover:bg-red-500 transition-colors shadow-xl\" data-kid=\"101\">\n        TRIGGER WICKET\n      </button>\n    </div>\n  \n\n  \n  <section id=\"roster\" class=\"items-center\" data-kid=\"102\">\n    <div class=\"text-center mb-16\" data-kid=\"103\">\n      <h2 class=\"text-7xl font-black text-slate-900 tracking-tighter mb-6\" data-kid=\"104\">CHAMPIONS ROSTER</h2>\n      <p class=\"text-slate-400 font-bold uppercase tracking-[0.4em] text-xs\" data-kid=\"105\">Scroll to Explore Team Depth</p>\n    </div>\n    \n    <div class=\"w-full max-w-7xl grid grid-cols-4 gap-8 px-4\" data-kid=\"106\">\n      <div class=\"bg-white border border-slate-100 p-8 rounded-[3.5rem] shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all group\" data-kid=\"107\">\n        <div class=\"aspect-[3/4] bg-slate-50 rounded-[2.8rem] mb-8 overflow-hidden relative border border-slate-100\" data-kid=\"108\">\n          <div class=\"absolute inset-0 bg-gradient-to-t from-slate-900/5 to-transparent\" data-kid=\"109\"></div>\n          <span class=\"absolute bottom-6 left-6 text-slate-200 font-black text-6xl group-hover:text-[var(--color-turf)] transition-colors group-hover:opacity-40\" data-kid=\"110\">07</span>\n        </div>\n        <h4 class=\"text-2xl font-bold text-slate-900 mb-1\" data-kid=\"111\">Virat Kohli</h4>\n        <p class=\"text-slate-400 font-bold text-[10px] uppercase tracking-[0.2em]\" data-kid=\"112\">Captain • Batter</p>\n      </div>\n      <div class=\"bg-white border-2 border-slate-50 p-8 rounded-[3rem] shadow-sm hover:shadow-xl transition-all translate-y-12\" data-kid=\"113\">\n        <div class=\"aspect-[3/4] bg-slate-50 rounded-[2.5rem] mb-8 overflow-hidden relative\" data-kid=\"114\">\n          <span class=\"absolute bottom-6 left-6 text-white font-black text-6xl opacity-30\" data-kid=\"115\">45</span>\n        </div>\n        <h4 class=\"text-2xl font-bold text-slate-900 mb-1\" data-kid=\"116\">Rohit Sharma</h4>\n        <p class=\"text-[var(--color-turf)] font-bold text-xs uppercase tracking-widest\" data-kid=\"117\">Opening Batter</p>\n      </div>\n      <div class=\"bg-white border-2 border-slate-50 p-8 rounded-[3rem] shadow-sm hover:shadow-xl transition-all\" data-kid=\"118\">\n        <div class=\"aspect-[3/4] bg-slate-50 rounded-[2.5rem] mb-8 overflow-hidden relative\" data-kid=\"119\">\n          <span class=\"absolute bottom-6 left-6 text-white font-black text-6xl opacity-30\" data-kid=\"120\">33</span>\n        </div>\n        <h4 class=\"text-2xl font-bold text-slate-900 mb-1\" data-kid=\"121\">Hardik Pandya</h4>\n        <p class=\"text-[var(--color-turf)] font-bold text-xs uppercase tracking-widest\" data-kid=\"122\">All-Rounder</p>\n      </div>\n      <div class=\"bg-white border-2 border-slate-50 p-8 rounded-[3rem] shadow-sm hover:shadow-xl transition-all translate-y-12\" data-kid=\"123\">\n        <div class=\"aspect-[3/4] bg-slate-50 rounded-[2.5rem] mb-8 overflow-hidden relative\" data-kid=\"124\">\n          <span class=\"absolute bottom-6 left-6 text-white font-black text-6xl opacity-30\" data-kid=\"125\">93</span>\n        </div>\n        <h4 class=\"text-2xl font-bold text-slate-900 mb-1\" data-kid=\"126\">Jasprit Bumrah</h4>\n        <p class=\"text-[var(--color-turf)] font-bold text-xs uppercase tracking-widest\" data-kid=\"127\">Lead Pacer</p>\n      </div>\n    </div>\n    \n    <div class=\"flex gap-6 mt-20\" data-kid=\"128\">\n      <button class=\"w-20 h-20 rounded-full bg-white border-2 border-slate-100 flex items-center justify-center text-2xl text-slate-900 hover:bg-[var(--color-turf)] hover:text-white hover:border-transparent transition-all shadow-sm\" data-kid=\"129\">\n        <i class=\"ti ti-arrow-left\" data-kid=\"130\"></i>\n      </button>\n      <button class=\"w-20 h-20 rounded-full bg-white border-2 border-slate-100 flex items-center justify-center text-2xl text-slate-900 hover:bg-[var(--color-turf)] hover:text-white hover:border-transparent transition-all shadow-sm\" data-kid=\"131\">\n        <i class=\"ti ti-arrow-right\" data-kid=\"132\"></i>\n      </button>\n    </div>\n  </section>\n\n  \n  <section id=\"wrap\" class=\"items-center\" data-kid=\"133\">\n    <div class=\"glass-card w-full max-w-5xl p-12 grid grid-cols-2 gap-16\" data-kid=\"134\">\n      <div class=\"space-y-10\" data-kid=\"135\">\n        <div data-kid=\"136\">\n          <h2 class=\"text-5xl font-black text-slate-900 leading-tight mb-6 tracking-tight\" data-kid=\"137\">GLORY SEALED</h2>\n          <p class=\"text-slate-500 text-lg leading-relaxed\" data-kid=\"138\">Customize your match highlights and create a commemorative championship poster.</p>\n        </div>\n        \n        <div class=\"space-y-6\" data-kid=\"139\">\n          <span class=\"text-[11px] font-black text-slate-400 uppercase tracking-widest\" data-kid=\"140\">3D Badges (Drag to Poster)</span>\n          <div class=\"flex gap-5\" data-kid=\"141\">\n            <div class=\"w-24 h-24 rounded-3xl bg-white border border-slate-100 flex items-center justify-center cursor-grab active:cursor-grabbing hover:shadow-xl hover:-translate-y-1 transition-all\" data-kid=\"142\">\n              <i class=\"ti ti-trophy text-4xl text-[var(--color-gold)]\" data-kid=\"143\"></i>\n            </div>\n            <div class=\"w-24 h-24 rounded-3xl bg-white border border-slate-100 flex items-center justify-center cursor-grab active:cursor-grabbing hover:shadow-xl hover:-translate-y-1 transition-all\" data-kid=\"144\">\n              <i class=\"ti ti-award text-4xl text-[var(--color-turf)]\" data-kid=\"145\"></i>\n            </div>\n            <div class=\"w-24 h-24 rounded-3xl bg-white border border-slate-100 flex items-center justify-center cursor-grab active:cursor-grabbing hover:shadow-xl hover:-translate-y-1 transition-all\" data-kid=\"146\">\n              <i class=\"ti ti-medal text-4xl text-slate-900\" data-kid=\"147\"></i>\n            </div>\n          </div>\n        </div>\n\n        <button class=\"w-full py-6 rounded-3xl bg-[var(--color-slate)] text-white font-black text-xl hover:scale-[0.98] transition-all shadow-2xl\" data-kid=\"148\">\n          EXPORT CHAMPION POSTER\n        </button>\n      </div>\n\n      <div class=\"aspect-[4/5] bg-white rounded-[2.5rem] p-12 text-slate-900 shadow-2xl relative overflow-hidden flex flex-col border border-slate-50\" data-kid=\"149\">\n        <div class=\"absolute top-0 left-0 w-full h-4 bg-[var(--color-turf)]\" data-kid=\"150\"></div>\n        <div class=\"flex justify-between items-start mb-12\" data-kid=\"151\">\n          <h3 class=\"text-5xl font-black italic tracking-tighter\" data-kid=\"152\">M.V.P</h3>\n          <div class=\"text-right\" data-kid=\"153\">\n            <div class=\"text-[10px] font-black uppercase text-slate-300 tracking-widest\" data-kid=\"154\">Final Statistics</div>\n            <div class=\"text-3xl font-black text-[var(--color-gold)]\" data-kid=\"155\">192/4</div>\n          </div>\n        </div>\n\n        <div class=\"h-64 poster-dropzone rounded-3xl flex flex-col items-center justify-center space-y-6 group bg-slate-50/50\" data-kid=\"156\">\n          <div class=\"w-16 h-16 rounded-full bg-white shadow-sm flex items-center justify-center text-slate-200 group-hover:text-[var(--color-turf)] transition-colors\" data-kid=\"157\">\n            <i class=\"ti ti-plus text-3xl\" data-kid=\"158\"></i>\n          </div>\n          <span class=\"text-[11px] font-bold text-slate-400 uppercase tracking-[0.4em]\" data-kid=\"159\">Drop 3D Artifact</span>\n        </div>\n\n        <div class=\"mt-12 space-y-5\" data-kid=\"160\">\n          <div class=\"flex justify-between border-b border-slate-100 pb-3\" data-kid=\"161\">\n            <span class=\"font-bold text-slate-400\" data-kid=\"162\">RAHUL S.</span>\n            <span class=\"font-black text-slate-900\" data-kid=\"163\">86 (44)</span>\n          </div>\n          <div class=\"flex justify-between border-b border-slate-100 pb-3\" data-kid=\"164\">\n            <span class=\"font-bold text-slate-400\" data-kid=\"165\">HARDICK P.</span>\n            <span class=\"font-black text-slate-900\" data-kid=\"166\">52* (21)</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/0.160.0/three.min.js\" data-kid=\"167\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"168\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"169\"></script>\n<script data-kid=\"170\">gsap.registerPlugin(ScrollTrigger);</script>\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"171\">\n<script type=\"module\" data-kid=\"172\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  const lenis = new Lenis();\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n</script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"173\">\n\n<script data-kid=\"174\">\n\n  // --- THREE.JS SCENE SETUP ---\n  const container = document.getElementById('canvas-container');\n  const scene = new THREE.Scene();\n  scene.background = new THREE.Color('#C9E7FF'); // More Vibrant Summer Sky\n  scene.fog = new THREE.FogExp2('#C9E7FF', 0.012);\n  \n  const camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.1, 1000);\n  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true, logarithmicDepthBuffer: true });\n  renderer.setSize(window.innerWidth, window.innerHeight);\n  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\n  renderer.shadowMap.enabled = true;\n  renderer.shadowMap.type = THREE.PCFSoftShadowMap;\n  container.appendChild(renderer.domElement);\n\n  // LIGHTING - High Noon Realistic\n  const ambientLight = new THREE.AmbientLight(0xffffff, 1.2);\n  scene.add(ambientLight);\n\n  const sunLight = new THREE.DirectionalLight(0xffffff, 2.5);\n  sunLight.position.set(15, 40, 5);\n  sunLight.castShadow = true;\n  sunLight.shadow.mapSize.width = 4096;\n  sunLight.shadow.mapSize.height = 4096;\n  sunLight.shadow.camera.left = -50;\n  sunLight.shadow.camera.right = 50;\n  sunLight.shadow.camera.top = 50;\n  sunLight.shadow.camera.bottom = -50;\n  scene.add(sunLight);\n\n  // TEXTURES\n  const texLoader = new THREE.TextureLoader();\n  const grassColorTex = texLoader.load('https://images.unsplash.com/photo-1544914379-806667cd9489?auto=format&w=800&q=80&fit=crop');\n  grassColorTex.wrapS = grassColorTex.wrapT = THREE.RepeatWrapping;\n  grassColorTex.repeat.set(10, 10);\n\n  const ballTex = texLoader.load('https://images.pexels.com/photos/30401509/pexels-photo-30401509.jpeg?auto=compress&cs=tinysrgb&w=800&q=80');\n\n  // GROUND\n  const groundGeo = new THREE.PlaneGeometry(300, 300);\n  const groundMat = new THREE.MeshStandardMaterial({ \n    color: '#10B981',\n    roughness: 1.0,\n    metalness: 0.0\n  });\n  const ground = new THREE.Mesh(groundGeo, groundMat);\n  ground.rotation.x = -Math.PI / 2;\n  ground.receiveShadow = true;\n  scene.add(ground);\n\n  // LUSH GRASS INSTANCING\n  const grassCount = 18000;\n  const grassBladeGeo = new THREE.PlaneGeometry(0.15, 0.8);\n  const grassBladeMat = new THREE.MeshStandardMaterial({ \n    color: '#10B981', \n    side: THREE.DoubleSide,\n    transparent: true,\n    alphaTest: 0.5,\n    roughness: 1\n  });\n  const instancedGrass = new THREE.InstancedMesh(grassBladeGeo, grassBladeMat, grassCount);\n  const dummy = new THREE.Object3D();\n\n  for (let i = 0; i < grassCount; i++) {\n    const x = (Math.random() - 0.5) * 100;\n    const z = (Math.random() - 0.5) * 100;\n    dummy.position.set(x, 0.3, z);\n    dummy.rotation.y = Math.random() * Math.PI;\n    dummy.rotation.x = (Math.random() - 0.5) * 0.3;\n    const s = 0.6 + Math.random() * 0.8;\n    dummy.scale.set(1, s, 1);\n    dummy.updateMatrix();\n    instancedGrass.setMatrixAt(i, dummy.matrix);\n  }\n  scene.add(instancedGrass);\n\n  // SECTION 1: HERO BALL\n  const ball = new THREE.Mesh(\n    new THREE.SphereGeometry(0.5, 64, 64),\n    new THREE.MeshStandardMaterial({ map: ballTex, roughness: 0.2, metalness: 0.0 })\n  );\n  ball.position.set(0, 0.5, 0);\n  ball.castShadow = true;\n  scene.add(ball);\n\n  const coin = new THREE.Mesh(\n    new THREE.CylinderGeometry(0.7, 0.7, 0.08, 64),\n    new THREE.MeshStandardMaterial({ color: '#F59E0B', metalness: 1.0, roughness: 0.1 })\n  );\n  coin.position.set(4, 2, -3);\n  coin.rotation.z = Math.PI / 2;\n  scene.add(coin);\n\n  // SECTION 2: SCOREKEEPER BAT\n  const batGroup = new THREE.Group();\n  const blade = new THREE.Mesh(\n    new THREE.BoxGeometry(0.4, 1.8, 0.15),\n    new THREE.MeshStandardMaterial({ color: '#FDE68A', roughness: 0.7 })\n  );\n  const handle = new THREE.Mesh(\n    new THREE.CylinderGeometry(0.08, 0.08, 0.9),\n    new THREE.MeshStandardMaterial({ color: '#334155' })\n  );\n  handle.position.y = 1.35;\n  batGroup.add(blade, handle);\n  batGroup.position.set(10, 5, 10);\n  scene.add(batGroup);\n\n  // SECTION 3: GOLD STUMPS\n  const stumps = new THREE.Group();\n  for (let i = -1; i <= 1; i++) {\n    const s = new THREE.Mesh(\n      new THREE.CylinderGeometry(0.08, 0.08, 2.2, 32),\n      new THREE.MeshStandardMaterial({ color: '#F59E0B', metalness: 0.9, roughness: 0.1 })\n    );\n    s.position.x = i * 0.35;\n    s.castShadow = true;\n    stumps.add(s);\n  }\n  const bails = new THREE.Group();\n  for (let i = -1; i <= 1; i += 2) {\n    const b = new THREE.Mesh(\n      new THREE.CylinderGeometry(0.04, 0.04, 0.3, 32),\n      new THREE.MeshStandardMaterial({ color: '#F59E0B', metalness: 0.9 })\n    );\n    b.position.y = 1.15;\n    b.position.x = i * 0.18;\n    b.rotation.z = Math.PI/2;\n    bails.add(b);\n  }\n  stumps.add(bails);\n  stumps.position.set(-10, 1.1, -2);\n  scene.add(stumps);\n\n  // SECTION 4: CAROUSEL CARDS\n  const cardsGroup = new THREE.Group();\n  for (let i = 0; i < 6; i++) {\n    const c = new THREE.Mesh(\n      new THREE.PlaneGeometry(3, 4.5),\n      new THREE.MeshStandardMaterial({ \n        color: '#fff', \n        transparent: true, \n        opacity: 0.9, \n        side: THREE.DoubleSide,\n        roughness: 0.2\n      })\n    );\n    const angle = (i / 6) * Math.PI * 2;\n    c.position.set(Math.cos(angle) * 8, 3, Math.sin(angle) * 8);\n    c.lookAt(0, 3, 0);\n    cardsGroup.add(c);\n  }\n  cardsGroup.position.set(0, 0, -25);\n  scene.add(cardsGroup);\n\n  // --- GSAP CAMERA JOURNEY ---\n  camera.position.set(0, 1.2, 5);\n  camera.lookAt(0, 0.5, 0);\n\n  const mainTimeline = gsap.timeline({\n    scrollTrigger: {\n      trigger: \".content-layer\",\n      start: \"top top\",\n      end: \"bottom bottom\",\n      scrub: 1.5\n    }\n  });\n\n  // Scene transitions\n  // 1 to 2: Pan to Bat\n  mainTimeline.to(camera.position, { x: 8, y: 4, z: 15, ease: \"power2.inOut\" }, 0);\n  mainTimeline.to(camera.rotation, { x: -0.2, y: 0.3, ease: \"power2.inOut\" }, 0);\n\n  // 2 to 3: Dive to Stumps\n  mainTimeline.to(camera.position, { x: -8, y: 1.5, z: 2, ease: \"power2.inOut\" }, 1);\n  mainTimeline.to(camera.rotation, { x: 0, y: -0.8, ease: \"power2.inOut\" }, 1);\n\n  // 3 to 4: Orbit for Roster\n  mainTimeline.to(camera.position, { x: 0, y: 5, z: -15, ease: \"power2.inOut\" }, 2);\n  mainTimeline.to(camera.rotation, { x: -0.2, y: 0, ease: \"power2.inOut\" }, 2);\n\n  // 4 to 5: Top Down Poster View\n  mainTimeline.to(camera.position, { x: 0, y: 50, z: -5, ease: \"expo.inOut\" }, 3);\n  mainTimeline.to(camera.rotation, { x: -Math.PI / 2, y: 0, ease: \"expo.inOut\" }, 3);\n\n  // --- INTERACTIONS ---\n  window.swingBat = function(runs) {\n    gsap.to(batGroup.rotation, { \n      z: -Math.PI / 1.2, \n      duration: 0.1, \n      yoyo: true, \n      repeat: 1,\n      onComplete: () => {\n        const scoreEl = document.getElementById('score-text');\n        let [runsCurrent, wickets] = scoreEl.innerText.split('/');\n        const newScore = `${parseInt(runsCurrent) + runs}/${wickets}`;\n        scoreEl.innerText = newScore;\n        gsap.fromTo(scoreEl, { scale: 1.3, color: '#FCD34D' }, { scale: 1, color: '#F59E0B', duration: 0.4, ease: \"elastic.out(1, 0.3)\" });\n      }\n    });\n  };\n\n  window.knockWicket = function() {\n    stumps.children.forEach((s, i) => {\n      if(i < 3) { // Stumps\n        gsap.to(s.position, { \n          x: s.position.x + (Math.random() - 0.5) * 4, \n          y: 6 + Math.random() * 4, \n          z: s.position.z + 5,\n          duration: 1.5,\n          ease: \"power3.out\"\n        });\n        gsap.to(s.rotation, { x: 10, y: 10, duration: 2 });\n      } else { // Bails\n        gsap.to(s.position, { y: 10, z: 8, duration: 1, ease: \"power4.out\" });\n      }\n    });\n  };\n\n  document.getElementById('coin-trigger').addEventListener('click', () => {\n    gsap.to(coin.position, { y: 8, duration: 0.8, yoyo: true, repeat: 1, ease: \"power2.out\" });\n    gsap.to(coin.rotation, { x: coin.rotation.x + Math.PI * 16, duration: 1.6, ease: \"expo.out\" });\n  });\n\n  // ANIMATION LOOP\n  function animate() {\n    requestAnimationFrame(animate);\n    \n    // Ambient movement\n    ball.rotation.y += 0.003;\n    cardsGroup.rotation.y += 0.002;\n    \n    // Wind effect for grass (subtle)\n    const time = Date.now() * 0.001;\n    instancedGrass.rotation.z = Math.sin(time) * 0.02;\n\n    renderer.render(scene, camera);\n  }\n\n  window.addEventListener('resize', () => {\n    camera.aspect = window.innerWidth / window.innerHeight;\n    camera.updateProjectionMatrix();\n    renderer.setSize(window.innerWidth, window.innerHeight);\n  });\n\n  animate();\n\n</script>\n</div>",
